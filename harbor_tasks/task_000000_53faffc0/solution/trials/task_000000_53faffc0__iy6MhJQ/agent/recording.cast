[16.066821, "o", "\u001b[?2004h"]
[16.066854, "o", "root@90af8f1b3823:/home/user# "]
[16.570265, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\nBASE_URL=\"http://localhost:8765\"\nOUTPUT_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear output file\n> \"$OUTPUT_FILE\"\n\n# Function to fetch endpoint and log results\nfetch_endpoint() {\n    local endpoint=$1\n    local response\n    local http_code\n    \n    # Make request and capture both body and status code\n    response=$(curl -s -w \"\\n%{http_code}\" \"${BASE_URL}${endpoint}\")\n    http_code=$(echo \"$response\" | tail -n1)\n    body=$(echo \"$response\" | sed '$d')\n    \n    echo \"ENDPOINT: $endpoint\" >> \"$OUTPUT_FILE\"\n    \n    if [ \"$http_code\" -eq 200 ]; then\n        # Count items in JSON array\n        count=$(echo \"$body\" | python3 -c \"import sys, json; print(len(json.load(sys.stdin)))\")\n        echo \"STATUS: SUCCESS\" >> \"$OUTPUT_FILE\"\n        echo \"COUNT: $count\" >> \"$OUTPUT_FILE\"\n    else\n        echo \"STATUS: ERROR\" >> \"$OUTPUT_FILE\"\n        echo \"ERROR_CODE: $http_code\" >> \"$OUTPUT_FILE\"\n    fi\n}\n\n# Fetch all endpoints\nfetch_endpoint \"/api/users\"\necho \"\" >> \""]
[16.570403, "i", "$OUTPUT_FILE\"\n\nfetch_endpoint \"/api/products\"\necho \"\" >> \"$OUTPUT_FILE\"\n\nfetch_endpoint \"/api/orders\"\nEOF\n"]
[16.5705, "o", "cat > /home/user/data_pipeline.sh << 'EOF'\r\n"]
