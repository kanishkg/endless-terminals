[19.294425, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\nBASE_URL=\"http://localhost:8765\"\nRESULTS_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear results file\n> \"$RESULTS_FILE\"\n\n# Function to fetch endpoint and log results\nfetch_endpoint() {\n    local endpoint=\"$1\"\n    local url=\"${BASE_URL}${endpoint}\"\n    \n    # Make request and capture response and HTTP code\n    response=$(curl -s -w \"\\n%{http_code}\" \"$url\")\n    http_code=$(echo \"$response\" | tail -n1)\n    body=$(echo \"$response\" | sed '$d')\n    \n    echo \"ENDPOINT: $endpoint\" >> \"$RESULTS_FILE\"\n    \n    if [ \"$http_code\" -ge 200 ] && [ \"$http_code\" -lt 300 ]; then\n        # Success - count items in JSON array\n        count=$(echo \"$body\" | python3 -c \"import sys, json; print(len(json.load(sys.stdin)))\" 2>/dev/null || echo \"0\")\n        echo \"STATUS: SUCCESS\" >> \"$RESULTS_FILE\"\n        echo \"COUNT: $count\" >> \"$RESULTS_FILE\"\n    else\n        # Error\n        echo \"STATUS: ERROR\" >> \"$RESULTS_FILE\"\n        echo \"ERROR_CODE: $http_code\" >> \"$RESULTS_FILE\"\n    f"]
[19.294558, "i", "i\n    \n    echo \"\" >> \"$RESULTS_FILE\"\n}\n\n# Fetch all endpoints\nfetch_endpoint \"/api/users\"\nfetch_endpoint \"/api/products\"\nfetch_endpoint \"/api/orders\"\n\n# Remove trailing blank line\nsed -i '$ { /^$/d }' \"$RESULTS_FILE\"\n\necho \"Pipeline completed. Results saved to $RESULTS_FILE\"\nEOF\n"]
