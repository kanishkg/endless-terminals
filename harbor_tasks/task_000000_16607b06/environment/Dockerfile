WORKDIR /tmp
RUN zip es_MX.zip messages.properties errors.properties ui_labels.properties && \
    mv es_MX.zip /home/user/translations/ && \
    rm -f messages.properties errors.properties ui_labels.properties && \
    chmod 0666 /home/user/translations/es_MX.zip

WORKDIR /home/user
