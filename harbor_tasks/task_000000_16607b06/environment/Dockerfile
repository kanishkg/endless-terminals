FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    unzip \
    zip \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install pytest

RUN mkdir -p /home/user/translations && chmod 0777 /home/user && chmod 0777 /home/user/translations

RUN cat > /tmp/messages.properties << 'ENDFILE'
