[83.728214, "i", "cat > scraper.js << 'EOF'\nconst puppeteer = require('puppeteer');\nconst fs = require('fs');\nconst path = require('path');\n\nasync function scrapeHackerNews() {\n  const browser = await puppeteer.launch({\n    headless: 'new',\n    args: ['--no-sandbox', '--disable-setuid-sandbox']\n  });\n  \n  const page = await browser.newPage();\n  await page.goto('https://news.ycombinator.com', { waitUntil: 'networkidle2' });\n  \n  // Extract the titles of stories - they are in elements with class 'titleline'\n  const titles = await page.evaluate(() => {\n    const titleElements = document.querySelectorAll('.titleline > a');\n    const result = [];\n    for (let i = 0; i < 5 && i < titleElements.length; i++) {\n      result.push(titleElements[i].innerText);\n    }\n    return result;\n  });\n  \n  await browser.close();\n  \n  // Format and save titles\n  const outputDir = '/home/user/project/scraped_data';\n  const titlesContent = titles.map((title, index) => `${index + 1}. ${title}`).join('\\n');\n  fs.writeFileSync(path.join(outputDir, 'hn_tit"]
[83.728346, "i", "les.txt'), titlesContent);\n  \n  // Create log file\n  const logContent = `STATUS: SUCCESS\\nITEMS_SCRAPED: 5\\nSOURCE: https://news.ycombinator.com`;\n  fs.writeFileSync(path.join(outputDir, 'scrape_log.txt'), logContent);\n  \n  console.log('Scraping completed successfully!');\n  console.log('Titles extracted:');\n  titles.forEach((title, index) => console.log(`${index + 1}. ${title}`));\n}\n\nscrapeHackerNews().catch(console.error);\nEOF\n"]
