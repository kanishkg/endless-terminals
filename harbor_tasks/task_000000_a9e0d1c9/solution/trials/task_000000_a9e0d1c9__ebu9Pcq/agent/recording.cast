[83.730283, "o", "  // Extract the titles of stories - they are in elements with class 'titleline'\r\n\u001b[?2004l\r"]
[83.730322, "o", "\u001b[?2004h> "]
[83.73044, "o", "  const titles = await page.evaluate(() => {\r\n\u001b[?2004l\r"]
[83.730475, "o", "\u001b[?2004h> "]
[83.730673, "o", "    const titleElements = document.querySelectorAll('.titleline > a');\r\n\u001b[?2004l\r"]
[83.730712, "o", "\u001b[?2004h> "]
[83.730771, "o", "    const result = [];\r\n\u001b[?2004l\r"]
[83.730803, "o", "\u001b[?2004h> "]
[83.730975, "o", "    for (let i = 0; i < 5 && i < titleElements.length; i++) {\r\n\u001b[?2004l\r"]
[83.731007, "o", "\u001b[?2004h> "]
[83.731157, "o", "      result.push(titleElements[i].innerText);\r\n\u001b[?2004l\r"]
[83.731191, "o", "\u001b[?2004h> "]
[83.731221, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[83.731255, "o", "> "]
[83.731291, "o", "    return result;\r\n\u001b[?2004l\r"]
[83.731323, "o", "\u001b[?2004h> "]
[83.731354, "o", "  });\r\n\u001b[?2004l\r"]
