[83.334398, "o", "  await page.goto('https://news.ycombinator.com', { waitUntil: 'networkidle2' });\r\n\u001b[?2004l\r"]
[83.334433, "o", "\u001b[?2004h>   \r\n"]
[83.334466, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[83.334567, "o", "  // Extract the top 5 story titles\r\n\u001b[?2004l\r"]
[83.334597, "o", "\u001b[?2004h> "]
[83.334728, "o", "  const titles = await page.evaluate(() => {\r\n\u001b[?2004l\r"]
[83.334765, "o", "\u001b[?2004h> "]
[83.334962, "o", "    const titleElements = document.querySelectorAll('.titleline > a');\r\n\u001b[?2004l\r"]
[83.334994, "o", "\u001b[?2004h> "]
[83.33506, "o", "    const result = [];\r\n\u001b[?2004l\r"]
[83.335092, "o", "\u001b[?2004h> "]
[83.335264, "o", "    for (let i = 0; i < 5 && i < titleElements.length; i++) {\r\n\u001b[?2004l\r"]
[83.335298, "o", "\u001b[?2004h> "]
[83.335434, "o", "      result.push(titleElements[i].textContent);\r\n\u001b[?2004l\r"]
[83.33547, "o", "\u001b[?2004h> "]
[83.3355, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[83.335532, "o", "> "]
[83.335571, "o", "    return result;\r\n\u001b[?2004l\r"]
[83.335603, "o", "\u001b[?2004h> "]
[83.335638, "o", "  });\r\n\u001b[?2004l\r\u001b[?2004h"]
[83.335671, "o", ">   \r\n\u001b[?2004l\r"]
[83.335698, "o", "\u001b[?2004h> "]
[83.335771, "o", "  await browser.close();\r\n\u001b[?2004l\r"]
[83.335791, "o", "\u001b[?2004h"]
[83.335838, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h> "]
