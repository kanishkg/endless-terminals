[83.332898, "o", "og('Titles extracted:');\r\n  console.log(titlesContent);\r\n}\r\n\r\nscrapeHackerNews().catch(co"]
[83.332941, "o", "nsole.error);\r\nEOF\r\n\u001b[?2004h> "]
