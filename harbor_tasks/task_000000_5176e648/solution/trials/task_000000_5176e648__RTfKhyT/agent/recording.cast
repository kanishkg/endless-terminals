[17.275781, "i", "python3 << 'EOF'\nimport csv\nimport json\n\n# Read iOS CSV and extract failed builds\nios_failed = []\nwith open('/home/user/pipelines/ios_builds.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    for row in reader:\n        if row['status'] == 'FAILED':\n            ios_failed.append({\n                'platform': 'ios',\n                'build_id': row['build_id'],\n                'app_name': row['app_name'],\n                'duration_minutes': round(int(row['build_time_seconds']) / 60, 2),\n                'branch': row['branch']\n            })\n\n# Read Android JSON and extract failed builds\nandroid_failed = []\nwith open('/home/user/pipelines/android_builds.json', 'r') as f:\n    android_data = json.load(f)\n    for build in android_data:\n        if build['result'] == 'FAILED':\n            android_failed.append({\n                'platform': 'android',\n                'build_id': build['buildId'],\n                'app_name': build['appName'],\n                'duration_minutes': round(build['buildDuration'] / 60, 2),\n  "]
[17.275916, "i", "              'branch': build['branch']\n            })\n\n# Combine and sort by app_name, then build_id\nall_failed = ios_failed + android_failed\nall_failed.sort(key=lambda x: (x['app_name'], x['build_id']))\n\n# Write unified JSON report\nwith open('/home/user/pipelines/failed_builds_report.json', 'w') as f:\n    json.dump(all_failed, f, indent=2)\n\n# Write summary file\nwith open('/home/user/pipelines/failure_summary.txt', 'w') as f:\n    f.write(f'Total failed builds: {len(all_failed)}\\n')\n    f.write(f'iOS failures: {len(ios_failed)}\\n')\n    f.write(f'Android failures: {len(android_failed)}\\n')\n\nprint('Done!')\nEOF\n"]
[17.275951, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r              'branch': build['branch']\r\n            })\r\n\r\n# Combine and sort by app_name, then build_id\r\nall_failed = ios_failed + android_failed\r\nall_failed.sort(key=lambda x: (x['app_name'], x['build_id']))\r\n\r\n# Write unified JSON report\r\nwith ope"]
[17.276003, "o", "n('/home/user/pipelines/failed_builds_report.json', 'w') as f:\r\n    json.dump(all_failed, f, indent=2)\r\n\r\n# Write summary file\r\nwith open('/home/user/pipelines/failure_summary.txt', 'w') as f:\r\n    f.w"]
[17.276052, "o", "rite(f'Total failed builds: {len(all_failed)}\\n')\r\n    f.write(f'iOS failures: {len(ios_failed)}\\n')\r\n    f.write(f'Android failures: {len(an"]
