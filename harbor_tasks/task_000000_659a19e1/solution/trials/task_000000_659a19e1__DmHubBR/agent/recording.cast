[9.473627, "o", "root@57c0f28d12b2:/home/user# "]
[9.569239, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Get current timestamp in YYYY-MM-DD HH:MM:SS format\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Get disk usage percentage for root filesystem (just the number)\nUSAGE_PERCENT=$(df / | awk 'NR==2 {gsub(/%/,\"\"); print $5}')\n\n# Filesystem mount point\nFILESYSTEM=\"/\"\n\n# Determine status based on usage\nif [ \"$USAGE_PERCENT\" -ge 80 ]; then\n    STATUS=\"WARNING\"\nelse\n    STATUS=\"OK\"\nfi\n\n# Write to log file\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE_PERCENT}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
