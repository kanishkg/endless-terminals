[10.041543, "i", "mkdir -p /home/user/scripts /home/user/logs\n"]
[10.041739, "o", "mkdir -p /home/user/scripts /home/user/logs\r\n\u001b[?2004l\r"]
[10.045278, "o", "\u001b[?2004h"]
[10.045355, "o", "root@1432890614c9:/home/user# "]
[10.14553, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Disk Space Monitoring Script\n\n# Get the disk usage percentage for root filesystem\nUSAGE=$(df / | awk 'NR==2 {gsub(/%/,\"\"); print $5}')\n\n# Get current timestamp\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Filesystem mount point\nFILESYSTEM=\"/\"\n\n# Determine status based on usage\nif [ \"$USAGE\" -ge 80 ]; then\n    STATUS=\"WARNING\"\nelse\n    STATUS=\"OK\"\nfi\n\n# Write to log file\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
