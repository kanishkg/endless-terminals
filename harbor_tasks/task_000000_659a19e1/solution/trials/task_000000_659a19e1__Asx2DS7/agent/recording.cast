[10.214752, "o", "mkdir -p /home/user/scripts /home/user/logs\r\n\u001b[?2004l\r"]
[10.218427, "o", "\u001b[?2004h"]
[10.218493, "o", "root@23594808435f:/home/user# "]
[10.311544, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Disk Space Monitoring Script\n\n# Get current timestamp in required format\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Get disk usage percentage for root filesystem (just the number)\nUSAGE_PERCENT=$(df / | awk 'NR==2 {gsub(/%/,\"\"); print $5}')\n\n# Filesystem mount point\nFILESYSTEM=\"/\"\n\n# Determine status based on usage threshold\nif [ \"$USAGE_PERCENT\" -ge 80 ]; then\n    STATUS=\"WARNING\"\nelse\n    STATUS=\"OK\"\nfi\n\n# Write to log file\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE_PERCENT}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
