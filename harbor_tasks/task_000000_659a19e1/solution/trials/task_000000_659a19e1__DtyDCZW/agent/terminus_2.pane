[?2004hroot@960168bb0f9d:/home/user# clear
[?2004l[H[J[?2004hroot@960168bb0f9d:/home/user# mkdir -p /home/user/scripts /home/user/logs
[?2004l[?2004hroot@960168bb0f9d:/home/user# cat > /home/user/scripts/disk_monitor.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Get disk usage percentage for root filesystem (just the number)
[?2004l[?2004h> USAGE=$(df / | awk 'NR==2 {gsub(/%/,""); print $5}')
[?2004l[?2004h> 
[?2004l[?2004h> # Get current timestamp
[?2004l[?2004h> TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
[?2004l[?2004h> 
[?2004l[?2004h> # Filesystem mount point
[?2004l[?2004h> FILESYSTEM="/"
[?2004l[?2004h> 
[?2004l[?2004h> # Determine status based on usage
[?2004l[?2004h> if [ "$USAGE" -ge 80 ]; then
[?2004l[?2004h>     STATUS="WARNING"
[?2004l[?2004h> else
[?2004l[?2004h>     STATUS="OK"
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Write to log file
[?2004l[?2004h> echo "${TIMESTAMP}|${FILESYSTEM}|${USAGE}|${STATUS}" > /home/user/logs/disk_status.log
[?2004l[?2004h> EOF
