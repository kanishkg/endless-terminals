[9.891126, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Get disk usage percentage for root filesystem (just the number)\nUSAGE=$(df / | awk 'NR==2 {gsub(/%/,\"\"); print $5}')\n\n# Get current timestamp\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Filesystem mount point\nFILESYSTEM=\"/\"\n\n# Determine status based on usage\nif [ \"$USAGE\" -ge 80 ]; then\n    STATUS=\"WARNING\"\nelse\n    STATUS=\"OK\"\nfi\n\n# Write to log file\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
