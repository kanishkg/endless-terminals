[0;32masciinema: press <ctrl-d> or type "exit" when you're done[0m
[?2004hroot@aa8d7ae983cc:/home/user# clear
[?2004l[H[J[?2004hroot@aa8d7ae983cc:/home/user# mkdir -p /home/user/scripts /home/user/logs
[?2004l[?2004hroot@aa8d7ae983cc:/home/user# cat > /home/user/scripts/disk_monitor.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Get disk usage percentage for root filesystem (just the number)
[?2004l[?2004h> USAGE_PERCENT=$(df / | awk 'NR==2 {gsub(/%/,""); print $5}')
[?2004l[?2004h> 
[?2004l[?2004h> # Get current timestamp in required format
[?2004l[?2004h> TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
[?2004l[?2004h> 
[?2004l[?2004h> # Filesystem mount point
[?2004l[?2004h> FILESYSTEM="/"
[?2004l[?2004h> 
[?2004l[?2004h> # Determine status based on usage
[?2004l[?2004h> if [ "$USAGE_PERCENT" -ge 80 ]; then
[?2004l[?2004h>     STATUS="WARNING"
[?2004l[?2004h> else
[?2004l[?2004h>     STATUS="OK"
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Write to log file
[?2004l[?2004h> echo "${TIMESTAMP}|${FILESYSTEM}|${USAGE_PERCENT}|${STATUS}" > /home/user/logs/disk_status.log
[?2004l[?2004h> EOF
[?2004l[?2004hroot@aa8d7ae983cc:/home/user# chmod +x /home/user/scripts/disk_monitor.sh
[?2004l[?2004hroot@aa8d7ae983cc:/home/user# /home/user/scripts/disk_monitor.sh
