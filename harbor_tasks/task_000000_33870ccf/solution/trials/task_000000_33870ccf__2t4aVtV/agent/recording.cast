[9.513912, "i", "# Run parallel analysis tasks and save results to temp files\ndu -h --max-depth=1 /home/user/app_data 2>/dev/null | sort -hr | head -6 > /tmp/large_dirs.txt &\nfind /home/user/app_data -type f -size +50M -exec ls -lh {} \\; 2>/dev/null | awk '{print $5, $NF}' > /tmp/large_files.txt &\nfind /home/user/app_data -name \"*.log\" -type f -mtime +7 2>/dev/null > /tmp/old_logs.txt &\nfind /home/user/app_data -type f 2>/dev/null | sed 's/.*\\.//' | sort | uniq -c | sort -rn > /tmp/file_types.txt &\nwait\necho \"Analysis complete\"\n"]
