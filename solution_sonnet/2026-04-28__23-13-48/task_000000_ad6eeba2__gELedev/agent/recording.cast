[83.892666, "i", "python3 << 'EOF'\nimport json\n\n# Validate assets.json\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\n\nprint(f\"Total valid assets: {len(assets)}\")\nprint(f\"\\nFirst asset:\")\nprint(json.dumps(assets[0], indent=2))\n\n# Check all required fields and types\nrequired_fields = ['id', 'name', 'serial', 'purchase_date', 'price_cents', 'location']\nerrors = []\n\nfor i, asset in enumerate(assets):\n    # Check all fields present\n    for field in required_fields:\n        if field not in asset:\n            errors.append(f\"Asset {i}: Missing field {field}\")\n    \n    # Check price_cents is positive integer\n    if 'price_cents' in asset:\n        if not isinstance(asset['price_cents'], int):\n            errors.append(f\"Asset {i} ({asset.get('id')}): price_cents not an integer\")\n        elif asset['price_cents'] <= 0:\n            errors.append(f\"Asset {i} ({asset.get('id')}): price_cents not positive\")\n    \n    # Check date format (ISO 8601: YYYY-MM-DD)\n    if 'purchase_date' in asset:\n        date_str = asset['purchase"]
[83.892733, "i", "_date']\n        if not (len(date_str) == 10 and date_str[4] == '-' and date_str[7] == '-'):\n            errors.append(f\"Asset {i} ({asset.get('id')}): Invalid date format {date_str}\")\n\nif errors:\n    print(f\"\\n❌ Found {len(errors)} validation errors:\")\n    for err in errors[:10]:\n        print(f\"  {err}\")\nelse:\n    print(f\"\\n✅ All {len(assets)} assets validated successfully!\")\n\n# Validate rejected.json\nwith open('rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(f\"\\nTotal rejected records: {len(rejected)}\")\nprint(f\"\\nFirst rejected record:\")\nprint(json.dumps(rejected[0], indent=2))\nEOF\n"]
