[44.73603, "o", "\u001b[?2004h> "]
[44.736062, "o", "    \r\n\u001b[?2004l\r"]
[44.73609, "o", "\u001b[?2004h> "]
[44.736217, "o", "    # Try DD.MM.YYYY (European)\r\n\u001b[?2004l\r"]
[44.736247, "o", "\u001b[?2004h> "]
[44.736288, "o", "    try:\r\n\u001b[?2004l\r"]
[44.736315, "o", "\u001b[?2004h"]
[44.73634, "o", "> "]
[44.736531, "o", "        dt = datetime.strptime(date_str, '%d.%m.%Y')\r\n\u001b[?2004l\r"]
[44.736561, "o", "\u001b[?2004h> "]
[44.736727, "o", "        return dt.strftime('%Y-%m-%d')\r\n\u001b[?2004l\r"]
[44.736758, "o", "\u001b[?2004h> "]
[44.73685, "o", "    except ValueError:\r\n\u001b[?2004l\r"]
[44.736878, "o", "\u001b[?2004h"]
[44.736898, "o", "> "]
[44.736943, "o", "        pass\r\n\u001b[?2004l\r"]
[44.736974, "o", "\u001b[?2004h> "]
[44.737003, "o", "    \r\n\u001b[?2004l\r"]
[44.737033, "o", "\u001b[?2004h> "]
[44.737096, "o", "    return None\r\n\u001b[?2004l\r"]
[44.737124, "o", "\u001b[?2004h"]
[44.737157, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[44.737187, "o", "> "]
[44.737294, "o", "def parse_price(price_str):\r\n\u001b[?2004l\r"]
[44.737321, "o", "\u001b[?2004h"]
[44.737349, "o", "> "]
[44.737558, "o", "    \"\"\"Parse price string and return cents as integer.\"\"\"\r\n\u001b[?2004l\r"]
[44.73759, "o", "\u001b[?2004h> "]
[44.737633, "o", "    try:\r\n\u001b[?2004l\r"]
[44.737661, "o", "\u001b[?2004h> "]
[44.737887, "o", "        # Remove dollar signs, commas, and whitespace\r\n\u001b[?2004l\r"]
[44.737911, "o", "\u001b[?2004h"]
[44.737936, "o", "> "]
[44.738149, "o", "        cleaned = price_str.strip().replace('$', '').replace(',', '')\r\n\u001b[?2004l\r"]
[44.738178, "o", "\u001b[?2004h> "]
[44.738294, "o", "        # Convert to float then to cents\r\n\u001b[?2004l\r"]
[44.738323, "o", "\u001b[?2004h> "]
[44.738429, "o", "        price_float = float(cleaned)\r\n\u001b[?2004l\r"]
[44.738458, "o", "\u001b[?2004h> "]
[44.738603, "o", "        price_cents = int(round(price_float * 100))\r\n\u001b[?2004l\r"]
[44.738626, "o", "\u001b[?2004h"]
[44.738651, "o", "> "]
[44.738727, "o", "        return price_cents\r\n\u001b[?2004l\r"]
[44.738748, "o", "\u001b[?2004h"]
[44.738782, "o", "> "]
[44.738873, "o", "    except (ValueError, AttributeError):\r\n\u001b[?2004l\r"]
[44.738892, "o", "\u001b[?2004h"]
[44.738934, "o", "> "]
[44.738959, "o", "        return None\r\n\u001b[?2004l\r"]
[44.738989, "o", "\u001b[?2004h> "]
[44.739021, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.739105, "o", "def is_serial_format(value):\r\n\u001b[?2004l\r"]
[44.739134, "o", "\u001b[?2004h> "]
[44.739328, "o", "    \"\"\"Check if value looks like a serial number (starts with SN-).\"\"\"\r\n\u001b[?2004l\r"]
[44.739357, "o", "\u001b[?2004h> "]
[44.739477, "o", "    return value.strip().startswith('SN-')\r\n\u001b[?2004l\r"]
[44.739506, "o", "\u001b[?2004h> \r\n"]
[44.739535, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[44.739625, "o", "def process_row(row, row_num):\r\n\u001b[?2004l\r"]
[44.739649, "o", "\u001b[?2004h"]
[44.739676, "o", "> "]
[44.739868, "o", "    \"\"\"Process a single row and return (success, data/error, reason).\"\"\"\r\n\u001b[?2004l\r"]
[44.739898, "o", "\u001b[?2004h"]
[44.739924, "o", ">     try:\r\n\u001b[?2004l\r"]
[44.739951, "o", "\u001b[?2004h> "]
[44.740058, "o", "        asset_id = row['id'].strip()\r\n\u001b[?2004l\r"]
[44.740088, "o", "\u001b[?2004h> "]
[44.740182, "o", "        name = row['name'].strip()\r\n\u001b[?2004l\r"]
[44.740211, "o", "\u001b[?2004h> "]
[44.740324, "o", "        serial = row['serial'].strip()\r\n\u001b[?2004l\r"]
[44.740355, "o", "\u001b[?2004h> "]
[44.74051, "o", "        purchase_date_raw = row['purchase_date'].strip()\r\n\u001b[?2004l\r"]
[44.740541, "o", "\u001b[?2004h> "]
[44.740649, "o", "        price_raw = row['price'].strip()\r\n\u001b[?2004l\r"]
[44.740676, "o", "\u001b[?2004h> "]
[44.740812, "o", "        location = row['location'].strip()\r\n\u001b[?2004l\r"]
[44.740844, "o", "\u001b[?2004h> "]
[44.740875, "o", "        \r\n\u001b[?2004l\r"]
[44.740904, "o", "\u001b[?2004h> "]
[44.741026, "o", "        # Check if serial and name are swapped\r\n\u001b[?2004l\r"]
[44.74106, "o", "\u001b[?2004h> "]
[44.741244, "o", "        if not is_serial_format(serial) and is_serial_format(name):\r\n"]
[44.741279, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[44.74135, "o", "            # Swap them\r\n\u001b[?2004l\r"]
[44.741379, "o", "\u001b[?2004h> "]
[44.741493, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[44.741521, "o", "\u001b[?2004h> "]
[44.741551, "o", "        \r\n\u001b[?2004l\r"]
[44.741579, "o", "\u001b[?2004h> "]
[44.741671, "o", "        # Validate serial format\r\n\u001b[?2004l\r"]
[44.741694, "o", "\u001b[?2004h"]
[44.741739, "o", "> "]
[44.741831, "o", "        if not is_serial_format(serial):\r\n\u001b[?2004l\r"]
[44.74186, "o", "\u001b[?2004h> "]
[44.742042, "o", "            return False, row, f\"Invalid serial format: {serial}\"\r\n"]
[44.742071, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[44.742102, "o", "        \r\n\u001b[?2004l\r"]
[44.742127, "o", "\u001b[?2004h> "]
[44.74219, "o", "        # Parse date\r\n\u001b[?2004l\r"]
[44.742223, "o", "\u001b[?2004h> "]
[44.742368, "o", "        purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[44.742393, "o", "\u001b[?2004h"]
[44.742421, "o", "> "]
[44.742497, "o", "        if purchase_date is None:\r\n\u001b[?2004l\r"]
[44.742523, "o", "\u001b[?2004h> "]
[44.742745, "o", "            return False, row, f\"Invalid date format: {purchase_date_raw}\"\r\n\u001b[?2004l\r"]
[44.74278, "o", "\u001b[?2004h> "]
[44.742808, "o", "        \r\n\u001b[?2004l\r"]
[44.742834, "o", "\u001b[?2004h> "]
[44.742896, "o", "        # Parse price\r\n\u001b[?2004l\r"]
[44.742924, "o", "\u001b[?2004h> "]
[44.743051, "o", "        price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[44.743079, "o", "\u001b[?2004h> "]
[44.743172, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[44.743206, "o", "\u001b[?2004h> "]
[44.743389, "o", "            return False, row, f\"Invalid price format: {price_raw}\"\r\n\u001b[?2004l\r"]
[44.743418, "o", "\u001b[?2004h> "]
[44.743448, "o", "        \r\n\u001b[?2004l\r"]
[44.743475, "o", "\u001b[?2004h> "]
[44.743571, "o", "        # Validate positive price\r\n\u001b[?2004l\r"]
[44.743598, "o", "\u001b[?2004h> "]
[44.743681, "o", "        if price_cents <= 0:\r\n\u001b[?2004l\r"]
[44.743714, "o", "\u001b[?2004h"]
[44.743741, "o", "> "]
[44.743921, "o", "            return False, row, f\"Price must be positive: {price_cents}\"\r\n\u001b[?2004l\r"]
[44.743953, "o", "\u001b[?2004h"]
[44.743981, "o", ">         \r\n\u001b[?2004l\r"]
[44.744011, "o", "\u001b[?2004h> "]
[44.744111, "o", "        # Validate required fields\r\n\u001b[?2004l\r"]
[44.74414, "o", "\u001b[?2004h> "]
[44.744288, "o", "        if not asset_id or not name or not location:\r\n\u001b[?2004l\r"]
[44.744313, "o", "\u001b[?2004h"]
[44.74434, "o", "> "]
[44.744478, "o", "            return False, row, \"Missing required fields\"\r\n\u001b[?2004l\r"]
[44.744506, "o", "\u001b[?2004h> "]
[44.744535, "o", "        \r\n\u001b[?2004l\r"]
[44.744563, "o", "\u001b[?2004h> "]
[44.744663, "o", "        # Create normalized record\r\n\u001b[?2004l\r"]
[44.744692, "o", "\u001b[?2004h> "]
[44.744763, "o", "        record = {\r\n\u001b[?2004l\r"]
[44.744781, "o", "\u001b[?2004h"]
[44.744812, "o", "> "]
[44.744872, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[44.7449, "o", "\u001b[?2004h> "]
[44.744974, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[44.745002, "o", "\u001b[?2004h> "]
[44.745087, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[44.745116, "o", "\u001b[?2004h> "]
[44.74524, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[44.745269, "o", "\u001b[?2004h"]
[44.745308, "o", "> "]
[44.745389, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[44.745416, "o", "\u001b[?2004h"]
[44.745448, "o", "> "]
[44.745515, "o", "            'location': location\r\n\u001b[?2004l\r"]
[44.745542, "o", "\u001b[?2004h"]
[44.745569, "o", "> "]
[44.745597, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.745625, "o", "> "]
[44.745651, "o", "        \r\n\u001b[?2004l\r"]
[44.745679, "o", "\u001b[?2004h> "]
[44.745775, "o", "        return True, record, None\r\n\u001b[?2004l\r"]
[44.745805, "o", "\u001b[?2004h> "]
[44.745833, "o", "        \r\n\u001b[?2004l\r"]
[44.745852, "o", "\u001b[?2004h"]
[44.745889, "o", "> "]
[44.745939, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[44.745967, "o", "\u001b[?2004h> "]
[44.746124, "o", "        return False, row, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[44.746157, "o", "\u001b[?2004h> \r\n"]
[44.746184, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[44.746221, "o", "def main():\r\n\u001b[?2004l\r"]
[44.746252, "o", "\u001b[?2004h"]
[44.746279, "o", "> "]
[44.746425, "o", "    valid_records = defaultdict(list)  # id -> list of records\r\n\u001b[?2004l\r"]
[44.746453, "o", "\u001b[?2004h> "]
[44.746531, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[44.746557, "o", "\u001b[?2004h> "]
[44.746586, "o", "    \r\n\u001b[?2004l\r"]
[44.746615, "o", "\u001b[?2004h> "]
[44.746666, "o", "    # Read CSV file\r\n\u001b[?2004l\r"]
[44.746711, "o", "\u001b[?2004h> "]
[44.746868, "o", "    with open('assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.746895, "o", "\u001b[?2004h"]
[44.746921, "o", "> "]
[44.746999, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[44.747027, "o", "\u001b[?2004h> "]
[44.747262, "o", "        for row_num, row in enumerate(reader, start=2):  # start=2 because of header\r\n\u001b[?2004l\r"]
[44.747291, "o", "\u001b[?2004h> "]
[44.747464, "o", "            success, data, reason = process_row(row, row_num)\r\n\u001b[?2004l\r"]
[44.747491, "o", "\u001b[?2004h> "]
[44.747533, "o", "            \r\n\u001b[?2004l\r"]
[44.74756, "o", "\u001b[?2004h> "]
[44.747631, "o", "            if success:\r\n\u001b[?2004l\r"]
[44.74766, "o", "\u001b[?2004h> "]
[44.74781, "o", "                # Store by ID for deduplication\r\n\u001b[?2004l\r"]
[44.747833, "o", "\u001b[?2004h"]
[44.747861, "o", "> "]
[44.747992, "o", "                valid_records[data['id']].append(data)\r\n\u001b[?2004l\r"]
[44.748018, "o", "\u001b[?2004h> "]
[44.748074, "o", "            else:\r\n\u001b[?2004l\r"]
[44.7481, "o", "\u001b[?2004h"]
[44.748128, "o", "> "]
[44.74822, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[44.748242, "o", "\u001b[?2004h"]
[44.748267, "o", "> "]
[44.748366, "o", "                    'original_row': data,\r\n\u001b[?2004l\r"]
[44.748388, "o", "\u001b[?2004h"]
[44.748414, "o", "> "]
[44.7485, "o", "                    'reason': reason\r\n\u001b[?2004l\r"]
[44.74853, "o", "\u001b[?2004h> "]
[44.74859, "o", "                })\r\n\u001b[?2004l\r"]
[44.748624, "o", "\u001b[?2004h> "]
[44.748652, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[44.748682, "o", "> "]
[44.74886, "o", "    # Deduplicate: keep record with latest purchase_date for each ID\r\n\u001b[?2004l\r"]
[44.748888, "o", "\u001b[?2004h> "]
[44.748955, "o", "    final_records = []\r\n\u001b[?2004l\r"]
[44.748991, "o", "\u001b[?2004h> "]
[44.749128, "o", "    for asset_id, records in valid_records.items():\r\n\u001b[?2004l\r"]
[44.749156, "o", "\u001b[?2004h> "]
[44.749242, "o", "        if len(records) == 1:\r\n\u001b[?2004l\r"]
[44.749274, "o", "\u001b[?2004h> "]
[44.749403, "o", "            final_records.append(records[0])\r\n\u001b[?2004l\r"]
[44.749439, "o", "\u001b[?2004h> "]
[44.749475, "o", "        else:\r\n\u001b[?2004l\r"]
[44.749501, "o", "\u001b[?2004h> "]
[44.749657, "o", "            # Sort by purchase_date and keep the latest\r\n\u001b[?2004l\r"]
[44.749679, "o", "\u001b[?2004h"]
[44.749719, "o", "> "]
[44.749955, "o", "            sorted_records = sorted(records, key=lambda x: x['purchase_date'], reverse=True)\r\n\u001b[?2004l\r"]
[44.749984, "o", "\u001b[?2004h"]
[44.750012, "o", "> "]
[44.750131, "o", "            final_records.append(sorted_records[0])\r\n\u001b[?2004l\r"]
[44.750158, "o", "\u001b[?2004h"]
[44.750187, "o", "> "]
[44.750281, "o", "            # Add duplicates to rejected\r\n\u001b[?2004l\r"]
[44.750317, "o", "\u001b[?2004h> "]
[44.750432, "o", "            for dup in sorted_records[1:]:\r\n\u001b[?2004l\r"]
[44.750459, "o", "\u001b[?2004h> "]
[44.750574, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[44.750602, "o", "\u001b[?2004h> "]
[44.750734, "o", "                    'original_row': dup,\r\n\u001b[?2004l\r"]
[44.75076, "o", "\u001b[?2004h"]
[44.750787, "o", "> "]
[44.751003, "o", "                    'reason': f\"Duplicate ID {asset_id}, kept record with latest date\"\r\n\u001b[?2004l\r"]
[44.75103, "o", "\u001b[?2004h> "]
[44.751091, "o", "                })\r\n\u001b[?2004l\r"]
[44.751122, "o", "\u001b[?2004h"]
[44.751149, "o", ">     \r\n\u001b[?2004l\r"]
[44.751178, "o", "\u001b[?2004h> "]
[44.751278, "o", "    # Sort by ID for consistent output\r\n\u001b[?2004l\r"]
[44.751307, "o", "\u001b[?2004h> "]
[44.751433, "o", "    final_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[44.751461, "o", "\u001b[?2004h> "]
[44.75148, "o", "    \r\n\u001b[?2004l\r"]
[44.751515, "o", "\u001b[?2004h> "]
[44.751581, "o", "    # Write output files\r\n\u001b[?2004l\r"]
[44.751609, "o", "\u001b[?2004h> "]
[44.751787, "o", "    with open('assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.751821, "o", "\u001b[?2004h"]
[44.75185, "o", "> "]
[44.751941, "o", "        json.dump(final_records, f, indent=2)\r\n\u001b[?2004l\r"]
[44.751968, "o", "\u001b[?2004h> "]
[44.752003, "o", "    \r\n\u001b[?2004l\r"]
[44.752029, "o", "\u001b[?2004h> "]
[44.752183, "o", "    with open('rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.75221, "o", "\u001b[?2004h> "]
[44.752349, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[44.752378, "o", "\u001b[?2004h> "]
[44.752403, "o", "    \r\n\u001b[?2004l\r"]
[44.752432, "o", "\u001b[?2004h> "]
[44.752521, "o", "    print(f\"Processing complete:\")\r\n\u001b[?2004l\r"]
[44.752547, "o", "\u001b[?2004h"]
[44.752575, "o", "> "]
[44.752697, "o", "    print(f\"  Valid records: {len(final_records)}\")\r\n\u001b[?2004l\r"]
[44.752743, "o", "\u001b[?2004h> "]
[44.752908, "o", "    print(f\"  Rejected records: {len(rejected_records)}\")\r\n\u001b[?2004l\r"]
[44.752931, "o", "\u001b[?2004h> "]
[44.752955, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.752981, "o", "> "]
[44.753045, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[44.753069, "o", "\u001b[?2004h> "]
[44.753107, "o", "    main()\r\n\u001b[?2004l\r"]
[44.753134, "o", "\u001b[?2004h> "]
[44.753167, "o", "EOF\r\n\u001b[?2004l\r"]
[44.757143, "o", "\u001b[?2004h"]
[44.757174, "o", "user@f51ce637451c:~/inventory$ "]
[48.55714, "i", "python3 process_assets.py\n"]
[48.557311, "o", "python3 process_assets.py\r\n\u001b[?2004l\r"]
