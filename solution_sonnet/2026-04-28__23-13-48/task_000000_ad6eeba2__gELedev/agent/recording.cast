[44.732071, "i", "cat > process_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse multiple date formats and return ISO 8601 string.\"\"\"\n    date_str = date_str.strip()\n    \n    # Try YYYY-MM-DD (ISO format)\n    try:\n        dt = datetime.strptime(date_str, '%Y-%m-%d')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try MM/DD/YYYY\n    try:\n        dt = datetime.strptime(date_str, '%m/%d/%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try DD.MM.YYYY (European)\n    try:\n        dt = datetime.strptime(date_str, '%d.%m.%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price string and return cents as integer.\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = price_str.strip().replace('$', '').replace(',', '')\n        # Con"]
[44.73219, "i", "vert to float then to cents\n        price_float = float(cleaned)\n        price_cents = int(round(price_float * 100))\n        return price_cents\n    except (ValueError, AttributeError):\n        return None\n\ndef is_serial_format(value):\n    \"\"\"Check if value looks like a serial number (starts with SN-).\"\"\"\n    return value.strip().startswith('SN-')\n\ndef process_row(row, row_num):\n    \"\"\"Process a single row and return (success, data/error, reason).\"\"\"\n    try:\n        asset_id = row['id'].strip()\n        name = row['name'].strip()\n        serial = row['serial'].strip()\n        purchase_date_raw = row['purchase_date'].strip()\n        price_raw = row['price'].strip()\n        location = row['location'].strip()\n        \n        # Check if serial and name are swapped\n        if not is_serial_format(serial) and is_serial_format(name):\n            # Swap them\n            name, serial = serial, name\n        \n        # Validate serial format\n        if not is_serial_format(serial):\n            return False, row, f\"Inval"]
[44.732234, "i", "id serial format: {serial}\"\n        \n        # Parse date\n        purchase_date = parse_date(purchase_date_raw)\n        if purchase_date is None:\n            return False, row, f\"Invalid date format: {purchase_date_raw}\"\n        \n        # Parse price\n        price_cents = parse_price(price_raw)\n        if price_cents is None:\n            return False, row, f\"Invalid price format: {price_raw}\"\n        \n        # Validate positive price\n        if price_cents <= 0:\n            return False, row, f\"Price must be positive: {price_cents}\"\n        \n        # Validate required fields\n        if not asset_id or not name or not location:\n            return False, row, \"Missing required fields\"\n        \n        # Create normalized record\n        record = {\n            'id': asset_id,\n            'name': name,\n            'serial': serial,\n            'purchase_date': purchase_date,\n            'price_cents': price_cents,\n            'location': location\n        }\n        \n        return True, record, None\n        \n   "]
[44.732264, "o", "cat > process_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[44.732302, "i", " except Exception as e:\n        return False, row, f\"Processing error: {str(e)}\"\n\ndef main():\n    valid_records = defaultdict(list)  # id -> list of records\n    rejected_records = []\n    \n    # Read CSV file\n    with open('assets.csv', 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        for row_num, row in enumerate(reader, start=2):  # start=2 because of header\n            success, data, reason = process_row(row, row_num)\n            \n            if success:\n                # Store by ID for deduplication\n                valid_records[data['id']].append(data)\n            else:\n                rejected_records.append({\n                    'original_row': data,\n                    'reason': reason\n                })\n    \n    # Deduplicate: keep record with latest purchase_date for each ID\n    final_records = []\n    for asset_id, records in valid_records.items():\n        if len(records) == 1:\n            final_records.append(records[0])\n        else:\n            # Sort by purchase_date and k"]
[44.732332, "o", "id serial format: {serial}\"\r\n        \r\n        # Parse date\r\n        purchase_date = parse_date(purchase_date_raw)\r\n        if purchase_date is None:\r\n            return False, row, f\"Invalid date format: {purchase_date_raw}\"\r\n        \r\n        # Parse price\r\n        price_cents = parse_price(price_raw)\r\n        if price_cents is None:\r\n            return False, ro"]
[44.732371, "i", "eep the latest\n            sorted_records = sorted(records, key=lambda x: x['purchase_date'], reverse=True)\n            final_records.append(sorted_records[0])\n            # Add duplicates to rejected\n            for dup in sorted_records[1:]:\n                rejected_records.append({\n                    'original_row': dup,\n                    'reason': f\"Duplicate ID {asset_id}, kept record with latest date\"\n                })\n    \n    # Sort by ID for consistent output\n    final_records.sort(key=lambda x: x['id'])\n    \n    # Write output files\n    with open('assets.json', 'w', encoding='utf-8') as f:\n        json.dump(final_records, f, indent=2)\n    \n    with open('rejected.json', 'w', encoding='utf-8') as f:\n        json.dump(rejected_records, f, indent=2)\n    \n    print(f\"Processing complete:\")\n    print(f\"  Valid records: {len(final_records)}\")\n    print(f\"  Rejected records: {len(rejected_records)}\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
