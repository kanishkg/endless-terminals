[53.077789, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean\n\n# Check if hosts.conf exists\ncheck-config:\n\t@if [ ! -f hosts.conf ]; then echo \"Error: hosts.conf not found. Cannot proceed.\"; exit 1; fi\n\nresults:\n\tmkdir -p results\n\nresults/ping.txt: hosts.conf | results check-config\n\t./scripts/check_ping.sh\n\nresults/ports.txt: hosts.conf | results check-config\n\t./scripts/check_ports.sh\n\nresults/status.json: results/ping.txt results/ports.txt\n\t./aggregate.py\n\nreport: results/status.json\n\t@echo \"Monitoring report complete. See results/status.json\"\n\nclean:\n\trm -rf results\nEOF\n"]
