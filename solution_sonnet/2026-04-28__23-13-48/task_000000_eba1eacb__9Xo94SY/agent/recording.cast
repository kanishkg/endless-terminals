[43.523829, "o", ".PHONY: report clean check-config\r\n\r\n# Main target to generate the full report\r\nreport: results/status.json\r\n@echo \"Monitoring report complete!\"\r\n\r\n# Check if hosts.conf exists\r\ncheck-config:\r\n@if [ ! -f hosts.conf ]; then \\\r\necho \"Error: hosts.conf is missing. Cannot proceed.\"; \\\r\nexit 1; \\\r\nfi\r\n\r\n# Generate the aggregated JSON report\r\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\r\n@echo \"Aggregating results...\"\r\npython3 aggregate.py\r\n\r\n# Run ping checks\r\nresults/ping.txt: check-config scripts/check_ping.sh hosts.conf\r\n@echo \"Running ping checks...\"\r\n./scripts/check_ping.sh\r\n\r\n# Run port checks\r\nresults/ports.txt: check-config scripts/check_ports.sh hosts.conf\r\n@echo \"Running port checks...\"\r\n./scripts/check_ports.sh\r\n\r\n# Clean up generated files\r\nclean:\r\n@echo \"Cleaning up results...\"\r\nrm -rf results/\r\n"]
