[34.86501, "i", "cat aggregate.py\n"]
[34.865124, "o", "cat aggregate.py\r\n\u001b[?2004l\r"]
[34.866057, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f:\r\n        json.dump(results, f, indent=2)\r\n    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[34.866212, "o", "\u001b[?2004h"]
[34.86625, "o", "root@26265d766d86:/home/user/netmon# "]
[43.424413, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean check-config\n\n# Main target to generate the full report\nreport: results/status.json\n\t@echo \"Monitoring report complete!\"\n\n# Check if hosts.conf exists\ncheck-config:\n\t@if [ ! -f hosts.conf ]; then \\\n\t\techo \"Error: hosts.conf is missing. Cannot proceed.\"; \\\n\t\texit 1; \\\n\tfi\n\n# Generate the aggregated JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\t@echo \"Aggregating results...\"\n\tpython3 aggregate.py\n\n# Run ping checks\nresults/ping.txt: check-config scripts/check_ping.sh hosts.conf\n\t@echo \"Running ping checks...\"\n\t./scripts/check_ping.sh\n\n# Run port checks\nresults/ports.txt: check-config scripts/check_ports.sh hosts.conf\n\t@echo \"Running port checks...\"\n\t./scripts/check_ports.sh\n\n# Clean up generated files\nclean:\n\t@echo \"Cleaning up results...\"\n\trm -rf results/\nEOF\n"]
