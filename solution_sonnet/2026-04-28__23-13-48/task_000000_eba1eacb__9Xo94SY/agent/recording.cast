[58.100441, "i", "python3 << 'PYSCRIPT'\nwith open('Makefile', 'w') as f:\n    f.write('''.PHONY: report clean check-config\n\n# Main target to generate the full report\nreport: results/status.json\n\\t@echo \"Monitoring report complete!\"\n\n# Check if hosts.conf exists\ncheck-config:\n\\t@if [ ! -f hosts.conf ]; then \\\\\n\\t\\techo \"Error: hosts.conf is missing. Cannot proceed.\"; \\\\\n\\t\\texit 1; \\\\\n\\tfi\n\n# Generate the aggregated JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\\t@echo \"Aggregating results...\"\n\\tpython3 aggregate.py\n\n# Run ping checks\nresults/ping.txt: check-config scripts/check_ping.sh hosts.conf\n\\t@echo \"Running ping checks...\"\n\\t./scripts/check_ping.sh\n\n# Run port checks\nresults/ports.txt: check-config scripts/check_ports.sh hosts.conf\n\\t@echo \"Running port checks...\"\n\\t./scripts/check_ports.sh\n\n# Clean up generated files\nclean:\n\\t@echo \"Cleaning up results...\"\n\\trm -rf results/\n''')\nPYSCRIPT\n"]
