[47.69342, "i", "cat > Makefile << 'EOF'\n.PHONY: report check-ping check-ports aggregate clean\n\n# Main target to generate the complete report\nreport: results/status.json\n\t@echo \"Monitoring report complete!\"\n\n# Check that hosts.conf exists before doing anything\nresults/ping.txt: hosts.conf scripts/check_ping.sh\n\t@test -f hosts.conf || (echo \"Error: hosts.conf not found\" && exit 1)\n\t@echo \"Running ping checks...\"\n\t./scripts/check_ping.sh\n\nresults/ports.txt: hosts.conf scripts/check_ports.sh\n\t@test -f hosts.conf || (echo \"Error: hosts.conf not found\" && exit 1)\n\t@echo \"Running port checks...\"\n\t./scripts/check_ports.sh\n\n# Aggregate results into JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\t@echo \"Aggregating results...\"\n\t./aggregate.py\n\n# Convenience targets\ncheck-ping: results/ping.txt\n\ncheck-ports: results/ports.txt\n\naggregate: results/status.json\n\n# Clean up generated files\nclean:\n\trm -rf results/\nEOF\n"]
