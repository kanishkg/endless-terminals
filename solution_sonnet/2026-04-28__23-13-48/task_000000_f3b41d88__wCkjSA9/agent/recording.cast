[6.418818, "o", "drwxrwxrwx 1 user user  4096 Apr 28 23:19 .\r\ndrwxrwxrwx 1 root root  4096 Apr 28 23:43 ..\r\n-rw-rw-rw- 1 user user    60 Apr 28 23:19 .env\r\n-rw-rw-rw- 1 user user  2009 Apr 28 23:19 app.py\r\n-rw-rw-rw- 1 user user 16384 Apr 28 23:19 data.db\r\n-rw-rw-rw- 1 user user    34 Apr 28 23:19 requirements.txt\r\n"]
