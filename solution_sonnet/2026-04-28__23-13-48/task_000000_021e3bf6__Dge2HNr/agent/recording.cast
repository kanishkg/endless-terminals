[29.985479, "i", "cat > process_mem.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Temporary file for collecting results\nTEMP_FILE=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Try to extract MemTotal and MemAvailable\n    mem_total=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    mem_available=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty\n    if [[ -z \"$mem_total\" || -z \"$mem_available\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage and check if less than 20% using awk\n    awk -v total=\"$mem_total\" -v avail=\"$mem_available\" -v host=\"$hostname\" '\n    BEGIN {\n        if (total > 0) {\n            percentage = (avail * 100) / total\n            if (percentage < 20) {\n                printf \"%.2f %s\\n\", percentage, host\n            }\n        }\n    }' >> \"$TEMP_FILE\"\ndone\n\n# Sort by percenta"]
[29.985615, "i", "ge (ascending - worst first) and format output\nif [[ -f \"$TEMP_FILE\" && -s \"$TEMP_FILE\" ]]; then\n    sort -n \"$TEMP_FILE\" | while read pct host; do\n        printf \"%s\\t%s%%\\n\" \"$host\" \"$pct\"\n    done > \"$OUTPUT\"\nelse\n    # Create empty file if no results\n    touch \"$OUTPUT\"\nfi\n\n# Cleanup\nrm -f \"$TEMP_FILE\"\nEOF\n"]
[29.985656, "o", "cat > process_mem.sh << 'EOF'\r\n\u001b[?2004l\rge (ascending - worst first) and format output\r\nif [[ -f \"$TEMP_FILE\" && -s \"$TEMP_FILE\" ]]; then\r\n    sort "]
[29.985706, "o", "-n \"$TEMP_FILE\" | while read pct host; do\r\n        printf \"%s\\t%s%%\\n\" \"$host\" \"$pct\"\r\n    done > \"$OUTPUT\"\r\nelse\r\n    # Create"]
[29.985741, "o", " empty file if no results\r\n    touch \"$OUTPUT\"\r\nfi\r\n\r\n# Cleanup\r\nrm -f \"$TEMP_FILE\"\r\nEOF\r\n"]
