[24.709313, "i", "grep -E '/api/v[0-9]+/internal/' /var/log/app/access.log | grep -v '^10\\.' | awk '{\n  # Extract timestamp from brackets\n  match($0, /\\[([^\\]]+)\\]/, ts);\n  timestamp = ts[1];\n  \n  # Parse: DD/Mon/YYYY:HH:MM:SS +ZONE\n  split(timestamp, dt, /[\\/:]/); \n  day = dt[1];\n  month = dt[2];\n  year = dt[3];\n  time = dt[4] \":\" dt[5] \":\" dt[6];\n  \n  # Convert month name to number\n  months[\"Jan\"]=\"01\"; months[\"Feb\"]=\"02\"; months[\"Mar\"]=\"03\"; months[\"Apr\"]=\"04\";\n  months[\"May\"]=\"05\"; months[\"Jun\"]=\"06\"; months[\"Jul\"]=\"07\"; months[\"Aug\"]=\"08\";\n  months[\"Sep\"]=\"09\"; months[\"Oct\"]=\"10\"; months[\"Nov\"]=\"11\"; months[\"Dec\"]=\"12\";\n  \n  iso_date = year \"-\" months[month] \"-\" day \"T\" time;\n  \n  # Replace timestamp in original line\n  sub(/\\[[^\\]]+\\]/, iso_date);\n  print;\n}' > /home/user/internal_hits.log\n"]
