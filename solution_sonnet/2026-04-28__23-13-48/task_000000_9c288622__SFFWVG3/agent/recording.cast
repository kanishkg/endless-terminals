[47.381913, "o", "print(f'\\\\nDifference: {(berlin_wrong.replace(tzinfo=None) - berlin_correct.replace(tzinfo=None)).total_seconds() / 3600} hours')\"\r\n\u001b[?2004l\r"]
[47.420439, "o", "OLD METHOD (buggy):\r\n"]
[47.420505, "o", "  2024-03-31 01:30:00+01:00 (offset: +0100)\r\nNEW METHOD (fixed):\r\n"]
[47.420541, "o", "  2024-03-31 03:30:00+02:00 (offset: +0200)\r\n\r\nDifference: -2.0 hours\r\n"]
