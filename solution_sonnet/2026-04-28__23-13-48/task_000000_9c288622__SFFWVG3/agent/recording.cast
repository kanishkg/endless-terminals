[38.91941, "o", "cat app.py\r\n\u001b[?2004l\r"]
[38.920232, "o", "#!/usr/bin/env python3\r\n\"\"\"\r\nMeeting reminder application.\r\nSends reminders 15 minutes before each meeting.\r\nConverts UTC times to Europe/Berlin timezone.\r\n\"\"\"\r\n\r\nimport json\r\nimport pytz\r\nfrom datetime import datetime, timedelta\r\n\r\nMEETINGS_FILE = '/home/user/scheduler/meetings.json'\r\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\r\nUTC_TZ = pytz.utc\r\n\r\ndef load_meetings():\r\n    \"\"\"Load meetings from JSON file.\"\"\"\r\n    with open(MEETINGS_FILE, 'r') as f:\r\n        return json.load(f)\r\n\r\ndef convert_to_berlin(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n\r\n    # First localize as UTC, then convert to Berlin time\r\n    # This properly handles DST transitions\r\n    utc_dt_aware = UTC_TZ.localize(utc_dt)\r\n    berlin_dt = utc_dt_aware.astimezone(BERLIN_TZ)\r\n\r\n    return berlin_dt\r\n\r\ndef get_current_time_berlin():\r\n    \"\"\"Get current time in Berlin timezone.\"\"\"\r\n    return datetime.now(B"]
[38.92029, "o", "ERLIN_TZ)\r\n\r\ndef check_reminders():\r\n    \"\"\"Check for meetings that need reminders (15-75 minutes from now).\"\"\"\r\n    meetings = load_meetings()\r\n    now = get_current_time_berlin()\r\n\r\n    reminder_start = now + timedelta(minutes=15)\r\n    reminder_end = now + timedelta(minutes=75)\r\n\r\n    reminders = []\r\n\r\n    for meeting in meetings:\r\n        berlin_time = convert_to_berlin(meeting['utc_time'])\r\n\r\n        # Check if meeting falls within reminder window\r\n        if reminder_start <= berlin_time <= reminder_end:\r\n            reminders.append({\r\n                'title': meeting['title'],\r\n                'time': berlin_time.strftime('%Y-%m-%d %H:%M:%S %Z%z')\r\n            })\r\n\r\n    return reminders\r\n\r\ndef main():\r\n    \"\"\"Main entry point.\"\"\"\r\n    reminders = check_reminders()\r\n\r\n    if reminders:\r\n        print(\"=== Meeting Reminders ===\")\r\n        for reminder in reminders:\r\n            print(f\"REMINDER: {reminder['title']} at {reminder['time']}\")\r\n    else:\r\n        print(\"No upcoming meetings in the next 15-75 "]
[38.920331, "o", "minutes.\")\r\n\r\nif __name__ == '__main__':\r\n    main()\r\n"]
[38.92045, "o", "\u001b[?2004h"]
[38.920493, "o", "user@8c8d49ec1f76:~/scheduler$ "]
[47.379446, "i", "python3 -c \"import pytz; from datetime import datetime; utc_dt = datetime.strptime('2024-03-31T01:30:00', '%Y-%m-%dT%H:%M:%S'); utc_tz = pytz.utc; berlin_tz = pytz.timezone('Europe/Berlin'); print('OLD METHOD (buggy):'); berlin_wrong = berlin_tz.localize(utc_dt); print(f'  {berlin_wrong} (offset: {berlin_wrong.strftime(\\\"%z\\\")})');\nprint('NEW METHOD (fixed):'); utc_aware = utc_tz.localize(utc_dt); berlin_correct = utc_aware.astimezone(berlin_tz); print(f'  {berlin_correct} (offset: {berlin_correct.strftime(\\\"%z\\\")})');\nprint(f'\\\\nDifference: {(berlin_wrong.replace(tzinfo=None) - berlin_correct.replace(tzinfo=None)).total_seconds() / 3600} hours')\"\n"]
[47.380509, "o", "python3 -c \"import pytz; from datetime import datetime; utc_dt = datetime.strptime('2024-03-31T01:30:00', '%Y-%m-%dT%H:%M:%S'); utc_tz = pytz.utc; berlin_tz = pytz.timezone('Europe/Berlin'); print('OLD METHOD (buggy):'); berlin_wrong = berlin_tz.localize(utc_dt); print(f'  {berlin_wrong} (offset: {berlin_wrong.strftime(\\\"%z\\\")})');\r\n\u001b[?2004l\r"]
