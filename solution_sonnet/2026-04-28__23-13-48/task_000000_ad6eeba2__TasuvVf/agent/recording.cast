[44.14096, "o", "\u001b[?2004h"]
[44.140984, "o", "> "]
[44.141181, "o", "    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.141213, "o", "\u001b[?2004h"]
[44.141242, "o", "> "]
[44.141337, "o", "        json.dump(valid_records, f, indent=2)\r\n\u001b[?2004l\r"]
[44.141365, "o", "\u001b[?2004h> "]
[44.1414, "o", "    \r\n\u001b[?2004l\r"]
[44.141415, "o", "\u001b[?2004h> "]
[44.141543, "o", "    # Write rejected records to rejected.json\r\n\u001b[?2004l\r"]
[44.141574, "o", "\u001b[?2004h"]
[44.141614, "o", "> "]
