[44.128958, "o", "\u001b[?2004h"]
[44.128999, "o", "> "]
[44.129095, "o", "        return cents if cents > 0 else None\r\n\u001b[?2004l\r"]
[44.129124, "o", "\u001b[?2004h> "]
[44.129239, "o", "    except (ValueError, AttributeError):\r\n\u001b[?2004l\r"]
[44.129268, "o", "\u001b[?2004h> "]
[44.129326, "o", "        return None\r\n\u001b[?2004l\r"]
[44.129358, "o", "\u001b[?2004h"]
[44.129388, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.129468, "o", "def is_serial_number(value):\r\n\u001b[?2004l\r"]
[44.129498, "o", "\u001b[?2004h"]
[44.129527, "o", "> "]
[44.129656, "o", "    \"\"\"Check if value looks like a serial number\"\"\"\r\n\u001b[?2004l\r"]
[44.129692, "o", "\u001b[?2004h"]
[44.129723, "o", "> "]
[44.12981, "o", "    return value.strip().startswith('SN-')\r\n\u001b[?2004l\r"]
[44.129842, "o", "\u001b[?2004h> "]
[44.129872, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.129929, "o", "def process_csv():\r\n\u001b[?2004l\r"]
[44.12996, "o", "\u001b[?2004h"]
[44.129994, "o", "> "]
[44.130028, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[44.13006, "o", "\u001b[?2004h> "]
[44.13013, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[44.130162, "o", "\u001b[?2004h> "]
[44.130264, "o", "    records_by_id = defaultdict(list)\r\n\u001b[?2004l\r"]
[44.130294, "o", "\u001b[?2004h> "]
[44.130325, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[44.130353, "o", "> "]
[44.130554, "o", "    with open('/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.13059, "o", "\u001b[?2004h> "]
[44.130698, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[44.130734, "o", "\u001b[?2004h> "]
[44.130765, "o", "        \r\n\u001b[?2004l\r"]
[44.130795, "o", "\u001b[?2004h> "]
[44.130939, "o", "        for row_num, row in enumerate(reader, start=2):\r\n\u001b[?2004l\r"]
[44.130969, "o", "\u001b[?2004h> "]
[44.131076, "o", "            original_row = dict(row)\r\n\u001b[?2004l\r"]
[44.131104, "o", "\u001b[?2004h> "]
[44.131187, "o", "            reasons = []\r\n\u001b[?2004l\r"]
[44.13122, "o", "\u001b[?2004h> "]
[44.131256, "o", "            \r\n\u001b[?2004l\r"]
[44.131279, "o", "\u001b[?2004h"]
[44.131306, "o", "> "]
[44.131395, "o", "            # Extract and clean fields\r\n\u001b[?2004l\r"]
[44.131429, "o", "\u001b[?2004h"]
[44.131458, "o", "> "]
[44.131561, "o", "            asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[44.131584, "o", "\u001b[?2004h"]
[44.131637, "o", "> "]
[44.131737, "o", "            name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[44.131769, "o", "\u001b[?2004h"]
[44.131799, "o", "> "]
[44.131909, "o", "            serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[44.131932, "o", "\u001b[?2004h"]
[44.131965, "o", "> "]
[44.13213, "o", "            purchase_date_raw = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[44.132162, "o", "\u001b[?2004h> "]
[44.132305, "o", "            price_raw = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[44.132333, "o", "\u001b[?2004h"]
[44.132362, "o", "> "]
[44.132496, "o", "            location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[44.132526, "o", "\u001b[?2004h> "]
[44.132563, "o", "            \r\n\u001b[?2004l\r"]
[44.132594, "o", "\u001b[?2004h> "]
[44.132767, "o", "            # Check for swapped name and serial columns\r\n\u001b[?2004l\r"]
[44.132798, "o", "\u001b[?2004h> "]
[44.133051, "o", "            if serial and name and not is_serial_number(serial) and is_serial_number(name):\r\n\u001b[?2004l\r"]
[44.133077, "o", "\u001b[?2004h"]
[44.133107, "o", "> "]
[44.133209, "o", "                name, serial = serial, name\r\n\u001b[?2004l\r"]
[44.133241, "o", "\u001b[?2004h"]
[44.133272, "o", "> "]
[44.133422, "o", "                reasons.append('Swapped name and serial columns')\r\n\u001b[?2004l\r"]
[44.133453, "o", "\u001b[?2004h> "]
[44.133488, "o", "            \r\n\u001b[?2004l\r"]
[44.133518, "o", "\u001b[?2004h> "]
[44.133666, "o", "            # Validate and parse purchase_date\r\n\u001b[?2004l\r"]
[44.133699, "o", "\u001b[?2004h> "]
[44.133853, "o", "            purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[44.133881, "o", "\u001b[?2004h> "]
[44.133981, "o", "            if not purchase_date:\r\n\u001b[?2004l\r"]
[44.134012, "o", "\u001b[?2004h> "]
[44.134247, "o", "                reasons.append(f'Invalid purchase_date format: {purchase_date_raw}')\r\n\u001b[?2004l\r"]
[44.134276, "o", "\u001b[?2004h> "]
[44.134314, "o", "            \r\n\u001b[?2004l\r"]
[44.134339, "o", "\u001b[?2004h> "]
[44.13445, "o", "            # Validate and parse price\r\n\u001b[?2004l\r"]
[44.13448, "o", "\u001b[?2004h"]
[44.134511, "o", "> "]
[44.134632, "o", "            price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[44.134665, "o", "\u001b[?2004h> "]
[44.134762, "o", "            if price_cents is None:\r\n\u001b[?2004l\r"]
[44.134793, "o", "\u001b[?2004h"]
[44.134825, "o", "> "]
[44.135006, "o", "                reasons.append(f'Invalid or non-positive price: {price_raw}')\r\n\u001b[?2004l\r"]
[44.135035, "o", "\u001b[?2004h> "]
[44.135075, "o", "            \r\n\u001b[?2004l\r"]
[44.135105, "o", "\u001b[?2004h> "]
[44.135215, "o", "            # Basic field validation\r\n\u001b[?2004l\r"]
[44.135249, "o", "\u001b[?2004h> "]
[44.135329, "o", "            if not asset_id:\r\n\u001b[?2004l\r"]
[44.135356, "o", "\u001b[?2004h> "]
[44.135499, "o", "                reasons.append('Missing asset ID')\r\n\u001b[?2004l\r"]
[44.135526, "o", "\u001b[?2004h"]
[44.135565, "o", "> "]
[44.135706, "o", "            if not serial or not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[44.135741, "o", "\u001b[?2004h"]
[44.135774, "o", "> "]
[44.135923, "o", "                reasons.append(f'Invalid serial number: {serial}')\r\n\u001b[?2004l\r"]
[44.135953, "o", "\u001b[?2004h> "]
[44.136023, "o", "            if not name:\r\n\u001b[?2004l\r"]
[44.13605, "o", "\u001b[?2004h"]
[44.136075, "o", "> "]
[44.136188, "o", "                reasons.append('Missing name')\r\n\u001b[?2004l\r"]
[44.13622, "o", "\u001b[?2004h> "]
[44.136297, "o", "            if not location:\r\n\u001b[?2004l\r"]
[44.136325, "o", "\u001b[?2004h> "]
[44.13647, "o", "                reasons.append('Missing location')\r\n\u001b[?2004l\r"]
[44.1365, "o", "\u001b[?2004h> "]
[44.136537, "o", "            \r\n\u001b[?2004l\r"]
[44.136565, "o", "\u001b[?2004h"]
[44.136593, "o", "> "]
[44.136759, "o", "            # If there are validation errors, reject the record\r\n\u001b[?2004l\r"]
[44.136796, "o", "\u001b[?2004h> "]
[44.136856, "o", "            if reasons:\r\n\u001b[?2004l\r"]
[44.13688, "o", "\u001b[?2004h"]
[44.136908, "o", "> "]
[44.137004, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[44.137027, "o", "\u001b[?2004h"]
[44.137053, "o", "> "]
[44.137173, "o", "                    'original_row': original_row,\r\n\u001b[?2004l\r"]
[44.137207, "o", "\u001b[?2004h"]
[44.137238, "o", "> "]
[44.137338, "o", "                    'reason': '; '.join(reasons)\r\n\u001b[?2004l\r"]
[44.137367, "o", "\u001b[?2004h> "]
[44.137422, "o", "                })\r\n\u001b[?2004l\r"]
[44.137443, "o", "\u001b[?2004h"]
[44.137468, "o", "> "]
[44.137504, "o", "            else:\r\n\u001b[?2004l\r"]
[44.137533, "o", "\u001b[?2004h> "]
[44.137698, "o", "                # Store valid record for deduplication\r\n\u001b[?2004l\r"]
[44.137725, "o", "\u001b[?2004h"]
[44.137749, "o", "> "]
[44.137804, "o", "                record = {\r\n\u001b[?2004l\r"]
[44.137829, "o", "\u001b[?2004h"]
[44.137857, "o", "> "]
[44.137937, "o", "                    'id': asset_id,\r\n\u001b[?2004l\r"]
[44.137963, "o", "\u001b[?2004h> "]
[44.138061, "o", "                    'name': name,\r\n\u001b[?2004l\r"]
[44.13809, "o", "\u001b[?2004h> "]
[44.138196, "o", "                    'serial': serial,\r\n\u001b[?2004l\r"]
[44.138221, "o", "\u001b[?2004h"]
[44.138246, "o", "> "]
[44.13837, "o", "                    'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[44.138399, "o", "\u001b[?2004h> "]
[44.138535, "o", "                    'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[44.138563, "o", "\u001b[?2004h> "]
[44.138693, "o", "                    'location': location\r\n\u001b[?2004l\r"]
[44.138726, "o", "\u001b[?2004h> "]
[44.138775, "o", "                }\r\n\u001b[?2004l\r"]
[44.138806, "o", "\u001b[?2004h> "]
[44.138956, "o", "                records_by_id[asset_id].append(record)\r\n\u001b[?2004l\r"]
[44.138988, "o", "\u001b[?2004h> "]
[44.139, "o", "    \r\n\u001b[?2004l\r"]
[44.139036, "o", "\u001b[?2004h> "]
[44.139253, "o", "    # Deduplicate: keep the record with the latest purchase_date for each ID\r\n\u001b[?2004l\r"]
[44.139279, "o", "\u001b[?2004h> "]
[44.139426, "o", "    for asset_id, records in records_by_id.items():\r\n\u001b[?2004l\r"]
[44.139451, "o", "\u001b[?2004h"]
[44.139476, "o", "> "]
[44.139544, "o", "        if len(records) == 1:\r\n\u001b[?2004l\r"]
[44.139575, "o", "\u001b[?2004h> "]
[44.139716, "o", "            valid_records.append(records[0])\r\n\u001b[?2004l\r"]
[44.139749, "o", "\u001b[?2004h"]
[44.139779, "o", ">         else:\r\n\u001b[?2004l\r"]
[44.139812, "o", "\u001b[?2004h> "]
[44.139966, "o", "            # Sort by purchase_date and keep the latest\r\n\u001b[?2004l\r"]
[44.140003, "o", "\u001b[?2004h"]
[44.140034, "o", "> "]
[44.140198, "o", "            records.sort(key=lambda x: x['purchase_date'], reverse=True)\r\n\u001b[?2004l\r"]
[44.140228, "o", "\u001b[?2004h> "]
[44.140355, "o", "            valid_records.append(records[0])\r\n\u001b[?2004l\r"]
[44.140384, "o", "\u001b[?2004h> "]
[44.140416, "o", "    \r\n\u001b[?2004l\r"]
[44.140445, "o", "\u001b[?2004h> "]
[44.140567, "o", "    # Sort valid records by ID for consistency\r\n\u001b[?2004l\r"]
[44.140622, "o", "\u001b[?2004h"]
[44.140654, "o", "> "]
[44.140739, "o", "    valid_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[44.140768, "o", "\u001b[?2004h> "]
[44.140794, "o", "    \r\n\u001b[?2004l\r"]
[44.140826, "o", "\u001b[?2004h> "]
