[121.556236, "i", "python3 << 'EOF'\nimport json\n\n# Load and validate rejected.json\nwith open('rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(f\"Rejected records count: {len(rejected)}\")\nprint(f\"\\nFirst rejected record:\")\nprint(json.dumps(rejected[0], indent=2))\n\n# Check that all rejected records have required structure\nfor i, record in enumerate(rejected[:3]):\n    if 'original_row' not in record:\n        print(f\"ERROR: Rejected record {i} missing 'original_row'\")\n    if 'reason' not in record:\n        print(f\"ERROR: Rejected record {i} missing 'reason'\")\n\nprint(f\"\\nSample rejection reasons:\")\nfor record in rejected[:5]:\n    print(f\"  - {record['reason']}\")\n\nprint(\"\\nRejected records validation passed!\")\nEOF\n"]
