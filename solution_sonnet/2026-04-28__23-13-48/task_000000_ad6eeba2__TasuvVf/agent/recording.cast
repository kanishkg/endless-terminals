[114.127638, "i", "python3 << 'EOF'\nimport json\n\n# Load and validate assets.json\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\n\nprint(f\"Valid assets count: {len(assets)}\")\nprint(f\"\\nFirst asset:\")\nprint(json.dumps(assets[0], indent=2))\n\n# Check for European date format record (AST-00229 had 17.07.2016)\nfor asset in assets:\n    if asset['id'] == 'AST-00229':\n        print(f\"\\nAST-00229 (European date 17.07.2016):\")\n        print(json.dumps(asset, indent=2))\n        break\n\n# Validate all records have required fields and correct types\nrequired_fields = ['id', 'name', 'serial', 'purchase_date', 'price_cents', 'location']\nfor i, asset in enumerate(assets[:5]):\n    for field in required_fields:\n        if field not in asset:\n            print(f\"ERROR: Record {i} missing field {field}\")\n    if not isinstance(asset['price_cents'], int):\n        print(f\"ERROR: Record {i} price_cents is not an integer: {type(asset['price_cents'])}\")\n    if not asset['purchase_date'].count('-') == 2:\n        print(f\"ERROR: Record {i} purch"]
[114.127738, "i", "ase_date not in ISO format: {asset['purchase_date']}\")\n\nprint(\"\\nValidation passed for sample records!\")\nEOF\n"]
