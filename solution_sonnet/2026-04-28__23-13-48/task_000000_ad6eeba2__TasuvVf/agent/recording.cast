[88.163514, "i", "cat > normalize_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse date from multiple formats to ISO 8601\"\"\"\n    date_str = date_str.strip()\n    \n    # Try YYYY-MM-DD (ISO format)\n    try:\n        dt = datetime.strptime(date_str, '%Y-%m-%d')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try MM/DD/YYYY (US format)\n    try:\n        dt = datetime.strptime(date_str, '%m/%d/%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try DD.MM.YYYY (European format)\n    try:\n        dt = datetime.strptime(date_str, '%d.%m.%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price to cents (integer)\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = re.sub(r'[$,\\s]', '', price_str.strip())\n        # Convert to float then"]
[88.163674, "i", " to cents\n        dollars = float(cleaned)\n        cents = int(round(dollars * 100))\n        return cents if cents > 0 else None\n    except (ValueError, AttributeError):\n        return None\n\ndef is_serial_number(value):\n    \"\"\"Check if value looks like a serial number\"\"\"\n    return value.strip().startswith('SN-')\n\ndef process_csv():\n    valid_records = []\n    rejected_records = []\n    records_by_id = defaultdict(list)\n    \n    with open('/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        \n        for row_num, row in enumerate(reader, start=2):\n            original_row = dict(row)\n            reasons = []\n            \n            # Extract and clean fields\n            asset_id = row.get('id', '').strip()\n            name = row.get('name', '').strip()\n            serial = row.get('serial', '').strip()\n            purchase_date_raw = row.get('purchase_date', '').strip()\n            price_raw = row.get('price', '').strip()\n            location = row.get('loca"]
[88.163717, "o", "cat > normalize_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[88.163758, "i", "tion', '').strip()\n            \n            # Check for swapped name and serial columns (auto-correct, don't reject)\n            if serial and name and not is_serial_number(serial) and is_serial_number(name):\n                name, serial = serial, name\n            \n            # Validate and parse purchase_date\n            purchase_date = parse_date(purchase_date_raw)\n            if not purchase_date:\n                reasons.append(f'Invalid purchase_date format: {purchase_date_raw}')\n            \n            # Validate and parse price\n            price_cents = parse_price(price_raw)\n            if price_cents is None:\n                reasons.append(f'Invalid or non-positive price: {price_raw}')\n            \n            # Basic field validation\n            if not asset_id:\n                reasons.append('Missing asset ID')\n            if not serial or not is_serial_number(serial):\n                reasons.append(f'Invalid serial number: {serial}')\n            if not name:\n                reasons.append('Missin"]
[88.163768, "o", "\u001b[?2004h> "]
[88.163783, "i", "g name')\n            if not location:\n                reasons.append('Missing location')\n            \n            # If there are validation errors, reject the record\n            if reasons:\n                rejected_records.append({\n                    'original_row': original_row,\n                    'reason': '; '.join(reasons)\n                })\n            else:\n                # Store valid record for deduplication\n                record = {\n                    'id': asset_id,\n                    'name': name,\n                    'serial': serial,\n                    'purchase_date': purchase_date,\n                    'price_cents': price_cents,\n                    'location': location\n                }\n                records_by_id[asset_id].append(record)\n    \n    # Deduplicate: keep the record with the latest purchase_date for each ID\n    for asset_id, records in records_by_id.items():\n        if len(records) == 1:\n            valid_records.append(records[0])\n        else:\n            # Sort by purchas"]
[88.163839, "i", "e_date and keep the latest\n            records.sort(key=lambda x: x['purchase_date'], reverse=True)\n            valid_records.append(records[0])\n    \n    # Sort valid records by ID for consistency\n    valid_records.sort(key=lambda x: x['id'])\n    \n    # Write valid records to assets.json\n    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\n        json.dump(valid_records, f, indent=2)\n    \n    # Write rejected records to rejected.json\n    with open('/home/user/inventory/rejected.json', 'w', encoding='utf-8') as f:\n        json.dump(rejected_records, f, indent=2)\n    \n    print(f'Processed {len(records_by_id)} unique asset IDs')\n    print(f'Valid records: {len(valid_records)}')\n    print(f'Rejected records: {len(rejected_records)}')\n    print(f'Duplicates resolved: {sum(len(v) - 1 for v in records_by_id.values() if len(v) > 1)}')\n\nif __name__ == '__main__':\n    process_csv()\nEOF\n"]
