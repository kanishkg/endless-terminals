[44.141848, "o", "\u001b[?2004h> "]
[44.141976, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[44.142005, "o", "\u001b[?2004h> "]
[44.142038, "o", "    \r\n\u001b[?2004l\r"]
[44.142066, "o", "\u001b[?2004h> "]
[44.142226, "o", "    print(f'Processed {len(records_by_id)} unique asset IDs')\r\n\u001b[?2004l\r"]
[44.142256, "o", "\u001b[?2004h> "]
[44.142393, "o", "    print(f'Valid records: {len(valid_records)}')\r\n\u001b[?2004l\r"]
[44.142415, "o", "\u001b[?2004h"]
[44.142443, "o", "> "]
[44.142579, "o", "    print(f'Rejected records: {len(rejected_records)}')\r\n\u001b[?2004l\r"]
[44.14262, "o", "\u001b[?2004h"]
[44.142634, "o", "> "]
[44.142897, "o", "    print(f'Duplicates resolved: {sum(len(v) - 1 for v in records_by_id.values() if len(v) > 1)}')\r\n\u001b[?2004l\r"]
[44.142945, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[44.142978, "o", "\u001b[?2004h> "]
