[121.577067, "o", "\r\nSample rejection reasons:\r\n  - Invalid or non-positive price: -579.02\r\n  - Missing asset ID\r\n  - Invalid or non-positive price: -2098.30\r\n  - Invalid or non-positive price: \r\n  - Invalid purchase_date format: 2020-13-45\r\n\r\nRejected records validation passed!\r\n"]
[121.580039, "o", "\u001b[?2004huser@08347ddfed8c:~/inventory$ "]
[135.732812, "i", "python3 << 'EOF'\nimport json\nimport re\nfrom datetime import datetime\n\n# Load both files\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\nwith open('rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(\"=== Final Validation Report ===\")\nprint(f\"\\nTotal records in CSV: 846 (excluding header)\")\nprint(f\"Valid assets: {len(assets)}\")\nprint(f\"Rejected records: {len(rejected)}\")\nprint(f\"Duplicates resolved: 21\")\nprint(f\"Expected: 846 = 809 + 16 + 21 ✓\")\n\n# Validate all assets\nerrors = []\nfor i, asset in enumerate(assets):\n    # Check ISO 8601 date format\n    try:\n        datetime.strptime(asset['purchase_date'], '%Y-%m-%d')\n    except ValueError:\n        errors.append(f\"Asset {i} ({asset['id']}): Invalid ISO date {asset['purchase_date']}\")\n    \n    # Check price_cents is positive integer\n    if not isinstance(asset['price_cents'], int) or asset['price_cents'] <= 0:\n        errors.append(f\"Asset {i} ({asset['id']}): Invalid price_cents {asset['price_cents']}\")\n    \n    # Check serial number fo"]
[135.732919, "i", "rmat\n    if not asset['serial'].startswith('SN-'):\n        errors.append(f\"Asset {i} ({asset['id']}): Invalid serial {asset['serial']}\")\n    \n    # Check all required fields are non-empty\n    for field in ['id', 'name', 'serial', 'location']:\n        if not asset[field]:\n            errors.append(f\"Asset {i} ({asset['id']}): Empty {field}\")\n\nif errors:\n    print(f\"\\n❌ Found {len(errors)} validation errors:\")\n    for error in errors[:10]:\n        print(f\"  {error}\")\nelse:\n    print(\"\\n✓ All assets passed validation!\")\n    print(\"  - All dates in ISO 8601 format (YYYY-MM-DD)\")\n    print(\"  - All price_cents are positive integers\")\n    print(\"  - All serial numbers start with 'SN-'\")\n    print(\"  - All required fields are present and non-empty\")\n\nprint(\"\\n✓ Files ready for import:\")\nprint(\"  - /home/user/inventory/assets.json\")\nprint(\"  - /home/user/inventory/rejected.json\")\nEOF\n"]
