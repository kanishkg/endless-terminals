[19.257604, "i", "cat > /tmp/process_mem.sh << 'EOF'\n#!/bin/bash\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable\n    memtotal=$(grep -oP '^MemTotal:\\s+\\K[0-9]+' \"$file\" 2>/dev/null)\n    memavail=$(grep -oP '^MemAvailable:\\s+\\K[0-9]+' \"$file\" 2>/dev/null)\n    \n    # Skip if we can't get both values\n    if [[ -z \"$memtotal\" ]] || [[ -z \"$memavail\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available\n    percent=$(awk \"BEGIN {printf \\\"%.2f\\\", ($memavail / $memtotal) * 100}\")\n    \n    # Check if less than 20%\n    if (( $(awk \"BEGIN {print ($percent < 20)}\") )); then\n        echo -e \"$hostname\\t$percent\"\n    fi\ndone | sort -t$'\\t' -k2 -n\nEOF\n"]
