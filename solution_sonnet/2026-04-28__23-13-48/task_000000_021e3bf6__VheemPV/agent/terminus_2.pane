MemAvai[?2004huser@3a816ecd5f64:~$ cat > /tmp/process_mem.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> for file in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$file" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable
[?2004l[?2004h>     memtotal=$(grep -oP '^MemTotal:\s+\K[0-9]+' "$file" 2>/dev/null)
[?2004l[?2004h>     memavail=$(grep -oP '^MemAvailable:\s+\K[0-9]+' "$file" 2>/dev/null)
[?2004l[?2004h>     
[?2004l[?2004h>     # Skip if we can't get both values
[?2004l[?2004h>     if [[ -z "$memtotal" ]] || [[ -z "$memavail" ]]; then
[?2004l[?2004h>         continue
[?2004l[?2004h>     fi
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate percentage available
[?2004l[?2004h>     percent=$(awk "BEGIN {printf \"%.2f\", ($memavail / $memtotal) * 100}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if less than 20%
[?2004l[?2004h>     if (( $(awk "BEGIN {print ($percent < 20)}") )); then
[?2004l[?2004h>         echo -e "$hostname\t$percent"
[?2004l[?2004h>     fi
[?2004l[?2004h> done | sort -t$'\t' -k2 -n
[?2004l[?2004h> EOF
