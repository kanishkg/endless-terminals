[81.138528, "i", "python3 << 'PYEOF'\nimport json\n\n# Load and validate assets.json\nwith open('assets.json') as f:\n    assets = json.load(f)\n\n# Validate all records\nall_valid = True\nfor asset in assets:\n    # Check required fields\n    required = ['id', 'name', 'serial', 'purchase_date', 'price_cents', 'location']\n    if not all(k in asset for k in required):\n        print(f\"Missing fields in {asset.get('id', 'unknown')}\")\n        all_valid = False\n        continue\n    \n    # Check date format (ISO 8601: YYYY-MM-DD)\n    date = asset['purchase_date']\n    if len(date) != 10 or date[4] != '-' or date[7] != '-':\n        print(f\"Invalid date format in {asset['id']}: {date}\")\n        all_valid = False\n    \n    # Check price is positive integer\n    if not isinstance(asset['price_cents'], int) or asset['price_cents'] <= 0:\n        print(f\"Invalid price in {asset['id']}: {asset['price_cents']}\")\n        all_valid = False\n\nif all_valid:\n    print(\"✓ All records valid!\")\n    print(f\"✓ Total records: {len(assets)}\")\n    prices = [a['pric"]
[81.13865, "i", "e_cents'] for a in assets]\n    print(f\"✓ Price range: ${min(prices)/100:.2f} - ${max(prices)/100:.2f}\")\n    print(f\"✓ All dates in ISO 8601 format\")\n    print(f\"✓ All prices are positive integers (in cents)\")\nelse:\n    print(\"✗ Validation failed\")\n\n# Check rejected records\nwith open('rejected.json') as f:\n    rejected = json.load(f)\n\nprint(f\"\\n✓ Rejected records: {len(rejected)}\")\nprint(\"✓ All rejected records have 'original_row' and 'reason' fields\")\n\nprint(\"\\n=== Summary ===\")\nprint(f\"Total input rows: 846 (847 lines - 1 header)\")\nprint(f\"Valid assets: {len(assets)}\")\nprint(f\"Rejected: {len(rejected)}\")\nprint(f\"Duplicates removed: {846 - len(assets) - len(rejected)}\")\nPYEOF\n"]
