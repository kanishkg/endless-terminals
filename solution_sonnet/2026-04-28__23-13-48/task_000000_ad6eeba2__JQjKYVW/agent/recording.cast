[88.984412, "i", "python3 << 'PYEOF'\nimport json\n\nwith open('assets.json') as f:\n    assets = json.load(f)\n\n# Find the specific records with European dates\nfor asset in assets:\n    if asset['id'] in ['AST-00229', 'AST-00205', 'AST-00325']:\n        print(f\"ID: {asset['id']}\")\n        print(f\"  Name: {asset['name']}\")\n        print(f\"  Serial: {asset['serial']}\")\n        print(f\"  Purchase Date: {asset['purchase_date']} (converted from European format)\")\n        print(f\"  Price: ${asset['price_cents']/100:.2f} ({asset['price_cents']} cents)\")\n        print(f\"  Location: {asset['location']}\")\n        print()\nPYEOF\n"]
