[36.040933, "i", "d)} rejected\")\n\n# Deduplicate by ID, keeping the one with latest purchase date\nprint(\"Deduplicating by ID...\")\nid_to_records = defaultdict(list)\nfor record in records:\n    id_to_records[record['id']].append(record)\n\ndeduped_records = []\nfor asset_id, recs in id_to_records.items():\n    if len(recs) > 1:\n        # Sort by date and keep the latest\n        recs.sort(key=lambda x: x['_date_obj'], reverse=True)\n        print(f\"  Duplicate ID {asset_id}: keeping latest of {len(recs)} records\")\n    # Remove temporary date object\n    latest = recs[0]\n    del latest['_date_obj']\n    deduped_records.append(latest)\n\nprint(f\"After deduplication: {len(deduped_records)} unique records\")\n\n# Sort by ID for consistency\ndeduped_records.sort(key=lambda x: x['id'])\n\n# Write output files\nwith open('/home/user/inventory/assets.json', 'w') as f:\n    json.dump(deduped_records, f, indent=2)\n\nwith open('/home/user/inventory/rejected.json', 'w') as f:\n    json.dump(rejected, f, indent=2)\n\nprint(f\"\\nComplete!\")\nprint(f\"  Valid assets: {l"]
