[36.04664, "o", "    \"\"\"Check if string looks like a serial number\"\"\"\r\n\u001b[?2004l\r"]
[36.046667, "o", "\u001b[?2004h"]
[36.046695, "o", "> "]
[36.046842, "o", "    return bool(re.match(r'^SN-[A-Z]{3}-\\d{5}$', s.strip()))\r\n\u001b[?2004l\r"]
[36.04687, "o", "\u001b[?2004h> "]
[36.046897, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.046925, "o", "> "]
[36.047006, "o", "print(\"Starting CSV processing...\")\r\n\u001b[?2004l\r"]
[36.047042, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[36.047068, "o", "\u001b[?2004h> "]
[36.047136, "o", "# Read and process CSV\r\n\u001b[?2004l\r"]
[36.047158, "o", "\u001b[?2004h"]
[36.047186, "o", "> "]
[36.047214, "o", "records = []\r\n\u001b[?2004l\r"]
[36.047242, "o", "\u001b[?2004h> "]
[36.047275, "o", "rejected = []\r\n\u001b[?2004l\r"]
[36.047302, "o", "\u001b[?2004h> "]
[36.047328, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.047358, "o", "> "]
[36.047492, "o", "with open('/home/user/inventory/assets.csv', 'r') as f:\r\n\u001b[?2004l\r"]
[36.04752, "o", "\u001b[?2004h"]
[36.047549, "o", "> "]
[36.047628, "o", "    reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[36.047657, "o", "\u001b[?2004h> "]
[36.047683, "o", "    \r\n\u001b[?2004l\r"]
[36.047715, "o", "\u001b[?2004h"]
[36.047744, "o", "> "]
[36.047849, "o", "    for row_num, row in enumerate(reader, start=2):\r\n\u001b[?2004l\r"]
[36.047878, "o", "\u001b[?2004h> "]
[36.04797, "o", "        original_row = dict(row)\r\n\u001b[?2004l\r"]
[36.047998, "o", "\u001b[?2004h> "]
[36.048085, "o", "        rejection_reason = []\r\n\u001b[?2004l\r"]
[36.048114, "o", "\u001b[?2004h> "]
[36.048151, "o", "        \r\n\u001b[?2004l\r"]
[36.048176, "o", "\u001b[?2004h"]
[36.048202, "o", "> "]
[36.048314, "o", "        # Check if serial and name are swapped\r\n\u001b[?2004l\r"]
[36.048343, "o", "\u001b[?2004h> "]
[36.048569, "o", "        if is_serial_format(row['name']) and not is_serial_format(row['serial']):\r\n\u001b[?2004l\r"]
[36.048623, "o", "\u001b[?2004h> "]
[36.048804, "o", "            row['name'], row['serial'] = row['serial'], row['name']\r\n\u001b[?2004l\r"]
[36.048831, "o", "\u001b[?2004h> "]
[36.04886, "o", "        \r\n\u001b[?2004l\r"]
[36.048882, "o", "\u001b[?2004h"]
[36.048911, "o", "> "]
[36.048952, "o", "        # Parse date\r\n\u001b[?2004l\r"]
[36.048983, "o", "\u001b[?2004h> "]
[36.049154, "o", "        iso_date, date_obj = parse_date(row['purchase_date'])\r\n\u001b[?2004l\r"]
[36.049187, "o", "\u001b[?2004h> "]
[36.049267, "o", "        if iso_date is None:\r\n\u001b[?2004l\r"]
[36.049289, "o", "\u001b[?2004h"]
[36.049317, "o", "> "]
[36.049527, "o", "            rejection_reason.append(f\"Invalid date format: {row['purchase_date']}\")\r\n\u001b[?2004l\r"]
[36.049555, "o", "\u001b[?2004h> "]
[36.0496, "o", "        \r\n"]
[36.049629, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[36.049697, "o", "        # Parse price\r\n\u001b[?2004l\r"]
[36.049725, "o", "\u001b[?2004h> "]
[36.049861, "o", "        price_cents = parse_price(row['price'])\r\n\u001b[?2004l\r"]
[36.049896, "o", "\u001b[?2004h> "]
[36.049981, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[36.050009, "o", "\u001b[?2004h> "]
[36.050225, "o", "            rejection_reason.append(f\"Invalid price format: {row['price']}\")\r\n\u001b[?2004l\r"]
[36.050254, "o", "\u001b[?2004h> "]
[36.050338, "o", "        elif price_cents <= 0:\r\n"]
[36.050356, "o", "\u001b[?2004l\r\u001b[?2004h"]
[36.050393, "o", "> "]
[36.050592, "o", "            rejection_reason.append(f\"Non-positive price: {price_cents} cents\")"]
[36.050622, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.050654, "o", "> "]
[36.050684, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[36.050713, "o", "> "]
[36.050787, "o", "        # Validate required fields\r\n\u001b[?2004l\r"]
[36.050816, "o", "\u001b[?2004h> "]
[36.050915, "o", "        if not row['id'].strip():\r\n\u001b[?2004l\r"]
[36.050947, "o", "\u001b[?2004h> "]
[36.051087, "o", "            rejection_reason.append(\"Missing ID\")\r\n\u001b[?2004l\r"]
[36.051116, "o", "\u001b[?2004h> "]
[36.051328, "o", "        if not row['serial'].strip() or not is_serial_format(row['serial']):\r\n\u001b[?2004l\r"]
[36.051362, "o", "\u001b[?2004h> "]
[36.051576, "o", "            rejection_reason.append(f\"Invalid serial format: {row['serial']}\")\r\n\u001b[?2004l\r"]
[36.051613, "o", "\u001b[?2004h"]
[36.051642, "o", "> "]
[36.051671, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[36.051699, "o", "> "]
[36.051762, "o", "        if rejection_reason:\r\n\u001b[?2004l\r"]
[36.051791, "o", "\u001b[?2004h> "]
[36.051878, "o", "            rejected.append({\r\n\u001b[?2004l\r"]
[36.051908, "o", "\u001b[?2004h> "]
[36.052036, "o", "                'original_row': original_row,\r\n\u001b[?2004l\r"]
[36.052059, "o", "\u001b[?2004h"]
[36.052086, "o", "> "]
[36.052226, "o", "                'reason': '; '.join(rejection_reason)\r\n\u001b[?2004l\r"]
[36.052256, "o", "\u001b[?2004h> "]
[36.052303, "o", "            })\r\n\u001b[?2004l\r"]
[36.052331, "o", "\u001b[?2004h> "]
[36.052376, "o", "        else:\r\n\u001b[?2004l\r"]
[36.052404, "o", "\u001b[?2004h> "]
[36.052486, "o", "            records.append({\r\n\u001b[?2004l\r"]
[36.052511, "o", "\u001b[?2004h> "]
[36.052645, "o", "                'id': row['id'].strip(),\r\n\u001b[?2004l\r"]
[36.052668, "o", "\u001b[?2004h"]
[36.0527, "o", "> "]
[36.052801, "o", "                'name': row['name'].strip(),\r\n\u001b[?2004l\r"]
[36.05283, "o", "\u001b[?2004h> "]
[36.052966, "o", "                'serial': row['serial'].strip(),\r\n\u001b[?2004l\r"]
[36.05299, "o", "\u001b[?2004h"]
[36.053019, "o", "> "]
[36.053119, "o", "                'purchase_date': iso_date,\r\n\u001b[?2004l\r"]
[36.053153, "o", "\u001b[?2004h> "]
[36.053267, "o", "                'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[36.053293, "o", "\u001b[?2004h> "]
[36.05344, "o", "                'location': row['location'].strip(),\r\n\u001b[?2004l\r"]
[36.053466, "o", "\u001b[?2004h> "]
[36.053645, "o", "                '_date_obj': date_obj  # For deduplication\r\n\u001b[?2004l\r"]
[36.053667, "o", "\u001b[?2004h"]
[36.053695, "o", "> "]
[36.053727, "o", "            })\r\n\u001b[?2004l\r"]
[36.053754, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[36.053783, "o", "\u001b[?2004h> "]
[36.05398, "o", "print(f\"Parsed {len(records)} valid records, {len(rejected)} rejected\")\r\n\u001b[?2004l\r"]
[36.05401, "o", "\u001b[?2004h> "]
[36.054039, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.054217, "o", "# Deduplicate by ID, keeping the one with latest purchase date\r\n\u001b[?2004l\r"]
[36.054247, "o", "\u001b[?2004h> "]
[36.054337, "o", "print(\"Deduplicating by ID...\")\r\n\u001b[?2004l\r"]
[36.054365, "o", "\u001b[?2004h> "]
[36.054462, "o", "id_to_records = defaultdict(list)\r\n\u001b[?2004l\r"]
[36.054497, "o", "\u001b[?2004h> "]
[36.05456, "o", "for record in records:\r\n\u001b[?2004l\r"]
[36.054599, "o", "\u001b[?2004h"]
[36.054634, "o", "> "]
[36.054735, "o", "    id_to_records[record['id']].append(record)\r\n\u001b[?2004l\r"]
[36.054764, "o", "\u001b[?2004h> "]
[36.054796, "o", "\r\n\u001b[?2004l\r"]
[36.054823, "o", "\u001b[?2004h> "]
[36.054861, "o", "deduped_records = []\r\n\u001b[?2004l\r"]
[36.054888, "o", "\u001b[?2004h> "]
[36.055014, "o", "for asset_id, recs in id_to_records.items():\r\n\u001b[?2004l\r"]
[36.055043, "o", "\u001b[?2004h> "]
[36.055107, "o", "    if len(recs) > 1:\r\n\u001b[?2004l\r"]
[36.055135, "o", "\u001b[?2004h> "]
[36.055256, "o", "        # Sort by date and keep the latest\r\n\u001b[?2004l\r"]
[36.055284, "o", "\u001b[?2004h> "]
[36.055456, "o", "        recs.sort(key=lambda x: x['_date_obj'], reverse=True)\r\n\u001b[?2004l\r"]
[36.055483, "o", "\u001b[?2004h"]
[36.055516, "o", "> "]
[36.055729, "o", "        print(f\"  Duplicate ID {asset_id}: keeping latest of {len(recs)} records\")\r\n\u001b[?2004l\r"]
[36.055753, "o", "\u001b[?2004h"]
[36.055783, "o", "> "]
[36.05586, "o", "    # Remove temporary date object\r\n\u001b[?2004l\r"]
[36.055888, "o", "\u001b[?2004h> "]
[36.055952, "o", "    latest = recs[0]\r\n\u001b[?2004l\r"]
[36.055979, "o", "\u001b[?2004h> "]
[36.056066, "o", "    del latest['_date_obj']\r\n\u001b[?2004l\r"]
[36.056085, "o", "\u001b[?2004h"]
[36.056121, "o", "> "]
[36.0562, "o", "    deduped_records.append(latest)\r\n\u001b[?2004l\r"]
[36.056224, "o", "\u001b[?2004h> \r\n"]
[36.056242, "o", "\u001b[?2004l\r"]
[36.056278, "o", "\u001b[?2004h> "]
[36.05645, "o", "print(f\"After deduplication: {len(deduped_records)} unique records\")\r\n\u001b[?2004l\r"]
[36.05648, "o", "\u001b[?2004h"]
[36.056505, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[36.056532, "o", "> "]
[36.056611, "o", "# Sort by ID for consistency\r\n\u001b[?2004l\r"]
[36.056637, "o", "\u001b[?2004h"]
[36.056663, "o", "> "]
[36.056769, "o", "deduped_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[36.056809, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[36.056837, "o", "\u001b[?2004h> "]
[36.05689, "o", "# Write output files\r\n\u001b[?2004l\r"]
[36.056918, "o", "\u001b[?2004h> "]
[36.057078, "o", "with open('/home/user/inventory/assets.json', 'w') as f:\r\n\u001b[?2004l\r"]
[36.057105, "o", "\u001b[?2004h> "]
[36.057229, "o", "    json.dump(deduped_records, f, indent=2)\r\n\u001b[?2004l\r"]
[36.057261, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[36.057292, "o", "\u001b[?2004h> "]
[36.057452, "o", "with open('/home/user/inventory/rejected.json', 'w') as f:\r\n\u001b[?2004l\r"]
[36.057484, "o", "\u001b[?2004h> "]
[36.057599, "o", "    json.dump(rejected, f, indent=2)\r\n\u001b[?2004l\r"]
[36.057628, "o", "\u001b[?2004h> "]
[36.057655, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.057673, "o", "> "]
[36.057727, "o", "print(f\"\\nComplete!\")\r\n\u001b[?2004l\r"]
[36.057756, "o", "\u001b[?2004h> "]
[36.057937, "o", "print(f\"  Valid assets: {len(deduped_records)} -> assets.json\")\r\n\u001b[?2004l\r"]
[36.05796, "o", "\u001b[?2004h"]
[36.057989, "o", "> "]
[36.058123, "o", "print(f\"  Rejected: {len(rejected)} -> rejected.json\")\r\n\u001b[?2004l\r"]
[36.058158, "o", "\u001b[?2004h"]
[36.058185, "o", "> EOF\r\n\u001b[?2004l\r"]
