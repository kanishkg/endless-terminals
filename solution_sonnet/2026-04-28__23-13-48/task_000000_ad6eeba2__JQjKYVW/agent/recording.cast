[36.040632, "i", "python3 << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Try to parse date in multiple formats and return ISO 8601 string\"\"\"\n    date_str = date_str.strip()\n    formats = [\n        '%Y-%m-%d',      # YYYY-MM-DD\n        '%m/%d/%Y',      # MM/DD/YYYY\n        '%d.%m.%Y',      # DD.MM.YYYY\n    ]\n    \n    for fmt in formats:\n        try:\n            dt = datetime.strptime(date_str, fmt)\n            return dt.strftime('%Y-%m-%d'), dt\n        except ValueError:\n            continue\n    return None, None\n\ndef parse_price(price_str):\n    \"\"\"Parse price and convert to cents (integer)\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = re.sub(r'[$,\\s]', '', str(price_str))\n        # Convert to float then to cents\n        price_float = float(cleaned)\n        price_cents = int(round(price_float * 100))\n        return price_cents\n    except (ValueError, TypeError):\n        return None\n\ndef is_serial_"]
[36.040771, "i", "format(s):\n    \"\"\"Check if string looks like a serial number\"\"\"\n    return bool(re.match(r'^SN-[A-Z]{3}-\\d{5}$', s.strip()))\n\nprint(\"Starting CSV processing...\")\n\n# Read and process CSV\nrecords = []\nrejected = []\n\nwith open('/home/user/inventory/assets.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    \n    for row_num, row in enumerate(reader, start=2):\n        original_row = dict(row)\n        rejection_reason = []\n        \n        # Check if serial and name are swapped\n        if is_serial_format(row['name']) and not is_serial_format(row['serial']):\n            row['name'], row['serial'] = row['serial'], row['name']\n        \n        # Parse date\n        iso_date, date_obj = parse_date(row['purchase_date'])\n        if iso_date is None:\n            rejection_reason.append(f\"Invalid date format: {row['purchase_date']}\")\n        \n        # Parse price\n        price_cents = parse_price(row['price'])\n        if price_cents is None:\n            rejection_reason.append(f\"Invalid price format: {row['price']}\")\n    "]
[36.040825, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r"]
[36.040875, "i", "    elif price_cents <= 0:\n            rejection_reason.append(f\"Non-positive price: {price_cents} cents\")\n        \n        # Validate required fields\n        if not row['id'].strip():\n            rejection_reason.append(\"Missing ID\")\n        if not row['serial'].strip() or not is_serial_format(row['serial']):\n            rejection_reason.append(f\"Invalid serial format: {row['serial']}\")\n        \n        if rejection_reason:\n            rejected.append({\n                'original_row': original_row,\n                'reason': '; '.join(rejection_reason)\n            })\n        else:\n            records.append({\n                'id': row['id'].strip(),\n                'name': row['name'].strip(),\n                'serial': row['serial'].strip(),\n                'purchase_date': iso_date,\n                'price_cents': price_cents,\n                'location': row['location'].strip(),\n                '_date_obj': date_obj  # For deduplication\n            })\n\nprint(f\"Parsed {len(records)} valid records, {len(rejecte"]
