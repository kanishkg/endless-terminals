[74.711254, "o", "#!/usr/bin/env python3\r\nimport json\r\nimport csv\r\nimport ipaddress\r\nimport sys\r\n\r\ndef parse_port_spec(port_spec):\r\n"]
[74.711344, "o", "    \"\"\"Parse a port specification into a list of allowed ports or ranges.\"\"\"\r\n    if '-' in str(port_spec):\r\n        start, end = map(int, str(port_spec).split('-'))\r\n        return ('range', start, end)\r\n    else:\r\n        return ('single', int(port_spec))\r\n\r\ndef port_matches(port, port_spec):\r\n    \"\"\"Check if a port matches a port specification.\"\"\"\r\n    parsed = parse_port_spec(port_spec)\r\n    port = int(port)\r\n    \r\n    if parsed[0] == 'single':\r\n"]
