[52.153566, "i", "python3 -c \"def port_matches(port, port_spec):\n    if '-' in str(port_spec):\n        start, end = map(int, str(port_spec).split('-'))\n        return start <= int(port) <= end\n    else:\n        return int(port) == int(port_spec)\n\nprint('8500 in 8000-9000:', port_matches(8500, '8000-9000'))\nprint('8080 in 8000-9000:', port_matches(8080, '8000-9000'))\nprint('7999 in 8000-9000:', port_matches(7999, '8000-9000'))\nprint('443 == 443:', port_matches(443, '443'))\"\n"]
