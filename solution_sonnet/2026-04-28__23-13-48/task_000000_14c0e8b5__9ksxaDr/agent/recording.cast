[29.895246, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse a port specification into a list of allowed ports or ranges.\"\"\"\n    if '-' in str(port_spec):\n        start, end = map(int, str(port_spec).split('-'))\n        return ('range', start, end)\n    else:\n        return ('single', int(port_spec))\n\ndef port_matches(port, port_spec):\n    \"\"\"Check if a port matches a port specification.\"\"\"\n    parsed = parse_port_spec(port_spec)\n    port = int(port)\n    \n    if parsed[0] == 'single':\n        return port == parsed[1]\n    elif parsed[0] == 'range':\n        return parsed[1] <= port <= parsed[2]\n    return False\n\ndef find_matching_rule(src_ip, rules):\n    \"\"\"Find the most specific matching rule for a source IP.\n    Rules should be pre-sorted by specificity (prefix length descending).\"\"\"\n    ip_obj = ipaddress.ip_address(src_ip)\n    \n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj"]
[29.895306, "i", " in network:\n            return rule\n    \n    return None\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        config = json.load(f)\n    \n    rules = config['rules']\n    default_action = config.get('default_action', 'deny')\n    \n    # Sort rules by CIDR specificity (more specific first)\n    # More specific = longer prefix length\n    rules_sorted = sorted(rules, \n                         key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen,\n                         reverse=True)\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = conn['dest_port']\n        \n        # Find the most specific matching rule\n        matching_rule = find_matching_rule(src_ip, rules_sorted)\n        \n        blocked = False\n        matched_cidr = None"]
[29.895421, "i", "\n        \n        if matching_rule is None:\n            # No rule matched, apply default action\n            if default_action == 'deny':\n                blocked = True\n                matched_cidr = 'default'\n        else:\n            matched_cidr = matching_rule['source_cidr']\n            \n            if matching_rule['action'] == 'deny':\n                # Explicit deny rule\n                if port_matches(dest_port, matching_rule['dest_port']):\n                    blocked = True\n            elif matching_rule['action'] == 'allow':\n                # Allow rule - check if port matches\n                if not port_matches(dest_port, matching_rule['dest_port']):\n                    blocked = True\n        \n        if blocked:\n            if matched_cidr == 'default':\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed (no matching rule)\")\n            else:\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matched_cidr}\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
