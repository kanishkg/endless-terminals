[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Output file
[?2004l[?2004h> OUTPUT="/home/user/low_memory_report.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for collecting results
[?2004l[?2004h> TEMP_FILE=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for hostfile in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handle missing/corrupted data
[?2004l[?2004h>     memtotal=$(grep -E '^MemTotal:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     memavail=$(grep -E '^MemAvailable:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Skip if we couldn't get both values (corrupted file)
[?2004l[?2004h>     if [[ -z "$memtotal" ]] || [[ -z "$memavail" ]]; then
[?2004l[?2004h>         continue
[?2004l[?2004h>     fi
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate percentage available (using bc for floating point)
[?2004l[?2004h>     percentage=$(echo "scale=2; ($memavail * 100) / $memtotal" | bc)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if less than 20%
[?2004l[?2004h>     is_low=$(echo "$percentage < 20" | bc)
[?2004l[?2004h>     
[?2004l[?2004h>     if [[ $is_low -eq 1 ]]; then
[?2004l[?2004h>         echo -e "${hostname}\t${percentage}" >> "$TEMP_FILE"
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending - worst first) and write to output
[?2004l[?2004h> sort -t$'\t' -k2 -n "$TEMP_FILE" > "$OUTPUT"
[?2004l[?2004h> 
[?2004l[?2004h> # Clean up
[?2004l[?2004h> rm -f "$TEMP_FILE"
[?2004l[?2004h> EOF
