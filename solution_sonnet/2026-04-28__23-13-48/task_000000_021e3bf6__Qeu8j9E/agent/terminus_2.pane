[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, calculate percentage, and filter in one awk command
[?2004l[?2004h>     awk -v host="$hostname" '
