[?2004l[?2004h>                     printf "%s\t%.2f\n", host, percentage
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     ' "$hostfile" >> "$TEMP_FILE"
[?2004l[?2004h> done
[?2004l[?2004h> 
