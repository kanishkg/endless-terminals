[19.967211, "i", "cat config/gunicorn.conf.py\n"]
[19.967333, "o", "cat config/gunicorn.conf.py\r\n"]
[19.96738, "o", "\u001b[?2004l\r"]
[19.96817, "o", "import configparser\r\nimport os\r\n\r\n# Read configuration from settings.ini\r\nconfig = configparser.ConfigParser()\r\nconfig_path = os.path.join(os.path.dirname(__file__), 'settings.ini')\r\nconfig.read(config_path)\r\n\r\n# Get settings with fallbacks\r\nhost = config.get('server', 'host', fallback='127.0.0.1')\r\nport = config.get('server', 'port', fallback='8000')\r\nworkers_count = config.get('server', 'workers', fallback='2')\r\n\r\n# Gunicorn configuration\r\nbind = f\"{host}:{port}\"\r\nworkers = int(workers_count)\r\ndaemon = False\r\n"]
