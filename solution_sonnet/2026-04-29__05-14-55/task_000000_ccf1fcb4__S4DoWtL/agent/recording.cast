[19.758553, "o", "cat app/__init__.py\r\n\u001b[?2004l\r"]
[19.759439, "o", "from flask import Flask\r\n\r\n\r\ndef create_app():\r\n    app = Flask(__name__)\r\n\r\n    from . import routes\r\n    app.register_blueprint(routes.bp)\r\n\r\n    return app\r\n"]
[19.759569, "o", "\u001b[?2004h"]
[19.759604, "o", "root@d223bac59547:/home/user/labeler# "]
[19.864026, "i", "cat app/routes.py\n"]
[19.864129, "o", "cat app/routes.py\r\n\u001b[?2004l\r"]
[19.864992, "o", "from flask import Blueprint\r\n\r\nbp = Blueprint('main', __name__)\r\n\r\n\r\n@bp.route('/')\r\ndef index():\r\n    return \"Labeler v2.1 running\"\r\n\r\n\r\n@bp.route('/health')\r\ndef health():\r\n    return {\"status\": \"ok\"}\r\n"]
[19.865128, "o", "\u001b[?2004h"]
