[?2004hroot@750e68c58db5:/home/user/audit# cat > check.py << 'EOF'
[?2004l[?2004h> #!/usr/bin/env python3
[?2004l[?2004h> import json
[?2004l[?2004h> import csv
[?2004l[?2004h> import ipaddress
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def parse_port_spec(port_spec):
[?2004l[?2004h>     """Parse a port specification (single port or range) into a set of allowed ports."""
[?2004l[?2004h>     port_spec = str(port_spec).strip()
[?2004l[?2004h>     if '-' in port_spec:
[?2004l[?2004h>         start, end = port_spec.split('-')
[?2004l[?2004h>         return set(range(int(start), int(end) + 1))
[?2004l[?2004h>     else:
[?2004l[?2004h>         return {int(port_spec)}
[?2004l[?2004h> 
[?2004l[?2004h> def find_matching_rules(src_ip, rules):
[?2004l[?2004h>     """Find all rules that match the source IP, sorted by most specific CIDR first."""
[?2004l[?2004h>     matching = []
[?2004l[?2004h>     ip_obj = ipaddress.ip_address(src_ip)
[?2004l[?2004h>     
[?2004l[?2004h>     for rule in rules:
[?2004l[?2004h>         network = ipaddress.ip_network(rule['source_cidr'])
[?2004l[?2004h>         if ip_obj in network:
[?2004l[?2004h>             matching.append(rule)
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by prefix length (most specific first)
[?2004l[?2004h>     matching.sort(key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen, reverse=True)
[?2004l[?2004h>     return matching
[?2004l[?2004h> 
[?2004l[?2004h> def is_connection_allowed(src_ip, dest_port, rules):
[?2004l[?2004h>     """Check if a connection is allowed based on firewall rules."""
[?2004l[?2004h>     matching_rules = find_matching_rules(src_ip, rules)
[?2004l[?2004h>     
[?2004l[?2004h>     for rule in matching_rules:
[?2004l[?2004h>         allowed_ports = parse_port_spec(rule['dest_port'])
[?2004l[?2004h>         if dest_port in allowed_ports:
[?2004l[?2004h>             if rule['action'] == 'allow':
[?2004l[?2004h>                 return True, rule
[?2004l[?2004h>             else:  # deny
[?2004l[?2004h>                 return False, rule
[?2004l[?2004h>     
[?2004l[?2004h>     # No matching rule found, default deny
[?2004l[?2004h>     return False, None
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     # Load firewall rules
[?2004l[?2004h>     with open('/home/user/audit/firewall_rules.json', 'r') as f:
[?2004l[?2004h>         config = json.load(f)
[?2004l[?2004h>         rules = config['rules']
[?2004l[?2004h>     
[?2004l[?2004h>     # Load connections
[?2004l[?2004h>     with open('/home/user/audit/connections.csv', 'r') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         connections = list(reader)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check each connection
[?2004l[?2004h>     for conn in connections:
[?2004l[?2004h>         src_ip = conn['src_ip']
[?2004l[?2004h>         dest_port = int(conn['dest_port'])
[?2004l[?2004h>         
[?2004l[?2004h>         allowed, matched_rule = is_connection_allowed(src_ip, dest_port, rules)
[?2004l[?2004h>         
[?2004l[?2004h>         if not allowed:
[?2004l[?2004h>             if matched_rule:
[?2004l[?2004h>                 # Explicitly denied or no port match
[?2004l[?2004h>                 print(f"BLOCKED: {src_ip}:{dest_port} not allowed from {matched_rule['source_cidr']}")
[?2004l[?2004h>             else:
[?2004l[?2004h>                 # No matching rule at all
[?2004l[?2004h>                 print(f"BLOCKED: {src_ip}:{dest_port} not allowed from any rule (default deny)")
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     main()
[?2004l[?2004h> EOF
