[32.675725, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse a port specification (single port or range) into a set of allowed ports.\"\"\"\n    port_spec = str(port_spec).strip()\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return set(range(int(start), int(end) + 1))\n    else:\n        return {int(port_spec)}\n\ndef find_matching_rules(src_ip, rules):\n    \"\"\"Find all rules that match the source IP, sorted by most specific CIDR first.\"\"\"\n    matching = []\n    ip_obj = ipaddress.ip_address(src_ip)\n    \n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj in network:\n            matching.append(rule)\n    \n    # Sort by prefix length (most specific first)\n    matching.sort(key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen, reverse=True)\n    return matching\n\ndef is_connection_allowed(src_ip, dest_port, rules):\n    \"\"\"Check if a connection is allowed"]
[32.675861, "i", " based on firewall rules.\"\"\"\n    matching_rules = find_matching_rules(src_ip, rules)\n    \n    for rule in matching_rules:\n        allowed_ports = parse_port_spec(rule['dest_port'])\n        if dest_port in allowed_ports:\n            if rule['action'] == 'allow':\n                return True, rule\n            else:  # deny\n                return False, rule\n    \n    # No matching rule found, default deny\n    return False, None\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        config = json.load(f)\n        rules = config['rules']\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = int(conn['dest_port'])\n        \n        allowed, matched_rule = is_connection_allowed(src_ip, dest_port, rules)\n        \n        if not allowed:\n            "]
[32.675909, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r"]
[32.67593, "i", "if matched_rule:\n                # Explicitly denied or no port match\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matched_rule['source_cidr']}\")\n            else:\n                # No matching rule at all\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule (default deny)\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
[32.67595, "o", "\u001b[?2004h> "]
