[49.643601, "o", "No upcoming meetings in the next 15-75 minutes.\r\n"]
[49.647931, "o", "\u001b[?2004huser@c83efca373bd:~/scheduler$ "]
[66.123582, "i", "cat > test_dst_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Test DST handling for the fixed conversion function.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\ndef convert_to_berlin_OLD(utc_time_str):\n    \"\"\"OLD buggy version.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    berlin_dt = BERLIN_TZ.localize(utc_dt)  # BUG: treats UTC as Berlin\n    return berlin_dt\n\ndef convert_to_berlin_NEW(utc_time_str):\n    \"\"\"NEW fixed version.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    utc_dt_aware = UTC_TZ.localize(utc_dt)\n    berlin_dt = utc_dt_aware.astimezone(BERLIN_TZ)\n    return berlin_dt\n\nprint(\"Testing DST transition handling...\\n\")\n\n# Test case: March 31, 2024 - DST transition in Europe/Berlin\n# At 2:00 AM CET, clocks moved forward to 3:00 AM CEST\n# So 01:30 UTC = 02:30 CET (before transition) or 03:30 CEST (after transition)\ntest_cases = [\n    (\"2024-03-31T00:30:00\", \"Before DST transition (should be 01"]
[66.123619, "i", ":30 or 02:30 Berlin)\"),\n    (\"2024-03-31T01:00:00\", \"At DST transition (should be 02:00 or 03:00 Berlin)\"),\n    (\"2024-03-31T01:30:00\", \"Maintenance Window - CRITICAL (should be 02:30 or 03:30 Berlin)\"),\n    (\"2024-03-31T02:00:00\", \"After DST transition (should be 04:00 CEST Berlin)\"),\n]\n\nfor utc_time, description in test_cases:\n    print(f\"Test: {description}\")\n    print(f\"  UTC time: {utc_time}\")\n    \n    old_result = convert_to_berlin_OLD(utc_time)\n    new_result = convert_to_berlin_NEW(utc_time)\n    \n    print(f\"  OLD (buggy):  {old_result.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\n    print(f\"  NEW (fixed):  {new_result.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\n    \n    if old_result != new_result:\n        print(f\"  ⚠️  DIFFERENCE DETECTED: {(new_result - old_result).total_seconds() / 3600:.1f} hours\")\n    else:\n        print(f\"  ✓ Same result (no DST issue for this time)\")\n    print()\n\nprint(\"\\nConclusion:\")\nprint(\"The OLD version incorrectly treats the UTC datetime as a Berlin datetime,\")\nprin"]
[66.123726, "i", "t(\"causing issues during DST transitions. The NEW version correctly converts\")\nprint(\"from UTC to Berlin time, properly handling DST.\")\nEOF\n"]
