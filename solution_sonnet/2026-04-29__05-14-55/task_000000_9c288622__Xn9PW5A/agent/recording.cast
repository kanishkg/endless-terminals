[21.424792, "o", "[\r\n    {\r\n        \"title\": \"Daily Standup\",\r\n        \"utc_time\": \"2024-03-31T08:00:00\"\r\n    },\r\n    {\r\n        \"title\": \"Maintenance Window Prep\",\r\n        \"utc_time\": \"2024-03-31T01:30:00\"\r\n    },\r\n    {\r\n        \"title\": \"Weekly Review\",\r\n        \"utc_time\": \"2024-04-01T14:00:00\"\r\n    },\r\n    {\r\n        \"title\": \"Client Call\",\r\n        \"utc_time\": \"2024-03-30T15:30:00\"\r\n    },\r\n    {\r\n        \"title\": \"Team Lunch\",\r\n        \"utc_time\": \"2024-03-29T11:00:00\"\r\n    }\r\n]\r\n"]
