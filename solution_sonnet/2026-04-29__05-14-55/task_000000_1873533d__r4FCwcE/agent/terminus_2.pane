[?2004l[?2004h> 
[?2004l[?2004h> if [ ! -f "$2" ]; then
[?2004l[?2004h>     echo "Error: File '$2' not found" >&2
[?2004l[?2004h>     exit 1
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Use associative array to store key-value pairs
[?2004l[?2004h> declare -A env_vars
[?2004l[?2004h> declare -a keys_order
[?2004l[?2004h> 
[?2004l[?2004h> # Function to parse env file
[?2004l[?2004h> parse_env_file() {
[?2004l[?2004h>     local file="$1"
[?2004l[?2004h>     while IFS= read -r line || [ -n "$line" ]; do
[?2004l[?2004h>         # Skip empty lines and comments
[?2004l[?2004h>         [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
[?2004l[?2004h>         
[?2004l[?2004h>         # Extract key=value
[?2004l[?2004h>         if [[ "$line" =~ ^([^=]+)=(.*)$ ]]; then
[?2004l[?2004h>             key="${BASH_REMATCH[1]}"
[?2004l[?2004h>             value="${BASH_REMATCH[2]}"
[?2004l[?2004h>             
[?2004l[?2004h>             # Only add to keys_order if it's a new key
[?2004l[?2004h>             if [ -z "${env_vars[$key]+x}" ]; then
[?2004l[?2004h>                 keys_order+=("$key")
[?2004l[?2004h>             fi
[?2004l[?2004h>             
[?2004l[?2004h>             env_vars["$key"]="$value"
[?2004l[?2004h>         fi
[?2004l[?2004h>     done < "$file"
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # Parse both files (second file overwrites first)
[?2004l[?2004h> parse_env_file "$1"
[?2004l[?2004h> parse_env_file "$2"
[?2004l[?2004h> 
[?2004l[?2004h> # Output merged environment variables
[?2004l[?2004h> for key in "${keys_order[@]}"; do
[?2004l[?2004h>     echo "${key}=${env_vars[$key]}"
[?2004l[?2004h> done
