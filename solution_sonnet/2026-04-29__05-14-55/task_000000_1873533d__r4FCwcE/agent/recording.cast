[21.561326, "i", "cat > /home/user/bin/env-merge.sh << 'EOF'\n#!/bin/bash\n\n# Check if two arguments are provided\nif [ $# -ne 2 ]; then\n    echo \"Usage: $0 <file1.env> <file2.env>\" >&2\n    exit 1\nfi\n\n# Check if both files exist\nif [ ! -f \"$1\" ]; then\n    echo \"Error: File '$1' not found\" >&2\n    exit 1\nfi\n\nif [ ! -f \"$2\" ]; then\n    echo \"Error: File '$2' not found\" >&2\n    exit 1\nfi\n\n# Use associative array to store key-value pairs\ndeclare -A env_vars\ndeclare -a keys_order\n\n# Function to parse env file\nparse_env_file() {\n    local file=\"$1\"\n    while IFS= read -r line || [ -n \"$line\" ]; do\n        # Skip empty lines and comments\n        [[ -z \"$line\" || \"$line\" =~ ^[[:space:]]*# ]] && continue\n        \n        # Extract key=value\n        if [[ \"$line\" =~ ^([^=]+)=(.*)$ ]]; then\n            key=\"${BASH_REMATCH[1]}\"\n            value=\"${BASH_REMATCH[2]}\"\n            \n            # Only add to keys_order if it's a new key\n            if [ -z \"${env_vars[$key]+x}\" ]; then\n                keys_order+=(\"$key\")\n            fi\n        "]
[21.561462, "i", "    \n            env_vars[\"$key\"]=\"$value\"\n        fi\n    done < \"$file\"\n}\n\n# Parse both files (second file overwrites first)\nparse_env_file \"$1\"\nparse_env_file \"$2\"\n\n# Output merged environment variables\nfor key in \"${keys_order[@]}\"; do\n    echo \"${key}=${env_vars[$key]}\"\ndone\nEOF\n"]
