[51.014074, "i", "cat > test_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Test the timezone conversion fix.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\ndef convert_to_berlin_old(utc_time_str):\n    \"\"\"OLD buggy version.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    berlin_dt = BERLIN_TZ.localize(utc_dt)\n    return berlin_dt\n\ndef convert_to_berlin_new(utc_time_str):\n    \"\"\"NEW fixed version.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    utc_dt = UTC_TZ.localize(utc_dt)\n    berlin_dt = utc_dt.astimezone(BERLIN_TZ)\n    return berlin_dt\n\n# Test case: March 31, 2024 01:30 UTC (DST transition day)\ntest_time = \"2024-03-31T01:30:00\"\n\nprint(\"Testing DST transition case:\")\nprint(f\"UTC time: {test_time}\")\nprint()\n\nold_result = convert_to_berlin_old(test_time)\nprint(f\"OLD (buggy) conversion: {old_result.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n\nnew_result = convert_to_berlin_new(test_time)\nprint(f\"NEW (fixed) conversion: {new_re"]
[51.014192, "i", "sult.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint()\n\n# On March 31, 2024, DST starts at 2am (clocks jump to 3am)\n# So 01:30 UTC should be 03:30 CEST (UTC+2), not 02:30\nprint(\"Expected: 2024-03-31 03:30:00 CEST+0200\")\nprint(f\"Got:      {new_result.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint()\n\nif new_result.hour == 3 and new_result.minute == 30:\n    print(\"✓ Fix is correct!\")\nelse:\n    print(\"✗ Fix failed!\")\nEOF\n"]
