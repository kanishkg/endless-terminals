MemAvai[?2004huser@9a0ab37fab15:~$ cat > /tmp/process_mem.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file to store results
[?2004l[?2004h> temp_file=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for hostfile in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handling errors gracefully
[?2004l[?2004h>     memtotal=$(grep -E '^MemTotal:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     memavail=$(grep -E '^MemAvailable:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if both values were found and are valid numbers
[?2004l[?2004h>     if [[ -n "$memtotal" && -n "$memavail" && "$memtotal" -gt 0 ]]; then
[?2004l[?2004h>         # Calculate percentage available (using bc for floating point)
[?2004l[?2004h>         percent=$(awk "BEGIN {printf \"%.2f\", ($memavail / $memtotal) * 100}")
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if less than 20%
[?2004l[?2004h>         if awk "BEGIN {exit !($percent < 20)}"; then
[?2004l[?2004h>             echo -e "${percent}\t${hostname}\t${percent}" >> "$temp_file"
[?2004l[?2004h>         fi
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending - worst first) and output hostname + percentage
[?2004l[?2004h> if [[ -s "$temp_file" ]]; then
[?2004l[?2004h>     sort -n "$temp_file" | awk -F'\t' '{printf "%s\t%.2f%%\n", $2, $3}' > /home/user/low_memory_report.txt
[?2004l[?2004h> else
[?2004l[?2004h>     # Create empty file if no hosts meet criteria
[?2004l[?2004h>     touch /home/user/low_memory_report.txt
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Cleanup
[?2004l[?2004h> rm -f "$temp_file"
[?2004l[?2004h> EOF
[?2004l[?2004huser@9a0ab37fab15:~$ chmod +x /tmp/process_mem.sh
[?2004l[?2004huser@9a0ab37fab15:~$ bash /tmp/process_mem.sh
