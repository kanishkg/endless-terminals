[23.584868, "i", "cat > /tmp/process_mem.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file to store results\ntemp_file=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handling errors gracefully\n    memtotal=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Check if both values were found and are valid numbers\n    if [[ -n \"$memtotal\" && -n \"$memavail\" && \"$memtotal\" -gt 0 ]]; then\n        # Calculate percentage available (using bc for floating point)\n        percent=$(awk \"BEGIN {printf \\\"%.2f\\\", ($memavail / $memtotal) * 100}\")\n        \n        # Check if less than 20%\n        if awk \"BEGIN {exit !($percent < 20)}\"; then\n            echo -e \"${percent}\\t${hostname}\\t${percent}\" >> \"$temp_file\"\n        fi\n    fi\ndone\n\n# Sort by percentage (ascending - worst first) and output hostname + percentage\nif [["]
[23.584994, "i", " -s \"$temp_file\" ]]; then\n    sort -n \"$temp_file\" | awk -F'\\t' '{printf \"%s\\t%.2f%%\\n\", $2, $3}' > /home/user/low_memory_report.txt\nelse\n    # Create empty file if no hosts meet criteria\n    touch /home/user/low_memory_report.txt\nfi\n\n# Cleanup\nrm -f \"$temp_file\"\nEOF\n"]
[23.585049, "o", "cat > /tmp/process_mem.sh << 'EOF'\r\n\u001b[?2004l\r"]
