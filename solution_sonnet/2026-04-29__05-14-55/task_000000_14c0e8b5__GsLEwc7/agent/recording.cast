[84.399719, "i", "python3 << 'PYTEST'\nimport json\nimport ipaddress\n\n# Load rules\nwith open('firewall_rules.json') as f:\n    data = json.load(f)\n\nrules = data['rules']\n\n# Test case: 10.1.5.200:8080\ntest_ip = '10.1.5.200'\ntest_port = 8080\n\nprint(f\"Testing {test_ip}:{test_port}\")\nprint(\"\\nRules sorted by prefix length (most specific first):\")\nsorted_rules = sorted(rules, key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen, reverse=True)\n\nfor rule in sorted_rules:\n    net = ipaddress.ip_network(rule['source_cidr'])\n    ip_obj = ipaddress.ip_address(test_ip)\n    if ip_obj in net:\n        print(f\"  Rule {rule['id']}: {rule['source_cidr']} (/{net.prefixlen}) - {rule['action']} port {rule['dest_port']}\")\n        # Check if port matches\n        port_str = rule['dest_port']\n        if '-' in port_str:\n            start, end = port_str.split('-')\n            port_matches = int(start) <= test_port <= int(end)\n        else:\n            port_matches = int(port_str) == test_port\n        print(f\"    IP matches: True, Port matches: "]
[84.399851, "i", "{port_matches}\")\n        if port_matches:\n            print(f\"    -> This rule applies: {rule['action'].upper()}\")\n            break\nPYTEST\n"]
[84.399896, "o", "python3 << 'PYTEST'\r\n\u001b[?2004l\r{port_matches}\")\r\n        if port_matches:\r\n            print(f\"    -> This rule applies: {rule['action'].upper()}\")\r\n            break\r\nPYTEST\r\n\u001b[?2004h"]
