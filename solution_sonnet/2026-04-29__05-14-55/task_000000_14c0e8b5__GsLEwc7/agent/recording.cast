[29.595112, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_range(port_str):\n    \"\"\"Parse a port string into a set of allowed ports.\n    Returns a tuple (min_port, max_port) for range checking.\n    \"\"\"\n    port_str = str(port_str).strip()\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return (int(start), int(end))\n    else:\n        port = int(port_str)\n        return (port, port)\n\ndef port_in_range(port, port_range):\n    \"\"\"Check if a port is within the given range.\"\"\"\n    min_port, max_port = port_range\n    return min_port <= port <= max_port\n\ndef find_matching_rule(src_ip, dest_port, rules):\n    \"\"\"Find the most specific matching rule for a given IP and port.\n    Returns the matching rule or None.\n    \"\"\"\n    ip_obj = ipaddress.ip_address(src_ip)\n    \n    # Sort rules by prefix length (most specific first)\n    # More specific CIDR (larger prefix) should be checked first\n    sorted_rules = sorted(rules, key=lambda r: ipaddress.ip"]
[29.595247, "i", "_network(r['source_cidr']).prefixlen, reverse=True)\n    \n    for rule in sorted_rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj in network:\n            # IP matches this CIDR, now check port\n            port_range = parse_port_range(rule['dest_port'])\n            if port_in_range(dest_port, port_range):\n                return rule\n    \n    return None\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        firewall_data = json.load(f)\n    \n    rules = firewall_data['rules']\n    default_action = firewall_data.get('default_action', 'deny')\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = int(conn['dest_port'])\n        \n        # Find the most specific matching rule\n        matching_rule = find_matchi"]
