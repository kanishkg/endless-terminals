[27.109197, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse a port specification (single port or range) into a set of ports.\"\"\"\n    port_spec = str(port_spec)\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return (int(start), int(end))\n    else:\n        port = int(port_spec)\n        return (port, port)\n\ndef port_in_range(port, port_range):\n    \"\"\"Check if a port is within a range.\"\"\"\n    start, end = port_range\n    return start <= port <= end\n\ndef load_rules(json_path):\n    \"\"\"Load and sort firewall rules by CIDR specificity (most specific first).\"\"\"\n    with open(json_path, 'r') as f:\n        data = json.load(f)\n    \n    rules = data['rules']\n    # Sort by prefix length (descending) so more specific rules are checked first\n    rules.sort(key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen, reverse=True)\n    \n    return rules, data.get('default_action', 'deny')\n\ndef check_connection(src_i"]
[27.109337, "i", "p, dest_port, rules):\n    \"\"\"Check if a connection is allowed by the firewall rules.\n    Returns (allowed, matching_cidr) tuple.\"\"\"\n    src_ip_obj = ipaddress.ip_address(src_ip)\n    \n    for rule in rules:\n        cidr = ipaddress.ip_network(rule['source_cidr'])\n        \n        # Check if source IP is in this CIDR\n        if src_ip_obj in cidr:\n            # Check if destination port matches\n            port_range = parse_port_spec(rule['dest_port'])\n            if port_in_range(dest_port, port_range):\n                # Found a matching rule\n                if rule['action'] == 'allow':\n                    return (True, rule['source_cidr'])\n                else:  # deny\n                    return (False, rule['source_cidr'])\n    \n    # No matching rule found - default deny\n    return (False, None)\n\ndef main():\n    rules, default_action = load_rules('/home/user/audit/firewall_rules.json')\n    \n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        \n        for "]
