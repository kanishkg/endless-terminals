[37.415469, "o", "#!/usr/bin/env python3\r\nimport json\r\nimport csv\r\nimport ipaddress\r\nimport sys\r\n\r\ndef parse_port_spec(port_spec):\r\n"]
[37.415529, "o", "    \"\"\"Parse a port specification (single port or range) into a set of ports.\"\"\"\r\n    port_spec = str(port_spec)\r\n    if '-' in port_spec:\r\n        start, end = port_spec.split('-')\r\n        return (int(start), int(end))\r\n    else:\r\n        port = int(port_spec)\r\n        return (port, port)\r\n"]
[37.415583, "o", "\r\ndef port_in_range(port, port_range):\r\n    \"\"\"Check if a port is within a range.\"\"\"\r\n    start, end = port_range\r\n    return start <= port <= end\r\n"]
[37.415681, "o", "\u001b[?2004h"]
