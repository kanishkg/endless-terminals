[81.712899, "o", ".PHONY: report clean check-config$\r\n$\r\n# Check if hosts.conf exists$\r\ncheck-config:$\r\n^I@if [ ! -f hosts.conf ]; then \\\\$\r\n^I^Iecho \"Error: hosts.conf not found. Cannot proceed.\"; \\\\$\r\n^I^Iexit 1; \\\\$\r\n^Ifi$\r\n$\r\n# Main target to generate the report$\r\n"]
