[106.042804, "i", "python3 << 'PYSCRIPT'\nwith open('Makefile', 'w') as f:\n    f.write('.PHONY: report clean check-config\\n\\n')\n    f.write('# Check if hosts.conf exists\\n')\n    f.write('check-config:\\n')\n    f.write('\\t@if [ ! -f hosts.conf ]; then echo \"Error: hosts.conf not found. Cannot proceed.\"; exit 1; fi\\n\\n')\n    f.write('# Main target to generate the report\\n')\n    f.write('report: results/status.json\\n')\n    f.write('\\t@echo \"Monitoring report complete!\"\\n\\n')\n    f.write('# Generate the aggregated JSON report\\n')\n    f.write('results/status.json: results/ping.txt results/ports.txt\\n')\n    f.write('\\t@echo \"Aggregating results...\"\\n')\n    f.write('\\tpython3 aggregate.py\\n\\n')\n    f.write('# Run ping checks\\n')\n    f.write('results/ping.txt: check-config\\n')\n    f.write('\\t@echo \"Running ping checks...\"\\n')\n    f.write('\\t./scripts/check_ping.sh\\n\\n')\n    f.write('# Run port checks\\n')\n    f.write('results/ports.txt: check-config\\n')\n    f.write('\\t@echo \"Running port checks...\"\\n')\n    f.write('\\t./scripts/check_ports"]
[106.042936, "i", ".sh\\n\\n')\n    f.write('# Clean up results\\n')\n    f.write('clean:\\n')\n    f.write('\\trm -rf results\\n')\n    f.write('\\t@echo \"Cleaned up results directory\"\\n')\nPYSCRIPT\n"]
