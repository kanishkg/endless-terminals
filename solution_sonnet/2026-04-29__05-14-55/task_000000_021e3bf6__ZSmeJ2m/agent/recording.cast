[26.06607, "i", "cat > /tmp/analyze_memory.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Clear output file\n> \"$OUTPUT\"\n\n# Temporary file for collecting results\nTEMP_RESULTS=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    # Extract hostname from filename\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Try to extract MemTotal and MemAvailable\n    memtotal=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Check if both values were found and are non-empty\n    if [[ -n \"$memtotal\" && -n \"$memavail\" ]]; then\n        # Calculate percentage available\n        percentage=$(awk \"BEGIN {printf \\\"%.2f\\\", ($memavail / $memtotal) * 100}\")\n        \n        # Check if less than 20%\n        is_low=$(awk \"BEGIN {print ($percentage < 20) ? 1 : 0}\")\n        \n        if [[ $is_low -eq 1 ]]; then\n            # Store result with percentage for sorting\n    "]
[26.066218, "i", "        echo -e \"${percentage}\\t${hostname}\\t${percentage}\" >> \"$TEMP_RESULTS\"\n        fi\n    fi\ndone\n\n# Sort by percentage (ascending - worst first) and output hostname + percentage\nif [[ -s \"$TEMP_RESULTS\" ]]; then\n    sort -n \"$TEMP_RESULTS\" | awk -F'\\t' '{print $2 \"\\t\" $3}' > \"$OUTPUT\"\nfi\n\n# Cleanup\nrm -f \"$TEMP_RESULTS\"\nEOF\n"]
