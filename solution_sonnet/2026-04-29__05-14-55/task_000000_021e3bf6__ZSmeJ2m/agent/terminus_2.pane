[?2004huser@2f4ff07c0a72:~$ cat > /tmp/analyze_memory.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Output file
[?2004l[?2004h> OUTPUT="/home/user/low_memory_report.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Clear output file
[?2004l[?2004h> > "$OUTPUT"
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for collecting results
[?2004l[?2004h> TEMP_RESULTS=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for hostfile in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     # Extract hostname from filename
[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Try to extract MemTotal and MemAvailable
[?2004l[?2004h>     memtotal=$(grep -E '^MemTotal:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     memavail=$(grep -E '^MemAvailable:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if both values were found and are non-empty
[?2004l[?2004h>     if [[ -n "$memtotal" && -n "$memavail" ]]; then
[?2004l[?2004h>         # Calculate percentage available
[?2004l[?2004h>         percentage=$(awk "BEGIN {printf \"%.2f\", ($memavail / $memtotal) * 100}")
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if less than 20%
[?2004l[?2004h>         is_low=$(awk "BEGIN {print ($percentage < 20) ? 1 : 0}")
[?2004l[?2004h>         
[?2004l[?2004h>         if [[ $is_low -eq 1 ]]; then
[?2004l[?2004h>             # Store result with percentage for sorting
[?2004l[?2004h>             echo -e "${percentage}\t${hostname}\t${percentage}" >> "$TEMP_RESULTS"
[?2004l[?2004h>         fi
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending - worst first) and output hostname + percentage
[?2004l[?2004h> if [[ -s "$TEMP_RESULTS" ]]; then
[?2004l[?2004h>     sort -n "$TEMP_RESULTS" | awk -F'\t' '{print $2 "\t" $3}' > "$OUTPUT"
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Cleanup
[?2004l[?2004h> rm -f "$TEMP_RESULTS"
[?2004l[?2004h> EOF
[?2004l[?2004huser@2f4ff07c0a72:~$ chmod +x /tmp/analyze_memory.sh
