[6.694209, "i", "ls -la\n"]
[6.694323, "o", "ls -la\r\n\u001b[?2004l\r"]
[6.695597, "o", "total 12\r\n"]
[6.695647, "o", "drwxrwxrwx 1 user user 4096 Apr 29 10:36 .\r\ndrwxrwxrwx 1 user user 4096 Apr 29 10:36 ..\r\n"]
[6.695704, "o", "-rw-r--r-- 1 user user  468 Apr 29 10:36 target_iptables.txt\r\n"]
