[43.808423, "i", "cat > normalize_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse multiple date formats and return ISO 8601 string.\"\"\"\n    date_str = date_str.strip()\n    \n    # Try YYYY-MM-DD\n    try:\n        dt = datetime.strptime(date_str, '%Y-%m-%d')\n        return dt.strftime('%Y-%m-%d'), dt\n    except ValueError:\n        pass\n    \n    # Try MM/DD/YYYY\n    try:\n        dt = datetime.strptime(date_str, '%m/%d/%Y')\n        return dt.strftime('%Y-%m-%d'), dt\n    except ValueError:\n        pass\n    \n    # Try DD.MM.YYYY\n    try:\n        dt = datetime.strptime(date_str, '%d.%m.%Y')\n        return dt.strftime('%Y-%m-%d'), dt\n    except ValueError:\n        pass\n    \n    return None, None\n\ndef parse_price(price_str):\n    \"\"\"Parse price and convert to cents (integer).\"\"\"\n    price_str = str(price_str).strip()\n    \n    # Remove dollar signs and commas\n    price_str = price_str.replace('$', '').replace(',', '')\n    \n    try:"]
[43.808549, "i", "\n        price_float = float(price_str)\n        \n        # Check if negative\n        if price_float < 0:\n            return None, \"negative price\"\n        \n        # Convert to cents\n        price_cents = int(round(price_float * 100))\n        \n        if price_cents <= 0:\n            return None, \"non-positive price\"\n        \n        return price_cents, None\n    except (ValueError, TypeError):\n        return None, \"invalid price format\"\n\ndef is_serial_format(value):\n    \"\"\"Check if value looks like a serial number (starts with SN-).\"\"\"\n    return isinstance(value, str) and value.startswith('SN-')\n\ndef process_csv():\n    valid_records = {}\n    rejected_records = []\n    \n    with open('/home/user/inventory/assets.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        \n        for row_num, row in enumerate(reader, start=2):\n            original_row = dict(row)\n            reject_reasons = []\n            \n            # Extract fields\n            asset_id = row.get('id', '').strip()\n            name = row.get"]
[43.808592, "i", "('name', '').strip()\n            serial = row.get('serial', '').strip()\n            purchase_date_str = row.get('purchase_date', '').strip()\n            price_str = row.get('price', '').strip()\n            location = row.get('location', '').strip()\n            \n            # Check for swapped name and serial\n            if is_serial_format(name) and not is_serial_format(serial):\n                name, serial = serial, name\n            \n            # Validate asset ID\n            if not asset_id:\n                reject_reasons.append(\"missing asset ID\")\n            \n            # Validate and parse date\n            iso_date, dt_obj = parse_date(purchase_date_str)\n            if iso_date is None:\n                reject_reasons.append(f\"invalid date format: {purchase_date_str}\")\n            \n            # Validate and parse price\n            price_cents, price_error = parse_price(price_str)\n            if price_cents is None:\n                reject_reasons.append(price_error or \"invalid price\")\n            \n     "]
[43.808621, "o", "cat > normalize_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[43.808656, "i", "       # Validate other required fields\n            if not name:\n                reject_reasons.append(\"missing name\")\n            if not serial:\n                reject_reasons.append(\"missing serial\")\n            if not location:\n                reject_reasons.append(\"missing location\")\n            \n            # If any validation failed, reject the record\n            if reject_reasons:\n                rejected_records.append({\n                    \"original_row\": original_row,\n                    \"reason\": \"; \".join(reject_reasons)\n                })\n                continue\n            \n            # Create valid record\n            record = {\n                \"id\": asset_id,\n                \"name\": name,\n                \"serial\": serial,\n                \"purchase_date\": iso_date,\n                \"price_cents\": price_cents,\n                \"location\": location\n            }\n            \n            # Handle duplicates - keep the one with latest purchase date\n            if asset_id in valid_records:\n         "]
