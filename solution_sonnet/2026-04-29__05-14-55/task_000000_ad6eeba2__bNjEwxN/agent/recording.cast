[43.815104, "o", "        \r\n\u001b[?2004l\r"]
[43.81513, "o", "\u001b[?2004h> "]
[43.81521, "o", "        # Convert to cents\r\n\u001b[?2004l\r"]
[43.815244, "o", "\u001b[?2004h"]
[43.815272, "o", "> "]
[43.815397, "o", "        price_cents = int(round(price_float * 100))\r\n\u001b[?2004l\r"]
[43.815432, "o", "\u001b[?2004h> "]
[43.815461, "o", "        \r\n\u001b[?2004l\r"]
[43.815487, "o", "\u001b[?2004h> "]
[43.815565, "o", "        if price_cents <= 0:\r\n\u001b[?2004l\r"]
[43.815592, "o", "\u001b[?2004h> "]
[43.815723, "o", "            return None, \"non-positive price\"\r\n\u001b[?2004l\r"]
[43.815756, "o", "\u001b[?2004h> "]
[43.815785, "o", "        \r\n\u001b[?2004l\r"]
[43.815811, "o", "\u001b[?2004h> "]
[43.815904, "o", "        return price_cents, None\r\n\u001b[?2004l\r"]
[43.815936, "o", "\u001b[?2004h> "]
[43.816035, "o", "    except (ValueError, TypeError):\r\n\u001b[?2004l\r"]
[43.816066, "o", "\u001b[?2004h> "]
[43.816187, "o", "        return None, \"invalid price format\"\r\n\u001b[?2004l\r"]
[43.816222, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[43.81625, "o", "\u001b[?2004h> "]
[43.816342, "o", "def is_serial_format(value):\r\n\u001b[?2004l\r"]
[43.816377, "o", "\u001b[?2004h> "]
[43.816568, "o", "    \"\"\"Check if value looks like a serial number (starts with SN-).\"\"\"\r\n\u001b[?2004l\r"]
[43.816595, "o", "\u001b[?2004h"]
[43.816623, "o", "> "]
[43.816772, "o", "    return isinstance(value, str) and value.startswith('SN-')\r\n\u001b[?2004l\r"]
[43.816807, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[43.816835, "o", "\u001b[?2004h> "]
[43.8169, "o", "def process_csv():\r\n\u001b[?2004l\r"]
[43.816929, "o", "\u001b[?2004h> "]
[43.816997, "o", "    valid_records = {}\r\n\u001b[?2004l\r"]
[43.817025, "o", "\u001b[?2004h> "]
[43.817103, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[43.81713, "o", "\u001b[?2004h> "]
[43.817157, "o", "    \r\n\u001b[?2004l\r"]
[43.817185, "o", "\u001b[?2004h> "]
[43.81736, "o", "    with open('/home/user/inventory/assets.csv', 'r') as f:\r\n\u001b[?2004l\r"]
[43.817389, "o", "\u001b[?2004h"]
[43.817419, "o", "> "]
[43.817489, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[43.817518, "o", "\u001b[?2004h> "]
[43.817549, "o", "        \r\n\u001b[?2004l\r"]
[43.817577, "o", "\u001b[?2004h> "]
[43.817733, "o", "        for row_num, row in enumerate(reader, start=2):\r\n\u001b[?2004l\r"]
[43.817759, "o", "\u001b[?2004h"]
[43.817789, "o", "> "]
[43.817868, "o", "            original_row = dict(row)\r\n\u001b[?2004l\r"]
[43.817897, "o", "\u001b[?2004h> "]
[43.817988, "o", "            reject_reasons = []\r\n\u001b[?2004l\r"]
[43.818015, "o", "\u001b[?2004h> "]
[43.818055, "o", "            \r\n\u001b[?2004l\r"]
[43.818086, "o", "\u001b[?2004h> "]
[43.818168, "o", "            # Extract fields\r\n\u001b[?2004l\r"]
[43.818195, "o", "\u001b[?2004h> "]
[43.818345, "o", "            asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[43.818368, "o", "\u001b[?2004h"]
[43.818393, "o", "> "]
[43.818506, "o", "            name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[43.818534, "o", "\u001b[?2004h> "]
[43.818678, "o", "            serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[43.818705, "o", "\u001b[?2004h> "]
[43.818901, "o", "            purchase_date_str = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[43.81893, "o", "\u001b[?2004h> "]
[43.81908, "o", "            price_str = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[43.819108, "o", "\u001b[?2004h"]
[43.819139, "o", "> "]
[43.819268, "o", "            location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[43.819311, "o", "\u001b[?2004h> "]
[43.819348, "o", "            \r\n\u001b[?2004l\r"]
[43.819367, "o", "\u001b[?2004h"]
[43.819404, "o", "> "]
[43.819511, "o", "            # Check for swapped name and serial\r\n\u001b[?2004l\r"]
[43.819539, "o", "\u001b[?2004h"]
[43.819565, "o", "> "]
[43.819743, "o", "            if is_serial_format(name) and not is_serial_format(serial):\r\n\u001b[?2004l\r"]
[43.819775, "o", "\u001b[?2004h> "]
[43.819898, "o", "                name, serial = serial, name\r\n\u001b[?2004l\r"]
[43.819929, "o", "\u001b[?2004h> "]
[43.819968, "o", "            \r\n\u001b[?2004l\r"]
[43.819996, "o", "\u001b[?2004h> "]
[43.820087, "o", "            # Validate asset ID\r\n\u001b[?2004l\r"]
[43.820115, "o", "\u001b[?2004h> "]
[43.820202, "o", "            if not asset_id:\r\n\u001b[?2004l\r"]
[43.82023, "o", "\u001b[?2004h> "]
[43.820404, "o", "                reject_reasons.append(\"missing asset ID\")\r\n\u001b[?2004l\r"]
[43.820437, "o", "\u001b[?2004h> "]
[43.820473, "o", "            \r\n\u001b[?2004l\r"]
[43.820501, "o", "\u001b[?2004h"]
[43.820527, "o", "> "]
[43.820609, "o", "            # Validate and parse date\r\n\u001b[?2004l\r"]
[43.820645, "o", "\u001b[?2004h> "]
[43.82081, "o", "            iso_date, dt_obj = parse_date(purchase_date_str)\r\n\u001b[?2004l\r"]
[43.820839, "o", "\u001b[?2004h"]
[43.820874, "o", "> "]
[43.82094, "o", "            if iso_date is None:\r\n\u001b[?2004l\r"]
[43.820962, "o", "\u001b[?2004h"]
[43.820991, "o", "> "]
[43.821202, "o", "                reject_reasons.append(f\"invalid date format: {purchase_date_str}\")\r\n\u001b[?2004l\r"]
[43.821229, "o", "\u001b[?2004h"]
[43.821256, "o", "> "]
[43.821279, "o", "            \r\n\u001b[?2004l\r"]
[43.821321, "o", "\u001b[?2004h"]
[43.821347, "o", "> "]
[43.82142, "o", "            # Validate and parse price\r\n\u001b[?2004l\r"]
[43.821449, "o", "\u001b[?2004h> "]
[43.821624, "o", "            price_cents, price_error = parse_price(price_str)\r\n\u001b[?2004l\r"]
[43.821651, "o", "\u001b[?2004h> "]
[43.821756, "o", "            if price_cents is None:\r\n\u001b[?2004l\r"]
[43.821787, "o", "\u001b[?2004h> "]
[43.82198, "o", "                reject_reasons.append(price_error or \"invalid price\")\r\n\u001b[?2004l\r"]
[43.822008, "o", "\u001b[?2004h> "]
[43.822049, "o", "            \r\n\u001b[?2004l\r"]
[43.822076, "o", "\u001b[?2004h> "]
[43.822205, "o", "            # Validate other required fields\r\n\u001b[?2004l\r"]
[43.822235, "o", "\u001b[?2004h> "]
[43.82232, "o", "            if not name:\r\n\u001b[?2004l\r"]
[43.822355, "o", "\u001b[?2004h"]
[43.822382, "o", "> "]
[43.822499, "o", "                reject_reasons.append(\"missing name\")\r\n\u001b[?2004l\r"]
[43.82253, "o", "\u001b[?2004h> "]
[43.82261, "o", "            if not serial:\r\n\u001b[?2004l\r"]
[43.822639, "o", "\u001b[?2004h> "]
[43.822797, "o", "                reject_reasons.append(\"missing serial\")\r\n\u001b[?2004l\r"]
[43.822825, "o", "\u001b[?2004h> "]
[43.822909, "o", "            if not location:\r\n\u001b[?2004l\r"]
[43.822935, "o", "\u001b[?2004h> "]
[43.823098, "o", "                reject_reasons.append(\"missing location\")\r\n\u001b[?2004l\r"]
[43.823121, "o", "\u001b[?2004h"]
[43.823147, "o", "> "]
[43.823173, "o", "            \r\n\u001b[?2004l\r"]
[43.823204, "o", "\u001b[?2004h"]
[43.823232, "o", "> "]
[43.823371, "o", "            # If any validation failed, reject the record\r\n\u001b[?2004l\r"]
[43.823395, "o", "\u001b[?2004h"]
[43.82342, "o", "> "]
[43.823491, "o", "            if reject_reasons:\r\n\u001b[?2004l\r"]
[43.823518, "o", "\u001b[?2004h> "]
[43.823638, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[43.823667, "o", "\u001b[?2004h> "]
[43.823807, "o", "                    \"original_row\": original_row,\r\n\u001b[?2004l\r"]
[43.823839, "o", "\u001b[?2004h> "]
[43.823992, "o", "                    \"reason\": \"; \".join(reject_reasons)\r\n\u001b[?2004l\r"]
[43.824014, "o", "\u001b[?2004h"]
[43.824042, "o", "> "]
[43.824079, "o", "                })\r\n\u001b[?2004l\r"]
[43.824108, "o", "\u001b[?2004h> "]
[43.824181, "o", "                continue\r\n\u001b[?2004l\r"]
[43.82421, "o", "\u001b[?2004h> "]
[43.82425, "o", "            \r\n\u001b[?2004l\r"]
[43.824276, "o", "\u001b[?2004h"]
[43.824312, "o", "> "]
[43.824386, "o", "            # Create valid record\r\n\u001b[?2004l\r"]
[43.824421, "o", "\u001b[?2004h> "]
[43.824484, "o", "            record = {\r\n\u001b[?2004l\r"]
[43.824512, "o", "\u001b[?2004h> "]
[43.824605, "o", "                \"id\": asset_id,\r\n\u001b[?2004l\r"]
[43.82464, "o", "\u001b[?2004h> "]
[43.824721, "o", "                \"name\": name,\r\n\u001b[?2004l\r"]
[43.824748, "o", "\u001b[?2004h> "]
[43.824853, "o", "                \"serial\": serial,\r\n\u001b[?2004l\r"]
[43.824883, "o", "\u001b[?2004h"]
[43.824913, "o", "> "]
[43.825005, "o", "                \"purchase_date\": iso_date,\r\n\u001b[?2004l\r"]
[43.825028, "o", "\u001b[?2004h"]
[43.825057, "o", "> "]
[43.825159, "o", "                \"price_cents\": price_cents,\r\n\u001b[?2004l\r"]
[43.825183, "o", "\u001b[?2004h"]
[43.825212, "o", "> "]
[43.825302, "o", "                \"location\": location\r\n\u001b[?2004l\r"]
[43.825331, "o", "\u001b[?2004h> "]
[43.825376, "o", "            }\r\n\u001b[?2004l\r"]
[43.825405, "o", "\u001b[?2004h> "]
[43.825444, "o", "            \r\n\u001b[?2004l\r"]
[43.82547, "o", "\u001b[?2004h> "]
[43.825675, "o", "            # Handle duplicates - keep the one with latest purchase date\r\n\u001b[?2004l\r"]
[43.825704, "o", "\u001b[?2004h> "]
[43.825824, "o", "            if asset_id in valid_records:\r\n\u001b[?2004l\r"]
[43.825852, "o", "\u001b[?2004h> "]
[43.826137, "o", "                existing_dt = datetime.strptime(valid_records[asset_id]['purchase_date'], '%Y-%m-%d')\r\n\u001b[?2004l\r"]
[43.82617, "o", "\u001b[?2004h> "]
[43.826283, "o", "                if dt_obj > existing_dt:\r\n\u001b[?2004l\r"]
[43.82632, "o", "\u001b[?2004h"]
[43.82635, "o", "> "]
[43.826474, "o", "                    valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[43.826504, "o", "\u001b[?2004h> "]
[43.826558, "o", "            else:\r\n\u001b[?2004l\r"]
[43.826586, "o", "\u001b[?2004h> "]
[43.826724, "o", "                valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[43.826752, "o", "\u001b[?2004h> "]
[43.82678, "o", "    \r\n\u001b[?2004l\r"]
[43.82681, "o", "\u001b[?2004h> "]
[43.826867, "o", "    # Convert to list\r\n\u001b[?2004l\r"]
[43.826895, "o", "\u001b[?2004h> "]
[43.827027, "o", "    valid_list = list(valid_records.values())\r\n\u001b[?2004l\r"]
[43.827055, "o", "\u001b[?2004h"]
[43.827085, "o", ">     \r\n\u001b[?2004l\r"]
[43.827111, "o", "\u001b[?2004h> "]
[43.827167, "o", "    # Write outputs\r\n\u001b[?2004l\r"]
[43.827193, "o", "\u001b[?2004h> "]
[43.827376, "o", "    with open('/home/user/inventory/assets.json', 'w') as f:\r\n\u001b[?2004l\r"]
[43.827406, "o", "\u001b[?2004h> "]
[43.827527, "o", "        json.dump(valid_list, f, indent=2)\r\n\u001b[?2004l\r"]
[43.827557, "o", "\u001b[?2004h> "]
[43.827585, "o", "    \r\n\u001b[?2004l\r"]
[43.827611, "o", "\u001b[?2004h> "]
[43.827781, "o", "    with open('/home/user/inventory/rejected.json', 'w') as f:\r\n\u001b[?2004l\r"]
[43.82781, "o", "\u001b[?2004h> "]
[43.827951, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[43.827979, "o", "\u001b[?2004h> "]
[43.828007, "o", "    \r\n\u001b[?2004l\r"]
[43.828036, "o", "\u001b[?2004h> "]
[43.828184, "o", "    print(f\"Processed {len(valid_list)} valid records\")\r\n\u001b[?2004l\r"]
[43.828211, "o", "\u001b[?2004h"]
[43.828231, "o", "> "]
[43.828377, "o", "    print(f\"Rejected {len(rejected_records)} records\")\r\n\u001b[?2004l\r"]
[43.828401, "o", "\u001b[?2004h"]
[43.828429, "o", "> "]
[43.82859, "o", "    print(f\"Deduplicated {len(valid_records)} unique asset IDs\")\r\n\u001b[?2004l\r"]
[43.828617, "o", "\u001b[?2004h> "]
[43.828644, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[43.82867, "o", "> "]
[43.828731, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[43.828763, "o", "\u001b[?2004h> "]
[43.828816, "o", "    process_csv()\r\n\u001b[?2004l\r"]
[43.828842, "o", "\u001b[?2004h"]
[43.828878, "o", "> EOF\r\n\u001b[?2004l\r"]
[43.833505, "o", "\u001b[?2004h"]
[43.833521, "o", "user@c864f994c26f:~/inventory$ "]
[43.916739, "i", "python3 normalize_assets.py\n"]
[43.916874, "o", "python3 normalize_assets.py\r\n"]
