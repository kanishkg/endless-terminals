[76.963122, "o", "# So 01:30 UTC should be 03:30 CEST (not 02:30 CET)\r\n\u001b[?2004l\r"]
[76.963149, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.963176, "o", "\u001b[?2004h> "]
[76.963316, "o", "maintenance_meeting_utc = '2024-03-31T01:30:00'\r\n\u001b[?2004l\r"]
[76.963343, "o", "\u001b[?2004h> "]
[76.963374, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.963501, "o", "print(f\"\\nMeeting: Maintenance Window Prep\")\r\n\u001b[?2004l\r"]
[76.963527, "o", "\u001b[?2004h> "]
[76.963676, "o", "print(f\"Stored UTC time: {maintenance_meeting_utc}\")\r\n\u001b[?2004l\r"]
