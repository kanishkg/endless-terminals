[76.966624, "o", "print(\"=\"*70)\r\n\u001b[?2004l\r"]
[76.966654, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.966683, "o", "\u001b[?2004h> "]
[76.966722, "o", "import json\r\n\u001b[?2004l\r"]
[76.96675, "o", "\u001b[?2004h> "]
[76.966931, "o", "with open('/home/user/scheduler/meetings.json', 'r') as f:\r\n\u001b[?2004l\r"]
