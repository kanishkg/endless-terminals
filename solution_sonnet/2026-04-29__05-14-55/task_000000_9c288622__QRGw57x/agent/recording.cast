[76.963739, "o", "\u001b[?2004h> "]
[76.963918, "o", "berlin_time = convert_to_berlin(maintenance_meeting_utc)\r\n\u001b[?2004l\r"]
[76.963941, "o", "\u001b[?2004h"]
[76.963967, "o", "> "]
[76.964172, "o", "print(f\"Converted Berlin time: {berlin_time.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\r\n\u001b[?2004l\r"]
