[76.96085, "i", "cat > verify_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Verify the fix works for the specific scenario in the ticket.\"\"\"\n\nimport sys\nsys.path.insert(0, '/home/user/scheduler')\n\nfrom app import convert_to_berlin\nimport pytz\nfrom datetime import datetime\n\nprint(\"Verifying fix for Monday 2:30am maintenance window issue\")\nprint(\"=\"*70)\n\n# The problematic meeting: Maintenance Window Prep at 2024-03-31T01:30:00 UTC\n# On March 31, 2024, Europe/Berlin transitions from CET to CEST at 2am\n# So 01:30 UTC should be 03:30 CEST (not 02:30 CET)\n\nmaintenance_meeting_utc = '2024-03-31T01:30:00'\n\nprint(f\"\\nMeeting: Maintenance Window Prep\")\nprint(f\"Stored UTC time: {maintenance_meeting_utc}\")\n\nberlin_time = convert_to_berlin(maintenance_meeting_utc)\nprint(f\"Converted Berlin time: {berlin_time.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n\n# Verify it's correct\nexpected_hour = 3  # Should be 3am CEST, not 2am CET\nexpected_tz_name = 'CEST'\n\nif berlin_time.hour == expected_hour and berlin_time.tzname() == expected_tz_name:\n    print(f\"\\n"]
[76.960973, "i", "✓ SUCCESS: Correctly converted to {expected_hour}:30am {expected_tz_name}\")\n    print(\"✓ The DST transition is now handled properly!\")\n    print(\"✓ Reminders will be sent at the correct time.\")\nelse:\n    print(f\"\\n✗ FAILED: Expected {expected_hour}:30am {expected_tz_name}, got {berlin_time.hour}:30 {berlin_time.tzname()}\")\n    sys.exit(1)\n\n# Additional verification: test all meetings\nprint(\"\\n\" + \"=\"*70)\nprint(\"Testing all meetings in meetings.json:\")\nprint(\"=\"*70)\n\nimport json\nwith open('/home/user/scheduler/meetings.json', 'r') as f:\n    meetings = json.load(f)\n\nfor meeting in meetings:\n    berlin_time = convert_to_berlin(meeting['utc_time'])\n    print(f\"{meeting['title']:30} | UTC: {meeting['utc_time']} | Berlin: {berlin_time.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n\nprint(\"\\n✓ All conversions completed successfully!\")\nprint(\"✓ Fix verified - the cron job will now send reminders at correct times.\")\nEOF\n"]
