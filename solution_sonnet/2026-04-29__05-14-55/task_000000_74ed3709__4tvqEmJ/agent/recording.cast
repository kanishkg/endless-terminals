[6.783836, "o", "drwxrwxrwx 1 user user 4096 Apr 29 09:42 .\r\ndrwxrwxrwx 1 user user 4096 Apr 29 09:43 ..\r\n-rwxr-xr-x 1 user user 1034 Apr 29 09:42 scrape.py\r\n"]
