[48.61059, "o", "> "]
[48.61068, "o", "def parse_price(price_str):\r\n\u001b[?2004l\r"]
[48.610707, "o", "\u001b[?2004h> "]
[48.610879, "o", "    \"\"\"Parse price to cents (integer)\"\"\"\r\n\u001b[?2004l\r"]
[48.610906, "o", "\u001b[?2004h"]
[48.610935, "o", "> "]
[48.610962, "o", "    try:\r\n\u001b[?2004l\r"]
[48.610991, "o", "\u001b[?2004h> "]
[48.61117, "o", "        # Remove dollar signs, commas, quotes, and whitespace\r\n\u001b[?2004l\r"]
[48.6112, "o", "\u001b[?2004h> "]
[48.611451, "o", "        price_str = price_str.strip().replace('$', '').replace(',', '').replace('\"', '')\r\n\u001b[?2004l\r"]
[48.611483, "o", "\u001b[?2004h> "]
[48.611511, "o", "        \r\n\u001b[?2004l\r"]
[48.611542, "o", "\u001b[?2004h> "]
[48.611671, "o", "        # Convert to float then to cents\r\n\u001b[?2004l\r"]
[48.611698, "o", "\u001b[?2004h"]
[48.611727, "o", "> "]
