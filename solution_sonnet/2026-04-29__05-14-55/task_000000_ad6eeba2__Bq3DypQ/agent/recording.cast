[48.619337, "o", "> "]
[48.619364, "o", "def main():\r\n\u001b[?2004l\r"]
[48.619392, "o", "\u001b[?2004h> "]
[48.619522, "o", "    input_file = '/home/user/inventory/assets.csv'\r\n\u001b[?2004l\r"]
[48.619549, "o", "\u001b[?2004h> "]
[48.619713, "o", "    output_file = '/home/user/inventory/assets.json'\r\n\u001b[?2004l\r"]
[48.619736, "o", "\u001b[?2004h"]
[48.619761, "o", "> "]
[48.619905, "o", "    rejected_file = '/home/user/inventory/rejected.json'\r\n\u001b[?2004l\r"]
[48.619934, "o", "\u001b[?2004h> "]
[48.619961, "o", "    \r\n\u001b[?2004l\r"]
[48.619989, "o", "\u001b[?2004h> "]
[48.620042, "o", "    # Read all rows\r\n\u001b[?2004l\r"]
[48.620069, "o", "\u001b[?2004h> "]
[48.620247, "o", "    valid_records = defaultdict(list)  # id -> list of records\r\n\u001b[?2004l\r"]
[48.620275, "o", "\u001b[?2004h> "]
[48.620351, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[48.62038, "o", "\u001b[?2004h> "]
[48.620408, "o", "    \r\n\u001b[?2004l\r"]
[48.620437, "o", "\u001b[?2004h> "]
[48.620591, "o", "    with open(input_file, 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[48.620618, "o", "\u001b[?2004h"]
[48.620649, "o", "> "]
[48.620728, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[48.620758, "o", "\u001b[?2004h> "]
[48.620787, "o", "        \r\n\u001b[?2004l\r"]
[48.620815, "o", "\u001b[?2004h> "]
[48.621071, "o", "        for row_num, row in enumerate(reader, start=2):  # start=2 because header is line 1\r\n\u001b[?2004l\r"]
[48.621094, "o", "\u001b[?2004h"]
[48.621123, "o", "> "]
[48.621248, "o", "            processed, error = process_row(row)\r\n\u001b[?2004l\r"]
[48.621283, "o", "\u001b[?2004h> "]
[48.621319, "o", "            \r\n\u001b[?2004l\r"]
[48.621353, "o", "\u001b[?2004h> "]
[48.621413, "o", "            if error:\r\n\u001b[?2004l\r"]
[48.621442, "o", "\u001b[?2004h> "]
[48.621562, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[48.621604, "o", "\u001b[?2004h> "]
[48.621738, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[48.621764, "o", "\u001b[?2004h"]
[48.621791, "o", "> "]
[48.621874, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[48.621901, "o", "\u001b[?2004h> "]
[48.622024, "o", "                    'line_number': row_num\r\n\u001b[?2004l\r"]
[48.622051, "o", "\u001b[?2004h> "]
[48.622108, "o", "                })\r\n\u001b[?2004l\r"]
[48.622135, "o", "\u001b[?2004h"]
[48.622164, "o", "> "]
[48.622194, "o", "            else:\r\n\u001b[?2004l\r"]
[48.622224, "o", "\u001b[?2004h> "]
[48.622358, "o", "                # Group by ID for deduplication\r\n\u001b[?2004l\r"]
[48.622386, "o", "\u001b[?2004h> "]
[48.622571, "o", "                valid_records[processed['id']].append(processed)\r\n\u001b[?2004l\r"]
[48.622612, "o", "\u001b[?2004h> "]
[48.62264, "o", "    \r\n\u001b[?2004l\r"]
[48.622668, "o", "\u001b[?2004h> "]
[48.622853, "o", "    # Deduplicate: keep record with latest purchase_date for each ID\r\n\u001b[?2004l\r"]
[48.62288, "o", "\u001b[?2004h> "]
[48.622948, "o", "    final_records = []\r\n\u001b[?2004l\r"]
[48.622977, "o", "\u001b[?2004h> "]
[48.623126, "o", "    for asset_id, records in valid_records.items():\r\n\u001b[?2004l\r"]
[48.623156, "o", "\u001b[?2004h"]
[48.623185, "o", "> "]
[48.623241, "o", "        if len(records) == 1:\r\n\u001b[?2004l\r"]
[48.623276, "o", "\u001b[?2004h> "]
[48.623398, "o", "            final_records.append(records[0])\r\n\u001b[?2004l\r"]
[48.62343, "o", "\u001b[?2004h> "]
[48.623469, "o", "        else:\r\n\u001b[?2004l\r"]
[48.623498, "o", "\u001b[?2004h> "]
[48.623672, "o", "            # Sort by purchase_date and keep the latest\r\n\u001b[?2004l\r"]
[48.623696, "o", "\u001b[?2004h"]
[48.62372, "o", "> "]
[48.623907, "o", "            records.sort(key=lambda x: x['purchase_date'], reverse=True)\r\n\u001b[?2004l\r"]
[48.623931, "o", "\u001b[?2004h"]
[48.623956, "o", "> "]
[48.624067, "o", "            final_records.append(records[0])\r\n\u001b[?2004l\r"]
[48.624089, "o", "\u001b[?2004h"]
[48.624113, "o", ">     \r\n\u001b[?2004l\r"]
[48.624136, "o", "\u001b[?2004h"]
[48.624161, "o", "> "]
[48.624276, "o", "    # Sort final records by ID for consistency\r\n\u001b[?2004l\r"]
[48.624302, "o", "\u001b[?2004h"]
[48.62433, "o", "> "]
[48.624436, "o", "    final_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[48.624457, "o", "\u001b[?2004h"]
[48.624485, "o", ">     \r\n\u001b[?2004l\r"]
[48.624513, "o", "\u001b[?2004h> "]
[48.624593, "o", "    # Write output files\r\n\u001b[?2004l\r"]
[48.624619, "o", "\u001b[?2004h"]
[48.624647, "o", "> "]
[48.624786, "o", "    with open(output_file, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[48.624815, "o", "\u001b[?2004h> "]
[48.624943, "o", "        json.dump(final_records, f, indent=2)\r\n\u001b[?2004l\r"]
[48.624969, "o", "\u001b[?2004h> "]
[48.624998, "o", "    \r\n\u001b[?2004l\r"]
[48.625031, "o", "\u001b[?2004h"]
[48.625059, "o", "> "]
[48.625192, "o", "    with open(rejected_file, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[48.625219, "o", "\u001b[?2004h> "]
[48.625358, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[48.625386, "o", "\u001b[?2004h> "]
[48.625414, "o", "    \r\n\u001b[?2004l\r"]
[48.62544, "o", "\u001b[?2004h> "]
[48.625534, "o", "    print(f\"Processing complete:\")\r\n\u001b[?2004l\r"]
