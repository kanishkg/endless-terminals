[48.611849, "o", "\u001b[?2004h> "]
[48.612, "o", "        price_cents = int(round(price_float * 100))\r\n\u001b[?2004l\r"]
[48.612029, "o", "\u001b[?2004h> "]
[48.612057, "o", "        \r\n"]
[48.612086, "o", "\u001b[?2004l\r\u001b[?2004h> "]
