[48.616311, "o", "            return None, f\"Invalid price format: {price_raw}\"\r\n\u001b[?2004l\r"]
[48.61634, "o", "\u001b[?2004h> "]
[48.61637, "o", "        \r\n\u001b[?2004l\r"]
[48.616399, "o", "\u001b[?2004h> "]
[48.616485, "o", "        if price_cents <= 0:\r\n\u001b[?2004l\r"]
[48.616513, "o", "\u001b[?2004h> "]
[48.616729, "o", "            return None, f\"Price must be positive: {price_cents} cents\"\r\n\u001b[?2004l\r"]
[48.616753, "o", "\u001b[?2004h"]
[48.616778, "o", "> "]
[48.616807, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[48.616837, "o", "> "]
[48.616935, "o", "        # Validate other required fields\r\n\u001b[?2004l\r"]
[48.616967, "o", "\u001b[?2004h> "]
[48.617028, "o", "        if not name:\r\n\u001b[?2004l\r"]
[48.617049, "o", "\u001b[?2004h"]
[48.617077, "o", "> "]
[48.61718, "o", "            return None, \"Missing name\"\r\n\u001b[?2004l\r"]
[48.617217, "o", "\u001b[?2004h> "]
[48.617277, "o", "        if not serial:\r\n\u001b[?2004l\r"]
[48.617306, "o", "\u001b[?2004h> "]
[48.617426, "o", "            return None, \"Missing serial\"\r\n\u001b[?2004l\r"]
[48.617455, "o", "\u001b[?2004h> "]
[48.617531, "o", "        if not location:\r\n\u001b[?2004l\r"]
[48.617597, "o", "\u001b[?2004h"]
[48.617624, "o", "> "]
[48.617739, "o", "            return None, \"Missing location\"\r\n\u001b[?2004l\r"]
