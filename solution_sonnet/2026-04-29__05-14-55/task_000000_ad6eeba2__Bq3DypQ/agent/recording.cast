[48.617917, "o", "\u001b[?2004h> "]
[48.618001, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[48.618029, "o", "\u001b[?2004h> "]
[48.618107, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[48.618137, "o", "\u001b[?2004h> "]
