[48.61316, "o", "\u001b[?2004h"]
[48.61319, "o", "> "]
[48.613303, "o", "        serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[48.613329, "o", "\u001b[?2004h"]
[48.613358, "o", "> "]
[48.613516, "o", "        purchase_date_raw = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[48.613548, "o", "\u001b[?2004h> "]
[48.613699, "o", "        price_raw = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
