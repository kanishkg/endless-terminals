[48.612194, "o", "\u001b[?2004h> "]
[48.612311, "o", "    except (ValueError, AttributeError):\r\n\u001b[?2004l\r"]
[48.61234, "o", "\u001b[?2004h> "]
[48.612398, "o", "        return None\r\n\u001b[?2004l\r"]
