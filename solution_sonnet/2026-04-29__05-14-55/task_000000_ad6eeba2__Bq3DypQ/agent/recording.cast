[48.618908, "o", "        return processed, None\r\n\u001b[?2004l\r"]
[48.618936, "o", "\u001b[?2004h> "]
[48.618968, "o", "        \r\n\u001b[?2004l\r"]
[48.618996, "o", "\u001b[?2004h> "]
[48.619075, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
