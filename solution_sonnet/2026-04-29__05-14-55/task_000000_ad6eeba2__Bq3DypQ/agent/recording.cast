[48.613982, "o", "> "]
[48.614182, "o", "        # Check if serial and name are swapped (serial should start with SN-)\r\n\u001b[?2004l\r"]
[48.614209, "o", "\u001b[?2004h"]
[48.614239, "o", "> "]
[48.614403, "o", "        if name.startswith('SN-') and not serial.startswith('SN-'):\r\n\u001b[?2004l\r"]
[48.614432, "o", "\u001b[?2004h> "]
[48.614548, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[48.614578, "o", "\u001b[?2004h> "]
[48.614621, "o", "        \r\n\u001b[?2004l\r"]
[48.614644, "o", "\u001b[?2004h"]
[48.614671, "o", "> "]
[48.614733, "o", "        # Validate asset_id\r\n\u001b[?2004l\r"]
[48.614759, "o", "\u001b[?2004h> "]
[48.614835, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[48.614866, "o", "\u001b[?2004h> "]
[48.61499, "o", "            return None, \"Missing asset ID\"\r\n\u001b[?2004l\r"]
[48.61502, "o", "\u001b[?2004h> "]
[48.615049, "o", "        \r\n\u001b[?2004l\r"]
[48.615077, "o", "\u001b[?2004h> "]
