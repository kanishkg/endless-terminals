[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Output file
[?2004l[?2004h> OUTPUT="/home/user/low_memory_report.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Clear output file
[?2004l[?2004h> > "$OUTPUT"
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for collecting data
[?2004l[?2004h> TEMP_FILE=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for hostfile in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Use awk to extract and calculate in one pass
[?2004l[?2004h>     awk -v host="$hostname" '
[?2004l[?2004h>         /^MemTotal:/ { memtotal = $2 }
[?2004l[?2004h>         /^MemAvailable:/ { memavail = $2 }
[?2004l[?2004h>         END {
[?2004l[?2004h>             if (memtotal > 0 && memavail > 0) {
[?2004l[?2004h>                 percentage = (memavail * 100) / memtotal
[?2004l[?2004h>                 if (percentage < 20) {
[?2004l[?2004h>                     printf "%s\t%.2f\n", host, percentage
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     ' "$hostfile" >> "$TEMP_FILE"
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending - worst first)
[?2004l[?2004h> sort -t$'\t' -k2 -n "$TEMP_FILE" > "$OUTPUT"
[?2004l[?2004h> 
[?2004l[?2004h> # Clean up
[?2004l[?2004h> rm -f "$TEMP_FILE"
[?2004l[?2004h> EOF
