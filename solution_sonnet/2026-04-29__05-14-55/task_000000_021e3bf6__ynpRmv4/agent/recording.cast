[30.529468, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Clear output file\n> \"$OUTPUT\"\n\n# Temporary file for collecting data\nTEMP_FILE=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Use awk to extract and calculate in one pass\n    awk -v host=\"$hostname\" '\n        /^MemTotal:/ { memtotal = $2 }\n        /^MemAvailable:/ { memavail = $2 }\n        END {\n            if (memtotal > 0 && memavail > 0) {\n                percentage = (memavail * 100) / memtotal\n                if (percentage < 20) {\n                    printf \"%s\\t%.2f\\n\", host, percentage\n                }\n            }\n        }\n    ' \"$hostfile\" >> \"$TEMP_FILE\"\ndone\n\n# Sort by percentage (ascending - worst first)\nsort -t$'\\t' -k2 -n \"$TEMP_FILE\" > \"$OUTPUT\"\n\n# Clean up\nrm -f \"$TEMP_FILE\"\nEOF\n"]
