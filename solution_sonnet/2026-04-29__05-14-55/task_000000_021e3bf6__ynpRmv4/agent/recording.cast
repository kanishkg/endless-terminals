[20.961495, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Clear output file\n> \"$OUTPUT\"\n\n# Temporary file for collecting data\nTEMP_FILE=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handle missing/corrupted data\n    memtotal=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty\n    if [[ -z \"$memtotal\" || -z \"$memavail\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available (using bc for floating point)\n    percentage=$(echo \"scale=2; ($memavail * 100) / $memtotal\" | bc)\n    \n    # Check if less than 20%\n    is_low=$(echo \"$percentage < 20\" | bc)\n    \n    if [[ $is_low -eq 1 ]]; then\n        echo -e \"$hostname\\t$percentage\" >> \"$TEMP_FILE\"\n    fi\ndone\n\n# Sort by percentag"]
[20.96163, "i", "e (ascending - worst first)\nsort -t$'\\t' -k2 -n \"$TEMP_FILE\" > \"$OUTPUT\"\n\n# Clean up\nrm -f \"$TEMP_FILE\"\nEOF\n"]
