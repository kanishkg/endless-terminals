[32.164544, "o", "        if [ -z \"$supp_names\" ]; then\r\n\u001b[?2004l\r"]
[32.164572, "o", "\u001b[?2004h> "]
[32.164666, "o", "            supp_names=\"$gname\"\r\n\u001b[?2004l\r"]
[32.164698, "o", "\u001b[?2004h> "]
[32.164734, "o", "        else\r\n\u001b[?2004l\r"]
[32.164762, "o", "\u001b[?2004h"]
[32.164788, "o", "> "]
[32.16489, "o", "            supp_names=\"$supp_names;$gname\"\r\n\u001b[?2004l\r"]
[32.164922, "o", "\u001b[?2004h> "]
[32.164955, "o", "        fi\r\n\u001b[?2004l\r"]
[32.164985, "o", "\u001b[?2004h> "]
[32.165027, "o", "    done\r\n\u001b[?2004l\r"]
[32.165056, "o", "\u001b[?2004h> "]
[32.165088, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
