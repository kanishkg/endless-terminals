[97.249035, "o", "grep -A 8 'def convert_to_berlin' app.py.bak\r\n"]
[97.249088, "o", "\u001b[?2004l\r"]
[97.250226, "o", "\u001b[01;31m\u001b[Kdef convert_to_berlin\u001b[m\u001b[K(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n\r\n    # Convert to Berlin time\r\n    # BUG: This incorrectly localizes the UTC datetime as if it were already Berlin time\r\n"]
[97.250427, "o", "\u001b[?2004h"]
[97.250463, "o", "user@1ddb5e1ce8eb:~/scheduler$ "]
[97.359988, "i", "echo -e '\\n--- NEW (FIXED) VERSION ---'\n"]
[97.360146, "o", "echo -e '\\n--- NEW (FIXED) VERSION ---'\r\n"]
[97.360186, "o", "\u001b[?2004l\r\r\n--- NEW (FIXED) VERSION ---\r\n"]
[97.360228, "o", "\u001b[?2004h"]
[97.360255, "o", "user@1ddb5e1ce8eb:~/scheduler$ "]
[97.458617, "i", "grep -A 9 'def convert_to_berlin' app.py\n"]
[97.458783, "o", "grep -A 9 'def convert_to_berlin' app.py\r\n"]
[97.458819, "o", "\u001b[?2004l\r"]
[97.459886, "o", "\u001b[01;31m\u001b[Kdef convert_to_berlin\u001b[m\u001b[K(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n"]
[97.459942, "o", "    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n\r\n    # First localize as UTC, then convert to Berlin time\r\n    utc_dt_aware = UTC_TZ.localize(utc_dt)\r\n    berlin_dt = utc_dt_aware.astimezone(BERLIN_TZ)\r\n"]
[97.460095, "o", "\u001b[?2004h"]
[97.460128, "o", "user@1ddb5e1ce8eb:~/scheduler$ "]
