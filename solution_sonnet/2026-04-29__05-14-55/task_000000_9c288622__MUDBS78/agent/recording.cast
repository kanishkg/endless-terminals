[45.548334, "i", "cat > test_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Test the timezone conversion fix.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\ndef old_convert(utc_time_str):\n    \"\"\"Old buggy version.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    berlin_dt = BERLIN_TZ.localize(utc_dt)\n    return berlin_dt\n\ndef new_convert(utc_time_str):\n    \"\"\"New fixed version.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    utc_dt_aware = UTC_TZ.localize(utc_dt)\n    berlin_dt = utc_dt_aware.astimezone(BERLIN_TZ)\n    return berlin_dt\n\nprint(\"Testing UTC to Berlin conversion:\")\nprint(\"=\"*50)\n\n# Test case: 2024-03-31 01:30:00 UTC\n# This is during DST transition in Europe (spring forward)\n# March 31, 2024 at 2am CET becomes 3am CEST\ntest_time = \"2024-03-31T01:30:00\"\n\nprint(f\"\\nUTC time: {test_time}\")\nprint(f\"\\nOLD (buggy) conversion:\")\nold_result = old_convert(test_time)\nprint(f\"  Result: {old_result.strftime('%Y-%m-%d %H:%M:"]
[45.548382, "i", "%S %Z%z')}\")\n\nprint(f\"\\nNEW (fixed) conversion:\")\nnew_result = new_convert(test_time)\nprint(f\"  Result: {new_result.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n\nprint(f\"\\nDifference: {(new_result - old_result).total_seconds() / 3600} hours\")\nprint(f\"\\nExpected: 2024-03-31 03:30:00 CEST (after DST transition)\")\nEOF\n"]
