[64.102228, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Clear output file\n> \"$OUTPUT\"\n\n# Temporary file for results\nTEMP_FILE=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handle missing data gracefully\n    memtotal=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Check if both values exist and are valid numbers\n    if [[ -n \"$memtotal\" && -n \"$memavail\" && \"$memtotal\" -gt 0 ]]; then\n        # Calculate percentage available and check if less than 20% using awk\n        result=$(awk -v total=\"$memtotal\" -v avail=\"$memavail\" 'BEGIN {\n            percentage = (avail * 100) / total\n            if (percentage < 20) {\n                printf \"%.2f\\t%s\\n\", percentage, \"MATCH\"\n            }\n        }')\n        \n        if [[ -n \"$resu"]
[64.102399, "i", "lt\" ]]; then\n            percentage=$(echo \"$result\" | cut -f1)\n            # Output: percentage for sorting, then hostname and percentage for final output\n            echo -e \"${percentage}\\t${hostname}\\t${percentage}\" >> \"$TEMP_FILE\"\n        fi\n    fi\ndone\n\n# Sort by percentage (ascending - worst first) and output hostname + percentage\nif [[ -s \"$TEMP_FILE\" ]]; then\n    sort -n \"$TEMP_FILE\" | awk -F'\\t' '{printf \"%s\\t%s\\n\", $2, $3}' > \"$OUTPUT\"\nfi\n\n# Cleanup\nrm -f \"$TEMP_FILE\"\nEOF\n"]
[64.102439, "o", "cat > process_memory.sh << 'EOF'\r\n\u001b[?2004l\rlt\" ]]; then\r\n            percentage=$(echo \"$result\" | cut -f1)\r\n            # Output: percentage for sorting, t"]
[64.102486, "o", "hen hostname and percentage for final output\r\n            echo -e \"${percentage}\\t${hostname}\\t${percentage}\" >> \"$TEMP_FILE\"\r\n        fi"]
[64.102524, "o", "\r\n    fi\r\ndone\r\n\r\n# Sort by percentage (ascending - worst first) and output hostname + percentage\r\nif [[ -s \"$TEMP_FILE\" ]]; then\r\n    sort -n \"$TEMP_F"]
[64.102564, "o", "ILE\" | awk -F'\\t' '{printf \"%s\\t%s\\n\", $2, $3}' > \"$OUTPUT\"\r\nfi\r\n\r\n# Cleanup\r\nrm -f \"$TEMP_FILE\"\r\nEOF\r\n"]
