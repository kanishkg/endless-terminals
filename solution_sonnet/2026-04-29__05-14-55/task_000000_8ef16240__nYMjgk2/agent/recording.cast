[81.33286, "o", "    conn.execute('CREATE TABLE IF NOT EXISTS summary (category TEXT PRIMARY KEY, total_value REAL, count INTEGER)')\r\n\u001b[?2004l\r"]
[81.332887, "o", "\u001b[?2004h> "]
[81.332916, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.332942, "o", "> "]
[81.333022, "o", "    checkpoint = load_checkpoint()\r\n\u001b[?2004l\r"]
[81.333058, "o", "\u001b[?2004h"]
[81.333084, "o", "> "]
[81.333224, "o", "    start_from = checkpoint['last_line'] if checkpoint else 0\r\n\u001b[?2004l\r"]
[81.33325, "o", "\u001b[?2004h"]
[81.333277, "o", "> "]
[81.333396, "o", "    print(f\"Starting from line: {start_from}\")\r\n\u001b[?2004l\r"]
[81.333431, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.333458, "o", "\u001b[?2004h> "]
[81.333584, "o", "    with open('data/events.json', 'r') as f:\r\n\u001b[?2004l\r"]
[81.333613, "o", "\u001b[?2004h> "]
[81.333665, "o", "        batch = []\r\n\u001b[?2004l\r"]
[81.333693, "o", "\u001b[?2004h> "]
[81.333773, "o", "        lines_processed = 0\r\n\u001b[?2004l\r"]
[81.333817, "o", "\u001b[?2004h> "]
[81.333883, "o", "        batch_count = 0\r\n\u001b[?2004l\r"]
[81.333911, "o", "\u001b[?2004h> "]
[81.33402, "o", "        for i, line in enumerate(f):\r\n\u001b[?2004l\r"]
[81.334053, "o", "\u001b[?2004h> "]
[81.334141, "o", "            if i < start_from:\r\n\u001b[?2004l\r"]
[81.334161, "o", "\u001b[?2004h"]
[81.334185, "o", "> "]
[81.334242, "o", "                continue\r\n\u001b[?2004l\r"]
[81.334275, "o", "\u001b[?2004h> "]
[81.334393, "o", "            batch.append(json.loads(line))\r\n\u001b[?2004l\r"]
[81.334422, "o", "\u001b[?2004h> "]
[81.334515, "o", "            lines_processed += 1\r\n\u001b[?2004l\r"]
[81.33454, "o", "\u001b[?2004h"]
[81.334564, "o", "> "]
[81.334662, "o", "            if len(batch) >= BATCH_SIZE:\r\n\u001b[?2004l\r"]
[81.334698, "o", "\u001b[?2004h> "]
[81.334821, "o", "                process_batch(conn, batch)\r\n\u001b[?2004l\r"]
[81.334852, "o", "\u001b[?2004h> "]
[81.334945, "o", "                batch_count += 1\r\n\u001b[?2004l\r"]
[81.334977, "o", "\u001b[?2004h> "]
[81.335147, "o", "                save_checkpoint(start_from + lines_processed)\r\n\u001b[?2004l\r"]
[81.33517, "o", "\u001b[?2004h"]
[81.335204, "o", "> "]
[81.335264, "o", "                conn.commit()\r\n\u001b[?2004l\r"]
[81.335295, "o", "\u001b[?2004h> "]
[81.335588, "o", "                print(f\"Processed batch {batch_count}, checkpoint at line {start_from + lines_processed}\")\r\n\u001b[?2004l\r"]
[81.33562, "o", "\u001b[?2004h> "]
[81.335829, "o", "                time.sleep(0.5)  # Add delay to make interruption easier\r\n\u001b[?2004l\r"]
[81.335868, "o", "\u001b[?2004h"]
[81.335893, "o", "> "]
[81.335931, "o", "                batch = []\r\n\u001b[?2004l\r"]
[81.335954, "o", "\u001b[?2004h"]
[81.335984, "o", "> "]
[81.336015, "o", "        if batch:\r\n\u001b[?2004l\r"]
[81.336045, "o", "\u001b[?2004h> "]
[81.336154, "o", "            process_batch(conn, batch)\r\n\u001b[?2004l\r"]
[81.336182, "o", "\u001b[?2004h> "]
[81.336346, "o", "            save_checkpoint(start_from + lines_processed)\r\n\u001b[?2004l\r"]
[81.336379, "o", "\u001b[?2004h> "]
[81.336452, "o", "            conn.commit()\r\n\u001b[?2004l\r"]
[81.336482, "o", "\u001b[?2004h> "]
[81.336742, "o", "            print(f\"Processed final batch, checkpoint at line {start_from + lines_processed}\")\r\n\u001b[?2004l\r"]
[81.336772, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.336814, "o", "\u001b[?2004h> "]
[81.336866, "o", "    conn.close()\r\n\u001b[?2004l\r"]
[81.336892, "o", "\u001b[?2004h> "]
[81.336996, "o", "    print(\"Processing complete!\")\r\n\u001b[?2004l\r"]
