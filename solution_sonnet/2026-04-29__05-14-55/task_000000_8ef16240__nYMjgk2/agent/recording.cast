[204.980479, "i", "python3 << 'PYEOF'\nimport sqlite3\nconn = sqlite3.connect('output/summary.db')\nresult = conn.execute('SELECT COUNT(*) as categories, SUM(count) as total_records, SUM(total_value) as total_value FROM summary').fetchone()\nprint(f\"Final result after resume:\")\nprint(f\"  Categories: {result[0]}\")\nprint(f\"  Total records: {result[1]}\")\nprint(f\"  Total value: {result[2]:.2f}\")\nprint(f\"\\nExpected: 50000 records, 2494808.87 total value\")\nif result[1] == 50000 and abs(result[2] - 2494808.87) < 0.01:\n    print(\"✓ SUCCESS: Checkpoint/resume working correctly!\")\nelse:\n    print(\"✗ FAILED: Totals don't match\")\nconn.close()\nPYEOF\n"]
