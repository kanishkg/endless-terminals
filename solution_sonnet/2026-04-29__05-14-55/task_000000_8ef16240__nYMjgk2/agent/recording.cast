[81.327983, "i", "cat > process_test.py << 'EOF'\nimport json\nimport sqlite3\nimport os\nimport time\n\nBATCH_SIZE = 1000\n\ndef load_checkpoint():\n    try:\n        with open('.checkpoint', 'r') as f:\n            return json.load(f)\n    except FileNotFoundError:\n        return None\n\ndef save_checkpoint(line_num):\n    with open('.checkpoint', 'w') as f:\n        json.dump({'last_line': line_num}, f)\n        f.flush()\n        os.fsync(f.fileno())\n\ndef process_batch(conn, batch):\n    aggregates = {}\n    for event in batch:\n        cat = event['category']\n        if cat not in aggregates:\n            aggregates[cat] = {'total': 0, 'count': 0}\n        aggregates[cat]['total'] += event['value']\n        aggregates[cat]['count'] += 1\n\n    for cat, data in aggregates.items():\n        conn.execute('''\n            INSERT INTO summary (category, total_value, count) VALUES (?, ?, ?)\n            ON CONFLICT(category) DO UPDATE SET\n                total_value = total_value + excluded.total_value,\n                count = count + excluded.count\n      "]
[81.328101, "i", "  ''', (cat, data['total'], data['count']))\n\ndef process():\n    conn = sqlite3.connect('output/summary.db')\n    conn.execute('CREATE TABLE IF NOT EXISTS summary (category TEXT PRIMARY KEY, total_value REAL, count INTEGER)')\n\n    checkpoint = load_checkpoint()\n    start_from = checkpoint['last_line'] if checkpoint else 0\n    print(f\"Starting from line: {start_from}\")\n\n    with open('data/events.json', 'r') as f:\n        batch = []\n        lines_processed = 0\n        batch_count = 0\n        for i, line in enumerate(f):\n            if i < start_from:\n                continue\n            batch.append(json.loads(line))\n            lines_processed += 1\n            if len(batch) >= BATCH_SIZE:\n                process_batch(conn, batch)\n                batch_count += 1\n                save_checkpoint(start_from + lines_processed)\n                conn.commit()\n                print(f\"Processed batch {batch_count}, checkpoint at line {start_from + lines_processed}\")\n                time.sleep(0.5)  # Add delay to make "]
[81.328151, "o", "cat > process_test.py << 'EOF'\r\n\u001b[?2004l\r"]
[81.328196, "i", "interruption easier\n                batch = []\n        if batch:\n            process_batch(conn, batch)\n            save_checkpoint(start_from + lines_processed)\n            conn.commit()\n            print(f\"Processed final batch, checkpoint at line {start_from + lines_processed}\")\n\n    conn.close()\n    print(\"Processing complete!\")\n\nif __name__ == '__main__':\n    process()\nEOF\n"]
