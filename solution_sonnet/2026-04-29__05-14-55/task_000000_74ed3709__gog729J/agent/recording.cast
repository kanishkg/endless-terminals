[13.199614, "o", "cat scrape.py\r\n\u001b[?2004l\r"]
[13.200507, "o", "#!/usr/bin/env python3\r\nimport asyncio\r\nimport json\r\nimport os\r\nfrom pyppeteer import launch\r\n\r\nasync def scrape_prices():\r\n    browser = await launch(\r\n        headless=False,\r\n        args=['--no-sandbox']\r\n    )\r\n\r\n    page = await browser.newPage()\r\n    await page.goto('http://localhost:8080/products')\r\n\r\n    await page.waitForSelector('.product', timeout=5000)\r\n\r\n    products = await page.evaluate('''() => {\r\n        const items = document.querySelectorAll('.product');\r\n        return Array.from(items).map(item => ({\r\n            name: item.querySelector('.name').textContent,\r\n            price: item.querySelector('.price').textContent\r\n        }));\r\n    }''')\r\n\r\n    script_dir = os.path.dirname(os.path.abspath(__file__))\r\n    output_path = os.path.join(script_dir, 'prices.json')\r\n\r\n    with open(output_path, 'w') as f:\r\n        json.dump(products, f, indent=2)\r\n\r\n    await browser.close()\r\n    print(f\"Scraped {len(products)} products to {output_path}\")\r\n\r\nif __name__ == \"__main__\":"]
[13.200559, "o", "\r\n    asyncio.get_event_loop().run_until_complete(scrape_prices())\r\n"]
[13.200688, "o", "\u001b[?2004h"]
[13.200722, "o", "root@4feb15517154:~/scraper# "]
[19.155323, "i", "curl -s http://localhost:8080/products | head -20\n"]
[19.155545, "o", "curl -s http://localhost:8080/products | head -20\r\n\u001b[?2004l\r"]
[19.171941, "o", "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <title>Product Listing</title>\r\n</head>\r\n<body>\r\n    <h1>Products</h1>\r\n"]
[19.172002, "o", "    <div class=\"product\">\r\n        <span class=\"name\">Widget A</span>\r\n        <span class=\"price\">$19.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Widget B</span>\r\n        <span class=\"price\">$24.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Gadget Pro</span>\r\n        <span class=\"price\">$149.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n"]
[19.172626, "o", "\u001b[?2004hroot@4feb15517154:~/scraper# "]
