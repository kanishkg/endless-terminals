[28.619497, "o", "\u001b[?2004hroot@4feb15517154:~/scraper# "]
[28.713562, "i", "cat > scrape.py << 'EOF'\n#!/usr/bin/env python3\nimport asyncio\nimport json\nimport os\nfrom pyppeteer import launch\n\nasync def scrape_prices():\n    browser = await launch(\n        headless=True,\n        args=[\n            '--no-sandbox',\n            '--disable-setuid-sandbox',\n            '--disable-dev-shm-usage',\n            '--disable-gpu',\n            '--single-process',\n            '--no-zygote'\n        ]\n    )\n\n    page = await browser.newPage()\n    await page.goto('http://localhost:8080/products')\n\n    await page.waitForSelector('.product', timeout=5000)\n\n    products = await page.evaluate('''() => {\n        const items = document.querySelectorAll('.product');\n        return Array.from(items).map(item => ({\n            name: item.querySelector('.name').textContent,\n            price: item.querySelector('.price').textContent\n        }));\n    }''')\n\n    script_dir = os.path.dirname(os.path.abspath(__file__))\n    output_path = os.path.join(script_dir, 'prices.json')\n\n    with open(output_path, 'w') as f:\n  "]
[28.713627, "i", "      json.dump(products, f, indent=2)\n\n    await browser.close()\n    print(f\"Scraped {len(products)} products to {output_path}\")\n\nif __name__ == \"__main__\":\n    asyncio.get_event_loop().run_until_complete(scrape_prices())\nEOF\n"]
