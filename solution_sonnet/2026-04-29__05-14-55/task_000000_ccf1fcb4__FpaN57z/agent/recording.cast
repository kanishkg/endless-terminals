[34.859845, "o", "from flask import Flask\r\n\r\n\r\ndef create_app():\r\n    app = Flask(__name__)\r\n\r\n    from . import routes\r\n    app.register_blueprint(routes.bp)\r\n\r\n    return app\r\n"]
