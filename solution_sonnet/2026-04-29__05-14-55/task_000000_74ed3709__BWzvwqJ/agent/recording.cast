[29.699842, "o", "curl -s http://localhost:8080/products | head -20\r\n\u001b[?2004l\r"]
[29.711999, "o", "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <title>Product Listing</title>\r\n</head>\r\n<body>\r\n    <h1>Products</h1>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Widget A</span>\r\n        <span class=\"price\">$19.99</span>\r\n    </div>\r\n"]
[29.712111, "o", "    <div class=\"product\">\r\n        <span class=\"name\">Widget B</span>\r\n        <span class=\"price\">$24.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Gadget Pro</span>\r\n        <span class=\"price\">$149.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n"]
[29.712682, "o", "\u001b[?2004h"]
