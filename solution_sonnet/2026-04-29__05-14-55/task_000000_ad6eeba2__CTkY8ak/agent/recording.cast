[44.12741, "i", "cat > normalize_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse date from multiple formats to ISO 8601\"\"\"\n    date_str = date_str.strip()\n    \n    # Try different date formats\n    formats = [\n        '%Y-%m-%d',      # YYYY-MM-DD\n        '%m/%d/%Y',      # MM/DD/YYYY\n        '%d.%m.%Y',      # DD.MM.YYYY\n    ]\n    \n    for fmt in formats:\n        try:\n            dt = datetime.strptime(date_str, fmt)\n            return dt.strftime('%Y-%m-%d'), dt\n        except ValueError:\n            continue\n    \n    return None, None\n\ndef parse_price(price_str):\n    \"\"\"Parse price and convert to cents (positive integer)\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = re.sub(r'[$,\\s]', '', price_str.strip())\n        \n        # Convert to float then to cents\n        price_float = float(cleaned)\n        \n        # Check if negative\n        if price_float < 0:\n            return None"]
[44.127545, "i", "\n        \n        # Convert to cents (round to nearest cent)\n        price_cents = int(round(price_float * 100))\n        \n        # Must be positive\n        if price_cents <= 0:\n            return None\n            \n        return price_cents\n    except (ValueError, TypeError):\n        return None\n\ndef is_serial_number(value):\n    \"\"\"Check if a value looks like a serial number\"\"\"\n    return value.strip().startswith('SN-')\n\ndef process_row(row):\n    \"\"\"Process a single row and return normalized data or error\"\"\"\n    try:\n        # Extract fields\n        asset_id = row.get('id', '').strip()\n        name = row.get('name', '').strip()\n        serial = row.get('serial', '').strip()\n        purchase_date_str = row.get('purchase_date', '').strip()\n        price_str = row.get('price', '').strip()\n        location = row.get('location', '').strip()\n        \n        # Check for swapped name and serial\n        if is_serial_number(name) and not is_serial_number(serial):\n            name, serial = serial, name\n        \n     "]
[44.127585, "i", "   # Validate required fields\n        if not asset_id:\n            return None, 'Missing asset ID'\n        if not name:\n            return None, 'Missing name'\n        if not serial:\n            return None, 'Missing serial number'\n        if not is_serial_number(serial):\n            return None, f'Invalid serial number format: {serial}'\n        if not purchase_date_str:\n            return None, 'Missing purchase date'\n        if not price_str:\n            return None, 'Missing price'\n        if not location:\n            return None, 'Missing location'\n        \n        # Parse and validate date\n        iso_date, date_obj = parse_date(purchase_date_str)\n        if iso_date is None:\n            return None, f'Invalid date format: {purchase_date_str}'\n        \n        # Parse and validate price\n        price_cents = parse_price(price_str)\n        if price_cents is None:\n            return None, f'Invalid price: {price_str}'\n        \n        # Return normalized record and date object for comparison\n        normal"]
[44.127615, "o", "cat > normalize_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
