[44.127697, "i", "ate_obj = result, info\n                asset_id = normalized_record['id']\n                \n                # Check if we already have this ID\n                if asset_id in valid_records:\n                    # Keep the one with the latest purchase date\n                    existing_date = valid_records[asset_id][1]\n                    if date_obj > existing_date:\n                        valid_records[asset_id] = (normalized_record, date_obj)\n                else:\n                    valid_records[asset_id] = (normalized_record, date_obj)\n    \n    # Extract just the normalized records (without date objects)\n    final_records = [record for record, _ in valid_records.values()]\n    \n    # Sort by ID for consistent output\n    final_records.sort(key=lambda x: x['id'])\n    \n    # Write valid records to assets.json\n    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\n        json.dump(final_records, f, indent=2)\n    \n    # Write rejected records to rejected.json\n    with open('/home/user/inve"]
