[44.134711, "o", "\u001b[?2004h> "]
[44.134848, "o", "        if price_cents <= 0:\r\n\u001b[?2004l\r"]
[44.134879, "o", "\u001b[?2004h> "]
[44.13498, "o", "            return None\r\n\u001b[?2004l\r"]
[44.135009, "o", "\u001b[?2004h> "]
[44.135075, "o", "            \r\n\u001b[?2004l\r"]
[44.135118, "o", "\u001b[?2004h> "]
[44.135237, "o", "        return price_cents\r\n\u001b[?2004l\r"]
[44.135267, "o", "\u001b[?2004h> "]
[44.135421, "o", "    except (ValueError, TypeError):\r\n\u001b[?2004l\r"]
[44.135452, "o", "\u001b[?2004h> "]
[44.135536, "o", "        return None\r\n\u001b[?2004l\r"]
[44.135566, "o", "\u001b[?2004h> "]
[44.135596, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.135623, "o", "> "]
[44.135727, "o", "def is_serial_number(value):\r\n\u001b[?2004l\r"]
[44.135758, "o", "\u001b[?2004h> "]
[44.135968, "o", "    \"\"\"Check if a value looks like a serial number\"\"\"\r\n\u001b[?2004l\r"]
[44.135997, "o", "\u001b[?2004h> "]
[44.136121, "o", "    return value.strip().startswith('SN-')\r\n\u001b[?2004l\r"]
[44.136151, "o", "\u001b[?2004h> "]
[44.136187, "o", "\r\n\u001b[?2004l\r"]
[44.136224, "o", "\u001b[?2004h> "]
[44.136267, "o", "def process_row(row):\r\n\u001b[?2004l\r"]
[44.136303, "o", "\u001b[?2004h> "]
[44.136484, "o", "    \"\"\"Process a single row and return normalized data or error\"\"\"\r\n\u001b[?2004l\r"]
[44.136511, "o", "\u001b[?2004h> "]
[44.136542, "o", "    try:\r\n\u001b[?2004l\r"]
[44.136566, "o", "\u001b[?2004h"]
[44.13659, "o", "> "]
[44.136645, "o", "        # Extract fields\r\n\u001b[?2004l\r"]
[44.136673, "o", "\u001b[?2004h> "]
[44.136802, "o", "        asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[44.136837, "o", "\u001b[?2004h> "]
[44.136952, "o", "        name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[44.136982, "o", "\u001b[?2004h> "]
[44.137115, "o", "        serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[44.137144, "o", "\u001b[?2004h> "]
[44.137339, "o", "        purchase_date_str = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[44.137368, "o", "\u001b[?2004h"]
[44.137397, "o", "> "]
[44.137506, "o", "        price_str = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[44.137535, "o", "\u001b[?2004h> "]
[44.137682, "o", "        location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[44.13771, "o", "\u001b[?2004h> "]
[44.137743, "o", "        \r\n\u001b[?2004l\r"]
[44.13777, "o", "\u001b[?2004h> "]
[44.137899, "o", "        # Check for swapped name and serial\r\n\u001b[?2004l\r"]
[44.137932, "o", "\u001b[?2004h"]
[44.13796, "o", "> "]
[44.138115, "o", "        if is_serial_number(name) and not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[44.138144, "o", "\u001b[?2004h> "]
[44.138273, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[44.138304, "o", "\u001b[?2004h> "]
[44.138335, "o", "        \r\n\u001b[?2004l\r"]
[44.138363, "o", "\u001b[?2004h> "]
[44.138463, "o", "        # Validate required fields\r\n\u001b[?2004l\r"]
[44.138488, "o", "\u001b[?2004h"]
[44.138516, "o", "> "]
[44.138567, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[44.138596, "o", "\u001b[?2004h> "]
[44.138719, "o", "            return None, 'Missing asset ID'\r\n\u001b[?2004l\r"]
[44.138748, "o", "\u001b[?2004h> "]
[44.138817, "o", "        if not name:\r\n\u001b[?2004l\r"]
[44.138845, "o", "\u001b[?2004h> "]
[44.138962, "o", "            return None, 'Missing name'\r\n\u001b[?2004l\r"]
[44.13899, "o", "\u001b[?2004h> "]
[44.13906, "o", "        if not serial:\r\n\u001b[?2004l\r"]
[44.139089, "o", "\u001b[?2004h> "]
[44.139245, "o", "            return None, 'Missing serial number'\r\n\u001b[?2004l\r"]
[44.139269, "o", "\u001b[?2004h"]
[44.139294, "o", "> "]
[44.139393, "o", "        if not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[44.139421, "o", "\u001b[?2004h> "]
[44.139609, "o", "            return None, f'Invalid serial number format: {serial}'\r\n\u001b[?2004l\r"]
[44.139643, "o", "\u001b[?2004h> "]
[44.139734, "o", "        if not purchase_date_str:\r\n\u001b[?2004l\r"]
[44.139766, "o", "\u001b[?2004h"]
[44.139794, "o", "> "]
[44.139904, "o", "            return None, 'Missing purchase date'\r\n\u001b[?2004l\r"]
[44.139932, "o", "\u001b[?2004h> "]
[44.140009, "o", "        if not price_str:\r\n\u001b[?2004l\r"]
[44.14004, "o", "\u001b[?2004h> "]
[44.140156, "o", "            return None, 'Missing price'\r\n\u001b[?2004l\r"]
[44.140184, "o", "\u001b[?2004h> "]
[44.140274, "o", "        if not location:\r\n\u001b[?2004l\r"]
[44.140304, "o", "\u001b[?2004h> "]
[44.140429, "o", "            return None, 'Missing location'\r\n\u001b[?2004l\r"]
[44.140458, "o", "\u001b[?2004h> "]
[44.140486, "o", "        \r\n\u001b[?2004l\r"]
[44.140515, "o", "\u001b[?2004h> "]
[44.140613, "o", "        # Parse and validate date\r\n\u001b[?2004l\r"]
[44.140641, "o", "\u001b[?2004h> "]
[44.140809, "o", "        iso_date, date_obj = parse_date(purchase_date_str)\r\n\u001b[?2004l\r"]
[44.140839, "o", "\u001b[?2004h> "]
[44.140923, "o", "        if iso_date is None:\r\n\u001b[?2004l\r"]
[44.140951, "o", "\u001b[?2004h> "]
[44.141144, "o", "            return None, f'Invalid date format: {purchase_date_str}'\r\n\u001b[?2004l\r"]
[44.141173, "o", "\u001b[?2004h> "]
[44.141218, "o", "        \r\n\u001b[?2004l\r"]
[44.141241, "o", "\u001b[?2004h"]
[44.141265, "o", "> "]
[44.14135, "o", "        # Parse and validate price\r\n\u001b[?2004l\r"]
[44.14138, "o", "\u001b[?2004h> "]
[44.141509, "o", "        price_cents = parse_price(price_str)\r\n\u001b[?2004l\r"]
[44.141536, "o", "\u001b[?2004h> "]
[44.141631, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[44.141658, "o", "\u001b[?2004h> "]
[44.141815, "o", "            return None, f'Invalid price: {price_str}'\r\n\u001b[?2004l\r"]
[44.141848, "o", "\u001b[?2004h> "]
[44.141874, "o", "        \r\n\u001b[?2004l\r"]
[44.141902, "o", "\u001b[?2004h> "]
[44.142087, "o", "        # Return normalized record and date object for comparison\r\n\u001b[?2004l\r"]
[44.142116, "o", "\u001b[?2004h> "]
[44.142183, "o", "        normalized = {\r\n\u001b[?2004l\r"]
[44.142223, "o", "\u001b[?2004h"]
[44.142255, "o", "> "]
[44.142309, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[44.142341, "o", "\u001b[?2004h"]
[44.142367, "o", "> "]
[44.142417, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[44.142446, "o", "\u001b[?2004h> "]
[44.142533, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[44.142561, "o", "\u001b[?2004h> "]
[44.14267, "o", "            'purchase_date': iso_date,\r\n\u001b[?2004l\r"]
[44.142699, "o", "\u001b[?2004h> "]
[44.142824, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[44.142858, "o", "\u001b[?2004h> "]
[44.142946, "o", "            'location': location\r\n\u001b[?2004l\r"]
[44.14298, "o", "\u001b[?2004h> "]
[44.143006, "o", "        }\r\n\u001b[?2004l\r"]
[44.14303, "o", "\u001b[?2004h"]
[44.14306, "o", ">         \r\n"]
[44.143079, "o", "\u001b[?2004l\r"]
[44.143111, "o", "\u001b[?2004h> "]
[44.143208, "o", "        return normalized, date_obj\r\n\u001b[?2004l\r"]
[44.143233, "o", "\u001b[?2004h"]
[44.143257, "o", "> "]
[44.143285, "o", "        \r\n\u001b[?2004l\r"]
[44.143309, "o", "\u001b[?2004h> "]
[44.143375, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[44.143404, "o", "\u001b[?2004h> "]
[44.143548, "o", "        return None, f'Processing error: {str(e)}'\r\n"]
[44.143574, "o", "\u001b[?2004l\r\u001b[?2004h"]
[44.143599, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[44.143626, "o", "> "]
[44.143649, "o", "def main():\r\n\u001b[?2004l\r"]
[44.143672, "o", "\u001b[?2004h"]
[44.143701, "o", "> "]
[44.143745, "o", "    valid_records = {}\r\n\u001b[?2004l\r"]
[44.143774, "o", "\u001b[?2004h> "]
[44.143848, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[44.143876, "o", "\u001b[?2004h> "]
[44.14391, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[44.143944, "o", "> "]
[44.143982, "o", "    # Read CSV file\r\n\u001b[?2004l\r"]
[44.144008, "o", "\u001b[?2004h> "]
[44.144243, "o", "    with open('/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.144271, "o", "\u001b[?2004h> "]
[44.144372, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[44.144399, "o", "\u001b[?2004h> "]
[44.144429, "o", "        \r\n\u001b[?2004l\r"]
[44.14446, "o", "\u001b[?2004h> "]
[44.144703, "o", "        for row_num, row in enumerate(reader, start=2):  # Start at 2 (header is row 1)\r\n\u001b[?2004l\r"]
[44.14473, "o", "\u001b[?2004h> "]
[44.144857, "o", "            result, info = process_row(row)\r\n\u001b[?2004l\r"]
[44.144886, "o", "\u001b[?2004h> "]
[44.144928, "o", "            \r\n\u001b[?2004l\r"]
[44.144957, "o", "\u001b[?2004h> "]
[44.145048, "o", "            if result is None:\r\n\u001b[?2004l\r"]
[44.145078, "o", "\u001b[?2004h> "]
[44.145165, "o", "                # Rejected row\r\n\u001b[?2004l\r"]
[44.145192, "o", "\u001b[?2004h> "]
[44.145327, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[44.14535, "o", "\u001b[?2004h"]
[44.145375, "o", "> "]
[44.14549, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[44.145518, "o", "\u001b[?2004h> "]
[44.14562, "o", "                    'reason': info\r\n\u001b[?2004l\r"]
[44.145648, "o", "\u001b[?2004h> "]
[44.145706, "o", "                })\r\n\u001b[?2004l\r"]
[44.145733, "o", "\u001b[?2004h> "]
[44.145788, "o", "            else:\r\n\u001b[?2004l\r"]
[44.145822, "o", "\u001b[?2004h> "]
[44.145996, "o", "                # Valid row - store with date for deduplication\r\n\u001b[?2004l\r"]
[44.146023, "o", "\u001b[?2004h> "]
[44.146188, "o", "                normalized_record, date_obj = result, info\r\n\u001b[?2004l\r"]
[44.146229, "o", "\u001b[?2004h"]
[44.146255, "o", "> "]
[44.146381, "o", "                asset_id = normalized_record['id']\r\n\u001b[?2004l\r"]
[44.146411, "o", "\u001b[?2004h> "]
[44.146462, "o", "                \r\n\u001b[?2004l\r"]
[44.14649, "o", "\u001b[?2004h> "]
[44.146632, "o", "                # Check if we already have this ID\r\n\u001b[?2004l\r"]
[44.146667, "o", "\u001b[?2004h> "]
[44.1468, "o", "                if asset_id in valid_records:\r\n\u001b[?2004l\r"]
[44.146828, "o", "\u001b[?2004h"]
[44.146852, "o", "> "]
[44.147013, "o", "                    # Keep the one with the latest purchase date\r\n\u001b[?2004l\r"]
[44.147043, "o", "\u001b[?2004h> "]
[44.147233, "o", "                    existing_date = valid_records[asset_id][1]\r\n\u001b[?2004l\r"]
[44.147263, "o", "\u001b[?2004h> "]
[44.147404, "o", "                    if date_obj > existing_date:\r\n\u001b[?2004l\r"]
[44.147434, "o", "\u001b[?2004h> "]
[44.147656, "o", "                        valid_records[asset_id] = (normalized_record, date_obj)\r\n\u001b[?2004l\r"]
[44.147686, "o", "\u001b[?2004h> "]
[44.147749, "o", "                else:\r\n\u001b[?2004l\r"]
[44.147775, "o", "\u001b[?2004h> "]
[44.147989, "o", "                    valid_records[asset_id] = (normalized_record, date_obj)\r\n\u001b[?2004l\r"]
[44.148024, "o", "\u001b[?2004h> "]
[44.14805, "o", "    \r\n\u001b[?2004l\r"]
[44.148076, "o", "\u001b[?2004h> "]
[44.148265, "o", "    # Extract just the normalized records (without date objects)\r\n\u001b[?2004l\r"]
[44.148289, "o", "\u001b[?2004h"]
[44.148318, "o", "> "]
[44.148489, "o", "    final_records = [record for record, _ in valid_records.values()]\r\n\u001b[?2004l\r"]
[44.148519, "o", "\u001b[?2004h> "]
[44.148545, "o", "    \r\n\u001b[?2004l\r"]
[44.148565, "o", "\u001b[?2004h> "]
[44.148679, "o", "    # Sort by ID for consistent output\r\n\u001b[?2004l\r"]
[44.148713, "o", "\u001b[?2004h> "]
[44.14884, "o", "    final_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[44.148868, "o", "\u001b[?2004h"]
[44.148894, "o", ">     \r\n\u001b[?2004l\r"]
[44.148922, "o", "\u001b[?2004h> "]
[44.149038, "o", "    # Write valid records to assets.json\r\n\u001b[?2004l\r"]
[44.149065, "o", "\u001b[?2004h> "]
[44.149302, "o", "    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.149326, "o", "\u001b[?2004h"]
[44.149351, "o", "> "]
[44.149465, "o", "        json.dump(final_records, f, indent=2)\r\n\u001b[?2004l\r"]
[44.149493, "o", "\u001b[?2004h> "]
[44.149522, "o", "    \r\n\u001b[?2004l\r"]
[44.149551, "o", "\u001b[?2004h> "]
[44.149672, "o", "    # Write rejected records to rejected.json\r\n\u001b[?2004l\r"]
[44.149702, "o", "\u001b[?2004h> "]
[44.149927, "o", "    with open('/home/user/inventory/rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[44.149958, "o", "\u001b[?2004h> "]
[44.150092, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[44.150125, "o", "\u001b[?2004h> "]
[44.150157, "o", "    \r\n\u001b[?2004l\r"]
[44.150184, "o", "\u001b[?2004h> "]
[44.15028, "o", "    print(f\"Processing complete:\")\r\n\u001b[?2004l\r"]
[44.150316, "o", "\u001b[?2004h> "]
[44.150457, "o", "    print(f\"  Valid records: {len(final_records)}\")\r\n\u001b[?2004l\r"]
[44.150485, "o", "\u001b[?2004h> "]
[44.150649, "o", "    print(f\"  Rejected records: {len(rejected_records)}\")\r\n\u001b[?2004l\r"]
[44.150678, "o", "\u001b[?2004h> "]
[44.150911, "o", "    print(f\"  Total input rows: {len(final_records) + len(rejected_records)}\")\r\n\u001b[?2004l\r"]
[44.15094, "o", "\u001b[?2004h> "]
[44.15097, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.150999, "o", "> "]
[44.151053, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[44.151083, "o", "\u001b[?2004h> "]
[44.15112, "o", "    main()\r\n\u001b[?2004l\r"]
[44.151147, "o", "\u001b[?2004h> "]
[44.151166, "o", "EOF\r\n\u001b[?2004l\r"]
[44.15465, "o", "\u001b[?2004huser@ff3fdcf23119:~/inventory$ "]
[44.239714, "i", "python3 normalize_assets.py\n"]
[44.239844, "o", "python3 normalize_assets.py\r\n\u001b[?2004l\r"]
[44.283078, "o", "Processing complete:\r\n  Valid records: 809\r\n  Rejected records: 16\r\n  Total input rows: 825\r\n"]
[44.287151, "o", "\u001b[?2004h"]
[44.287189, "o", "user@ff3fdcf23119:~/inventory$ "]
[53.105726, "i", "ls -lh *.json\n"]
[53.10585, "o", "ls -lh *.json\r\n\u001b[?2004l\r"]
[53.107065, "o", "-rw-r--r-- 1 user user 146K Apr 29 07:13 assets.json\r\n-rw-r--r-- 1 user user 4.1K Apr 29 07:13 rejected.json\r\n"]
