[55.726936, "i", "cat > config/gunicorn.conf.py << 'EOF'\nimport configparser\nimport os\n\n# Read configuration from settings.ini\nconfig = configparser.ConfigParser()\nconfig_path = os.path.join(os.path.dirname(__file__), 'settings.ini')\nconfig.read(config_path)\n\n# Get settings with fallbacks\nif config.has_section('server'):\n    host = config.get('server', 'host') if config.has_option('server', 'host') else '127.0.0.1'\n    port = config.get('server', 'port') if config.has_option('server', 'port') else '8000'\n    workers_count = config.get('server', 'workers') if config.has_option('server', 'workers') else '2'\nelse:\n    host = '127.0.0.1'\n    port = '8000'\n    workers_count = '2'\n\n# Gunicorn configuration\nbind = f\"{host}:{port}\"\nworkers = int(workers_count)\ndaemon = False\nEOF\n"]
