[30.437578, "i", "cat > /home/user/backup.sh << 'EOF'\n#!/bin/bash\n\n# Backup script that handles complex permissions\nSOURCE_DIR=\"/home/user/projects\"\nBACKUP_DIR=\"/home/user/backups\"\nMANIFEST=\"${BACKUP_DIR}/manifest.txt\"\n\n# Clear/create manifest\n> \"${MANIFEST}\"\n\n# Find all readable files and process them\nfind \"${SOURCE_DIR}\" -type f -readable 2>/dev/null | while IFS= read -r file; do\n    # Get the relative path from source directory\n    rel_path=\"${file#${SOURCE_DIR}/}\"\n    dest_file=\"${BACKUP_DIR}/${rel_path}\"\n    \n    # Get owner:group information\n    owner_info=$(stat -c \"%U:%G\" \"${file}\" 2>/dev/null)\n    \n    if [ -n \"${owner_info}\" ]; then\n        # Create destination directory structure\n        dest_dir=$(dirname \"${dest_file}\")\n        mkdir -p \"${dest_dir}\" 2>/dev/null\n        \n        # Copy the file\n        if cp \"${file}\" \"${dest_file}\" 2>/dev/null; then\n            # Write to manifest\n            echo \"${rel_path} ${owner_info}\" >> \"${MANIFEST}\"\n        fi\n    fi\ndone\n\necho \"Backup complete. Manifest written to ${MAN"]
[30.437629, "i", "IFEST}\"\nEOF\n"]
