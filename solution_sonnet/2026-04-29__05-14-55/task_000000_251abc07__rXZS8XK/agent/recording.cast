[26.410425, "i", "awk '\n/\\/api\\/v[0-9]+\\/internal\\// && !/^10\\./ {\n  # Extract timestamp\n  match($0, /\\[([^\\]]+)\\]/, ts)\n  timestamp = ts[1]\n  \n  # Convert month name to number\n  split(\"Jan Feb Mar Apr May Jun Jul Aug Sep Oct Nov Dec\", months, \" \")\n  for (i=1; i<=12; i++) month_map[months[i]] = sprintf(\"%02d\", i)\n  \n  # Parse: DD/Mon/YYYY:HH:MM:SS +0000\n  split(timestamp, dt, /[\\/: ]/)\n  day = dt[1]\n  mon = month_map[dt[2]]\n  year = dt[3]\n  time = dt[4] \":\" dt[5] \":\" dt[6]\n  \n  # Replace timestamp in original line\n  sub(/\\[[^\\]]+\\]/, year \"-\" mon \"-\" day \"T\" time)\n  print\n}' /var/log/app/access.log > /home/user/internal_hits.log\n"]
