[63.021463, "i", "cat > /home/user/backup.sh << 'EOF'\n#!/bin/bash\n\n# Backup script that copies accessible files from /home/user/projects to /home/user/backups\n# and creates a manifest with owner:group information\n\nSOURCE_DIR=\"/home/user/projects\"\nBACKUP_DIR=\"/home/user/backups\"\nMANIFEST=\"${BACKUP_DIR}/manifest.txt\"\n\n# Create backup directory if it doesn't exist\nmkdir -p \"${BACKUP_DIR}\" 2>/dev/null\n\n# Clear/create manifest file\n> \"${MANIFEST}\"\n\n# Find all readable files and process them\nfind \"${SOURCE_DIR}\" -type f -readable 2>/dev/null | while IFS= read -r file; do\n    # Get relative path from source directory\n    rel_path=\"${file#${SOURCE_DIR}/}\"\n    \n    # Get owner:group information\n    owner_info=$(stat -c \"%U:%G\" \"${file}\" 2>/dev/null)\n    \n    if [ -n \"${owner_info}\" ]; then\n        # Create target directory structure\n        target_file=\"${BACKUP_DIR}/${rel_path}\"\n        target_dir=$(dirname \"${target_file}\")\n        mkdir -p \"${target_dir}\" 2>/dev/null\n        \n        # Copy the file\n        cp \"${file}\" \"${target_fi"]
[63.021518, "i", "le}\" 2>/dev/null\n        \n        # If copy succeeded, add to manifest\n        if [ $? -eq 0 ]; then\n            echo \"${rel_path} ${owner_info}\" >> \"${MANIFEST}\"\n        fi\n    fi\ndone\n\necho \"Backup complete. Manifest written to ${MANIFEST}\"\nEOF\n"]
