[41.17079, "o", "     1\t#!/usr/bin/env python3\r\n     2\timport json\r\n     3\t\r\n     4\tdef main():\r\n     5\t    results = {\"hosts\": {}}\r\n     6\t\r\n     7\t    with open(\"results/ping.txt\") as f:\r\n     8\t        for line in f:\r\n     9\t            host, status = line.strip().split(\": \")\r\n    10\t            results[\"hosts\"][host] = {\"ping\": status}\r\n    11\t\r\n    12\t    with open(\"results/ports.txt\") as f:\r\n    13\t        for line in f:\r\n    14\t            parts = line.strip().split()\r\n    15\t            host_port = parts[0].split(\":\")\r\n    16\t            host = host_port[0]\r\n    17\t            port = host_port[1]\r\n    18\t            status = parts[1]\r\n    19\t            if host not in results[\"hosts\"]:\r\n    20\t                results[\"hosts\"][host] = {}\r\n    21\t            if \"ports\" not in results[\"hosts\"][host]:\r\n    22\t                results[\"hosts\"][host][\"ports\"] = {}\r\n    23\t            results[\"hosts\"][host][\"ports\"][port] = status\r\n    24\t\r\n    25"]
