[35.27686, "i", "cat test.sh\n"]
[35.276985, "o", "cat test.sh\r\n\u001b[?2004l\r"]
[35.277778, "o", "#!/bin/bash\r\n# Simulates packet check through the firewall\r\n# Returns 0 if 10.200.0.50 can reach 10.100.0.42:5000, 1 otherwise\r\n\r\n# Check if FORWARD chain would accept this traffic\r\n# (simplified simulation using iptables-save parsing)\r\n\r\nRULES=$(iptables-save 2>/dev/null)\r\n\r\n# Check for explicit DROP before any ACCEPT for this traffic\r\nif echo \"$RULES\" | grep -q \"\\-A FORWARD.*10\\.200\\.0\\.0/16.*10\\.100\\.0\\.0/16.*DROP\"; then\r\n    # Check if there's an ACCEPT for this specific traffic BEFORE the drop\r\n    ACCEPT_LINE=$(echo \"$RULES\" | grep -n \"\\-A FORWARD.*10\\.200\\.0\\.0/16.*10\\.100\\.0\\.0/16.*ACCEPT\" | head -1 | cut -d: -f1)\r\n    DROP_LINE=$(echo \"$RULES\" | grep -n \"\\-A FORWARD.*10\\.200\\.0\\.0/16.*10\\.100\\.0\\.0/16.*DROP\" | head -1 | cut -d: -f1)\r\n\r\n    if [ -z \"$ACCEPT_LINE\" ] || [ \"$DROP_LINE\" -lt \"$ACCEPT_LINE\" ]; then\r\n        echo \"BLOCKED: Traffic from 10.200.0.0/16 to 10.100.0.42:5000 is being dropped\"\r\n        exit 1\r\n    fi\r\nfi\r\n\r\n# Check if there's any ACCEPT rule that would match\r\nif echo \"$RULES\" | gre"]
[35.277825, "o", "p -qE \"\\-A FORWARD.*(10\\.200\\.0\\.0/16|eth1).*ACCEPT\"; then\r\n    echo \"OK: Traffic from 10.200.0.0/16 to 10.100.0.42:5000 would be accepted\"\r\n    exit 0\r\nfi\r\n\r\necho \"BLOCKED: No matching ACCEPT rule in FORWARD chain\"\r\nexit 1\r\n"]
[35.277958, "o", "\u001b[?2004h"]
[35.277999, "o", "root@ea7849a717f2:/home/user/firewall# "]
