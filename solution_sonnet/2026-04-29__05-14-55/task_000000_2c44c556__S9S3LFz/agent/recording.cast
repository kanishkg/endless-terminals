[130.295287, "o", "*filter\r\n:INPUT DROP [0:0]\r\n:FORWARD DROP [0:0]\r\n:OUTPUT ACCEPT [0:0]\r\n-A INPUT -p tcp --dport 22 -j ACCEPT\r\n-A FORWARD -s 10.200.0.0/16 -d 10.100.0.42/32 -p tcp --dport 5000 -j ACCEPT\r\n-A FORWARD -i eth1 -o eth2 -j ACCEPT\r\nCOMMIT\r\n*nat\r\n:PREROUTING ACCEPT [0:0]\r\n:INPUT ACCEPT [0:0]\r\n:OUTPUT ACCEPT [0:0]\r\n:POSTROUTING ACCEPT [0:0]\r\n-A POSTROUTING -s 10.200.0.0/16 -o eth2 -j MASQUERADE\r\nCOMMIT\r\n"]
