[37.291616, "o", "from flask import Blueprint\r\n\r\nbp = Blueprint('main', __name__)\r\n\r\n\r\n@bp.route('/')\r\ndef index():\r\n    return \"Labeler v2.1 running\"\r\n\r\n\r\n@bp.route('/health')\r\ndef health():\r\n    return {\"status\": \"ok\"}\r\n"]
