[12.802448, "o", "#!/usr/bin/env python3\r\nimport sys\r\nimport yaml\r\n\r\nfor path in sys.argv[1:]:\r\n    try:\r\n        with open(path) as f:\r\n            yaml.safe_load(f)\r\n        print(f\"OK: {path}\")\r\n    except yaml.YAMLError as e:\r\n        print(f\"ERROR: {path}: {e}\")\r\n    except Exception as e:\r\n        print(f\"ERROR: {path}: {e}\")\r\n"]
