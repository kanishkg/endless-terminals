[7.164127, "o", "total 12\r\n"]
[7.164179, "o", "drwxrwxrwx 1 user user 4096 Apr 29 08:19 .\r\ndrwxrwxrwx 1 user user 4096 Apr 29 08:19 ..\r\n-rw-r--r-- 1 user user  468 Apr 29 08:19 target_iptables.txt\r\n"]
[7.164329, "o", "\u001b[?2004h"]
