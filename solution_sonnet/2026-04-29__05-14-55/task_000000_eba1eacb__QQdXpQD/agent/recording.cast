[18.147072, "i", "cat scripts/check_ping.sh\n"]
[18.147197, "o", "cat scripts/check_ping.sh\r\n\u001b[?2004l\r"]
[18.148059, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    if ping -c 1 -W 1 \"$host\" &>/dev/null; then\r\n        echo \"$host: up\"\r\n    else\r\n        echo \"$host: down\"\r\n    fi\r\ndone < hosts.conf > results/ping.txt\r\n"]
[18.148231, "o", "\u001b[?2004hroot@3aa63b9cbae8:/home/user/netmon# "]
[18.287452, "i", "cat scripts/check_ports.sh\n"]
[18.287572, "o", "cat scripts/check_ports.sh\r\n"]
[18.287637, "o", "\u001b[?2004l\r"]
[18.288433, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    for port in 22 80 443; do\r\n        timeout 1 bash -c \"echo >/dev/tcp/$host/$port\" 2>/dev/null && status=\"open\" || status=\"closed\"\r\n        echo \"$host:$port $status\"\r\n    done\r\ndone < hosts.conf > results/ports.txt\r\n"]
[18.28862, "o", "\u001b[?2004h"]
[18.288666, "o", "root@3aa63b9cbae8:/home/user/netmon# "]
[18.389424, "i", "cat aggregate.py\n"]
[18.389535, "o", "cat aggregate.py\r\n\u001b[?2004l\r"]
[18.390373, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f\r\n        json.dump(results, f, indent=2)\r\n\r\n    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[18.390518, "o", "\u001b[?2004h"]
[18.390579, "o", "root@3aa63b9cbae8:/home/user/netmon# "]
[25.502404, "i", "sed -i 's/with open(\"results\\/status.json\", \"w\") as f$/with open(\"results\\/status.json\", \"w\") as f:/' aggregate.py\n"]
[25.50281, "o", "sed -i 's/with open(\"results\\/status.json\", \"w\") as f$/with open(\"results\\/status.json\", \"w\") as f:/' aggregate.py\r\n\u001b[?2004l\r"]
[25.508597, "o", "\u001b[?2004hroot@3aa63b9cbae8:/home/user/netmon# "]
[25.607294, "i", "cat aggregate.py\n"]
[25.607415, "o", "cat aggregate.py\r\n\u001b[?2004l\r"]
[25.608246, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f:\r\n        json.dump(results, f, indent=2)\r\n\r\n    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[25.608429, "o", "\u001b[?2004h"]
[25.608465, "o", "root@3aa63b9cbae8:/home/user/netmon# "]
[35.415542, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean check-config\n\n# Check if hosts.conf exists before doing anything\ncheck-config:\n\t@if [ ! -f hosts.conf ]; then \\\n\t\techo \"ERROR: hosts.conf is missing. Cannot proceed with monitoring checks.\"; \\\n\t\texit 1; \\\n\tfi\n\t@echo \"Configuration file hosts.conf found.\"\n\n# Run ping checks\nresults/ping.txt: hosts.conf check-config\n\t@echo \"Running ping checks...\"\n\t./scripts/check_ping.sh\n\n# Run port checks\nresults/ports.txt: hosts.conf check-config\n\t@echo \"Running port checks...\"\n\t./scripts/check_ports.sh\n\n# Generate the aggregated JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\t@echo \"Generating aggregated report...\"\n\t./aggregate.py\n\n# Main target to generate the full report\nreport: results/status.json\n\t@echo \"Monitoring report complete!\"\n\n# Clean up generated results\nclean:\n\trm -rf results\nEOF\n"]
