[180.371273, "i", "cat Makefile\n"]
[180.371379, "o", "cat Makefile\r\n\u001b[?2004l\r"]
[180.372246, "o", ".PHONY: report clean check-config\r\n\r\n# Main target to generate the full report\r\nreport: check-config results/status.json\r\n\t@echo \"Monitoring report complete!\"\r\n\r\n# Check if hosts.conf exists before doing anything\r\ncheck-config:\r\n\t@if [ ! -f hosts.conf ]; then echo \"ERROR: hosts.conf is missing. Cannot proceed with monitoring checks.\"; exit 1; fi\r\n\t@echo \"Configuration file hosts.conf found.\"\r\n\r\n# Run ping checks\r\nresults/ping.txt: hosts.conf\r\n\t@echo \"Running ping checks...\"\r\n\t./scripts/check_ping.sh\r\n\r\n# Run port checks\r\nresults/ports.txt: hosts.conf\r\n\t@echo \"Running port checks...\"\r\n\t./scripts/check_ports.sh\r\n\r\n# Generate the aggregated JSON report\r\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\r\n\t@echo \"Generating aggregated report...\"\r\n\t./aggregate.py\r\n\r\n# Clean up generated results\r\nclean:\r\n\trm -rf results\r\n"]
[180.372401, "o", "\u001b[?2004h"]
