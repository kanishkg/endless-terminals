[48.821608, "o", "--- app.py.backup\t2026-04-29 06:02:53.576053946 +0000\r\n+++ app.py\t2026-04-29 06:02:53.690330499 +0000\r\n@@ -25,9 +25,9 @@\r\n     # Parse the UTC time string\r\n"]
[48.821677, "o", "     utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n \r\n-    # Convert to Berlin time\r\n-    # BUG: This incorrectly localizes the UTC datetime as if it were already Berlin time\r\n-    berlin_dt = BERLIN_TZ.localize(utc_dt)\r\n+    # First localize as UTC, then convert to Berlin time\r\n+    utc_dt = UTC_TZ.localize(utc_dt)\r\n+    berlin_dt = utc_dt.astimezone(BERLIN_TZ)\r\n \r\n     return berlin_dt\r\n \r\n"]
