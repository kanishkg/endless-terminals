[63.17605, "i", "cat > test_dst_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"\nTest to verify DST handling is correct.\nTests the specific case of meetings around 2am-3am Berlin time.\n\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\n# Old buggy implementation\ndef convert_to_berlin_OLD(utc_time_str):\n    BERLIN_TZ = pytz.timezone('Europe/Berlin')\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    berlin_dt = BERLIN_TZ.localize(utc_dt)  # BUG: treats as Berlin time\n    return berlin_dt\n\n# New fixed implementation\ndef convert_to_berlin_NEW(utc_time_str):\n    BERLIN_TZ = pytz.timezone('Europe/Berlin')\n    UTC_TZ = pytz.utc\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    utc_dt = UTC_TZ.localize(utc_dt)  # Localize as UTC\n    berlin_dt = utc_dt.astimezone(BERLIN_TZ)  # Convert to Berlin\n    return berlin_dt\n\nprint(\"Testing timezone conversion fix...\\n\")\n\n# Test case: The problematic maintenance window at 01:30 UTC\n# This should be 2:30 or 3:30 Berlin time depending on DST\ntest_time = \"2024-03-31T"]
[63.176173, "i", "01:30:00\"  # UTC\n\nprint(f\"Test time (UTC): {test_time}\")\nprint()\n\nold_result = convert_to_berlin_OLD(test_time)\nprint(f\"OLD (buggy) conversion: {old_result}\")\nprint(f\"  Formatted: {old_result.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\nprint()\n\nnew_result = convert_to_berlin_NEW(test_time)\nprint(f\"NEW (fixed) conversion: {new_result}\")\nprint(f\"  Formatted: {new_result.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\nprint()\n\n# Show the difference\ntime_diff = (new_result - old_result).total_seconds() / 3600\nprint(f\"Time difference: {abs(time_diff):.1f} hour(s)\")\nprint()\n\n# Verify the correct conversion\nprint(\"Verification:\")\nprint(f\"  01:30 UTC should convert to a Berlin time\")\nprint(f\"  March 31, 2024 is around DST transition in Europe\")\nprint(f\"  The NEW conversion shows: {new_result.strftime('%H:%M %Z')}\")\nprint()\n\nif time_diff != 0:\n    print(\"✓ FIX CONFIRMED: The conversions now differ, bug is fixed!\")\nelse:\n    print(\"✗ WARNING: No difference detected\")\nEOF\n"]
