[25.840225, "i", "awk '\n/\\/api\\/v[0-9]+\\/internal\\// && $1 !~ /^10\\./ {\n  # Parse timestamp [DD/Mon/YYYY:HH:MM:SS +0000]\n  timestamp = $4\n  gsub(/\\[/, \"\", timestamp)\n  \n  # Split timestamp components\n  split(timestamp, dt, /[:\\/]/);\n  day = dt[1]\n  month = dt[2]\n  year = dt[3]\n  time = dt[4] \":\" dt[5] \":\" dt[6]\n  \n  # Convert month name to number\n  months[\"Jan\"]=\"01\"; months[\"Feb\"]=\"02\"; months[\"Mar\"]=\"03\"; months[\"Apr\"]=\"04\";\n  months[\"May\"]=\"05\"; months[\"Jun\"]=\"06\"; months[\"Jul\"]=\"07\"; months[\"Aug\"]=\"08\";\n  months[\"Sep\"]=\"09\"; months[\"Oct\"]=\"10\"; months[\"Nov\"]=\"11\"; months[\"Dec\"]=\"12\";\n  \n  iso_timestamp = year \"-\" months[month] \"-\" day \"T\" time\n  \n  # Replace original timestamp with ISO format\n  $4 = iso_timestamp\n  $5 = \"\"  # Remove timezone\n  \n  print\n}' /var/log/app/access.log > /home/user/internal_hits.log\n"]
