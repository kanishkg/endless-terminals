[55.105038, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef ip_in_cidr(ip_str, cidr_str):\n    \"\"\"Check if an IP address is within a CIDR range.\"\"\"\n    try:\n        ip = ipaddress.ip_address(ip_str)\n        network = ipaddress.ip_network(cidr_str, strict=False)\n        return ip in network\n    except ValueError:\n        return False\n\ndef port_in_range(port, port_spec):\n    \"\"\"Check if a port matches a port specification (single port or range).\"\"\"\n    try:\n        port = int(port)\n        port_spec = str(port_spec)\n        if '-' in port_spec:\n            start, end = map(int, port_spec.split('-'))\n            return start <= port <= end\n        else:\n            return port == int(port_spec)\n    except (ValueError, AttributeError):\n        return False\n\ndef find_matching_rules(source_ip, dest_port, rules):\n    \"\"\"Find all matching rules for a given source IP and destination port.\n    Returns list of (prefix_length, rule) tuples sorted by specificity.\"\"\"\n    matching_r"]
[55.105091, "i", "ules = []\n    \n    for rule in rules:\n        source_cidr = rule.get('source_cidr', '')\n        rule_port = rule.get('dest_port', '')\n        \n        if ip_in_cidr(source_ip, source_cidr) and port_in_range(dest_port, rule_port):\n            try:\n                network = ipaddress.ip_network(source_cidr, strict=False)\n                prefix_len = network.prefixlen\n                matching_rules.append((prefix_len, rule))\n            except ValueError:\n                pass\n    \n    matching_rules.sort(key=lambda x: x[0], reverse=True)\n    return matching_rules\n\ndef is_connection_allowed(source_ip, dest_port, rules):\n    \"\"\"Check if a connection is allowed based on firewall rules.\n    Returns (allowed, most_specific_cidr)\"\"\"\n    matching_rules = find_matching_rules(source_ip, dest_port, rules)\n    \n    if not matching_rules:\n        return False, None\n    \n    most_specific_rule = matching_rules[0][1]\n    action = most_specific_rule.get('action', 'deny')\n    cidr = most_specific_rule.get('source_cidr', '')\n   "]
[55.105188, "i", " \n    return action == 'allow', cidr\n\ndef main():\n    try:\n        with open('/home/user/audit/firewall_rules.json', 'r') as f:\n            data = json.load(f)\n            rules = data.get('rules', [])\n    except (FileNotFoundError, json.JSONDecodeError) as e:\n        print(f\"Error loading firewall rules: {e}\", file=sys.stderr)\n        sys.exit(1)\n    \n    try:\n        with open('/home/user/audit/connections.csv', 'r') as f:\n            reader = csv.DictReader(f)\n            connections = list(reader)\n    except FileNotFoundError as e:\n        print(f\"Error loading connections: {e}\", file=sys.stderr)\n        sys.exit(1)\n    \n    for conn in connections:\n        source_ip = conn.get('src_ip', '').strip()\n        dest_port = conn.get('dest_port', '').strip()\n        \n        if not source_ip or not dest_port:\n            continue\n        \n        allowed, cidr = is_connection_allowed(source_ip, dest_port, rules)\n        \n        if not allowed:\n            if cidr:\n                print(f\"BLOCKED: {source_ip}:{"]
