[55.105349, "o", "\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\rdest_port} not allowed from {cidr}\")\r\n            else:\r\n                print(f\"BLOCKED: {source_ip}:{dest_port} not allowed from any\")\r\n\r\nif __name__ == '__main__':\r\n    main()\r\nEOF"]
