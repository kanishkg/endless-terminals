[95.530423, "o", "-rw-r--r-- 1 user user 2596 Apr 29 05:20 FIX_SUMMARY.md\r\ndrwxr-xr-x 2 user user 4096 Apr 29 05:20 \u001b[01;34m__pycache__\u001b[0m\r\n-rwxr-xr-x 1 user user 1973 Apr 29 05:19 \u001b[01;32mapp.py\u001b[0m\r\n-rwxr-xr-x 1 user user 1995 Apr 29 05:19 \u001b[01;32mapp.py.backup\u001b[0m\r\n-rw-r--r-- 1 user user  144 Apr 29 05:07 crontab\r\n-rw-r--r-- 1 user user  453 Apr 29 05:07 meetings.json\r\n-rwxr-xr-x 1 user user 1015 Apr 29 05:07 \u001b[01;32mtest_conversion.py\u001b[0m\r\n-rw-r--r-- 1 user user 1734 Apr 29 05:20 test_dst_fix.py\r\n"]
