[59.346675, "i", "cat > test_dst_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Test that DST conversion is now correct.\"\"\"\n\nimport sys\nsys.path.insert(0, '/home/user/scheduler')\n\nfrom app import convert_to_berlin\nimport pytz\nfrom datetime import datetime\n\n# Test the problematic meeting time\nprint(\"Testing DST transition fix...\")\nprint()\n\n# The maintenance window meeting: 2024-03-31T01:30:00 UTC\n# March 31, 2024 is when DST transition happens in Europe (2am -> 3am)\nutc_time_str = \"2024-03-31T01:30:00\"\n\nprint(f\"UTC time: {utc_time_str}\")\n\nberlin_time = convert_to_berlin(utc_time_str)\nprint(f\"Berlin time: {berlin_time.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint()\n\n# Verify the conversion is correct\n# At 01:30 UTC on March 31, 2024, Berlin should be in CEST (UTC+2)\n# So 01:30 UTC = 03:30 CEST (not 02:30 because 2am-3am doesn't exist due to DST)\nexpected_hour = 3  # Should be 3am in CEST\nexpected_minute = 30\n\nif berlin_time.hour == expected_hour and berlin_time.minute == expected_minute:\n    print(\"✓ SUCCESS: Conversion is correct!\")"]
[59.346775, "i", "\n    print(f\"  01:30 UTC correctly converts to {berlin_time.hour:02d}:{berlin_time.minute:02d} CEST\")\n    print(f\"  Timezone offset: {berlin_time.strftime('%z')}\")\nelse:\n    print(\"✗ FAILED: Conversion is still wrong!\")\n    print(f\"  Expected: {expected_hour:02d}:{expected_minute:02d}\")\n    print(f\"  Got: {berlin_time.hour:02d}:{berlin_time.minute:02d}\")\n    sys.exit(1)\n\nprint()\nprint(\"Testing another time outside DST transition...\")\nutc_time_str2 = \"2024-03-31T08:00:00\"\nberlin_time2 = convert_to_berlin(utc_time_str2)\nprint(f\"UTC: {utc_time_str2} -> Berlin: {berlin_time2.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint(\"Expected: 10:00 CEST (UTC+2)\")\nif berlin_time2.hour == 10:\n    print(\"✓ Correct!\")\nelse:\n    print(\"✗ Wrong!\")\n\nEOF\n"]
