[99.705624, "i", "grep -A 8 'def convert_to_berlin' app.py\n"]
[99.705788, "o", "grep -A 8 'def convert_to_berlin' app.py\r\n"]
[99.705827, "o", "\u001b[?2004l\r"]
[99.707029, "o", "\u001b[01;31m\u001b[Kdef convert_to_berlin\u001b[m\u001b[K(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n\r\n    # First localize as UTC, then convert to Berlin time\r\n"]
[99.707054, "o", "    utc_dt = UTC_TZ.localize(utc_dt)\r\n"]
[99.707255, "o", "\u001b[?2004huser@b897f1e02288:~/scheduler$ "]
[103.525841, "i", "grep -A 10 'def convert_to_berlin' app.py\n"]
[103.52601, "o", "grep -A 10 'def convert_to_berlin' app.py\r\n\u001b[?2004l\r"]
[103.527148, "o", "\u001b[01;31m\u001b[Kdef convert_to_berlin\u001b[m\u001b[K(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n"]
[103.527207, "o", "\r\n    # First localize as UTC, then convert to Berlin time\r\n    utc_dt = UTC_TZ.localize(utc_dt)\r\n    berlin_dt = utc_dt.astimezone(BERLIN_TZ)\r\n\r\n"]
[103.52734, "o", "\u001b[?2004h"]
