[54.160107, "o", "    # FIX BUG 3: Resolve supplementary group names with colon delimiter\r\n\u001b[?2004l\r"]
[54.160142, "o", "\u001b[?2004h> "]
[54.160202, "o", "    supp_names=\"\"\r\n\u001b[?2004l\r"]
[54.160241, "o", "\u001b[?2004h> "]
[54.160322, "o", "    for sgid in $supp_gids; do\r\n\u001b[?2004l\r"]
[54.160356, "o", "\u001b[?2004h> "]
[54.160559, "o", "        gname=$(awk -F':' -v g=\"$sgid\" '$1 == g {print $2}' \"$GROUPS_DAT\")\r\n\u001b[?2004l\r"]
[54.160598, "o", "\u001b[?2004h> "]
[54.16068, "o", "        if [ -z \"$gname\" ]; then\r\n\u001b[?2004l\r"]
[54.160711, "o", "\u001b[?2004h> "]
[54.160783, "o", "            gname=\"$sgid\"\r\n\u001b[?2004l\r"]
[54.160822, "o", "\u001b[?2004h> "]
[54.160855, "o", "        fi\r\n\u001b[?2004l\r"]
[54.160892, "o", "\u001b[?2004h> "]
[54.160995, "o", "        if [ -z \"$supp_names\" ]; then\r\n\u001b[?2004l\r"]
[54.161026, "o", "\u001b[?2004h> "]
[54.161113, "o", "            supp_names=\"$gname\"\r\n\u001b[?2004l\r"]
[54.161143, "o", "\u001b[?2004h> "]
[54.161178, "o", "        else\r\n"]
[54.161234, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[54.16135, "o", "            supp_names=\"$supp_names;$gname\"\r\n\u001b[?2004l\r"]
[54.161384, "o", "\u001b[?2004h> "]
[54.161419, "o", "        fi\r\n\u001b[?2004l\r"]
[54.161452, "o", "\u001b[?2004h> "]
[54.161485, "o", "    done\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.161517, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.161546, "o", "> "]
[54.161596, "o", "    # Output CSV line\r\n\u001b[?2004l\r"]
[54.161627, "o", "\u001b[?2004h> "]
[54.161811, "o", "    echo \"$username,$uid,$primary_group,$email,$shell,$supp_names\"\r\n\u001b[?2004l\r"]
[54.161843, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[54.161874, "o", "\u001b[?2004h> "]
[54.162028, "o", "done < \"$TMPDIR/users_sorted.tmp\" >> \"$OUTPUT_FILE\"\r\n\u001b[?2004l\r"]
[54.16206, "o", "\u001b[?2004h> "]
[54.1621, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[54.162138, "o", "exit 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.16217, "o", "> EOF\r\n\u001b[?2004l\r"]
