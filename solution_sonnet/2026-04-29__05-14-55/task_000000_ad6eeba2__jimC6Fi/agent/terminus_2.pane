[?2004l[?2004h> import csv
[?2004l[?2004h> import json
[?2004l[?2004h> import re
[?2004l[?2004h> from datetime import datetime
[?2004l[?2004h> from collections import defaultdict
[?2004l[?2004h> 
[?2004l[?2004h> def parse_date(date_str):
[?2004l[?2004h>     """Try to parse date in multiple formats and return ISO 8601 string"""
[?2004l[?2004h>     date_str = date_str.strip()
[?2004l[?2004h>     
[?2004l[?2004h>     # Try different date formats
[?2004l[?2004h>     formats = [
[?2004l[?2004h>         '%Y-%m-%d',      # 2021-03-22
[?2004l[?2004h>         '%m/%d/%Y',      # 02/12/2017
[?2004l[?2004h>         '%d.%m.%Y',      # 17.07.2016
[?2004l[?2004h>     ]
[?2004l[?2004h>     
[?2004l[?2004h>     for fmt in formats:
[?2004l[?2004h>         try:
[?2004l[?2004h>             dt = datetime.strptime(date_str, fmt)
[?2004l[?2004h>             return dt.strftime('%Y-%m-%d')
[?2004l[?2004h>         except ValueError:
[?2004l[?2004h>             continue
[?2004l[?2004h>     
[?2004l[?2004h>     return None
[?2004l[?2004h> 
[?2004l[?2004h> def parse_price_to_cents(price_str):
[?2004l[?2004h>     """Parse price string to cents (integer)"""
[?2004l[?2004h>     try:
[?2004l[?2004h>         # Remove dollar signs, commas, and whitespace
[?2004l[?2004h>         cleaned = re.sub(r'[$,\s]', '', str(price_str))
[?2004l[?2004h>         
[?2004l[?2004h>         # Convert to float then to cents
[?2004l[?2004h>         price_float = float(cleaned)
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if positive
[?2004l[?2004h>         if price_float <= 0:
[?2004l[?2004h>             return None
[?2004l[?2004h>             
[?2004l[?2004h>         # Convert to cents (round to avoid floating point issues)
[?2004l[?2004h>         price_cents = int(round(price_float * 100))
[?2004l[?2004h>         
[?2004l[?2004h>         return price_cents
[?2004l[?2004h>     except (ValueError, TypeError):
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h> def is_serial_number(s):
[?2004l[?2004h>     """Check if string looks like a serial number (starts with SN-)"""
[?2004l[?2004h>     return str(s).strip().startswith('SN-')
[?2004l[?2004h> 
[?2004l[?2004h> def process_row(row):
[?2004l[?2004h>     """Process a single row and return normalized data or error"""
[?2004l[?2004h>     try:
[?2004l[?2004h>         asset_id = row.get('id', '').strip()
[?2004l[?2004h>         name = row.get('name', '').strip()
[?2004l[?2004h>         serial = row.get('serial', '').strip()
[?2004l[?2004h>         purchase_date_raw = row.get('purchase_date', '').strip()
[?2004l[?2004h>         price_raw = row.get('price', '').strip()
[?2004l[?2004h>         location = row.get('location', '').strip()
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if serial and name are swapped
[?2004l[?2004h>         if is_serial_number(name) and not is_serial_number(serial):
[?2004l[?2004h>             name, serial = serial, name
[?2004l[?2004h>         
[?2004l[?2004h>         # Validate required fields
[?2004l[?2004h>         if not asset_id:
[?2004l[?2004h>             return None, "Missing asset ID"
[?2004l[?2004h>         if not name:
[?2004l[?2004h>             return None, "Missing name"
[?2004l[?2004h>         if not serial:
[?2004l[?2004h>             return None, "Missing serial number"
[?2004l[?2004h>         if not location:
[?2004l[?2004h>             return None, "Missing location"
[?2004l[?2004h>         
[?2004l[?2004h>         # Parse date
[?2004l[?2004h>         purchase_date = parse_date(purchase_date_raw)
[?2004l[?2004h>         if not purchase_date:
[?2004l[?2004h>             return None, f"Invalid date format: {purchase_date_raw}"
[?2004l[?2004h>         
[?2004l[?2004h>         # Parse price
[?2004l[?2004h>         price_cents = parse_price_to_cents(price_raw)
[?2004l[?2004h>         if price_cents is None:
[?2004l[?2004h>             return None, f"Invalid price: {price_raw}"
[?2004l[?2004h>         
[?2004l[?2004h>         # Create normalized record
[?2004l[?2004h>         normalized = {
[?2004l[?2004h>             'id': asset_id,
[?2004l[?2004h>             'name': name,
[?2004l[?2004h>             'serial': serial,
[?2004l[?2004h>             'purchase_date': purchase_date,
[?2004l[?2004h>             'price_cents': price_cents,
[?2004l[?2004h>             'location': location
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         return normalized, None
[?2004l[?2004h>         
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         return None, f"Processing error: {str(e)}"
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     valid_records = {}
[?2004l[?2004h>     rejected_records = []
[?2004l[?2004h>     
[?2004l[?2004h>     # Read CSV file
[?2004l[?2004h>     with open('assets.csv', 'r', encoding='utf-8') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         
[?2004l[?2004h>         for row_num, row in enumerate(reader, start=2):  # start=2 because row 1 is header
[?2004l[?2004h>             normalized, error = process_row(row)
[?2004l[?2004h>             
[?2004l[?2004h>             if error:
[?2004l[?2004h>                 # Add to rejected
[?2004l[?2004h>                 rejected_records.append({
[?2004l[?2004h>                     'original_row': dict(row),
[?2004l[?2004h>                     'reason': error,
[?2004l[?2004h>                     'row_number': row_num
[?2004l[?2004h>                 })
[?2004l[?2004h>             else:
[?2004l[?2004h>                 asset_id = normalized['id']
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Handle duplicates - keep the one with latest purchase date
[?2004l[?2004h>                 if asset_id in valid_records:
[?2004l[?2004h>                     existing_date = valid_records[asset_id]['purchase_date']
[?2004l[?2004h>                     new_date = normalized['purchase_date']
[?2004l[?2004h>                     
[?2004l[?2004h>                     if new_date > existing_date:
[?2004l[?2004h>                         valid_records[asset_id] = normalized
[?2004l[?2004h>                 else:
[?2004l[?2004h>                     valid_records[asset_id] = normalized
[?2004l[?2004h>     
[?2004l[?2004h>     # Convert valid records dict to list
[?2004l[?2004h>     assets_list = list(valid_records.values())
[?2004l[?2004h>     
[?2004l[?2004h>     # Write valid records to assets.json
[?2004l[?2004h>     with open('assets.json', 'w', encoding='utf-8') as f:
[?2004l[?2004h>         json.dump(assets_list, f, indent=2)
[?2004l[?2004h>     
[?2004l[?2004h>     # Write rejected records to rejected.json
[?2004l[?2004h>     with open('rejected.json', 'w', encoding='utf-8') as f:
[?2004l[?2004h>         json.dump(rejected_records, f, indent=2)
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Processing complete:")
[?2004l[?2004h>     print(f"  Valid assets: {len(assets_list)}")
[?2004l[?2004h>     print(f"  Rejected rows: {len(rejected_records)}")
[?2004l[?2004h>     print(f"  Output: assets.json, rejected.json")
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     main()
[?2004l[?2004h> EOF
