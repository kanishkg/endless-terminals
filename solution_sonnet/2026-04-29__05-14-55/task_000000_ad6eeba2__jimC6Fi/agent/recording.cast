[41.430052, "o", "\u001b[?2004h"]
[41.430082, "o", "> "]
[41.43016, "o", "        # Validate required fields\r\n\u001b[?2004l\r"]
[41.430189, "o", "\u001b[?2004h> "]
[41.430267, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[41.430292, "o", "\u001b[?2004h"]
[41.430322, "o", "> "]
[41.430414, "o", "            return None, \"Missing asset ID\"\r\n\u001b[?2004l\r"]
[41.430439, "o", "\u001b[?2004h"]
[41.430467, "o", "> "]
[41.430503, "o", "        if not name:\r\n\u001b[?2004l\r"]
[41.430531, "o", "\u001b[?2004h> "]
[41.430645, "o", "            return None, \"Missing name\"\r\n\u001b[?2004l\r"]
[41.430679, "o", "\u001b[?2004h> "]
[41.430741, "o", "        if not serial:\r\n\u001b[?2004l\r"]
[41.430768, "o", "\u001b[?2004h> "]
[41.430907, "o", "            return None, \"Missing serial number\"\r\n\u001b[?2004l\r"]
[41.430936, "o", "\u001b[?2004h> "]
[41.431023, "o", "        if not location:\r\n\u001b[?2004l\r"]
[41.431046, "o", "\u001b[?2004h"]
[41.431073, "o", "> "]
[41.431183, "o", "            return None, \"Missing location\"\r\n\u001b[?2004l\r"]
[41.431211, "o", "\u001b[?2004h> "]
[41.43124, "o", "        \r\n\u001b[?2004l\r"]
[41.43127, "o", "\u001b[?2004h> "]
[41.431332, "o", "        # Parse date\r\n\u001b[?2004l\r"]
[41.431358, "o", "\u001b[?2004h"]
[41.431386, "o", "> "]
[41.431516, "o", "        purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[41.431553, "o", "\u001b[?2004h> "]
[41.431637, "o", "        if not purchase_date:\r\n\u001b[?2004l\r"]
[41.431667, "o", "\u001b[?2004h> "]
[41.43186, "o", "            return None, f\"Invalid date format: {purchase_date_raw}\"\r\n\u001b[?2004l\r"]
[41.431883, "o", "\u001b[?2004h"]
[41.431909, "o", "> "]
[41.431939, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.431968, "o", "> "]
[41.432026, "o", "        # Parse price\r\n\u001b[?2004l\r"]
[41.432061, "o", "\u001b[?2004h> "]
[41.432208, "o", "        price_cents = parse_price_to_cents(price_raw)\r\n\u001b[?2004l\r"]
[41.432242, "o", "\u001b[?2004h> "]
[41.432327, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[41.432352, "o", "\u001b[?2004h"]
[41.432379, "o", "> "]
[41.432511, "o", "            return None, f\"Invalid price: {price_raw}\"\r\n\u001b[?2004l\r"]
[41.432542, "o", "\u001b[?2004h> "]
[41.43257, "o", "        \r\n\u001b[?2004l\r"]
[41.432601, "o", "\u001b[?2004h> "]
[41.4327, "o", "        # Create normalized record\r\n\u001b[?2004l\r"]
[41.43273, "o", "\u001b[?2004h> "]
[41.432799, "o", "        normalized = {\r\n\u001b[?2004l\r"]
[41.432826, "o", "\u001b[?2004h> "]
[41.43291, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[41.432938, "o", "\u001b[?2004h> "]
[41.433028, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[41.433054, "o", "\u001b[?2004h> "]
[41.433141, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[41.433168, "o", "\u001b[?2004h> "]
[41.433294, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[41.433324, "o", "\u001b[?2004h> "]
[41.433438, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[41.433469, "o", "\u001b[?2004h> "]
[41.433563, "o", "            'location': location\r\n\u001b[?2004l\r"]
[41.433594, "o", "\u001b[?2004h> "]
[41.433623, "o", "        }\r\n\u001b[?2004l\r"]
[41.433652, "o", "\u001b[?2004h> "]
[41.43368, "o", "        \r\n\u001b[?2004l\r"]
[41.43371, "o", "\u001b[?2004h> "]
[41.433801, "o", "        return normalized, None\r\n\u001b[?2004l\r"]
[41.433831, "o", "\u001b[?2004h> "]
[41.43386, "o", "        \r\n\u001b[?2004l\r"]
[41.433889, "o", "\u001b[?2004h> "]
[41.433968, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[41.434013, "o", "\u001b[?2004h> "]
[41.434155, "o", "        return None, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[41.434186, "o", "\u001b[?2004h> "]
[41.434216, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.434245, "o", "> "]
[41.434276, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.434304, "o", "> "]
[41.434353, "o", "    valid_records = {}\r\n\u001b[?2004l\r"]
[41.434382, "o", "\u001b[?2004h> "]
[41.434458, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[41.434487, "o", "\u001b[?2004h> "]
[41.434515, "o", "    \r\n\u001b[?2004l\r"]
[41.434543, "o", "\u001b[?2004h> "]
[41.434589, "o", "    # Read CSV file\r\n\u001b[?2004l\r"]
[41.434618, "o", "\u001b[?2004h> "]
[41.434779, "o", "    with open('assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[41.434807, "o", "\u001b[?2004h> "]
[41.434907, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[41.434936, "o", "\u001b[?2004h> "]
[41.434963, "o", "        \r\n\u001b[?2004l\r"]
[41.435005, "o", "\u001b[?2004h> "]
[41.43526, "o", "        for row_num, row in enumerate(reader, start=2):  # start=2 because row 1 is header\r\n\u001b[?2004l\r"]
[41.43529, "o", "\u001b[?2004h> "]
[41.435429, "o", "            normalized, error = process_row(row)\r\n\u001b[?2004l\r"]
[41.435458, "o", "\u001b[?2004h> "]
[41.435497, "o", "            \r\n\u001b[?2004l\r"]
[41.435524, "o", "\u001b[?2004h> "]
[41.435599, "o", "            if error:\r\n\u001b[?2004l\r"]
[41.435629, "o", "\u001b[?2004h> "]
[41.435728, "o", "                # Add to rejected\r\n\u001b[?2004l\r"]
[41.435759, "o", "\u001b[?2004h> "]
[41.435875, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[41.435905, "o", "\u001b[?2004h> "]
[41.436053, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[41.436079, "o", "\u001b[?2004h"]
[41.43611, "o", "> "]
[41.436191, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[41.436221, "o", "\u001b[?2004h> "]
[41.43634, "o", "                    'row_number': row_num\r\n\u001b[?2004l\r"]
[41.436366, "o", "\u001b[?2004h> "]
[41.436424, "o", "                })\r\n\u001b[?2004l\r"]
[41.436452, "o", "\u001b[?2004h> "]
[41.436507, "o", "            else:\r\n\u001b[?2004l\r"]
[41.436536, "o", "\u001b[?2004h> "]
[41.436663, "o", "                asset_id = normalized['id']\r\n\u001b[?2004l\r"]
[41.436691, "o", "\u001b[?2004h> "]
[41.43674, "o", "                \r\n\u001b[?2004l\r"]
[41.436769, "o", "\u001b[?2004h> "]
[41.436997, "o", "                # Handle duplicates - keep the one with latest purchase date\r\n\u001b[?2004l\r"]
[41.437028, "o", "\u001b[?2004h> "]
[41.437159, "o", "                if asset_id in valid_records:\r\n\u001b[?2004l\r"]
[41.437187, "o", "\u001b[?2004h> "]
[41.437404, "o", "                    existing_date = valid_records[asset_id]['purchase_date']\r\n\u001b[?2004l\r"]
[41.43743, "o", "\u001b[?2004h> "]
[41.437598, "o", "                    new_date = normalized['purchase_date']\r\n\u001b[?2004l\r"]
[41.437627, "o", "\u001b[?2004h> "]
[41.437688, "o", "                    \r\n\u001b[?2004l\r"]
[41.437715, "o", "\u001b[?2004h"]
[41.437744, "o", "> "]
[41.437853, "o", "                    if new_date > existing_date:\r\n\u001b[?2004l\r"]
[41.437876, "o", "\u001b[?2004h"]
[41.437912, "o", "> "]
[41.438069, "o", "                        valid_records[asset_id] = normalized\r\n\u001b[?2004l\r"]
[41.438092, "o", "\u001b[?2004h"]
[41.438103, "o", "> "]
[41.438162, "o", "                else:\r\n\u001b[?2004l\r"]
[41.438193, "o", "\u001b[?2004h> "]
[41.438352, "o", "                    valid_records[asset_id] = normalized\r\n\u001b[?2004l\r"]
[41.438388, "o", "\u001b[?2004h> "]
[41.438418, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.438436, "o", "> "]
[41.438546, "o", "    # Convert valid records dict to list\r\n\u001b[?2004l\r"]
[41.438573, "o", "\u001b[?2004h> "]
[41.43871, "o", "    assets_list = list(valid_records.values())\r\n\u001b[?2004l\r"]
[41.43874, "o", "\u001b[?2004h> "]
[41.438771, "o", "    \r\n\u001b[?2004l\r"]
[41.438801, "o", "\u001b[?2004h> "]
[41.438904, "o", "    # Write valid records to assets.json\r\n\u001b[?2004l\r"]
[41.438934, "o", "\u001b[?2004h> "]
[41.439111, "o", "    with open('assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[41.439141, "o", "\u001b[?2004h> "]
[41.439265, "o", "        json.dump(assets_list, f, indent=2)\r\n\u001b[?2004l\r"]
[41.439291, "o", "\u001b[?2004h"]
[41.439319, "o", ">     \r\n\u001b[?2004l\r"]
[41.439348, "o", "\u001b[?2004h> "]
[41.439469, "o", "    # Write rejected records to rejected.json\r\n\u001b[?2004l\r"]
[41.439497, "o", "\u001b[?2004h> "]
[41.439674, "o", "    with open('rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[41.439699, "o", "\u001b[?2004h"]
[41.439728, "o", "> "]
[41.43984, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[41.439869, "o", "\u001b[?2004h"]
[41.439896, "o", ">     \r\n\u001b[?2004l\r"]
[41.439922, "o", "\u001b[?2004h> "]
[41.440035, "o", "    print(f\"Processing complete:\")\r\n\u001b[?2004l\r"]
[41.440064, "o", "\u001b[?2004h> "]
[41.440203, "o", "    print(f\"  Valid assets: {len(assets_list)}\")\r\n\u001b[?2004l\r"]
[41.440231, "o", "\u001b[?2004h"]
[41.440261, "o", "> "]
[41.44039, "o", "    print(f\"  Rejected rows: {len(rejected_records)}\")\r\n\u001b[?2004l\r"]
[41.440419, "o", "\u001b[?2004h> "]
[41.440563, "o", "    print(f\"  Output: assets.json, rejected.json\")\r\n\u001b[?2004l\r"]
[41.440593, "o", "\u001b[?2004h> "]
[41.440624, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.440704, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[41.440732, "o", "\u001b[?2004h> "]
[41.44077, "o", "    main()\r\n\u001b[?2004l\r"]
[41.4408, "o", "\u001b[?2004h> "]
[41.44083, "o", "EOF\r\n\u001b[?2004l\r"]
[41.44516, "o", "\u001b[?2004h"]
[41.445192, "o", "user@7a5957a118c9:~/inventory$ "]
[41.530349, "i", "python3 normalize_assets.py\n"]
