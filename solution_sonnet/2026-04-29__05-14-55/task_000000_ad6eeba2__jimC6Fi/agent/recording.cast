[41.421257, "i", "cat > normalize_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Try to parse date in multiple formats and return ISO 8601 string\"\"\"\n    date_str = date_str.strip()\n    \n    # Try different date formats\n    formats = [\n        '%Y-%m-%d',      # 2021-03-22\n        '%m/%d/%Y',      # 02/12/2017\n        '%d.%m.%Y',      # 17.07.2016\n    ]\n    \n    for fmt in formats:\n        try:\n            dt = datetime.strptime(date_str, fmt)\n            return dt.strftime('%Y-%m-%d')\n        except ValueError:\n            continue\n    \n    return None\n\ndef parse_price_to_cents(price_str):\n    \"\"\"Parse price string to cents (integer)\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = re.sub(r'[$,\\s]', '', str(price_str))\n        \n        # Convert to float then to cents\n        price_float = float(cleaned)\n        \n        # Check if positive\n        if price_float <= 0:\n            return N"]
[41.421405, "i", "one\n            \n        # Convert to cents (round to avoid floating point issues)\n        price_cents = int(round(price_float * 100))\n        \n        return price_cents\n    except (ValueError, TypeError):\n        return None\n\ndef is_serial_number(s):\n    \"\"\"Check if string looks like a serial number (starts with SN-)\"\"\"\n    return str(s).strip().startswith('SN-')\n\ndef process_row(row):\n    \"\"\"Process a single row and return normalized data or error\"\"\"\n    try:\n        asset_id = row.get('id', '').strip()\n        name = row.get('name', '').strip()\n        serial = row.get('serial', '').strip()\n        purchase_date_raw = row.get('purchase_date', '').strip()\n        price_raw = row.get('price', '').strip()\n        location = row.get('location', '').strip()\n        \n        # Check if serial and name are swapped\n        if is_serial_number(name) and not is_serial_number(serial):\n            name, serial = serial, name\n        \n        # Validate required fields\n        if not asset_id:\n            return None,"]
[41.421444, "o", "cat > normalize_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[41.421481, "i", " \"Missing asset ID\"\n        if not name:\n            return None, \"Missing name\"\n        if not serial:\n            return None, \"Missing serial number\"\n        if not location:\n            return None, \"Missing location\"\n        \n        # Parse date\n        purchase_date = parse_date(purchase_date_raw)\n        if not purchase_date:\n            return None, f\"Invalid date format: {purchase_date_raw}\"\n        \n        # Parse price\n        price_cents = parse_price_to_cents(price_raw)\n        if price_cents is None:\n            return None, f\"Invalid price: {price_raw}\"\n        \n        # Create normalized record\n        normalized = {\n            'id': asset_id,\n            'name': name,\n            'serial': serial,\n            'purchase_date': purchase_date,\n            'price_cents': price_cents,\n            'location': location\n        }\n        \n        return normalized, None\n        \n    except Exception as e:\n        return None, f\"Processing error: {str(e)}\"\n\ndef main():\n    valid_records = {}\n    r"]
[41.421505, "o", "\u001b[?2004h> "]
[41.42154, "i", "ejected_records = []\n    \n    # Read CSV file\n    with open('assets.csv', 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        \n        for row_num, row in enumerate(reader, start=2):  # start=2 because row 1 is header\n            normalized, error = process_row(row)\n            \n            if error:\n                # Add to rejected\n                rejected_records.append({\n                    'original_row': dict(row),\n                    'reason': error,\n                    'row_number': row_num\n                })\n            else:\n                asset_id = normalized['id']\n                \n                # Handle duplicates - keep the one with latest purchase date\n                if asset_id in valid_records:\n                    existing_date = valid_records[asset_id]['purchase_date']\n                    new_date = normalized['purchase_date']\n                    \n                    if new_date > existing_date:\n                        valid_records[asset_id] = normalized\n            "]
[41.421551, "o", "import csv\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.421631, "i", "    else:\n                    valid_records[asset_id] = normalized\n    \n    # Convert valid records dict to list\n    assets_list = list(valid_records.values())\n    \n    # Write valid records to assets.json\n    with open('assets.json', 'w', encoding='utf-8') as f:\n        json.dump(assets_list, f, indent=2)\n    \n    # Write rejected records to rejected.json\n    with open('rejected.json', 'w', encoding='utf-8') as f:\n        json.dump(rejected_records, f, indent=2)\n    \n    print(f\"Processing complete:\")\n    print(f\"  Valid assets: {len(assets_list)}\")\n    print(f\"  Rejected rows: {len(rejected_records)}\")\n    print(f\"  Output: assets.json, rejected.json\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
