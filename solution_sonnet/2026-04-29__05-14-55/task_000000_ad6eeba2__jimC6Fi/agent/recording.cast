[106.010244, "i", "python3 << 'EOF'\nimport json\n\n# Load and validate assets.json\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\n\n# Load and validate rejected.json\nwith open('rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(f\"Assets in JSON: {len(assets)}\")\nprint(f\"Rejected rows: {len(rejected)}\")\nprint(f\"Total processed: {len(assets) + len(rejected)}\")\nprint(f\"CSV data rows: 846 (847 - 1 header)\")\nprint()\n\n# Verify structure of first few assets\nprint(\"Sample asset record:\")\nprint(json.dumps(assets[0], indent=2))\nprint()\n\n# Validate all records have correct structure\nrequired_fields = {'id', 'name', 'serial', 'purchase_date', 'price_cents', 'location'}\nerrors = []\n\nfor i, asset in enumerate(assets):\n    if set(asset.keys()) != required_fields:\n        errors.append(f\"Asset {i}: incorrect fields\")\n    if not isinstance(asset['price_cents'], int):\n        errors.append(f\"Asset {i}: price_cents not an integer\")\n    if asset['price_cents'] <= 0:\n        errors.append(f\"Asset {i}: price_cents not positive\""]
[106.010384, "i", ")\n    # Basic ISO 8601 date format check (YYYY-MM-DD)\n    if len(asset['purchase_date']) != 10 or asset['purchase_date'][4] != '-' or asset['purchase_date'][7] != '-':\n        errors.append(f\"Asset {i}: invalid date format\")\n\nif errors:\n    print(\"Validation errors found:\")\n    for error in errors[:10]:  # Show first 10 errors\n        print(f\"  {error}\")\nelse:\n    print(\"✓ All assets validated successfully!\")\n    print(\"✓ All dates are in ISO 8601 format (YYYY-MM-DD)\")\n    print(\"✓ All price_cents are positive integers\")\n    print(\"✓ All required fields present\")\n\nprint()\nprint(\"Sample rejected record:\")\nif rejected:\n    print(json.dumps(rejected[0], indent=2))\nEOF\n"]
