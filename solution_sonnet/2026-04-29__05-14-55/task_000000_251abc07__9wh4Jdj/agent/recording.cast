[26.768796, "i", "awk '\n/\\/api\\/v[0-9]+\\/internal\\// {\n  # Check if this is a 10.x.x.x health check to exclude\n  if ($1 ~ /^10\\./ && ($7 ~ /\\/(health|ready)/)) {\n    next\n  }\n  \n  # Extract and convert timestamp\n  match($0, /\\[([0-9]{2})\\/([A-Za-z]{3})\\/([0-9]{4}):([0-9]{2}):([0-9]{2}):([0-9]{2})/, ts)\n  \n  # Month conversion\n  months[\"Jan\"]=\"01\"; months[\"Feb\"]=\"02\"; months[\"Mar\"]=\"03\"; months[\"Apr\"]=\"04\"\n  months[\"May\"]=\"05\"; months[\"Jun\"]=\"06\"; months[\"Jul\"]=\"07\"; months[\"Aug\"]=\"08\"\n  months[\"Sep\"]=\"09\"; months[\"Oct\"]=\"10\"; months[\"Nov\"]=\"11\"; months[\"Dec\"]=\"12\"\n  \n  iso_timestamp = ts[3] \"-\" months[ts[2]] \"-\" ts[1] \"T\" ts[4]\":\" ts[5]\":\" ts[6]\n  \n  # Replace timestamp in original line\n  sub(/\\[[^\\]]+\\]/, iso_timestamp)\n  print\n}\n' /var/log/app/access.log > /home/user/internal_hits.log\n"]
