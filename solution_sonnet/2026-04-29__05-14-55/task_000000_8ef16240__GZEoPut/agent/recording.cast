[106.878164, "i", "python3 << 'EOF'\n# First run: process 2 batches (2000 records)\nimport json\nimport sqlite3\nimport os\nimport sys\n\nBATCH_SIZE = 1000\n\ndef load_checkpoint():\n    try:\n        with open('.checkpoint', 'r') as f:\n            return json.load(f)\n    except FileNotFoundError:\n        return None\n\ndef save_checkpoint(line_num):\n    with open('.checkpoint', 'w') as f:\n        json.dump({'last_line': line_num}, f)\n        f.flush()\n        os.fsync(f.fileno())\n\ndef process_batch(conn, batch):\n    aggregates = {}\n    for event in batch:\n        cat = event['category']\n        if cat not in aggregates:\n            aggregates[cat] = {'total': 0, 'count': 0}\n        aggregates[cat]['total'] += event['value']\n        aggregates[cat]['count'] += 1\n    for cat, data in aggregates.items():\n        conn.execute('''\n            INSERT INTO summary (category, total_value, count) VALUES (?, ?, ?)\n            ON CONFLICT(category) DO UPDATE SET\n                total_value = total_value + excluded.total_value,\n                count ="]
[106.878318, "i", " count + excluded.count\n        ''', (cat, data['total'], data['count']))\n\nconn = sqlite3.connect('output/summary.db')\nconn.execute('CREATE TABLE IF NOT EXISTS summary (category TEXT PRIMARY KEY, total_value REAL, count INTEGER)')\ncheckpoint = load_checkpoint()\nstart_from = checkpoint['last_line'] if checkpoint else 0\n\nwith open('data/events.json', 'r') as f:\n    batch = []\n    batch_num = 0\n    for i, line in enumerate(f):\n        if i < start_from:\n            continue\n        batch.append(json.loads(line))\n        if len(batch) >= BATCH_SIZE:\n            process_batch(conn, batch)\n            conn.commit()\n            batch_num += 1\n            save_checkpoint(start_from + batch_num * BATCH_SIZE)\n            if batch_num >= 2:\n                print(f\"Run 1: Stopped after {batch_num} batches, checkpoint at {start_from + batch_num * BATCH_SIZE}\")\n                sys.exit(0)\n            batch = []\nconn.close()\nEOF\n"]
