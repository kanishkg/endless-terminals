[129.390249, "i", "python3 << 'EOF'\nimport sqlite3\nconn = sqlite3.connect('output/summary.db')\ncursor = conn.execute('SELECT category, total_value, count FROM summary ORDER BY category')\nprint(\"Final results after multiple resumes:\")\nprint(\"=\"*50)\ntotal_count = 0\nfor row in cursor:\n    print(f\"{row[0]:15} total={row[1]:10.2f}, count={row[2]:5}\")\n    total_count += row[2]\nprint(\"=\"*50)\nprint(f\"Total records: {total_count}\")\nconn.close()\nwith open('.checkpoint', 'r') as f:\n    import json\n    cp = json.load(f)\n    print(f\"Final checkpoint: {cp['last_line']}\")\nEOF\n"]
