[80.251186, "i", "python3 << 'EOF'\nimport sqlite3\nconn = sqlite3.connect('output/summary.db')\ncursor = conn.execute('SELECT category, total_value, count FROM summary ORDER BY category')\nprint(\"BASELINE - Full run results:\")\nbaseline = {}\nfor row in cursor:\n    baseline[row[0]] = (row[1], row[2])\n    print(f\"  {row[0]}: total={row[1]:.2f}, count={row[2]}\")\nconn.close()\n\nimport json\nwith open('/tmp/baseline.json', 'w') as f:\n    json.dump(baseline, f)\nEOF\n"]
