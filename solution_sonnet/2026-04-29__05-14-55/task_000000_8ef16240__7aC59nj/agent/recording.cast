[120.716992, "i", "python3 << 'EOF'\nimport sqlite3\nimport json\n\nwith open('/tmp/baseline.json', 'r') as f:\n    baseline = json.load(f)\n\nconn = sqlite3.connect('output/summary.db')\ncursor = conn.execute('SELECT category, total_value, count FROM summary ORDER BY category')\n\nprint(\"\\nFinal verification after interrupt + resume:\")\nall_match = True\ntotal_count = 0\nfor row in cursor:\n    cat, total, count = row\n    total_count += count\n    base_total, base_count = baseline[cat]\n    if abs(total - base_total) >= 0.01 or count != base_count:\n        all_match = False\n        print(f\"MISMATCH: {cat}\")\n\nprint(f\"Total records processed: {total_count}\")\nif all_match and total_count == 50000:\n    print(\"✓ SUCCESS! Resume functionality works perfectly.\")\n    print(\"✓ All 50,000 records processed exactly once.\")\n    print(\"✓ No data loss or duplication.\")\nelse:\n    print(\"✗ FAILURE!\")\n\nconn.close()\nEOF\n"]
