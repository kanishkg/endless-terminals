[147.381118, "o", "\u001b[?2004l\r\u001b[?2004h"]
[147.381154, "o", "> "]
[147.381314, "o", "conn.execute('INSERT OR REPLACE INTO summary VALUES (?, ?, ?)',\r\n\u001b[?2004l\r"]
[147.381346, "o", "\u001b[?2004h"]
[147.381371, "o", "> "]
[147.381494, "o", "             (cat, data['total'], data['count']))\r\n\u001b[?2004l\r"]
[147.381523, "o", "\u001b[?2004h"]
[147.381547, "o", "> \r\n\u001b[?2004l\r"]
[147.381576, "o", "\u001b[?2004h> "]
[147.381614, "o", "# AFTER:\r\n\u001b[?2004l\r"]
[147.381646, "o", "\u001b[?2004h> "]
[147.381684, "o", "conn.execute('''\r\n\u001b[?2004l\r"]
