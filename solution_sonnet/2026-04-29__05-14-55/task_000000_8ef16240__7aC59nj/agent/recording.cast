[105.421575, "i", "python3 << 'EOF'\nimport sqlite3\nimport json\n\n# Load baseline\nwith open('/tmp/baseline.json', 'r') as f:\n    baseline = json.load(f)\n\n# Get resumed results\nconn = sqlite3.connect('output/summary.db')\ncursor = conn.execute('SELECT category, total_value, count FROM summary ORDER BY category')\n\nprint(\"\\nCOMPARISON - Resumed run vs Baseline:\")\nprint(\"Category        | Resumed Total  | Baseline Total | Match | Resumed Count | Baseline Count | Match\")\nprint(\"-\" * 100)\n\nall_match = True\nfor row in cursor:\n    cat, total, count = row\n    base_total, base_count = baseline[cat]\n    total_match = abs(total - base_total) < 0.01\n    count_match = count == base_count\n    match_str = \"✓\" if (total_match and count_match) else \"✗\"\n    if not (total_match and count_match):\n        all_match = False\n    print(f\"{cat:15} | {total:14.2f} | {base_total:14.2f} | {'✓' if total_match else '✗':5} | {count:13} | {base_count:14} | {'✓' if count_match else '✗'}\")\n\nconn.close()\n\nprint(\"\\n\" + \"=\" * 100)\nif all_match:\n    print(\""]
[105.421737, "i", "SUCCESS! All totals and counts match perfectly. Resume functionality works correctly!\")\nelse:\n    print(\"FAILURE! Some values don't match. There's still a bug.\")\nEOF\n"]
