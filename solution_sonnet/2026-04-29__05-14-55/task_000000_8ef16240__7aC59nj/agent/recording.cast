[31.927208, "i", "cat > process.py << 'EOF'\nimport json\nimport sqlite3\nimport os\n\nBATCH_SIZE = 1000\n\ndef load_checkpoint():\n    try:\n        with open('.checkpoint', 'r') as f:\n            return json.load(f)\n    except FileNotFoundError:\n        return None\n\ndef save_checkpoint(records_processed):\n    with open('.checkpoint', 'w') as f:\n        json.dump({'records_processed': records_processed}, f)\n        f.flush()\n        os.fsync(f.fileno())\n\ndef process_batch(conn, batch):\n    aggregates = {}\n    for event in batch:\n        cat = event['category']\n        if cat not in aggregates:\n            aggregates[cat] = {'total': 0, 'count': 0}\n        aggregates[cat]['total'] += event['value']\n        aggregates[cat]['count'] += 1\n\n    for cat, data in aggregates.items():\n        # Use INSERT with ON CONFLICT to accumulate values on resume\n        conn.execute('''\n            INSERT INTO summary (category, total_value, count) \n            VALUES (?, ?, ?)\n            ON CONFLICT(category) DO UPDATE SET\n                total_value "]
[31.927342, "i", "= total_value + excluded.total_value,\n                count = count + excluded.count\n        ''', (cat, data['total'], data['count']))\n\ndef process():\n    conn = sqlite3.connect('output/summary.db')\n    conn.execute('CREATE TABLE IF NOT EXISTS summary (category TEXT PRIMARY KEY, total_value REAL, count INTEGER)')\n\n    checkpoint = load_checkpoint()\n    start_from = checkpoint['records_processed'] if checkpoint else 0\n\n    with open('data/events.json', 'r') as f:\n        batch = []\n        records_processed = 0\n        for i, line in enumerate(f):\n            if i < start_from:\n                continue\n            batch.append(json.loads(line))\n            records_processed = i + 1\n            if len(batch) >= BATCH_SIZE:\n                process_batch(conn, batch)\n                conn.commit()\n                save_checkpoint(records_processed)\n                batch = []\n        if batch:\n            process_batch(conn, batch)\n            conn.commit()\n            save_checkpoint(records_processed)\n\n    conn.co"]
