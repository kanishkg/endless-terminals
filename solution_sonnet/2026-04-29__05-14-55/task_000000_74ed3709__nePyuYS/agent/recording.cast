[12.089176, "o", "cat scrape.py\r\n\u001b[?2004l\r"]
[12.090062, "o", "#!/usr/bin/env python3\r\nimport asyncio\r\nimport json\r\nimport os\r\nfrom pyppeteer import launch\r\n\r\nasync def scrape_prices():\r\n    browser = await launch(\r\n        headless=False,\r\n        args=['--no-sandbox']\r\n    )\r\n\r\n    page = await browser.newPage()\r\n    await page.goto('http://localhost:8080/products')\r\n\r\n    await page.waitForSelector('.product', timeout=5000)\r\n\r\n    products = await page.evaluate('''() => {\r\n        const items = document.querySelectorAll('.product');\r\n        return Array.from(items).map(item => ({\r\n            name: item.querySelector('.name').textContent,\r\n            price: item.querySelector('.price').textContent\r\n        }));\r\n"]
[12.090113, "o", "    }''')\r\n\r\n    script_dir = os.path.dirname(os.path.abspath(__file__))\r\n    output_path = os.path.join(script_dir, 'prices.json')\r\n\r\n    with open(output_path, 'w') as f:\r\n        json.dump(products, f, indent=2)\r\n\r\n    await browser.close()\r\n    print(f\"Scraped {len(products)} products to {output_path}\")\r\n\r\nif __name__ == \"__main__\":\r\n    asyncio.get_event_loop().run_until_complete(scrape_prices())\r\n"]
[12.090256, "o", "\u001b[?2004h"]
[12.090288, "o", "root@d39faa6aada8:~/scraper# "]
[19.195177, "i", "curl -s http://localhost:8080/products | head -20\n"]
[19.19537, "o", "curl -s http://localhost:8080/products | head -20\r\n\u001b[?2004l\r"]
[19.209985, "o", "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <title>Product Listing</title>\r\n</head>\r\n"]
[19.210078, "o", "<body>\r\n    <h1>Products</h1>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Widget A</span>\r\n        <span class=\"price\">$19.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Widget B</span>\r\n        <span class=\"price\">$24.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Gadget Pro</span>\r\n        <span class=\"price\">$149.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n"]
[19.210663, "o", "\u001b[?2004h"]
[19.210702, "o", "root@d39faa6aada8:~/scraper# "]
[29.512744, "i", "cat > scrape.py << 'EOF'\n#!/usr/bin/env python3\nimport asyncio\nimport json\nimport os\nfrom pyppeteer import launch\n\nasync def scrape_prices():\n    browser = await launch(\n        headless=True,\n        args=[\n            '--no-sandbox',\n            '--disable-setuid-sandbox',\n            '--disable-dev-shm-usage',\n            '--disable-gpu',\n            '--disable-software-rasterizer',\n            '--single-process',\n            '--no-zygote'\n        ]\n    )\n\n    page = await browser.newPage()\n    await page.goto('http://localhost:8080/products')\n\n    await page.waitForSelector('.product', timeout=5000)\n\n    products = await page.evaluate('''() => {\n        const items = document.querySelectorAll('.product');\n        return Array.from(items).map(item => ({\n            name: item.querySelector('.name').textContent,\n            price: item.querySelector('.price').textContent\n        }));\n    }''')\n\n    script_dir = os.path.dirname(os.path.abspath(__file__))\n    output_path = os.path.join(script_dir, 'prices.jso"]
[29.512786, "i", "n')\n\n    with open(output_path, 'w') as f:\n        json.dump(products, f, indent=2)\n\n    await browser.close()\n    print(f\"Scraped {len(products)} products to {output_path}\")\n\nif __name__ == \"__main__\":\n    asyncio.get_event_loop().run_until_complete(scrape_prices())\nEOF\n"]
