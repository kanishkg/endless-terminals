[39.638811, "i", "ss_batch(conn, batch)\n                conn.commit()  # Commit after each batch\n                save_checkpoint(records_processed)\n                print(f\"Processed batch, total records: {records_processed}\")\n                batch = []\n        if batch:\n            process_batch(conn, batch)\n            conn.commit()\n            save_checkpoint(records_processed)\n            print(f\"Processed final batch, total records: {records_processed}\")\n\n    conn.close()\n    print(\"Processing complete!\")\n\nif __name__ == '__main__':\n    process()\nEOF\n"]
