[28.430424, "i", "awk '\n/\\/api\\/v[0-9]+\\/internal\\// && !/^10\\./ {\n  # Extract timestamp from brackets\n  match($0, /\\[([^\\]]+)\\]/, ts)\n  timestamp = ts[1]\n  \n  # Parse: 23/Aug/2024:03:38:50 +0000\n  split(timestamp, parts, /[\\/:]/)\n  day = parts[1]\n  month_str = parts[2]\n  year = parts[3]\n  time = parts[4] \":\" parts[5] \":\" parts[6]\n  \n  # Convert month name to number\n  months[\"Jan\"]=\"01\"; months[\"Feb\"]=\"02\"; months[\"Mar\"]=\"03\"; months[\"Apr\"]=\"04\"\n  months[\"May\"]=\"05\"; months[\"Jun\"]=\"06\"; months[\"Jul\"]=\"07\"; months[\"Aug\"]=\"08\"\n  months[\"Sep\"]=\"09\"; months[\"Oct\"]=\"10\"; months[\"Nov\"]=\"11\"; months[\"Dec\"]=\"12\"\n  month = months[month_str]\n  \n  # Format as ISO 8601\n  iso_timestamp = year \"-\" month \"-\" sprintf(\"%02d\", day) \"T\" time\n  \n  # Replace the timestamp in the original line\n  sub(/\\[[^\\]]+\\]/, iso_timestamp)\n  print\n}\n' /var/log/app/access.log > /home/user/internal_hits.log\n"]
