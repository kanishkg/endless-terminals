[33.244664, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_range(port_str):\n    \"\"\"Parse port string into a set of allowed ports.\"\"\"\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return set(range(int(start), int(end) + 1))\n    else:\n        return {int(port_str)}\n\ndef find_matching_rule(src_ip, dest_port, rules):\n    \"\"\"Find the most specific matching rule for a given IP and port.\"\"\"\n    ip_obj = ipaddress.ip_address(src_ip)\n    matching_rules = []\n    \n    # Find all rules that match the source IP\n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj in network:\n            matching_rules.append(rule)\n    \n    if not matching_rules:\n        return None\n    \n    # Sort by most specific (longest prefix length) first\n    matching_rules.sort(key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen, reverse=True)\n    \n    # Check each rule in order of specificity for port match\n  "]
[33.244797, "i", "  for rule in matching_rules:\n        allowed_ports = parse_port_range(rule['dest_port'])\n        if dest_port in allowed_ports:\n            return rule\n    \n    return None\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        config = json.load(f)\n    \n    rules = config['rules']\n    default_action = config.get('default_action', 'deny')\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = int(conn['dest_port'])\n        \n        # Find matching rule\n        matching_rule = find_matching_rule(src_ip, dest_port, rules)\n        \n        if matching_rule:\n            if matching_rule['action'] == 'deny':\n                print(f\"BLOCKED: {src_ip}:{dest_port} explicitly denied by rule for {matching_rule['source_cidr']}\")\n        else:\n      "]
[33.244839, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r"]
[33.244879, "i", "      # No matching rule found, apply default action\n            if default_action == 'deny':\n                # Find the most specific CIDR that matches the IP (even if port doesn't match)\n                ip_obj = ipaddress.ip_address(src_ip)\n                matching_cidrs = []\n                for rule in rules:\n                    network = ipaddress.ip_network(rule['source_cidr'])\n                    if ip_obj in network:\n                        matching_cidrs.append(rule['source_cidr'])\n                \n                if matching_cidrs:\n                    # Sort by prefix length to get most specific\n                    matching_cidrs.sort(key=lambda c: ipaddress.ip_network(c).prefixlen, reverse=True)\n                    most_specific = matching_cidrs[0]\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {most_specific}\")\n                else:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any defined network\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
