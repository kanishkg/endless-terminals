[?2004l[?2004h>                         matching_cidrs.append(rule['source_cidr'])
[?2004l[?2004h>                 
[?2004l[?2004h>                 if matching_cidrs:
[?2004l[?2004h>                     # Sort by prefix length to get most specific
[?2004l[?2004h>                     matching_cidrs.sort(key=lambda c: ipaddress.ip_network(c).prefixlen, reverse=True)
[?2004l[?2004h>                     most_specific = matching_cidrs[0]
