[?2004l[?2004h> #!/usr/bin/env python3
[?2004l[?2004h> import json
[?2004l[?2004h> import csv
[?2004l[?2004h> import ipaddress
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def parse_port_range(port_str):
[?2004l[?2004h>     """Parse port string into a set of allowed ports."""
[?2004l[?2004h>     if '-' in port_str:
[?2004l[?2004h>         start, end = port_str.split('-')
[?2004l[?2004h>         return set(range(int(start), int(end) + 1))
[?2004l[?2004h>     else:
[?2004l[?2004h>         return {int(port_str)}
[?2004l[?2004h> 
[?2004l[?2004h> def find_matching_rule(src_ip, dest_port, rules):
[?2004l[?2004h>     """Find the most specific matching rule for a given IP and port."""
[?2004l[?2004h>     ip_obj = ipaddress.ip_address(src_ip)
[?2004l[?2004h>     matching_rules = []
[?2004l[?2004h>     
[?2004l[?2004h>     # Find all rules that match the source IP
[?2004l[?2004h>     for rule in rules:
[?2004l[?2004h>         network = ipaddress.ip_network(rule['source_cidr'])
[?2004l[?2004h>         if ip_obj in network:
[?2004l[?2004h>             matching_rules.append(rule)
[?2004l[?2004h>     
[?2004l[?2004h>     if not matching_rules:
[?2004l[?2004h>         return None
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by most specific (longest prefix length) first
[?2004l[?2004h>     matching_rules.sort(key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen, reverse=True)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check each rule in order of specificity for port match
[?2004l[?2004h>     for rule in matching_rules:
[?2004l[?2004h>         allowed_ports = parse_port_range(rule['dest_port'])
[?2004l[?2004h>         if dest_port in allowed_ports:
[?2004l[?2004h>             return rule
[?2004l[?2004h>     
[?2004l[?2004h>     return None
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     # Load firewall rules
[?2004l[?2004h>     with open('/home/user/audit/firewall_rules.json', 'r') as f:
[?2004l[?2004h>         config = json.load(f)
[?2004l[?2004h>     
[?2004l[?2004h>     rules = config['rules']
[?2004l[?2004h>     default_action = config.get('default_action', 'deny')
[?2004l[?2004h>     
[?2004l[?2004h>     # Load connections
[?2004l[?2004h>     with open('/home/user/audit/connections.csv', 'r') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         connections = list(reader)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check each connection
[?2004l[?2004h>     for conn in connections:
[?2004l[?2004h>         src_ip = conn['src_ip']
[?2004l[?2004h>         dest_port = int(conn['dest_port'])
[?2004l[?2004h>         
[?2004l[?2004h>         # Find matching rule
[?2004l[?2004h>         matching_rule = find_matching_rule(src_ip, dest_port, rules)
[?2004l[?2004h>         
[?2004l[?2004h>         if matching_rule:
[?2004l[?2004h>             if matching_rule['action'] == 'deny':
[?2004l[?2004h>                 print(f"BLOCKED: {src_ip}:{dest_port} explicitly denied by rule for {matching_rule['source_cidr']}")
[?2004l[?2004h>         else:
[?2004l[?2004h>             # No matching rule found, apply default action
[?2004l[?2004h>             if default_action == 'deny':
[?2004l[?2004h>                 # Find the most specific CIDR that matches the IP (even if port doesn't match)
[?2004l[?2004h>                 ip_obj = ipaddress.ip_address(src_ip)
[?2004l[?2004h>                 matching_cidrs = []
[?2004l[?2004h>                 for rule in rules:
[?2004l[?2004h>                     network = ipaddress.ip_network(rule['source_cidr'])
