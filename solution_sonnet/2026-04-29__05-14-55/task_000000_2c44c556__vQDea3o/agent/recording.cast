[8.980137, "o", "#!/bin/bash\r\n# Flush existing rules\r\niptables -F\r\niptables -t nat -F\r\n\r\n# Default policies\r\niptables -P INPUT DROP\r\niptables -P FORWARD DROP\r\niptables -P OUTPUT ACCEPT\r\n\r\n# Allow established connections\r\niptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT\r\niptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT\r\n\r\n# Allow SSH to gateway\r\niptables -A INPUT -p tcp --dport 22 -j ACCEPT\r\n\r\n# Allow inference subnet to registry (THE USER'S RULE - WRONG CHAIN)\r\n"]
[8.980214, "o", "iptables -A INPUT -s 10.200.0.0/16 -p tcp --dport 5000 -j ACCEPT\r\n\r\n# NAT for outbound\r\niptables -t nat -A POSTROUTING -s 10.200.0.0/16 -o eth2 -j MASQUERADE\r\n\r\n# Block known bad actors\r\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.0/16 -j LOG --log-prefix \"FORWARD_DROP: \"\r\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.0/16 -j DROP\r\n\r\n# General forwarding (added later, supposedly to fix things)\r\niptables -A FORWARD -i eth1 -o eth2 -j ACCEPT\r\n"]
[8.980373, "o", "\u001b[?2004hroot@d29ceaee5705:/home/user/firewall# "]
[21.663331, "i", "cp rules.sh rules.sh.backup\n"]
[21.663461, "o", "cp rules.sh rules.sh.backup\r\n\u001b[?2004l\r"]
[21.681307, "o", "\u001b[?2004hroot@d29ceaee5705:/home/user/firewall# "]
[21.756484, "i", "cat > rules.sh << 'EOF'\n#!/bin/bash\n# Flush existing rules\niptables -F\niptables -t nat -F\n\n# Default policies\niptables -P INPUT DROP\niptables -P FORWARD DROP\niptables -P OUTPUT ACCEPT\n\n# Allow established connections\niptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT\niptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT\n\n# Allow SSH to gateway\niptables -A INPUT -p tcp --dport 22 -j ACCEPT\n\n# Allow inference subnet to registry - FIXED: moved to FORWARD chain and placed before DROP rules\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.42 -p tcp --dport 5000 -j ACCEPT\n\n# NAT for outbound\niptables -t nat -A POSTROUTING -s 10.200.0.0/16 -o eth2 -j MASQUERADE\n\n# Block known bad actors\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.0/16 -j LOG --log-prefix \"FORWARD_DROP: \"\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.0/16 -j DROP\n\n# General forwarding (added later, supposedly to fix things)\niptables -A FORWARD -i eth1 -o eth2 -j ACCEPT\nEOF\n"]
[21.756608, "o", "cat > rules.sh << 'EOF'\r\n"]
