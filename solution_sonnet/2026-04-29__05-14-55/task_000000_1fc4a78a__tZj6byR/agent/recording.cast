[54.316874, "i", "uct_object(value_node, deep=deep)\n            mapping[key] = value\n        return mapping\n\nfor path in sys.argv[1:]:\n    try:\n        with open(path) as f:\n            yaml.load(f, Loader=DuplicateKeysLoader)\n        print(f\"OK: {path}\")\n    except yaml.YAMLError as e:\n        print(f\"ERROR: {path}: {e}\")\n    except Exception as e:\n        print(f\"ERROR: {path}: {e}\")\nEOF\n"]
