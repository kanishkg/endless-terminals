[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     ' "$file" 2>/dev/null)
[?2004l[?2004h>     
[?2004l[?2004h>     # If result is not empty, add to temp file
