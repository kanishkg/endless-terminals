MemAvai[?2004huser@0b52afb56a16:~$ cat > /tmp/analyze_memory.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Output file
[?2004l[?2004h> OUTPUT="/home/user/low_memory_report.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for collecting results
[?2004l[?2004h> TEMP_FILE=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Loop through all host files
[?2004l[?2004h> for file in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     # Extract hostname from filename
[?2004l[?2004h>     hostname=$(basename "$file" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handle errors gracefully
[?2004l[?2004h>     memtotal=$(grep -E '^MemTotal:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     memavail=$(grep -E '^MemAvailable:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if both values were found and are valid numbers
[?2004l[?2004h>     if [[ -n "$memtotal" && -n "$memavail" && "$memtotal" -gt 0 ]]; then
[?2004l[?2004h>         # Calculate percentage available (using bc for floating point)
[?2004l[?2004h>         percentage=$(echo "scale=2; ($memavail * 100) / $memtotal" | bc)
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if less than 20%
[?2004l[?2004h>         is_low=$(echo "$percentage < 20" | bc)
[?2004l[?2004h>         if [[ "$is_low" -eq 1 ]]; then
[?2004l[?2004h>             # Store hostname, percentage, and raw percentage for sorting
[?2004l[?2004h>             echo -e "${percentage}\t${hostname}\t${percentage}" >> "$TEMP_FILE"
[?2004l[?2004h>         fi
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending = worst first) and output hostname + percentage
[?2004l[?2004h> if [[ -s "$TEMP_FILE" ]]; then
[?2004l[?2004h>     sort -n "$TEMP_FILE" | awk -F'\t' '{printf "%s\t%s\n", $2, $3}' > "$OUTPUT"
[?2004l[?2004h> else
[?2004l[?2004h>     # Create empty file if no hosts meet criteria
[?2004l[?2004h>     touch "$OUTPUT"
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Cleanup
[?2004l[?2004h> rm -f "$TEMP_FILE"
[?2004l[?2004h> EOF
