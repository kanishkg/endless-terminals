[21.906247, "i", "cat > /tmp/analyze_memory.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Temporary file for collecting results\nTEMP_FILE=$(mktemp)\n\n# Loop through all host files\nfor file in /home/user/memstats/host*.txt; do\n    # Extract hostname from filename\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handle errors gracefully\n    memtotal=$(grep -E '^MemTotal:' \"$file\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$file\" 2>/dev/null | awk '{print $2}')\n    \n    # Check if both values were found and are valid numbers\n    if [[ -n \"$memtotal\" && -n \"$memavail\" && \"$memtotal\" -gt 0 ]]; then\n        # Calculate percentage available (using bc for floating point)\n        percentage=$(echo \"scale=2; ($memavail * 100) / $memtotal\" | bc)\n        \n        # Check if less than 20%\n        is_low=$(echo \"$percentage < 20\" | bc)\n        if [[ \"$is_low\" -eq 1 ]]; then\n            # Store hostname, percentage, and raw percentage for so"]
[21.906389, "i", "rting\n            echo -e \"${percentage}\\t${hostname}\\t${percentage}\" >> \"$TEMP_FILE\"\n        fi\n    fi\ndone\n\n# Sort by percentage (ascending = worst first) and output hostname + percentage\nif [[ -s \"$TEMP_FILE\" ]]; then\n    sort -n \"$TEMP_FILE\" | awk -F'\\t' '{printf \"%s\\t%s\\n\", $2, $3}' > \"$OUTPUT\"\nelse\n    # Create empty file if no hosts meet criteria\n    touch \"$OUTPUT\"\nfi\n\n# Cleanup\nrm -f \"$TEMP_FILE\"\nEOF\n"]
