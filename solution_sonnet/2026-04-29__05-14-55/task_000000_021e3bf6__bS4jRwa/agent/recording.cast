[39.185295, "o", "\u001b[?2004h> "]
[39.18535, "o", "    fi\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.185388, "o", "> done\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.185424, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[39.185461, "o", "> "]
[39.185658, "o", "# Sort by percentage (ascending = worst first) and output hostname + percentage\r\n\u001b[?2004l\r"]
[39.185697, "o", "\u001b[?2004h> "]
[39.185779, "o", "if [[ -s \"$TEMP_FILE\" ]]; then\r\n\u001b[?2004l\r"]
[39.185823, "o", "\u001b[?2004h> "]
[39.186035, "o", "    sort -n \"$TEMP_FILE\" | awk -F'\\t' '{printf \"%s\\t%s\\n\", $2, $3}' > \"$OUTPUT\"\r\n\u001b[?2004l\r"]
[39.186073, "o", "\u001b[?2004h> "]
[39.186107, "o", "else\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.186142, "o", "> "]
[39.186174, "o", "    touch \"$OUTPUT\"\r\n\u001b[?2004l\r"]
[39.186212, "o", "\u001b[?2004h> fi\r\n"]
[39.186251, "o", "\u001b[?2004l\r"]
[39.186288, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.186348, "o", "rm -f \"$TEMP_FILE\"\r\n\u001b[?2004l\r"]
[39.186387, "o", "\u001b[?2004h> EOF\r\n"]
[39.186423, "o", "\u001b[?2004l\r"]
[39.187505, "o", "\u001b[?2004h"]
