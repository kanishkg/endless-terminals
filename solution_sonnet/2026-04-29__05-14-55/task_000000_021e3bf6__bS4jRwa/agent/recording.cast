[39.182094, "i", "cat > /tmp/analyze_memory.sh << 'EOF'\n#!/bin/bash\n\nOUTPUT=\"/home/user/low_memory_report.txt\"\nTEMP_FILE=$(mktemp)\n\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Use awk to extract and calculate in one go\n    result=$(awk '\n        /^MemTotal:/ { memtotal = $2 }\n        /^MemAvailable:/ { memavail = $2 }\n        END {\n            if (memtotal > 0 && memavail != \"\") {\n                percentage = (memavail * 100.0) / memtotal\n                if (percentage < 20) {\n                    printf \"%.2f\\t%s\\t%.2f\\n\", percentage, \"'$hostname'\", percentage\n                }\n            }\n        }\n    ' \"$file\" 2>/dev/null)\n    \n    # If result is not empty, add to temp file\n    if [[ -n \"$result\" ]]; then\n        echo \"$result\" >> \"$TEMP_FILE\"\n    fi\ndone\n\n# Sort by percentage (ascending = worst first) and output hostname + percentage\nif [[ -s \"$TEMP_FILE\" ]]; then\n    sort -n \"$TEMP_FILE\" | awk -F'\\t' '{printf \"%s\\t%s\\n\", $2, $3}' > \"$OUTPUT\"\nelse\n    touch \"$OUTPUT\"\nfi\n"]
[39.182146, "i", "\nrm -f \"$TEMP_FILE\"\nEOF\n"]
