[?2004huser@d625e057607c:~$ cat > /home/user/backup.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Backup script that copies accessible files from /home/user/projects to /home/user/backups
[?2004l[?2004h> # and creates a manifest with ownership information
[?2004l[?2004h> 
[?2004l[?2004h> SOURCE_DIR="/home/user/projects"
[?2004l[?2004h> BACKUP_DIR="/home/user/backups"
[?2004l[?2004h> MANIFEST="${BACKUP_DIR}/manifest.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Create backup directory if it doesn't exist
[?2004l[?2004h> mkdir -p "${BACKUP_DIR}" 2>/dev/null
[?2004l[?2004h> 
[?2004l[?2004h> # Initialize manifest file
[?2004l[?2004h> > "${MANIFEST}"
[?2004l[?2004h> 
[?2004l[?2004h> # Find all readable files in the source directory
[?2004l[?2004h> # Suppress all error messages about permission denied
[?2004l[?2004h> find "${SOURCE_DIR}" -type f -readable 2>/dev/null | while IFS= read -r file; do
[?2004l[?2004h>     # Get the relative path from source directory
[?2004l[?2004h>     rel_path="${file#${SOURCE_DIR}/}"
[?2004l[?2004h>     
[?2004l[?2004h>     # Destination file path
[?2004l[?2004h>     dest_file="${BACKUP_DIR}/${rel_path}"
[?2004l[?2004h>     
[?2004l[?2004h>     # Get owner:group information using stat
[?2004l[?2004h>     owner_info=$(stat -c "%U:%G" "${file}" 2>/dev/null)
[?2004l[?2004h>     
[?2004l[?2004h>     # Only proceed if we could read the file info
[?2004l[?2004h>     if [ $? -eq 0 ]; then
[?2004l[?2004h>         # Create destination directory structure
[?2004l[?2004h>         dest_dir=$(dirname "${dest_file}")
[?2004l[?2004h>         mkdir -p "${dest_dir}" 2>/dev/null
[?2004l[?2004h>         
[?2004l[?2004h>         # Copy the file (suppress errors)
[?2004l[?2004h>         if cp "${file}" "${dest_file}" 2>/dev/null; then
[?2004l[?2004h>             # Add entry to manifest
[?2004l[?2004h>             echo "${rel_path} ${owner_info}" >> "${MANIFEST}"
[?2004l[?2004h>         fi
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> echo "Backup completed. Manifest written to ${MANIFEST}"
[?2004l[?2004h> EOF
