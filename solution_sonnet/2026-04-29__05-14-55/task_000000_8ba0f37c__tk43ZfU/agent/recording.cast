[10.09349, "o", "total 12\r\n"]
[10.093515, "o", "drwxrwxrwx 1 user user 4096 Apr 29 09:03 .\r\ndrwxrwxrwx 1 user user 4096 Apr 29 09:04 ..\r\n-rw-r--r-- 1 user user  468 Apr 29 09:03 target_iptables.txt\r\n"]
