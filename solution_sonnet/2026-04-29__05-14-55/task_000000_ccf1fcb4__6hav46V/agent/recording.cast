[68.910712, "o", "import configparser\r\nimport os\r\n\r\n# Read configuration from settings.ini\r\ncfg = configparser.ConfigParser()\r\nconfig_path = os.path.join(os.path.dirname(__file__), 'settings.ini')\r\ncfg.read(config_path)\r\n\r\n# Get settings with fallbacks\r\nhost = cfg.get('server', 'host', fallback='127.0.0.1')\r\nport = cfg.get('server', 'port', fallback='8000')\r\nworkers_count = cfg.get('server', 'workers', fallback='2')\r\n\r\n# Gunicorn configuration\r\nbind = f\"{host}:{port}\"\r\nworkers = int(workers_count)\r\ndaemon = False\r\n"]
