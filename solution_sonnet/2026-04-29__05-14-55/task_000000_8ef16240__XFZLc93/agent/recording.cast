[89.222124, "i", "cat > test_interrupt.py << 'EOF'\nimport subprocess\nimport time\nimport signal\nimport os\n\n# Start the process\nproc = subprocess.Popen(['python3', 'process.py'])\nprint(f\"Started process PID: {proc.pid}\")\n\n# Let it run for 0.5 seconds\ntime.sleep(0.5)\n\n# Kill it\nprint(\"Interrupting process...\")\nproc.send_signal(signal.SIGTERM)\nproc.wait()\nprint(\"Process interrupted\")\n\n# Check checkpoint\nif os.path.exists('.checkpoint'):\n    with open('.checkpoint', 'r') as f:\n        print(f\"Checkpoint after interrupt: {f.read()}\")\n\n# Check database state\nimport sqlite3\nif os.path.exists('output/summary.db'):\n    conn = sqlite3.connect('output/summary.db')\n    result = conn.execute('SELECT SUM(count) FROM summary').fetchone()\n    print(f\"Events in DB after interrupt: {result[0]}\")\n    conn.close()\n\n# Resume\nprint(\"\\nResuming process...\")\nproc2 = subprocess.Popen(['python3', 'process.py'])\nproc2.wait()\nprint(\"Process completed\")\n\n# Check final state\nconn = sqlite3.connect('output/summary.db')\nresult = conn.execute('SELECT SUM(count"]
[89.222248, "i", ") FROM summary').fetchone()\nprint(f\"\\nFinal events in DB: {result[0]}\")\nprint(f\"Expected: 50000\")\nif result[0] == 50000:\n    print(\"✓ SUCCESS: Checkpoint resume working correctly!\")\nelse:\n    print(f\"✗ FAILED: Expected 50000, got {result[0]}\")\nconn.close()\nEOF\n"]
