[161.610389, "i", "python3 << 'EOF'\nimport subprocess\nimport time\nimport signal\nimport sqlite3\nimport json\nimport os\n\nprint(\"Testing checkpoint resume with fixed process.py...\\n\")\n\n# Run 1: Process partially\nprint(\"[1] Starting first run...\")\nproc = subprocess.Popen(['python3', 'process.py'])\ntime.sleep(0.3)\nproc.send_signal(signal.SIGTERM)\nproc.wait()\n\nwith open('.checkpoint', 'r') as f:\n    ckpt1 = json.load(f)['last_line']\nconn = sqlite3.connect('output/summary.db')\ncount1 = conn.execute('SELECT SUM(count) FROM summary').fetchone()[0]\nconn.close()\nprint(f\"    Interrupted at line {ckpt1}, processed {count1} events\")\n\n# Run 2: Resume and complete\nprint(\"\\n[2] Resuming from checkpoint...\")\nproc = subprocess.Popen(['python3', 'process.py'])\nproc.wait()\n\nwith open('.checkpoint', 'r') as f:\n    ckpt2 = json.load(f)['last_line']\nconn = sqlite3.connect('output/summary.db')\ncount2 = conn.execute('SELECT SUM(count) FROM summary').fetchone()[0]\nconn.close()\nprint(f\"    Completed at line {ckpt2}, total {count2} events\")\n\n# Verify\nprint("]
[161.610498, "i", "\"\\n[3] Verification:\")\nif count2 == 50000:\n    print(f\"    ✓ SUCCESS: All 50,000 events processed correctly\")\n    print(f\"    ✓ First run: {count1} events\")\n    print(f\"    ✓ Second run: {count2 - count1} events (no duplication)\")\n    print(f\"    ✓ Total: {count2} events\")\nelse:\n    print(f\"    ✗ FAILED: Expected 50000, got {count2}\")\nEOF\n"]
