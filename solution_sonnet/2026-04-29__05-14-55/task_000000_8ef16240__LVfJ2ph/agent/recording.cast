[179.332771, "i", "cat > test_checkpoint_resume.sh << 'EOF'\n#!/bin/bash\nset -e\n\necho \"=== Checkpoint Resume Test ===\"\necho \"\"\n\necho \"Step 1: Clean up previous run\"\nrm -f .checkpoint output/summary.db\n\necho \"Step 2: Start processing and kill after 0.15 seconds\"\ntimeout 0.15 python3 process.py || true\n\necho \"\"\necho \"Step 3: Check partial progress\"\necho -n \"Checkpoint: \"\ncat .checkpoint\necho \"\"\npython3 << 'PYEOF'\nimport sqlite3\nconn = sqlite3.connect('output/summary.db')\nresult = conn.execute('SELECT SUM(count) FROM summary').fetchone()\nprint(f\"Records processed so far: {result[0]}\")\nconn.close()\nPYEOF\n\necho \"\"\necho \"Step 4: Resume processing to completion\"\npython3 process.py\n\necho \"\"\necho \"Step 5: Verify final results\"\npython3 << 'PYEOF'\nimport sqlite3\nconn = sqlite3.connect('output/summary.db')\nresult = conn.execute('SELECT COUNT(*), SUM(count) FROM summary').fetchone()\nprint(f\"Final: {result[0]} categories, {result[1]} total records\")\nif result[1] == 50000:\n    print(\"✓ SUCCESS: All 50,000 records processed exactly once!\")\nel"]
[179.332881, "i", "se:\n    print(f\"✗ FAILED: Expected 50000, got {result[1]}\")\nconn.close()\nPYEOF\nEOF\n"]
