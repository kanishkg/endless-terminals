[?2004l[?2004h> #!/usr/bin/env python3
[?2004l[?2004h> import json
[?2004l[?2004h> import csv
[?2004l[?2004h> import ipaddress
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def parse_port_spec(port_spec):
[?2004l[?2004h>     """Parse port specification into a set of allowed ports."""
[?2004l[?2004h>     port_str = str(port_spec)
[?2004l[?2004h>     if '-' in port_str:
[?2004l[?2004h>         start, end = port_str.split('-')
[?2004l[?2004h>         return set(range(int(start), int(end) + 1))
[?2004l[?2004h>     else:
[?2004l[?2004h>         return {int(port_str)}
[?2004l[?2004h> 
[?2004l[?2004h> def load_firewall_rules(json_path):
[?2004l[?2004h>     """Load and parse firewall rules from JSON."""
[?2004l[?2004h>     with open(json_path, 'r') as f:
[?2004l[?2004h>         data = json.load(f)
[?2004l[?2004h>     
[?2004l[?2004h>     rules = []
[?2004l[?2004h>     for rule in data['rules']:
[?2004l[?2004h>         network = ipaddress.ip_network(rule['source_cidr'])
[?2004l[?2004h>         allowed_ports = parse_port_spec(rule['dest_port'])
[?2004l[?2004h>         rules.append({
[?2004l[?2004h>             'id': rule['id'],
[?2004l[?2004h>             'action': rule['action'],
[?2004l[?2004h>             'network': network,
[?2004l[?2004h>             'allowed_ports': allowed_ports,
[?2004l[?2004h>             'source_cidr': rule['source_cidr']
[?2004l[?2004h>         })
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by prefix length (most specific first)
[?2004l[?2004h>     rules.sort(key=lambda r: r['network'].prefixlen, reverse=True)
[?2004l[?2004h>     
[?2004l[?2004h>     return rules, data.get('default_action', 'deny')
[?2004l[?2004h> 
[?2004l[?2004h> def check_connection(src_ip, dest_port, rules, default_action):
[?2004l[?2004h>     """Check if a connection is allowed by firewall rules.
[?2004l[?2004h>     Returns (allowed, matching_rule_cidr) tuple."""
[?2004l[?2004h>     src_addr = ipaddress.ip_address(src_ip)
[?2004l[?2004h>     dest_port_int = int(dest_port)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check rules in order (most specific CIDR first)
[?2004l[?2004h>     for rule in rules:
[?2004l[?2004h>         if src_addr in rule['network']:
[?2004l[?2004h>             if dest_port_int in rule['allowed_ports']:
[?2004l[?2004h>                 if rule['action'] == 'allow':
[?2004l[?2004h>                     return (True, rule['source_cidr'])
[?2004l[?2004h>                 else:  # deny
[?2004l[?2004h>                     return (False, rule['source_cidr'])
[?2004l[?2004h>             # If port doesn't match, continue to less specific rules
[?2004l[?2004h>     
[?2004l[?2004h>     # No matching rule found, use default action
[?2004l[?2004h>     return (default_action == 'allow', None)
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     rules, default_action = load_firewall_rules('firewall_rules.json')
[?2004l[?2004h>     
[?2004l[?2004h>     with open('connections.csv', 'r') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         for row in reader:
[?2004l[?2004h>             src_ip = row['src_ip']
[?2004l[?2004h>             dest_port = row['dest_port']
[?2004l[?2004h>             
[?2004l[?2004h>             allowed, matching_cidr = check_connection(src_ip, dest_port, rules, default_action)
[?2004l[?2004h>             
[?2004l[?2004h>             if not allowed:
[?2004l[?2004h>                 if matching_cidr:
[?2004l[?2004h>                     print(f"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_cidr}")
[?2004l[?2004h>                 else:
[?2004l[?2004h>                     print(f"BLOCKED: {src_ip}:{dest_port} not allowed from any rule (default deny)")
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     main()
