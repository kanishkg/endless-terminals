[77.956671, "i", "cat > test_detailed.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\n\ndef parse_port_spec(port_spec):\n    port_str = str(port_spec)\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return set(range(int(start), int(end) + 1))\n    else:\n        return {int(port_str)}\n\ndef load_firewall_rules(json_path):\n    with open(json_path, 'r') as f:\n        data = json.load(f)\n    rules = []\n    for rule in data['rules']:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        allowed_ports = parse_port_spec(rule['dest_port'])\n        rules.append({\n            'id': rule['id'],\n            'action': rule['action'],\n            'network': network,\n            'allowed_ports': allowed_ports,\n            'source_cidr': rule['source_cidr']\n        })\n    rules.sort(key=lambda r: r['network'].prefixlen, reverse=True)\n    return rules, data.get('default_action', 'deny')\n\ndef check_connection(src_ip, dest_port, rules, default_action):\n    src_addr = ipaddress.ip_addr"]
[77.956798, "i", "ess(src_ip)\n    dest_port_int = int(dest_port)\n    for rule in rules:\n        if src_addr in rule['network']:\n            if dest_port_int in rule['allowed_ports']:\n                if rule['action'] == 'allow':\n                    return (True, rule['source_cidr'])\n                else:\n                    return (False, rule['source_cidr'])\n    return (default_action == 'allow', None)\n\nrules, default_action = load_firewall_rules('firewall_rules.json')\nwith open('connections.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    for row in reader:\n        src_ip = row['src_ip']\n        dest_port = row['dest_port']\n        allowed, matching_cidr = check_connection(src_ip, dest_port, rules, default_action)\n        status = \"ALLOWED\" if allowed else \"BLOCKED\"\n        cidr_info = f\" (matched {matching_cidr})\" if matching_cidr else \" (default deny)\"\n        print(f\"{status}: {src_ip}:{dest_port}{cidr_info}\")\nEOF\n"]
