[31.399687, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse port specification into a set of allowed ports.\"\"\"\n    port_str = str(port_spec)\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return set(range(int(start), int(end) + 1))\n    else:\n        return {int(port_str)}\n\ndef load_firewall_rules(json_path):\n    \"\"\"Load and parse firewall rules from JSON.\"\"\"\n    with open(json_path, 'r') as f:\n        data = json.load(f)\n    \n    rules = []\n    for rule in data['rules']:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        allowed_ports = parse_port_spec(rule['dest_port'])\n        rules.append({\n            'id': rule['id'],\n            'action': rule['action'],\n            'network': network,\n            'allowed_ports': allowed_ports,\n            'source_cidr': rule['source_cidr']\n        })\n    \n    # Sort by prefix length (most specific first)\n    rules.sort(key=lambda r: r['network"]
[31.399727, "i", "'].prefixlen, reverse=True)\n    \n    return rules, data.get('default_action', 'deny')\n\ndef check_connection(src_ip, dest_port, rules, default_action):\n    \"\"\"Check if a connection is allowed by firewall rules.\n    Returns (allowed, matching_rule_cidr) tuple.\"\"\"\n    src_addr = ipaddress.ip_address(src_ip)\n    dest_port_int = int(dest_port)\n    \n    # Check rules in order (most specific CIDR first)\n    for rule in rules:\n        if src_addr in rule['network']:\n            if dest_port_int in rule['allowed_ports']:\n                if rule['action'] == 'allow':\n                    return (True, rule['source_cidr'])\n                else:  # deny\n                    return (False, rule['source_cidr'])\n            # If port doesn't match, continue to less specific rules\n    \n    # No matching rule found, use default action\n    return (default_action == 'allow', None)\n\ndef main():\n    rules, default_action = load_firewall_rules('firewall_rules.json')\n    \n    with open('connections.csv', 'r') as f:\n        reader = c"]
[31.399883, "i", "sv.DictReader(f)\n        for row in reader:\n            src_ip = row['src_ip']\n            dest_port = row['dest_port']\n            \n            allowed, matching_cidr = check_connection(src_ip, dest_port, rules, default_action)\n            \n            if not allowed:\n                if matching_cidr:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_cidr}\")\n                else:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule (default deny)\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
