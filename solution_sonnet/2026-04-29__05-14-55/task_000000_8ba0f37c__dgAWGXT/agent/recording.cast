[28.344162, "o", "\u001b[?2004h> "]
[28.344374, "o", "2. HTTP/HTTPS (ports 80/443): Require packet payloads to contain \"Mozilla\" string\r\n\u001b[?2004l\r"]
[28.344402, "o", "\u001b[?2004h> "]
[28.344616, "o", "   - Tools like curl use \"curl/X.X\" as the default User-Agent, not \"Mozilla\"\r\n\u001b[?2004l\r"]
[28.34464, "o", "\u001b[?2004h"]
[28.344666, "o", "> "]
