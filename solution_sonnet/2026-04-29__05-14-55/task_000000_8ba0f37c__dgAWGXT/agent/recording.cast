[28.345389, "o", "\u001b[?2004h> "]
[28.345474, "o", "PROBLEMS WITH CURRENT APPROACH:\r\n\u001b[?2004l\r"]
[28.345503, "o", "\u001b[?2004h> "]
[28.345744, "o", "1. Blocks legitimate HTTP clients (curl, wget, APIs, monitoring tools, mobile apps)\r\n\u001b[?2004l\r"]
