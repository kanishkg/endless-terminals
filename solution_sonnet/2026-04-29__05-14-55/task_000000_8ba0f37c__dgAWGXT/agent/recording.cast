[28.343904, "o", "1. SSH (port 22): Has an unconditional ACCEPT rule with no content inspection\r\n\u001b[?2004l\r"]
[28.343937, "o", "\u001b[?2004h> "]
[28.344079, "o", "   Rule: -A INPUT -p tcp --dport 22 -j ACCEPT\r\n\u001b[?2004l\r"]
