[?2004l[?2004h>                 key_order+=("$key")
[?2004l[?2004h>             fi
[?2004l[?2004h>             
[?2004l[?2004h>             env_vars["$key"]="$value"
[?2004l[?2004h>         fi
[?2004l[?2004h>     done < "$file"
[?2004l[?2004h> }
