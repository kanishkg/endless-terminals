[?2004l[?2004h> # Function to parse env file
[?2004l[?2004h> parse_env_file() {
[?2004l[?2004h>     local file="$1"
[?2004l[?2004h>     while IFS= read -r line || [ -n "$line" ]; do
[?2004l[?2004h>         # Skip empty lines and comments
[?2004l[?2004h>         if [[ -z "$line" ]] || [[ "$line" =~ ^[[:space:]]*# ]]; then
[?2004l[?2004h>             continue
[?2004l[?2004h>         fi
[?2004l[?2004h>         
[?2004l[?2004h>         # Extract key=value
