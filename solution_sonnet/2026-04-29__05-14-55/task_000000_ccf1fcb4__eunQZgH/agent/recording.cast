[14.080869, "o", "#!/bin/bash\r\necho \"Starting labeler service...\"\r\ncd /home/user/labeler\r\nsource venv/bin/activate\r\ngunicorn -c config/gunicorn.conf.py \"app:create_app()\" --daemon\r\n"]
