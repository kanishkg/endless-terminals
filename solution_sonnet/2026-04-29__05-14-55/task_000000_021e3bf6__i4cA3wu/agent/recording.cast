[29.925552, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file for collecting results\ntempfile=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handling missing/corrupted data\n    memtotal=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty (corrupted file)\n    if [[ -z \"$memtotal\" ]] || [[ -z \"$memavail\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage and check if less than 20% using awk\n    awk -v total=\"$memtotal\" -v avail=\"$memavail\" -v host=\"$hostname\" '\n    BEGIN {\n        percent = (avail / total) * 100\n        if (percent < 20) {\n            printf \"%.2f\\t%s\\t%.2f\\n\", percent, host, percent\n        }\n    }' >> \"$tempfile\"\ndone\n\n# Sort by percentage (ascending - worst first) and output hostname + percentage\nsort -n"]
[29.925686, "i", " \"$tempfile\" | awk -F'\\t' '{printf \"%s\\t%.2f\\n\", $2, $3}' > /home/user/low_memory_report.txt\n\n# Clean up\nrm -f \"$tempfile\"\nEOF\n"]
