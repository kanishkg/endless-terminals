[20.705757, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file for collecting results\ntempfile=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handling missing/corrupted data\n    memtotal=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty (corrupted file)\n    if [[ -z \"$memtotal\" ]] || [[ -z \"$memavail\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available (using bc for floating point)\n    percent=$(echo \"scale=2; ($memavail / $memtotal) * 100\" | bc)\n    \n    # Check if less than 20%\n    is_low=$(echo \"$percent < 20\" | bc)\n    \n    if [[ $is_low -eq 1 ]]; then\n        # Store hostname and percentage for sorting\n        echo -e \"$percent\\t$hostname\\t$percent\" >> \"$tempfile\"\n    fi\ndone\n\n# Sort by percentage (ascendin"]
[20.705899, "i", "g - worst first) and output hostname + percentage\nsort -n \"$tempfile\" | awk -F'\\t' '{printf \"%s\\t%.2f\\n\", $2, $3}' > /home/user/low_memory_report.txt\n\n# Clean up\nrm -f \"$tempfile\"\nEOF\n"]
[20.705914, "o", "cat > process_memory.sh << 'EOF'\r\n\u001b[?2004l\r"]
