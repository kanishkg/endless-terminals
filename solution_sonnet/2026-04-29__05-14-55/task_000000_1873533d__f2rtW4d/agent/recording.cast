[18.015377, "i", "cat > /home/user/bin/env-merge.sh << 'EOF'\n#!/bin/bash\n\nif [ $# -ne 2 ]; then\n    echo \"Usage: $0 <file1.env> <file2.env>\" >&2\n    exit 1\nfi\n\nif [ ! -f \"$1\" ]; then\n    echo \"Error: File '$1' not found\" >&2\n    exit 1\nfi\n\nif [ ! -f \"$2\" ]; then\n    echo \"Error: File '$2' not found\" >&2\n    exit 1\nfi\n\ndeclare -A env_vars\ndeclare -a keys_order\n\n# Function to parse env file\nparse_env_file() {\n    local file=\"$1\"\n    while IFS= read -r line || [ -n \"$line\" ]; do\n        # Skip empty lines and comments\n        [[ -z \"$line\" || \"$line\" =~ ^[[:space:]]*# ]] && continue\n        \n        # Extract key=value\n        if [[ \"$line\" =~ ^[[:space:]]*([^=]+)=(.*)$ ]]; then\n            key=\"${BASH_REMATCH[1]}\"\n            value=\"${BASH_REMATCH[2]}\"\n            \n            # Store in associative array\n            if [ -z \"${env_vars[$key]+x}\" ]; then\n                keys_order+=(\"$key\")\n            fi\n            env_vars[\"$key\"]=\"$value\"\n        fi\n    done < \"$file\"\n}\n\n# Parse both files (second file will override first)\np"]
[18.015529, "i", "arse_env_file \"$1\"\nparse_env_file \"$2\"\n\n# Output merged result\nfor key in \"${keys_order[@]}\"; do\n    echo \"${key}=${env_vars[$key]}\"\ndone\nEOF\n"]
[18.015568, "o", "cat > /home/user/bin/env-merge.sh << 'EOF'\r\n"]
