[66.987899, "i", "cat > config/gunicorn.conf.py << 'EOF'\nimport configparser\nimport os\n\n# Read configuration from settings.ini\nini_config = configparser.ConfigParser()\nconfig_path = os.path.join(os.path.dirname(__file__), 'settings.ini')\nini_config.read(config_path)\n\n# Get settings with fallbacks\nif ini_config.has_section('server'):\n    host = ini_config.get('server', 'host')\n    port = ini_config.get('server', 'port')\n    workers_count = ini_config.get('server', 'workers')\nelse:\n    host = '127.0.0.1'\n    port = '8000'\n    workers_count = '2'\n\n# Gunicorn configuration\nbind = f\"{host}:{port}\"\nworkers = int(workers_count)\ndaemon = False\nEOF\n"]
