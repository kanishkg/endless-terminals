[13.01852, "o", "cat start.sh\r\n\u001b[?2004l\r"]
[13.019349, "o", "#!/bin/bash\r\necho \"Starting labeler service...\"\r\ncd /home/user/labeler\r\nsource venv/bin/activate\r\ngunicorn -c config/gunicorn.conf.py \"app:create_app()\" --daemon\r\n"]
