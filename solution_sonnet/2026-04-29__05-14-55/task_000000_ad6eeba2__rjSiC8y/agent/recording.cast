[115.71406, "i", "python3 << 'EOF'\nimport json\nimport csv\n\n# Check specific examples from original CSV\nwith open('assets.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    rows = list(reader)\n\nprint(\"Verifying price conversions:\")\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\n    asset_dict = {a['id']: a for a in assets}\n\nfor row in rows[:10]:\n    asset_id = row['id']\n    if asset_id in asset_dict:\n        asset = asset_dict[asset_id]\n        print(f\"{asset_id}: {row['price']:>12} -> {asset['price_cents']:>8} cents (${asset['price_cents']/100:>10.2f})\")\n\nprint(\"\\nChecking special cases (dollar signs and commas):\")\nfor row in rows:\n    if '$' in row['price']:\n        asset_id = row['id']\n        if asset_id in asset_dict:\n            asset = asset_dict[asset_id]\n            print(f\"{asset_id}: {row['price']:>15} -> ${asset['price_cents']/100:.2f}\")\n            break\n\nEOF\n"]
