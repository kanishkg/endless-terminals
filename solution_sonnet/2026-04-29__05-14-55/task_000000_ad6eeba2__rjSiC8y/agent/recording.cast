[131.664643, "i", "python3 << 'EOF'\nimport json\nimport re\nfrom datetime import datetime\n\n# Load files\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\n\nwith open('rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(\"=== FINAL VALIDATION ===\")\nprint(f\"\\nTotal valid assets: {len(assets)}\")\nprint(f\"Total rejected records: {len(rejected)}\")\nprint(f\"Total processed: {len(assets) + len(rejected)}\")\n\n# Validate structure\nrequired_fields = ['id', 'name', 'serial', 'purchase_date', 'price_cents', 'location']\nerrors = []\n\nfor asset in assets:\n    # Check all fields present\n    if not all(field in asset for field in required_fields):\n        errors.append(f\"Missing fields in {asset.get('id', 'unknown')}\")\n    \n    # Validate date format (ISO 8601)\n    if not re.match(r'^\\d{4}-\\d{2}-\\d{2}$', asset['purchase_date']):\n        errors.append(f\"Invalid date format in {asset['id']}: {asset['purchase_date']}\")\n    else:\n        # Verify it's a valid date\n        try:\n            datetime.strptime(asset['purchase_date'], '%Y"]
[131.664778, "i", "-%m-%d')\n        except ValueError:\n            errors.append(f\"Invalid date value in {asset['id']}: {asset['purchase_date']}\")\n    \n    # Validate price_cents is positive integer\n    if not isinstance(asset['price_cents'], int) or asset['price_cents'] <= 0:\n        errors.append(f\"Invalid price in {asset['id']}: {asset['price_cents']}\")\n\nif errors:\n    print(\"\\n❌ VALIDATION ERRORS:\")\n    for error in errors[:10]:\n        print(f\"  - {error}\")\nelse:\n    print(\"\\n✅ All validations passed!\")\n\n# Check for duplicates\nids = [a['id'] for a in assets]\nif len(ids) != len(set(ids)):\n    print(\"\\n❌ Duplicate IDs found!\")\nelse:\n    print(\"✅ No duplicate IDs\")\n\n# Show price range\nprices = [a['price_cents'] for a in assets]\nprint(f\"\\nPrice range: ${min(prices)/100:.2f} - ${max(prices)/100:.2f}\")\n\n# Show date range\ndates = sorted([a['purchase_date'] for a in assets])\nprint(f\"Date range: {dates[0]} to {dates[-1]}\")\n\n# Show rejection reasons summary\nprint(\"\\nRejection reasons:\")\nreasons = {}\nfor rec in rejected:\n    "]
