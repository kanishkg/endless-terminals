[82.426851, "i", "python3 << 'EOF'\nimport json\nimport csv\n\n# Check specific examples from original CSV\nwith open('assets.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    rows = list(reader)\n    \nprint(\"Sample original prices:\")\nfor row in rows[:10]:\n    print(f\"{row['id']}: {row['price']}\")\n\nprint(\"\\nCorresponding converted prices:\")\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\n    asset_dict = {a['id']: a for a in assets}\n    \nfor row in rows[:10]:\n    asset_id = row['id']\n    if asset_id in asset_dict:\n        asset = asset_dict[asset_id]\n        print(f\"{asset_id}: {row['price']} -> {asset['price_cents']} cents (${asset['price_cents']/100:.2f})\")\n\nEOF\n"]
