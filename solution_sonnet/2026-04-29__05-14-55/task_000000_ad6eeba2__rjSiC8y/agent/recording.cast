[45.910665, "o", "        \r\n\u001b[?2004l\r"]
[45.910687, "o", "\u001b[?2004h"]
[45.910716, "o", "> "]
[45.910777, "o", "        # Convert to cents\r\n\u001b[?2004l\r"]
[45.910804, "o", "\u001b[?2004h> "]
[45.911122, "o", "        price_cents = int(round(price_float * 100)) if '.' in price_str or price_float < 100 else int(price_float)\r\n\u001b[?2004l\r"]
[45.91117, "o", "\u001b[?2004h> "]
[45.911204, "o", "        \r\n\u001b[?2004l\r"]
[45.91123, "o", "\u001b[?2004h> "]
[45.911304, "o", "        # Check if positive\r\n\u001b[?2004l\r"]
[45.911334, "o", "\u001b[?2004h> "]
[45.911412, "o", "        if price_cents > 0:\r\n\u001b[?2004l\r"]
[45.911441, "o", "\u001b[?2004h> "]
[45.911532, "o", "            return price_cents\r\n\u001b[?2004l\r"]
[45.911562, "o", "\u001b[?2004h> "]
[45.91162, "o", "        return None\r\n\u001b[?2004l\r"]
[45.911645, "o", "\u001b[?2004h> "]
[45.911763, "o", "    except (ValueError, AttributeError):\r\n\u001b[?2004l\r"]
[45.911792, "o", "\u001b[?2004h> "]
[45.911851, "o", "        return None\r\n\u001b[?2004l\r"]
[45.911879, "o", "\u001b[?2004h> "]
[45.911908, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.911943, "o", "> "]
[45.911985, "o", "def is_serial_number(s):\r\n\u001b[?2004l\r"]
[45.91201, "o", "\u001b[?2004h"]
[45.912034, "o", "> "]
[45.912182, "o", "    \"\"\"Check if string matches serial number pattern\"\"\"\r\n\u001b[?2004l\r"]
[45.912207, "o", "\u001b[?2004h> "]
[45.91238, "o", "    return bool(re.match(r'^SN-[A-Z]{3}-\\d{5}$', s.strip()))\r\n\u001b[?2004l\r"]
[45.912413, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[45.912441, "o", "\u001b[?2004h> "]
[45.912506, "o", "def process_row(row):\r\n\u001b[?2004l\r"]
[45.912534, "o", "\u001b[?2004h> "]
[45.912746, "o", "    \"\"\"Process a single row and return (valid_record, error_reason)\"\"\"\r\n\u001b[?2004l\r"]
[45.912776, "o", "\u001b[?2004h> "]
[45.912806, "o", "    try:\r\n\u001b[?2004l\r"]
[45.912837, "o", "\u001b[?2004h> "]
[45.912941, "o", "        asset_id = row['id'].strip()\r\n\u001b[?2004l\r"]
[45.912969, "o", "\u001b[?2004h"]
[45.913, "o", "> "]
[45.913074, "o", "        name = row['name'].strip()\r\n\u001b[?2004l\r"]
[45.913101, "o", "\u001b[?2004h> "]
[45.913223, "o", "        serial = row['serial'].strip()\r\n\u001b[?2004l\r"]
[45.913252, "o", "\u001b[?2004h"]
[45.91328, "o", "> "]
[45.913414, "o", "        purchase_date_raw = row['purchase_date'].strip()\r\n\u001b[?2004l\r"]
[45.913443, "o", "\u001b[?2004h> "]
[45.913555, "o", "        price_raw = row['price'].strip()\r\n\u001b[?2004l\r"]
[45.913579, "o", "\u001b[?2004h> "]
[45.913704, "o", "        location = row['location'].strip()\r\n\u001b[?2004l\r"]
[45.913732, "o", "\u001b[?2004h> "]
[45.913765, "o", "        \r\n\u001b[?2004l\r"]
[45.913789, "o", "\u001b[?2004h"]
[45.913813, "o", "> "]
[45.913926, "o", "        # Check if serial and name are swapped\r\n\u001b[?2004l\r"]
[45.91395, "o", "\u001b[?2004h"]
[45.913974, "o", "> "]
[45.914159, "o", "        if is_serial_number(name) and not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[45.91419, "o", "\u001b[?2004h> "]
[45.914299, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[45.914321, "o", "\u001b[?2004h> "]
[45.914353, "o", "        \r\n\u001b[?2004l\r"]
[45.914383, "o", "\u001b[?2004h"]
[45.914409, "o", "> "]
[45.914482, "o", "        # Validate required fields\r\n\u001b[?2004l\r"]
[45.914508, "o", "\u001b[?2004h> "]
[45.91458, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[45.91461, "o", "\u001b[?2004h> "]
[45.914735, "o", "            return None, \"Missing asset ID\"\r\n\u001b[?2004l\r"]
[45.914766, "o", "\u001b[?2004h> "]
[45.914795, "o", "        \r\n\u001b[?2004l\r"]
[45.914823, "o", "\u001b[?2004h> "]
[45.914935, "o", "        if not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[45.914962, "o", "\u001b[?2004h> "]
[45.915165, "o", "            return None, f\"Invalid serial number format: {serial}\"\r\n\u001b[?2004l\r"]
[45.915189, "o", "\u001b[?2004h> "]
[45.915217, "o", "        \r\n\u001b[?2004l\r"]
[45.915243, "o", "\u001b[?2004h> "]
[45.915307, "o", "        # Parse date\r\n\u001b[?2004l\r"]
[45.915334, "o", "\u001b[?2004h> "]
[45.91549, "o", "        purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[45.915519, "o", "\u001b[?2004h> "]
[45.915604, "o", "        if not purchase_date:\r\n\u001b[?2004l\r"]
[45.915633, "o", "\u001b[?2004h> "]
[45.915825, "o", "            return None, f\"Invalid date format: {purchase_date_raw}\"\r\n\u001b[?2004l\r"]
[45.915852, "o", "\u001b[?2004h> "]
[45.915883, "o", "        \r\n\u001b[?2004l\r"]
[45.915911, "o", "\u001b[?2004h> "]
[45.915975, "o", "        # Parse price\r\n\u001b[?2004l\r"]
[45.916003, "o", "\u001b[?2004h> "]
[45.91613, "o", "        price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[45.916162, "o", "\u001b[?2004h"]
[45.916197, "o", "> "]
[45.916262, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[45.91629, "o", "\u001b[?2004h> "]
[45.916444, "o", "            return None, f\"Invalid price: {price_raw}\"\r\n\u001b[?2004l\r"]
[45.91647, "o", "\u001b[?2004h> "]
[45.916502, "o", "        \r\n\u001b[?2004l\r"]
[45.916529, "o", "\u001b[?2004h"]
[45.916563, "o", "> "]
[45.91662, "o", "        # Create valid record\r\n\u001b[?2004l\r"]
[45.916648, "o", "\u001b[?2004h> "]
[45.916724, "o", "        record = {\r\n\u001b[?2004l\r"]
[45.916753, "o", "\u001b[?2004h> "]
[45.916835, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[45.916865, "o", "\u001b[?2004h> "]
[45.916942, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[45.916967, "o", "\u001b[?2004h"]
[45.916992, "o", "> "]
[45.917058, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[45.917083, "o", "\u001b[?2004h"]
[45.917111, "o", "> "]
[45.917227, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[45.917254, "o", "\u001b[?2004h> "]
[45.91737, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[45.917403, "o", "\u001b[?2004h> "]
[45.917496, "o", "            'location': location\r\n\u001b[?2004l\r"]
[45.917521, "o", "\u001b[?2004h"]
[45.917546, "o", "> "]
[45.91757, "o", "        }\r\n\u001b[?2004l\r"]
[45.917588, "o", "\u001b[?2004h> "]
[45.917616, "o", "        \r\n\u001b[?2004l\r"]
[45.917644, "o", "\u001b[?2004h> "]
[45.917725, "o", "        return record, None\r\n\u001b[?2004l\r"]
[45.917752, "o", "\u001b[?2004h> "]
[45.917783, "o", "        \r\n\u001b[?2004l\r"]
[45.917812, "o", "\u001b[?2004h> "]
[45.917892, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[45.917925, "o", "\u001b[?2004h> "]
[45.918063, "o", "        return None, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[45.918094, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[45.918123, "o", "\u001b[?2004h> "]
[45.918171, "o", "def main():\r\n\u001b[?2004l\r"]
[45.918199, "o", "\u001b[?2004h"]
[45.918225, "o", "> "]
[45.918376, "o", "    valid_records = defaultdict(list)  # id -> list of records\r\n\u001b[?2004l\r"]
[45.918404, "o", "\u001b[?2004h> "]
[45.91848, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[45.918508, "o", "\u001b[?2004h> "]
[45.918531, "o", "    \r\n\u001b[?2004l\r"]
[45.918561, "o", "\u001b[?2004h> "]
[45.918605, "o", "    # Read CSV\r\n\u001b[?2004l\r"]
[45.918638, "o", "\u001b[?2004h> "]
[45.918794, "o", "    with open('assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[45.918823, "o", "\u001b[?2004h> "]
[45.918925, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[45.918951, "o", "\u001b[?2004h> "]
[45.919111, "o", "        for row_num, row in enumerate(reader, start=2):\r\n\u001b[?2004l\r"]
[45.919162, "o", "\u001b[?2004h> "]
[45.919282, "o", "            record, error = process_row(row)\r\n\u001b[?2004l\r"]
[45.919307, "o", "\u001b[?2004h"]
[45.919336, "o", "> "]
[45.919364, "o", "            \r\n\u001b[?2004l\r"]
[45.919391, "o", "\u001b[?2004h> "]
[45.919452, "o", "            if record:\r\n\u001b[?2004l\r"]
[45.919482, "o", "\u001b[?2004h> "]
[45.919647, "o", "                valid_records[record['id']].append(record)\r\n\u001b[?2004l\r"]
[45.919676, "o", "\u001b[?2004h> "]
[45.919728, "o", "            else:\r\n\u001b[?2004l\r"]
[45.919755, "o", "\u001b[?2004h> "]
[45.919875, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[45.919904, "o", "\u001b[?2004h> "]
[45.920037, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[45.920067, "o", "\u001b[?2004h> "]
[45.920184, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[45.920212, "o", "\u001b[?2004h"]
[45.92024, "o", "> "]
[45.920349, "o", "                    'row_number': row_num\r\n\u001b[?2004l\r"]
[45.920375, "o", "\u001b[?2004h"]
[45.920405, "o", "> "]
[45.920442, "o", "                })\r\n\u001b[?2004l\r"]
[45.920472, "o", "\u001b[?2004h> "]
[45.920501, "o", "    \r\n\u001b[?2004l\r"]
[45.920529, "o", "\u001b[?2004h> "]
[45.920724, "o", "    # Deduplicate: keep record with latest purchase_date for each ID\r\n\u001b[?2004l\r"]
[45.920746, "o", "\u001b[?2004h"]
[45.92078, "o", "> "]
[45.920827, "o", "    final_records = []\r\n\u001b[?2004l\r"]
[45.920855, "o", "\u001b[?2004h> "]
[45.921, "o", "    for asset_id, records in valid_records.items():\r\n\u001b[?2004l\r"]
[45.921036, "o", "\u001b[?2004h> "]
[45.921118, "o", "        if len(records) == 1:\r\n\u001b[?2004l\r"]
[45.921137, "o", "\u001b[?2004h"]
[45.921181, "o", "> "]
[45.921284, "o", "            final_records.append(records[0])\r\n\u001b[?2004l\r"]
[45.92131, "o", "\u001b[?2004h"]
[45.921334, "o", "> "]
[45.921359, "o", "        else:\r\n"]
[45.921383, "o", "\u001b[?2004l\r\u001b[?2004h"]
[45.921407, "o", "> "]
[45.921547, "o", "            # Sort by purchase_date and take the latest\r\n\u001b[?2004l\r"]
[45.921576, "o", "\u001b[?2004h> "]
[45.921835, "o", "            sorted_records = sorted(records, key=lambda x: x['purchase_date'], reverse=True)\r\n\u001b[?2004l\r"]
[45.92186, "o", "\u001b[?2004h"]
[45.921884, "o", "> "]
[45.92201, "o", "            final_records.append(sorted_records[0])\r\n\u001b[?2004l\r"]
[45.922034, "o", "\u001b[?2004h"]
[45.922058, "o", "> "]
[45.922081, "o", "            \r\n\u001b[?2004l\r"]
[45.922104, "o", "\u001b[?2004h"]
[45.922129, "o", "> "]
[45.922271, "o", "            # Add duplicates to rejected with reason\r\n\u001b[?2004l\r"]
[45.922293, "o", "\u001b[?2004h"]
[45.922317, "o", "> "]
[45.922421, "o", "            for dup in sorted_records[1:]:\r\n\u001b[?2004l\r"]
[45.922449, "o", "\u001b[?2004h> "]
[45.922571, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[45.9226, "o", "\u001b[?2004h> "]
[45.922717, "o", "                    'original_row': dup,\r\n\u001b[?2004l\r"]
[45.922744, "o", "\u001b[?2004h> "]
[45.923008, "o", "                    'reason': f\"Duplicate asset ID {asset_id}, kept record with latest date\",\r\n\u001b[?2004l\r"]
[45.923038, "o", "\u001b[?2004h> "]
[45.923162, "o", "                    'row_number': 'N/A'\r\n\u001b[?2004l\r"]
[45.923192, "o", "\u001b[?2004h> "]
[45.923245, "o", "                })\r\n\u001b[?2004l\r"]
[45.923267, "o", "\u001b[?2004h"]
[45.923299, "o", ">     \r\n\u001b[?2004l\r"]
[45.92333, "o", "\u001b[?2004h> "]
[45.923456, "o", "    # Sort final records by ID for consistency\r\n\u001b[?2004l\r"]
[45.923485, "o", "\u001b[?2004h> "]
[45.923616, "o", "    final_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[45.923641, "o", "\u001b[?2004h"]
[45.923669, "o", ">     \r\n\u001b[?2004l\r"]
[45.923703, "o", "\u001b[?2004h> "]
[45.923755, "o", "    # Write outputs\r\n\u001b[?2004l\r"]
[45.923783, "o", "\u001b[?2004h> "]
[45.923947, "o", "    with open('assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[45.92397, "o", "\u001b[?2004h"]
[45.923995, "o", "> "]
[45.924108, "o", "        json.dump(final_records, f, indent=2)\r\n\u001b[?2004l\r"]
[45.924129, "o", "\u001b[?2004h"]
[45.924175, "o", ">     \r\n\u001b[?2004l\r"]
[45.924199, "o", "\u001b[?2004h> "]
[45.924363, "o", "    with open('rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[45.924392, "o", "\u001b[?2004h"]
[45.924418, "o", "> "]
[45.924536, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[45.924564, "o", "\u001b[?2004h> "]
[45.92459, "o", "    \r\n\u001b[?2004l\r"]
[45.924615, "o", "\u001b[?2004h> "]
[45.924789, "o", "    print(f\"Processed {len(final_records)} valid records\")\r\n\u001b[?2004l\r"]
[45.924813, "o", "\u001b[?2004h"]
[45.92484, "o", "> "]
[45.924977, "o", "    print(f\"Rejected {len(rejected_records)} records\")\r\n\u001b[?2004l\r"]
[45.925001, "o", "\u001b[?2004h"]
[45.92503, "o", "> "]
[45.925196, "o", "    print(f\"Output written to assets.json and rejected.json\")\r\n\u001b[?2004l\r"]
[45.92522, "o", "\u001b[?2004h"]
[45.925248, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[45.925268, "o", "> "]
[45.925338, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[45.925366, "o", "\u001b[?2004h> "]
[45.925402, "o", "    main()\r\n\u001b[?2004l\r"]
[45.925431, "o", "\u001b[?2004h> "]
[45.925459, "o", "EOF\r\n\u001b[?2004l\r"]
[45.929722, "o", "\u001b[?2004h"]
[45.92976, "o", "user@6f0c20b3912a:~/inventory$ "]
