[71.7035, "i", "python3 << 'EOF'\nimport json\n\n# Load and verify assets.json\nwith open('assets.json', 'r') as f:\n    assets = json.load(f)\n\n# Load rejected.json\nwith open('rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(f\"Total valid assets: {len(assets)}\")\nprint(f\"Total rejected records: {len(rejected)}\")\n\n# Check for duplicates\nids = [a['id'] for a in assets]\nif len(ids) != len(set(ids)):\n    print(\"ERROR: Duplicate IDs found!\")\n    from collections import Counter\n    dupes = [id for id, count in Counter(ids).items() if count > 1]\n    print(f\"Duplicates: {dupes}\")\nelse:\n    print(\"✓ No duplicate IDs in assets.json\")\n\n# Verify all price_cents are positive integers\ninvalid_prices = [a for a in assets if not isinstance(a['price_cents'], int) or a['price_cents'] <= 0]\nif invalid_prices:\n    print(f\"ERROR: Found {len(invalid_prices)} invalid prices\")\n    for a in invalid_prices[:3]:\n        print(f\"  {a['id']}: {a['price_cents']}\")\nelse:\n    print(\"✓ All prices are positive integers\")\n\n# Verify all dates are IS"]
[71.70362, "i", "O 8601 format (YYYY-MM-DD)\nimport re\ndate_pattern = re.compile(r'^\\d{4}-\\d{2}-\\d{2}$')\ninvalid_dates = [a for a in assets if not date_pattern.match(a['purchase_date'])]\nif invalid_dates:\n    print(f\"ERROR: Found {len(invalid_dates)} invalid date formats\")\n    for a in invalid_dates[:3]:\n        print(f\"  {a['id']}: {a['purchase_date']}\")\nelse:\n    print(\"✓ All dates are in ISO 8601 format\")\n\n# Show sample of valid records\nprint(\"\\nSample valid records:\")\nfor asset in assets[:3]:\n    print(f\"  {asset['id']}: {asset['name']}, ${asset['price_cents']/100:.2f}, {asset['purchase_date']}\")\n\n# Show sample of rejected records\nprint(\"\\nSample rejected records:\")\nfor rec in rejected[:3]:\n    print(f\"  Row {rec['row_number']}: {rec['reason']}\")\n\nEOF\n"]
[71.703654, "o", "python3 << 'EOF'\r\n\u001b[?2004l\rO 8601 format (YYYY-MM-DD)\r\nimport re\r\ndate_pattern = re.compile(r'^\\d{4}-\\d{2}-\\d{2}$')\r\ninvalid_dates = [a for a in assets if not date_pat"]
