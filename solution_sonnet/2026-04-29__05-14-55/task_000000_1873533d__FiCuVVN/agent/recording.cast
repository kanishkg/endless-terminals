[20.908682, "i", "cat > /home/user/bin/env-merge.sh << 'EOF'\n#!/bin/bash\n\nif [ $# -ne 2 ]; then\n    echo \"Usage: $0 <file1.env> <file2.env>\" >&2\n    exit 1\nfi\n\nif [ ! -f \"$1\" ]; then\n    echo \"Error: File '$1' not found\" >&2\n    exit 1\nfi\n\nif [ ! -f \"$2\" ]; then\n    echo \"Error: File '$2' not found\" >&2\n    exit 1\nfi\n\n# Use associative array to store key-value pairs\ndeclare -A env_vars\ndeclare -a all_keys\n\n# Read first file\nwhile IFS= read -r line || [ -n \"$line\" ]; do\n    # Skip empty lines and comments\n    if [[ -z \"$line\" || \"$line\" =~ ^[[:space:]]*# ]]; then\n        continue\n    fi\n    \n    # Extract key (everything before first =)\n    if [[ \"$line\" =~ ^([^=]+)=(.*)$ ]]; then\n        key=\"${BASH_REMATCH[1]}\"\n        value=\"${BASH_REMATCH[2]}\"\n        \n        # Store in associative array\n        if [[ -z \"${env_vars[$key]+x}\" ]]; then\n            all_keys+=(\"$key\")\n        fi\n        env_vars[\"$key\"]=\"$value\"\n    fi\ndone < \"$1\"\n\n# Read second file (overwrites conflicts)\nwhile IFS= read -r line || [ -n \"$line\" ]; do\n    # S"]
[20.908813, "i", "kip empty lines and comments\n    if [[ -z \"$line\" || \"$line\" =~ ^[[:space:]]*# ]]; then\n        continue\n    fi\n    \n    # Extract key (everything before first =)\n    if [[ \"$line\" =~ ^([^=]+)=(.*)$ ]]; then\n        key=\"${BASH_REMATCH[1]}\"\n        value=\"${BASH_REMATCH[2]}\"\n        \n        # Store in associative array (overwrites if exists)\n        if [[ -z \"${env_vars[$key]+x}\" ]]; then\n            all_keys+=(\"$key\")\n        fi\n        env_vars[\"$key\"]=\"$value\"\n    fi\ndone < \"$2\"\n\n# Output merged result\nfor key in \"${all_keys[@]}\"; do\n    echo \"${key}=${env_vars[$key]}\"\ndone\nEOF\n"]
[20.908861, "o", "cat > /home/user/bin/env-merge.sh << 'EOF'\r\n"]
