[26.911281, "i", "awk '\n/\\/api\\/v[0-9]+\\/internal\\// {\n  # Extract timestamp\n  match($0, /\\[([^\\]]+)\\]/, ts)\n  timestamp = ts[1]\n  \n  # Parse: DD/Mon/YYYY:HH:MM:SS +0000\n  split(timestamp, parts, /[:\\/]| /)\n  day = parts[1]\n  month = parts[2]\n  year = parts[3]\n  time = parts[4] \":\" parts[5] \":\" parts[6]\n  \n  # Convert month name to number\n  months[\"Jan\"]=\"01\"; months[\"Feb\"]=\"02\"; months[\"Mar\"]=\"03\"; months[\"Apr\"]=\"04\"\n  months[\"May\"]=\"05\"; months[\"Jun\"]=\"06\"; months[\"Jul\"]=\"07\"; months[\"Aug\"]=\"08\"\n  months[\"Sep\"]=\"09\"; months[\"Oct\"]=\"10\"; months[\"Nov\"]=\"11\"; months[\"Dec\"]=\"12\"\n  \n  # Build ISO 8601 timestamp\n  iso_ts = year \"-\" months[month] \"-\" day \"T\" time\n  \n  # Replace timestamp in line\n  sub(/\\[[^\\]]+\\]/, iso_ts)\n  print\n}\n' /var/log/app/access.log > /home/user/internal_hits.log\n"]
