[12.584567, "o", "# Changelog\r\n\r\nAll notable changes to this project will be documented in this file.\r\n\r\n## [0.7.2] - 2024-11-15\r\n\r\n### Fixed\r\n- Resolved mobile navigation collapse issue\r\n\r\n## [0.7.1] - 2024-11-01\r\n\r\n### Added\r\n- Dark mode support for documentation pages\r\n\r\n## [0.7.0] - October 28, 2024\r\n\r\n### Added\r\n- Initial search functionality\r\n- New getting started guide\r\n\r\n### Fixed\r\n- Typography inconsistencies in code blocks\r\n\r\n## [0.6.0] - 2024-10-15\r\n\r\n### Added\r\n- API reference documentation\r\n"]
