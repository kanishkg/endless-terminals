[88.809788, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_range(port_str):\n    \"\"\"Parse port string into a list of valid ports.\"\"\"\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return (int(start), int(end))\n    else:\n        port = int(port_str)\n        return (port, port)\n\ndef port_in_range(port, port_range):\n    \"\"\"Check if a port is within a range.\"\"\"\n    start, end = port_range\n    return start <= port <= end\n\ndef load_firewall_rules(json_path):\n    \"\"\"Load and parse firewall rules from JSON.\"\"\"\n    with open(json_path, 'r') as f:\n        data = json.load(f)\n    \n    rules = []\n    for rule in data['rules']:\n        rules.append({\n            'id': rule['id'],\n            'action': rule['action'],\n            'network': ipaddress.ip_network(rule['source_cidr']),\n            'port_range': parse_port_range(rule['dest_port'])\n        })\n    \n    # Sort rules by prefix length (most specific first)\n    rules.sort(key=lambda r: r"]
[88.809841, "i", "['network'].prefixlen, reverse=True)\n    \n    return rules, data.get('default_action', 'deny')\n\ndef check_connection(src_ip, dest_port, rules):\n    \"\"\"Check if a connection is allowed by firewall rules.\n    Returns (allowed, matching_rule_or_reason)\n    \"\"\"\n    ip_obj = ipaddress.ip_address(src_ip)\n    \n    # Check rules in order (most specific CIDR first)\n    for rule in rules:\n        if ip_obj in rule['network']:\n            if port_in_range(dest_port, rule['port_range']):\n                if rule['action'] == 'allow':\n                    return True, rule\n                else:\n                    return False, rule\n    \n    # No matching rule found - default deny\n    return False, None\n\ndef main():\n    rules, default_action = load_firewall_rules('/home/user/audit/firewall_rules.json')\n    \n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        \n        for row in reader:\n            src_ip = row['src_ip']\n            dest_port = int(row['dest_port'])\n       "]
[88.80994, "i", "     \n            allowed, rule = check_connection(src_ip, dest_port, rules)\n            \n            if not allowed:\n                if rule:\n                    # Explicitly denied by a rule\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {rule['network']}\")\n                else:\n                    # No matching rule found\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
