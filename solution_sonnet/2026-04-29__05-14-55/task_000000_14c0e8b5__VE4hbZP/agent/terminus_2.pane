[?2004hroot@92e8fc3f361c:/home/user/audit# cat > check.py << 'EOF'
[?2004l[?2004h> #!/usr/bin/env python3
[?2004l[?2004h> import json
[?2004l[?2004h> import csv
[?2004l[?2004h> import ipaddress
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def parse_port_range(port_str):
[?2004l[?2004h>     """Parse port string into a list of valid ports."""
[?2004l[?2004h>     if '-' in port_str:
[?2004l[?2004h>         start, end = port_str.split('-')
[?2004l[?2004h>         return (int(start), int(end))
[?2004l[?2004h>     else:
[?2004l[?2004h>         port = int(port_str)
[?2004l[?2004h>         return (port, port)
[?2004l[?2004h> 
[?2004l[?2004h> def port_in_range(port, port_range):
[?2004l[?2004h>     """Check if a port is within a range."""
[?2004l[?2004h>     start, end = port_range
[?2004l[?2004h>     return start <= port <= end
[?2004l[?2004h> 
[?2004l[?2004h> def load_firewall_rules(json_path):
[?2004l[?2004h>     """Load and parse firewall rules from JSON."""
[?2004l[?2004h>     with open(json_path, 'r') as f:
[?2004l[?2004h>         data = json.load(f)
[?2004l[?2004h>     
[?2004l[?2004h>     rules = []
[?2004l[?2004h>     for rule in data['rules']:
[?2004l[?2004h>         rules.append({
[?2004l[?2004h>             'id': rule['id'],
[?2004l[?2004h>             'action': rule['action'],
[?2004l[?2004h>             'network': ipaddress.ip_network(rule['source_cidr']),
[?2004l[?2004h>             'port_range': parse_port_range(rule['dest_port'])
[?2004l[?2004h>         })
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort rules by prefix length (most specific first)
[?2004l[?2004h>     rules.sort(key=lambda r: r['network'].prefixlen, reverse=True)
[?2004l[?2004h>     
[?2004l[?2004h>     return rules, data.get('default_action', 'deny')
[?2004l[?2004h> 
[?2004l[?2004h> def check_connection(src_ip, dest_port, rules):
[?2004l[?2004h>     """Check if a connection is allowed by firewall rules.
[?2004l[?2004h>     Returns (allowed, matching_rule_or_reason)
[?2004l[?2004h>     """
[?2004l[?2004h>     ip_obj = ipaddress.ip_address(src_ip)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check rules in order (most specific CIDR first)
[?2004l[?2004h>     for rule in rules:
[?2004l[?2004h>         if ip_obj in rule['network']:
[?2004l[?2004h>             if port_in_range(dest_port, rule['port_range']):
[?2004l[?2004h>                 if rule['action'] == 'allow':
[?2004l[?2004h>                     return True, rule
[?2004l[?2004h>                 else:
[?2004l[?2004h>                     return False, rule
[?2004l[?2004h>     
[?2004l[?2004h>     # No matching rule found - default deny
[?2004l[?2004h>     return False, None
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     rules, default_action = load_firewall_rules('/home/user/audit/firewall_rules.json')
[?2004l[?2004h>     
[?2004l[?2004h>     with open('/home/user/audit/connections.csv', 'r') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         
[?2004l[?2004h>         for row in reader:
[?2004l[?2004h>             src_ip = row['src_ip']
[?2004l[?2004h>             dest_port = int(row['dest_port'])
[?2004l[?2004h>             
[?2004l[?2004h>             allowed, rule = check_connection(src_ip, dest_port, rules)
[?2004l[?2004h>             
[?2004l[?2004h>             if not allowed:
[?2004l[?2004h>                 if rule:
[?2004l[?2004h>                     # Explicitly denied by a rule
[?2004l[?2004h>                     print(f"BLOCKED: {src_ip}:{dest_port} not allowed from {rule['network']}")
[?2004l[?2004h>                 else:
[?2004l[?2004h>                     # No matching rule found
[?2004l[?2004h>                     print(f"BLOCKED: {src_ip}:{dest_port} not allowed from any rule")
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     main()
