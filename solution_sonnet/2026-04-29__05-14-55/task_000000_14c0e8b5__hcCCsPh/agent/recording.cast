[41.773029, "o", "#!/usr/bin/env python3\r\nimport json\r\nimport csv\r\nimport ipaddress\r\nimport sys\r\n\r\ndef parse_port_range(port_str):\r\n"]
[41.773129, "o", "    \"\"\"Parse port string (single port or range) and return set of ports or range tuple.\"\"\"\r\n    port_str = str(port_str).strip()\r\n    if '-' in port_str:\r\n        start, end = port_str.split('-')\r\n        return ('range', int(start), int(end))\r\n    else:\r\n        return ('single', int(port_str))\r\n\r\ndef port_matches(conn_port, rule_port_str):\r\n    \"\"\"Check if connection port matches rule port (single or range).\"\"\"\r\n    conn_port = int(conn_port)\r\n    port_type, *port_data = parse_port_range(rule_port_str)\r\n    \r\n"]
