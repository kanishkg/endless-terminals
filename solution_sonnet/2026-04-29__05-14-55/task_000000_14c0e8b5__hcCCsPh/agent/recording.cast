[27.977557, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_range(port_str):\n    \"\"\"Parse port string (single port or range) and return set of ports or range tuple.\"\"\"\n    port_str = str(port_str).strip()\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return ('range', int(start), int(end))\n    else:\n        return ('single', int(port_str))\n\ndef port_matches(conn_port, rule_port_str):\n    \"\"\"Check if connection port matches rule port (single or range).\"\"\"\n    conn_port = int(conn_port)\n    port_type, *port_data = parse_port_range(rule_port_str)\n    \n    if port_type == 'single':\n        return conn_port == port_data[0]\n    elif port_type == 'range':\n        start, end = port_data\n        return start <= conn_port <= end\n    return False\n\ndef ip_in_cidr(ip_str, cidr_str):\n    \"\"\"Check if IP address is in CIDR range.\"\"\"\n    try:\n        ip = ipaddress.ip_address(ip_str)\n        network = ipaddress.ip_network(cidr_str, strict=False)\n "]
[27.9777, "i", "       return ip in network\n    except ValueError:\n        return False\n\ndef find_matching_rules(src_ip, dest_port, rules):\n    \"\"\"Find all rules that match the connection.\"\"\"\n    matching = []\n    for rule in rules:\n        if ip_in_cidr(src_ip, rule['source_cidr']) and port_matches(dest_port, rule['dest_port']):\n            # Add prefix length for sorting (more specific = higher prefix)\n            network = ipaddress.ip_network(rule['source_cidr'], strict=False)\n            rule_with_prefix = rule.copy()\n            rule_with_prefix['prefix_len'] = network.prefixlen\n            matching.append(rule_with_prefix)\n    return matching\n\ndef get_best_match(matching_rules):\n    \"\"\"Get the most specific matching rule (highest prefix length).\"\"\"\n    if not matching_rules:\n        return None\n    # Sort by prefix length (descending) - more specific wins\n    return sorted(matching_rules, key=lambda r: r['prefix_len'], reverse=True)[0]\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rul"]
[27.977717, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r"]
[27.977765, "i", "es.json', 'r') as f:\n        firewall_data = json.load(f)\n    \n    rules = firewall_data['rules']\n    default_action = firewall_data.get('default_action', 'deny')\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = conn['dest_port']\n        \n        # Find all matching rules\n        matching_rules = find_matching_rules(src_ip, dest_port, rules)\n        \n        # Get the most specific match\n        best_match = get_best_match(matching_rules)\n        \n        # Determine if connection is allowed\n        if best_match:\n            action = best_match['action']\n            source_cidr = best_match['source_cidr']\n            if action == 'deny':\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {source_cidr}\")\n        else:\n            # No matching rule, apply default action"]
[27.977794, "o", "\u001b[?2004h> "]
[27.977822, "i", "\n            if default_action == 'deny':\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from 0.0.0.0/0\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
