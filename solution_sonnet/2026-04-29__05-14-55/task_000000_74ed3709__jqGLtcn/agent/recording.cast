[23.472984, "o", "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <title>Product Listing</title>\r\n</head>\r\n<body>\r\n    <h1>Products</h1>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Widget A</span>\r\n        <span class=\"price\">$19.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n"]
[23.473078, "o", "        <span class=\"name\">Widget B</span>\r\n        <span class=\"price\">$24.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Gadget Pro</span>\r\n        <span class=\"price\">$149.99</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Super Gizmo</span>\r\n        <span class=\"price\">$79.50</span>\r\n    </div>\r\n    <div class=\"product\">\r\n        <span class=\"name\">Mega Device</span>\r\n        <span class=\"price\">$299.00</span>\r\n    </div>\r\n</body>\r\n</html>\r\n"]
