[12.416383, "o", "import os\r\nfrom flask import Flask, request, jsonify\r\nfrom flask_sqlalchemy import SQLAlchemy\r\nfrom dotenv import load_dotenv\r\nfrom functools import wraps\r\n\r\nload_dotenv()\r\n\r\napp = Flask(__name__)\r\napp.config['SQLALCHEMY_DATABASE_URI'] = os.getenv('DATABASE_URL', 'sqlite:///data.db')\r\napp.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False\r\n\r\ndb = SQLAlchemy(app)\r\n\r\nAPI_KEY = os.getenv('API_KEY')\r\n\r\nclass Item(db.Model):\r\n    __tablename__ = 'items'\r\n    id = db.Column(db.Integer, primary_key=True)\r\n    sku = db.Column(db.String(100), unique=True, nullable=False)\r\n    name = db.Column(db.String(200), nullable=False)\r\n    quantity = db.Column(db.Integer, default=0)\r\n\r\n    def to_dict(self):\r\n        return {"]
[12.41644, "o", "\r\n            'id': self.id,\r\n            'sku': self.sku,\r\n            'name': self.name,\r\n            'quantity': self.quantity\r\n        }\r\n\r\ndef require_api_key(f):\r\n    @wraps(f)\r\n    def decorated(*args, **kwargs):\r\n        api_key = request.headers.get('X-Api-Key')\r\n        if not api_key or api_key != API_KEY:\r\n            return jsonify({'error': 'Unauthorized'}), 401\r\n        return f(*args, **kwargs)\r\n    return decorated\r\n\r\n@app.route('/api/items', methods=['GET'])\r\n@require_api_key\r\ndef get_items():\r\n    items = Item.query.all()\r\n    return jsonify([item.to_dict() for item in items])\r\n\r\n@app.route('/api/items', methods=['POST'])\r\n@require_api_key\r\ndef create_item():\r\n    data = request.get_json()\r\n    if not data:\r\n        return jsonify({'error': 'No data provided'}), 400\r\n\r\n    sku = data.get('sku')\r\n    name = data.get('name')\r\n    quantity = data.get('quantity', 0)\r\n\r\n    if not sku or not name:\r\n        return jsonify({'error': 'sku and name are required'}), 400\r\n\r\n    existing = Item.query.f"]
[12.416495, "o", "ilter_by(sku=sku).first()\r\n    if existing:\r\n        return jsonify({'error': 'Item with this SKU already exists'}), 409\r\n\r\n    item = Item(sku=sku, name=name, quantity=quantity)\r\n    db.session.add(item)\r\n    db.session.commit()\r\n\r\n    return jsonify(item.to_dict()), 201\r\n\r\nif __name__ == '__main__':\r\n    app.run(host='0.0.0.0', port=8080)\r\n"]
