[?2004l.PHONY: report clean check-config$
$
# Main target to generate the monitoring report$
report: check-config results/status.json$
^I@echo "Monitoring report complete!"$
$
# Check if hosts.conf exists before proceeding$
check-config:$
^I@if [ ! -f hosts.conf ]; then echo "Error: hosts.conf is missing. Cannot proceed."; exit 1; fi$
^I@echo "Configuration file found."$
$
# Ensure results directory exists$
results:$
^Imkdir -p results$
$
# Run ping checks$
