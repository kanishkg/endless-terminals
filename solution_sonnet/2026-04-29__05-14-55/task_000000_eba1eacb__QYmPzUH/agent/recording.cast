[81.19001, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean check-config ping ports aggregate\n\n# Main target to generate the monitoring report\nreport: check-config results/status.json\n\t@echo \"Monitoring report complete!\"\n\n# Check if hosts.conf exists before proceeding\ncheck-config:\n\t@if [ ! -f hosts.conf ]; then \\\n\t\techo \"Error: hosts.conf is missing. Cannot proceed.\"; \\\n\t\texit 1; \\\n\tfi\n\t@echo \"Configuration file found.\"\n\n# Ensure results directory exists\nresults:\n\tmkdir -p results\n\n# Run ping checks\nresults/ping.txt: check-config results hosts.conf scripts/check_ping.sh\n\t@echo \"Running ping checks...\"\n\t./scripts/check_ping.sh\n\n# Run port checks\nresults/ports.txt: check-config results hosts.conf scripts/check_ports.sh\n\t@echo \"Running port checks...\"\n\t./scripts/check_ports.sh\n\n# Aggregate results into JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\t@echo \"Aggregating results...\"\n\tpython3 aggregate.py\n\n# Clean up generated files\nclean:\n\trm -rf results\n\t@echo \"Cleaned up results directory.\"\nEO"]
