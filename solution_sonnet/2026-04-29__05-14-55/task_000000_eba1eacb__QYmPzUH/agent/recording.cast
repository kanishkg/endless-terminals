[137.546591, "o", "results:$\r\n^Imkdir -p results$\r\n$\r\n# Run ping checks$\r\nresults/ping.txt: check-config results hosts.conf scripts/check_ping.sh$\r\n^I@echo \"Running ping checks...\"$\r\n^I./scripts/check_ping.sh$\r\n$\r\n"]
