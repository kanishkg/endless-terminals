[?2004l[?2004h>                 rejection_reasons.append('Missing name')
[?2004l[?2004h>             if not serial:
[?2004l[?2004h>                 rejection_reasons.append('Missing serial')
[?2004l[?2004h>             if not location:
[?2004l[?2004h>                 rejection_reasons.append('Missing location')
[?2004l[?2004h>             
[?2004l[?2004h>             # If any validation failed, reject the record
