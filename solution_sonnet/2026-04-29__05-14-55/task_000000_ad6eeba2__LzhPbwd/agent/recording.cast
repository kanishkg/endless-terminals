[29.170248, "i", "{\n                    'original_row': original_row,\n                    'reason': '; '.join(rejection_reasons)\n                })\n                continue\n            \n            # Create valid record\n            record = {\n                'id': asset_id,\n                'name': name,\n                'serial': serial,\n                'purchase_date': purchase_date,\n                'price_cents': price_cents,\n                'location': location\n            }\n            \n            # Handle duplicates - keep the one with latest purchase date\n            if asset_id in valid_records:\n                existing_date = valid_records[asset_id]['purchase_date']\n                if purchase_date > existing_date:\n                    valid_records[asset_id] = record\n            else:\n                valid_records[asset_id] = record\n    \n    # Convert to list\n    assets_list = list(valid_records.values())\n    \n    # Write valid records\n    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\n     "]
