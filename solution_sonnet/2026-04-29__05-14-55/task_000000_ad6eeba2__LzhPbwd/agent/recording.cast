[58.498157, "o", "            # Handle duplicates - keep the one with latest purchase date\r\n\u001b[?2004l\r"]
[58.498184, "o", "\u001b[?2004h"]
[58.498212, "o", "> "]
[58.498312, "o", "            if asset_id in valid_records:\r\n\u001b[?2004l\r"]
[58.498341, "o", "\u001b[?2004h> "]
[58.498542, "o", "                existing_date = valid_records[asset_id]['purchase_date']\r\n\u001b[?2004l\r"]
[58.49857, "o", "\u001b[?2004h> "]
[58.498712, "o", "                if purchase_date > existing_date:\r\n\u001b[?2004l\r"]
[58.498739, "o", "\u001b[?2004h> "]
[58.498901, "o", "                    valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[58.498936, "o", "\u001b[?2004h"]
[58.498965, "o", "> "]
[58.498992, "o", "            else:\r\n\u001b[?2004l\r"]
[58.499021, "o", "\u001b[?2004h> "]
[58.499144, "o", "                valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[58.499178, "o", "\u001b[?2004h> "]
[58.499206, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[58.499234, "o", "> "]
[58.499283, "o", "    # Convert to list\r\n\u001b[?2004l\r"]
[58.499311, "o", "\u001b[?2004h> "]
[58.499451, "o", "    assets_list = list(valid_records.values())\r\n\u001b[?2004l\r"]
[58.499481, "o", "\u001b[?2004h> "]
[58.499509, "o", "    \r\n\u001b[?2004l\r"]
[58.499537, "o", "\u001b[?2004h> "]
[58.499604, "o", "    # Write valid records\r\n\u001b[?2004l\r"]
[58.499632, "o", "\u001b[?2004h> "]
[58.499864, "o", "    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[58.49989, "o", "\u001b[?2004h"]
[58.499922, "o", "> "]
[58.500015, "o", "        json.dump(assets_list, f, indent=2)\r\n\u001b[?2004l\r"]
[58.500044, "o", "\u001b[?2004h> "]
[58.500072, "o", "    \r\n\u001b[?2004l\r"]
[58.5001, "o", "\u001b[?2004h> "]
[58.500177, "o", "    # Write rejected records\r\n\u001b[?2004l\r"]
[58.500206, "o", "\u001b[?2004h> "]
[58.50043, "o", "    with open('/home/user/inventory/rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[58.500458, "o", "\u001b[?2004h> "]
[58.500601, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[58.500632, "o", "\u001b[?2004h> "]
[58.500664, "o", "    \r\n\u001b[?2004l\r"]
[58.500693, "o", "\u001b[?2004h> "]
[58.500828, "o", "    print(f\"Processed {len(assets_list)} valid assets\")\r\n\u001b[?2004l\r"]
[58.500871, "o", "\u001b[?2004h"]
[58.500895, "o", "> "]
[58.501022, "o", "    print(f\"Rejected {len(rejected_records)} records\")\r\n\u001b[?2004l\r"]
[58.501051, "o", "\u001b[?2004h> "]
[58.501263, "o", "    print(f\"Total input rows: {len(assets_list) + len(rejected_records)}\")\r\n\u001b[?2004l\r"]
[58.50129, "o", "\u001b[?2004h> "]
[58.501309, "o", "\r\n\u001b[?2004l\r"]
[58.50134, "o", "\u001b[?2004h> "]
[58.501408, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[58.501437, "o", "\u001b[?2004h"]
[58.501466, "o", "> "]
[58.501495, "o", "    process_csv()\r\n\u001b[?2004l\r"]
[58.501523, "o", "\u001b[?2004h> "]
