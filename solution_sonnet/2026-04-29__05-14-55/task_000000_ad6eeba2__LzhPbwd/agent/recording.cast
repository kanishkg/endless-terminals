[58.481043, "i", "cat > /home/user/inventory/process_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse various date formats to ISO 8601\"\"\"\n    date_str = date_str.strip()\n    \n    # Try MM/DD/YYYY\n    try:\n        dt = datetime.strptime(date_str, '%m/%d/%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try YYYY-MM-DD (already ISO)\n    try:\n        dt = datetime.strptime(date_str, '%Y-%m-%d')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try DD.MM.YYYY (European)\n    try:\n        dt = datetime.strptime(date_str, '%d.%m.%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price to cents (integer)\"\"\"\n    price_str = str(price_str).strip()\n    \n    # Remove dollar signs, commas, quotes\n    price_str = price_str.replace('$', '').replace(',', '').replace('\"',"]
[58.481163, "i", " '').strip()\n    \n    try:\n        # Convert to float first, then to cents\n        price_float = float(price_str)\n        price_cents = int(round(price_float * 100))\n        \n        if price_cents <= 0:\n            return None\n        \n        return price_cents\n    except (ValueError, TypeError):\n        return None\n\ndef fix_swapped_columns(row):\n    \"\"\"Detect and fix swapped name/serial columns\"\"\"\n    name = row.get('name', '').strip()\n    serial = row.get('serial', '').strip()\n    \n    # If name looks like a serial (starts with SN-) and serial doesn't, swap them\n    if name.startswith('SN-') and not serial.startswith('SN-'):\n        row['name'] = serial\n        row['serial'] = name\n    \n    return row\n\ndef process_csv():\n    valid_records = {}\n    rejected_records = []\n    \n    with open('/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        \n        for row_num, row in enumerate(reader, start=2):\n            original_row = dict(row)\n            rejectio"]
[58.481203, "i", "n_reasons = []\n            \n            # Fix swapped columns if needed\n            row = fix_swapped_columns(row)\n            \n            # Extract and validate fields\n            asset_id = row.get('id', '').strip()\n            name = row.get('name', '').strip()\n            serial = row.get('serial', '').strip()\n            location = row.get('location', '').strip()\n            \n            if not asset_id:\n                rejected_records.append({\n                    'original_row': original_row,\n                    'reason': 'Missing asset ID'\n                })\n                continue\n            \n            # Parse date\n            purchase_date = parse_date(row.get('purchase_date', ''))\n            if not purchase_date:\n                rejection_reasons.append(f\"Invalid date format: {row.get('purchase_date', '')}\")\n            \n            # Parse price\n            price_cents = parse_price(row.get('price', ''))\n            if price_cents is None:\n                rejection_reasons.append(f\"Invalid p"]
[58.481244, "i", "rice: {row.get('price', '')}\")\n            \n            # Check for missing required fields\n            if not name:\n                rejection_reasons.append('Missing name')\n            if not serial:\n                rejection_reasons.append('Missing serial')\n            if not location:\n                rejection_reasons.append('Missing location')\n            \n            # If any validation failed, reject the record\n            if rejection_reasons:\n                rejected_records.append({\n                    'original_row': original_row,\n                    'reason': '; '.join(rejection_reasons)\n                })\n                continue\n            \n            # Create valid record\n            record = {\n                'id': asset_id,\n                'name': name,\n                'serial': serial,\n                'purchase_date': purchase_date,\n                'price_cents': price_cents,\n                'location': location\n            }\n            \n            # Handle duplicates - keep the one with "]
