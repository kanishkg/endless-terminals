[10.061105, "o", "cat rules.sh\r\n\u001b[?2004l\r"]
[10.061938, "o", "#!/bin/bash\r\n# Flush existing rules\r\niptables -F\r\niptables -t nat -F\r\n\r\n# Default policies\r\niptables -P INPUT DROP\r\niptables -P FORWARD DROP\r\niptables -P OUTPUT ACCEPT\r\n\r\n# Allow established connections\r\niptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT\r\niptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT\r\n\r\n# Allow SSH to gateway\r\niptables -A INPUT -p tcp --dport 22 -j ACCEPT\r\n\r\n# Allow inference subnet to registry (THE USER'S RULE - WRONG CHAIN)\r\niptables -A INPUT -s 10.200.0.0/16 -p tcp --dport 5000 -j ACCEPT\r\n\r\n# NAT for outbound\r\niptables -t nat -A POSTROUTING -s 10.200.0.0/16 -o eth2 -j MASQUERADE\r\n\r\n# Block known bad actors\r\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.0/16 -j LOG --log-prefix \"FORWARD_DROP: \"\r\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.0/16 -j DROP\r\n\r\n# General forwarding (added later, supposedly to fix things)\r\niptables -A FORWARD -i eth1 -o eth2 -j ACCEPT\r\n"]
[10.062099, "o", "\u001b[?2004h"]
[10.062137, "o", "root@a31c3d1cad0d:/home/user/firewall# "]
[24.143945, "i", "cp rules.sh rules.sh.backup\n"]
[24.144078, "o", "cp rules.sh rules.sh.backup\r\n\u001b[?2004l\r"]
[24.14852, "o", "\u001b[?2004h"]
[24.148588, "o", "root@a31c3d1cad0d:/home/user/firewall# "]
[24.240537, "i", "cat > rules.sh << 'EOF'\n#!/bin/bash\n# Flush existing rules\niptables -F\niptables -t nat -F\n\n# Default policies\niptables -P INPUT DROP\niptables -P FORWARD DROP\niptables -P OUTPUT ACCEPT\n\n# Allow established connections\niptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT\niptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT\n\n# Allow SSH to gateway\niptables -A INPUT -p tcp --dport 22 -j ACCEPT\n\n# Allow inference subnet to registry on port 5000 (FIXED: moved to FORWARD chain)\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.42 -p tcp --dport 5000 -j ACCEPT\n\n# NAT for outbound\niptables -t nat -A POSTROUTING -s 10.200.0.0/16 -o eth2 -j MASQUERADE\n\n# General forwarding between networks\niptables -A FORWARD -i eth1 -o eth2 -j ACCEPT\niptables -A FORWARD -i eth2 -o eth1 -j ACCEPT\nEOF\n"]
