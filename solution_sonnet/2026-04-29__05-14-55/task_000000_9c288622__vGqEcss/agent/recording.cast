[18.644675, "o", "# Scheduler crontab - runs at the top of every hour\r\n0 * * * * cd /home/user/scheduler && python3 app.py >> /home/user/scheduler/output.log 2>&1\r\n"]
[18.644831, "o", "\u001b[?2004h"]
