[62.055662, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean\n\n# Check that hosts.conf exists before doing anything\ncheck-config:\n\t@test -f hosts.conf || (echo \"Error: hosts.conf not found\" && exit 1)\n\n# Main target to generate the report\nreport: results/status.json\n\t@echo \"Monitoring report complete\"\n\n# Generate the aggregated JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\t./aggregate.py\n\n# Run ping checks\nresults/ping.txt: hosts.conf scripts/check_ping.sh | check-config\n\t./scripts/check_ping.sh\n\n# Run port checks\nresults/ports.txt: hosts.conf scripts/check_ports.sh | check-config\n\t./scripts/check_ports.sh\n\n# Clean up generated files\nclean:\n\trm -rf results\nEOF\n"]
