[20.805349, "i", "cat > /home/user/process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Process each host file\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handle missing values gracefully\n    mem_total=$(grep -E '^MemTotal:' \"$file\" 2>/dev/null | awk '{print $2}')\n    mem_available=$(grep -E '^MemAvailable:' \"$file\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty\n    if [[ -z \"$mem_total\" ]] || [[ -z \"$mem_available\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available\n    percent_available=$(awk \"BEGIN {printf \\\"%.2f\\\", ($mem_available / $mem_total) * 100}\")\n    \n    # Check if less than 20%\n    is_low=$(awk \"BEGIN {print ($percent_available < 20) ? 1 : 0}\")\n    \n    if [[ \"$is_low\" -eq 1 ]]; then\n        echo -e \"${hostname}\\t${percent_available}\"\n    fi\ndone | sort -t$'\\t' -k2 -n\nEOF\n"]
