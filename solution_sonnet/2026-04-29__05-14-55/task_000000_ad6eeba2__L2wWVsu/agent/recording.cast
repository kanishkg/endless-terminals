[45.884076, "o", "\u001b[?2004h"]
[45.884102, "o", ">         \r\n"]
[45.884129, "o", "\u001b[?2004l\r\u001b[?2004h"]
[45.884155, "o", "> "]
[45.884225, "o", "        return price_cents\r\n\u001b[?2004l\r"]
[45.884254, "o", "\u001b[?2004h> "]
[45.884417, "o", "    except (InvalidOperation, ValueError, AttributeError):\r\n\u001b[?2004l\r"]
[45.884446, "o", "\u001b[?2004h> "]
[45.884506, "o", "        return None\r\n\u001b[?2004l\r"]
[45.884538, "o", "\u001b[?2004h"]
[45.88457, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[45.884598, "o", "> "]
[45.884658, "o", "def is_serial_format(value):\r\n\u001b[?2004l\r"]
[45.884686, "o", "\u001b[?2004h> "]
[45.884892, "o", "    \"\"\"Check if value looks like a serial number (SN-XXX-XXXXX format)\"\"\"\r\n\u001b[?2004l\r"]
[45.884918, "o", "\u001b[?2004h> "]
[45.885104, "o", "    return bool(re.match(r'^SN-[A-Z]{3}-\\d{5}$', value.strip()))\r\n\u001b[?2004l\r"]
[45.885132, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[45.885159, "o", "\u001b[?2004h"]
[45.885203, "o", "> "]
[45.885265, "o", "def process_row(row, row_num):\r\n\u001b[?2004l\r"]
[45.885293, "o", "\u001b[?2004h> "]
[45.885485, "o", "    \"\"\"Process a single row and return normalized data or error\"\"\"\r\n\u001b[?2004l\r"]
[45.885517, "o", "\u001b[?2004h> "]
[45.885544, "o", "    try:\r\n\u001b[?2004l\r"]
[45.885573, "o", "\u001b[?2004h> "]
[45.885692, "o", "        asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[45.885721, "o", "\u001b[?2004h> "]
[45.885842, "o", "        name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[45.885869, "o", "\u001b[?2004h> "]
[45.886003, "o", "        serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[45.886031, "o", "\u001b[?2004h> "]
[45.886222, "o", "        purchase_date_str = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[45.886253, "o", "\u001b[?2004h> "]
[45.886389, "o", "        price_str = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[45.886409, "o", "\u001b[?2004h"]
[45.886438, "o", "> "]
[45.886557, "o", "        location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[45.886582, "o", "\u001b[?2004h"]
[45.88661, "o", "> "]
[45.886633, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[45.88666, "o", "> "]
[45.886782, "o", "        # Check for swapped name and serial\r\n\u001b[?2004l\r"]
[45.886807, "o", "\u001b[?2004h"]
[45.886832, "o", "> "]
[45.887002, "o", "        if is_serial_format(name) and not is_serial_format(serial):\r\n\u001b[?2004l\r"]
[45.88703, "o", "\u001b[?2004h"]
[45.887057, "o", "> "]
[45.887144, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[45.88716, "o", "\u001b[?2004h"]
[45.887215, "o", "> "]
[45.887243, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.887339, "o", "        # Validate and parse date\r\n\u001b[?2004l\r"]
[45.887362, "o", "\u001b[?2004h"]
[45.887387, "o", "> "]
[45.887589, "o", "        purchase_date_iso, purchase_date_obj = parse_date(purchase_date_str)\r\n\u001b[?2004l\r"]
[45.887615, "o", "\u001b[?2004h> "]
[45.887713, "o", "        if not purchase_date_iso:\r\n\u001b[?2004l\r"]
[45.887737, "o", "\u001b[?2004h"]
[45.887765, "o", "> "]
[45.887937, "o", "            return None, f\"Invalid date format: {purchase_date_str}\"\r\n\u001b[?2004l\r"]
[45.887965, "o", "\u001b[?2004h> "]
[45.887994, "o", "        \r\n\u001b[?2004l\r"]
[45.888023, "o", "\u001b[?2004h> "]
[45.888123, "o", "        # Validate and parse price\r\n\u001b[?2004l\r"]
[45.888153, "o", "\u001b[?2004h> "]
[45.888291, "o", "        price_cents = parse_price(price_str)\r\n\u001b[?2004l\r"]
[45.888321, "o", "\u001b[?2004h> "]
[45.888413, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[45.888449, "o", "\u001b[?2004h> "]
[45.888613, "o", "            return None, f\"Invalid price format: {price_str}\"\r\n\u001b[?2004l\r"]
[45.888642, "o", "\u001b[?2004h> "]
[45.888672, "o", "        \r\n\u001b[?2004l\r"]
[45.888697, "o", "\u001b[?2004h> "]
[45.888781, "o", "        if price_cents <= 0:\r\n\u001b[?2004l\r"]
[45.88881, "o", "\u001b[?2004h> "]
[45.889025, "o", "            return None, f\"Price must be positive, got: {price_cents} cents\"\r\n\u001b[?2004l\r"]
[45.889052, "o", "\u001b[?2004h"]
[45.889082, "o", ">         \r\n\u001b[?2004l\r"]
[45.889107, "o", "\u001b[?2004h"]
[45.889133, "o", "> "]
[45.889217, "o", "        # Validate required fields\r\n\u001b[?2004l\r"]
[45.889246, "o", "\u001b[?2004h> "]
[45.889317, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[45.889399, "o", "\u001b[?2004h> "]
[45.889478, "o", "            return None, \"Missing asset ID\"\r\n\u001b[?2004l\r"]
[45.889507, "o", "\u001b[?2004h> "]
[45.88957, "o", "        if not name:\r\n\u001b[?2004l\r"]
[45.889599, "o", "\u001b[?2004h> "]
[45.889713, "o", "            return None, \"Missing name\"\r\n\u001b[?2004l\r"]
[45.889743, "o", "\u001b[?2004h> "]
[45.889811, "o", "        if not serial:\r\n\u001b[?2004l\r"]
[45.889839, "o", "\u001b[?2004h> "]
[45.88996, "o", "            return None, \"Missing serial\"\r\n\u001b[?2004l\r"]
[45.889982, "o", "\u001b[?2004h"]
[45.890008, "o", "> "]
[45.890063, "o", "        if not location:\r\n\u001b[?2004l\r"]
[45.890094, "o", "\u001b[?2004h> "]
[45.890229, "o", "            return None, \"Missing location\"\r\n\u001b[?2004l\r"]
[45.890258, "o", "\u001b[?2004h> "]
[45.890284, "o", "        \r\n\u001b[?2004l\r"]
[45.890317, "o", "\u001b[?2004h> "]
[45.890411, "o", "        # Return normalized record\r\n\u001b[?2004l\r"]
[45.890438, "o", "\u001b[?2004h> "]
[45.890496, "o", "        record = {\r\n\u001b[?2004l\r"]
[45.890523, "o", "\u001b[?2004h> "]
[45.890605, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[45.890626, "o", "\u001b[?2004h"]
[45.890655, "o", "> "]
[45.890709, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[45.890739, "o", "\u001b[?2004h"]
[45.89077, "o", "> "]
[45.890833, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[45.890861, "o", "\u001b[?2004h"]
[45.89089, "o", "> "]
[45.891002, "o", "            'purchase_date': purchase_date_iso,\r\n\u001b[?2004l\r"]
[45.89103, "o", "\u001b[?2004h"]
[45.891056, "o", "> "]
[45.891145, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[45.891179, "o", "\u001b[?2004h"]
[45.891207, "o", "> "]
[45.891281, "o", "            'location': location,\r\n\u001b[?2004l\r"]
[45.891308, "o", "\u001b[?2004h> "]
[45.891487, "o", "            '_date_obj': purchase_date_obj  # For deduplication\r\n\u001b[?2004l\r"]
[45.891515, "o", "\u001b[?2004h> "]
[45.891548, "o", "        }\r\n\u001b[?2004l\r"]
[45.891576, "o", "\u001b[?2004h> "]
[45.891614, "o", "        \r\n"]
[45.891643, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[45.891721, "o", "        return record, None\r\n\u001b[?2004l\r"]
[45.891751, "o", "\u001b[?2004h> "]
[45.891782, "o", "        \r\n\u001b[?2004l\r"]
[45.891811, "o", "\u001b[?2004h> "]
[45.89189, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[45.891917, "o", "\u001b[?2004h> "]
[45.892062, "o", "        return None, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[45.892089, "o", "\u001b[?2004h> "]
[45.892117, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.892143, "o", "> "]
[45.892188, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.89222, "o", "> "]
[45.892268, "o", "    valid_records = {}\r\n\u001b[?2004l\r"]
[45.892298, "o", "\u001b[?2004h> "]
[45.892372, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[45.892401, "o", "\u001b[?2004h> "]
[45.892429, "o", "    \r\n\u001b[?2004l\r"]
[45.892457, "o", "\u001b[?2004h> "]
[45.892527, "o", "    # Read and process CSV\r\n\u001b[?2004l\r"]
[45.892555, "o", "\u001b[?2004h> "]
[45.892773, "o", "    with open('/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[45.892802, "o", "\u001b[?2004h> "]
[45.892901, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[45.89293, "o", "\u001b[?2004h> "]
[45.892956, "o", "        \r\n"]
[45.892985, "o", "\u001b[?2004l\r\u001b[?2004h"]
[45.893011, "o", "> "]
[45.893245, "o", "        for row_num, row in enumerate(reader, start=2):  # Start at 2 (header is row 1)\r\n\u001b[?2004l\r"]
[45.89327, "o", "\u001b[?2004h> "]
[45.893423, "o", "            record, error = process_row(row, row_num)\r\n\u001b[?2004l\r"]
[45.893451, "o", "\u001b[?2004h> "]
[45.893491, "o", "            \r\n\u001b[?2004l\r"]
[45.89352, "o", "\u001b[?2004h> "]
[45.893585, "o", "            if error:\r\n\u001b[?2004l\r"]
[45.893613, "o", "\u001b[?2004h> "]
[45.893713, "o", "                # Add to rejected\r\n\u001b[?2004l\r"]
[45.893742, "o", "\u001b[?2004h> "]
[45.893862, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[45.893888, "o", "\u001b[?2004h> "]
[45.894023, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[45.894061, "o", "\u001b[?2004h> "]
[45.894156, "o", "                    'reason': error\r\n\u001b[?2004l\r"]
[45.894203, "o", "\u001b[?2004h"]
[45.894233, "o", "> "]
[45.894261, "o", "                })\r\n\u001b[?2004l\r"]
[45.89429, "o", "\u001b[?2004h"]
[45.894318, "o", "> "]
[45.894348, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.894379, "o", "> "]
[45.894472, "o", "                asset_id = record['id']\r\n\u001b[?2004l\r"]
[45.8945, "o", "\u001b[?2004h> "]
[45.894551, "o", "                \r\n\u001b[?2004l\r"]
[45.894578, "o", "\u001b[?2004h> "]
[45.894803, "o", "                # Handle duplicates - keep the one with latest purchase date\r\n\u001b[?2004l\r"]
[45.89483, "o", "\u001b[?2004h> "]
[45.894962, "o", "                if asset_id in valid_records:\r\n\u001b[?2004l\r"]
[45.894984, "o", "\u001b[?2004h"]
[45.894997, "o", "> "]
[45.895143, "o", "                    existing = valid_records[asset_id]\r\n\u001b[?2004l\r"]
[45.895181, "o", "\u001b[?2004h> "]
[45.895378, "o", "                    if record['_date_obj'] > existing['_date_obj']:\r\n\u001b[?2004l\r"]
[45.895406, "o", "\u001b[?2004h> "]
[45.895567, "o", "                        valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[45.895594, "o", "\u001b[?2004h"]
[45.895623, "o", "> "]
[45.895667, "o", "                else:\r\n\u001b[?2004l\r"]
[45.895694, "o", "\u001b[?2004h"]
[45.895705, "o", "> "]
[45.89584, "o", "                    valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[45.895877, "o", "\u001b[?2004h> "]
[45.895904, "o", "    \r\n\u001b[?2004l\r"]
[45.895929, "o", "\u001b[?2004h> "]
[45.896086, "o", "    # Remove temporary _date_obj field and convert to list\r\n\u001b[?2004l\r"]
[45.896114, "o", "\u001b[?2004h> "]
[45.896194, "o", "    final_records = []\r\n\u001b[?2004l\r"]
[45.896223, "o", "\u001b[?2004h> "]
[45.896345, "o", "    for record in valid_records.values():\r\n\u001b[?2004l\r"]
[45.896369, "o", "\u001b[?2004h"]
[45.896397, "o", "> "]
[45.896465, "o", "        del record['_date_obj']\r\n\u001b[?2004l\r"]
[45.896493, "o", "\u001b[?2004h> "]
[45.896602, "o", "        final_records.append(record)\r\n\u001b[?2004l\r"]
[45.89663, "o", "\u001b[?2004h> "]
[45.896657, "o", "    \r\n\u001b[?2004l\r"]
[45.896683, "o", "\u001b[?2004h> "]
[45.896787, "o", "    # Sort by ID for consistent output\r\n\u001b[?2004l\r"]
[45.896814, "o", "\u001b[?2004h> "]
[45.896947, "o", "    final_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[45.89697, "o", "\u001b[?2004h"]
[45.896996, "o", ">     \r\n\u001b[?2004l\r"]
[45.897025, "o", "\u001b[?2004h> "]
[45.897139, "o", "    # Write valid records to assets.json\r\n\u001b[?2004l\r"]
[45.897182, "o", "\u001b[?2004h"]
[45.897219, "o", "> "]
[45.897441, "o", "    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[45.897468, "o", "\u001b[?2004h"]
[45.897497, "o", "> "]
[45.897607, "o", "        json.dump(final_records, f, indent=2)\r\n\u001b[?2004l\r"]
[45.897632, "o", "\u001b[?2004h"]
[45.897643, "o", "> "]
[45.897687, "o", "    \r\n\u001b[?2004l\r"]
[45.897707, "o", "\u001b[?2004h> "]
[45.897814, "o", "    # Write rejected records to rejected.json\r\n\u001b[?2004l\r"]
[45.897841, "o", "\u001b[?2004h"]
[45.89786, "o", "> "]
[45.898067, "o", "    with open('/home/user/inventory/rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[45.898095, "o", "\u001b[?2004h> "]
[45.898252, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[45.898278, "o", "\u001b[?2004h"]
[45.898288, "o", "> "]
[45.898329, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.898494, "o", "    print(f\"Processed {len(valid_records)} valid records\")\r\n\u001b[?2004l\r"]
[45.898516, "o", "\u001b[?2004h"]
[45.898529, "o", "> "]
[45.898677, "o", "    print(f\"Rejected {len(rejected_records)} records\")\r\n\u001b[?2004l\r"]
[45.898705, "o", "\u001b[?2004h> "]
[45.898895, "o", "    print(f\"Output written to assets.json and rejected.json\")\r\n\u001b[?2004l\r"]
[45.898924, "o", "\u001b[?2004h> "]
[45.898954, "o", "\r\n\u001b[?2004l\r"]
[45.898982, "o", "\u001b[?2004h> "]
[45.899039, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[45.899064, "o", "\u001b[?2004h"]
[45.899096, "o", "> "]
[45.899113, "o", "    main()\r\n\u001b[?2004l\r"]
[45.899153, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[45.902164, "o", "\u001b[?2004h"]
[45.902211, "o", "user@56d33505d48c:~/inventory$ "]
[45.978498, "i", "python3 process_assets.py\n"]
[45.978606, "o", "python3 process_assets.py\r\n\u001b[?2004l\r"]
[46.024286, "o", "Processed 809 valid records\r\nRejected 16 records\r\nOutput written to assets.json and rejected.json\r\n"]
[46.028452, "o", "\u001b[?2004h"]
