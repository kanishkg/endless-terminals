[88.865386, "i", "python3 << 'EOF'\nimport json\nimport re\nfrom datetime import datetime\n\n# Load the data\nwith open('assets.json') as f:\n    data = json.load(f)\n\nprint(f\"Total valid records: {len(data)}\")\nprint(\"\\nValidating all records...\")\n\nerrors = []\nfor record in data:\n    # Check all required fields\n    required = ['id', 'name', 'serial', 'purchase_date', 'price_cents', 'location']\n    for field in required:\n        if field not in record:\n            errors.append(f\"Record {record.get('id', 'unknown')}: missing {field}\")\n    \n    # Validate price_cents is positive integer\n    if not isinstance(record.get('price_cents'), int):\n        errors.append(f\"Record {record['id']}: price_cents not an integer\")\n    elif record['price_cents'] <= 0:\n        errors.append(f\"Record {record['id']}: price_cents not positive\")\n    \n    # Validate ISO 8601 date format\n    try:\n        datetime.fromisoformat(record['purchase_date'])\n    except (ValueError, KeyError):\n        errors.append(f\"Record {record['id']}: invalid ISO 8601 date\")\n\nif "]
[88.865437, "i", "errors:\n    print(f\"\\nFound {len(errors)} validation errors:\")\n    for err in errors[:10]:\n        print(f\"  - {err}\")\nelse:\n    print(\"\\n✓ All records pass validation!\")\n    print(\"✓ All purchase_date fields are valid ISO 8601\")\n    print(\"✓ All price_cents fields are positive integers\")\n    print(\"✓ All required fields present\")\n\n# Check for duplicate IDs\nids = [r['id'] for r in data]\nif len(ids) != len(set(ids)):\n    print(\"\\n✗ Found duplicate IDs!\")\nelse:\n    print(\"✓ No duplicate IDs\")\n\nprint(f\"\\nSummary:\")\nprint(f\"  - Valid records: {len(data)}\")\nwith open('rejected.json') as f:\n    rejected = json.load(f)\nprint(f\"  - Rejected records: {len(rejected)}\")\nEOF\n"]
