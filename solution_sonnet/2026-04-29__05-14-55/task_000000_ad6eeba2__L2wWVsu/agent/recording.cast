[55.86173, "o", "[\r\n  {\r\n    \"id\": \"AST-00001\",\r\n    \"name\": \"Whiteboard Digital\",\r\n    \"serial\": \"SN-QQB-00002\","]
[55.8618, "o", "\r\n    \"purchase_date\": \"2023-10-08\",\r\n    \"price_cents\": 381700,\r\n    \"location\": \"Warehouse A\"\r\n  },\r\n  {\r\n"]
[55.86184, "o", "    \"id\": \"AST-00002\",\r\n    \"name\": \"Headset Bluetooth\",\r\n    \"serial\": \"SN-DLP-00003\",\r\n    \"purchase_date\": \"2017-11-15\",\r\n    \"price_cents\": 279400,\r\n    \"location\": \"Building C\"\r\n  },\r\n  {\r\n    \"id\": \"AST-00003\",\r\n    \"name\": \"Server Rack\",\r\n    \"serial\": \"SN-ZBN-00004\",\r\n    \"purchase_date\": \"2021-08-02\",\r\n    \"price_cents\": 338200,\r\n    \"location\": \"Warehouse A\"\r\n  },\r\n  {\r\n    \"id\": \"AST-00004\",\r\n    \"name\": \"Network Switch\",\r\n    \"serial\": \"SN-KJT-00005\",\r\n    \"purchase_date\": \"2020-04-16\",\r\n    \"price_cents\": 409400,\r\n    \"location\": \"Warehouse B\"\r\n  },\r\n  {\r\n    \"id\": \"AST-00005\",\r\n    \"name\": \"Network Switch\",\r\n    \"serial\": \"SN-PTD-00006\",\r\n    \"purchase_date\": \"2017-11-15\",\r\n    \"price_cents\": 369584,\r\n    \"location\": \"IT Closet\"\r\n"]
