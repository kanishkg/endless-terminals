[80.877484, "i", "python3 << 'PYEOF'\nimport json\n\n# Validate assets.json\nwith open('assets.json', 'r') as f:\n    data = json.load(f)\n\nprint(f'Valid records: {len(data)}')\nprint(f'All have required fields: {all(set(r.keys()) == {\"id\", \"name\", \"serial\", \"purchase_date\", \"price_cents\", \"location\"} for r in data)}')\nprint(f'All price_cents are positive integers: {all(isinstance(r[\"price_cents\"], int) and r[\"price_cents\"] > 0 for r in data)}')\nprint(f'All dates are ISO 8601 format: {all(len(r[\"purchase_date\"]) == 10 for r in data)}')\nprint(f'All IDs are unique: {len(data) == len(set(r[\"id\"] for r in data))}')\n\n# Validate rejected.json\nwith open('rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(f'\\nRejected records: {len(rejected)}')\nprint(f'All rejected have original_row and reason: {all(\"original_row\" in r and \"reason\" in r for r in rejected)}')\n\nprint('\\nValidation complete!')\nPYEOF\n"]
