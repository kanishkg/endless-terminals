[41.921993, "o", "def process_csv():\r\n\u001b[?2004l\r"]
[41.92202, "o", "\u001b[?2004h> "]
[41.92209, "o", "    valid_records = {}\r\n\u001b[?2004l\r"]
[41.922117, "o", "\u001b[?2004h> "]
[41.922197, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[41.922225, "o", "\u001b[?2004h> "]
[41.922254, "o", "    \r\n\u001b[?2004l\r"]
[41.922281, "o", "\u001b[?2004h> "]
[41.922445, "o", "    with open('/home/user/inventory/assets.csv', 'r') as f:\r\n\u001b[?2004l\r"]
[41.922487, "o", "\u001b[?2004h> "]
[41.922585, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[41.922613, "o", "\u001b[?2004h> "]
[41.922642, "o", "        \r\n\u001b[?2004l\r"]
[41.922676, "o", "\u001b[?2004h> "]
[41.922828, "o", "        for row_num, row in enumerate(reader, start=2):\r\n\u001b[?2004l\r"]
[41.922856, "o", "\u001b[?2004h> "]
[41.92297, "o", "            original_row = dict(row)\r\n\u001b[?2004l\r"]
[41.923, "o", "\u001b[?2004h> "]
[41.923065, "o", "            reason = []\r\n\u001b[?2004l\r"]
[41.923093, "o", "\u001b[?2004h> "]
[41.923135, "o", "            \r\n\u001b[?2004l\r"]
[41.923161, "o", "\u001b[?2004h> "]
[41.923248, "o", "            # Extract fields\r\n\u001b[?2004l\r"]
[41.923275, "o", "\u001b[?2004h> "]
[41.923416, "o", "            asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[41.923447, "o", "\u001b[?2004h> "]
[41.923593, "o", "            name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[41.923622, "o", "\u001b[?2004h"]
[41.923648, "o", "> "]
[41.923763, "o", "            serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[41.92379, "o", "\u001b[?2004h"]
[41.923816, "o", "> "]
[41.923986, "o", "            purchase_date_raw = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[41.924015, "o", "\u001b[?2004h> "]
[41.924173, "o", "            price_raw = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[41.924203, "o", "\u001b[?2004h> "]
[41.924356, "o", "            location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[41.924383, "o", "\u001b[?2004h> "]
[41.924424, "o", "            \r\n\u001b[?2004l\r"]
[41.924453, "o", "\u001b[?2004h> "]
[41.924693, "o", "            # Check if serial and name are swapped (serial should start with SN-)\r\n\u001b[?2004l\r"]
[41.924725, "o", "\u001b[?2004h> "]
[41.924952, "o", "            if serial and not serial.startswith('SN-') and name.startswith('SN-'):\r\n\u001b[?2004l\r"]
[41.92498, "o", "\u001b[?2004h> "]
[41.925062, "o", "                # Swap them\r\n\u001b[?2004l\r"]
[41.925091, "o", "\u001b[?2004h> "]
[41.925217, "o", "                name, serial = serial, name\r\n\u001b[?2004l\r"]
[41.925246, "o", "\u001b[?2004h"]
[41.925275, "o", "> "]
[41.925302, "o", "            \r\n\u001b[?2004l\r"]
[41.92533, "o", "\u001b[?2004h> "]
[41.925435, "o", "            # Validate and parse fields\r\n\u001b[?2004l\r"]
[41.925476, "o", "\u001b[?2004h> "]
[41.925561, "o", "            if not asset_id:\r\n\u001b[?2004l\r"]
[41.925584, "o", "\u001b[?2004h"]
[41.925608, "o", "> "]
[41.925732, "o", "                reason.append('Missing asset ID')\r\n\u001b[?2004l\r"]
[41.925758, "o", "\u001b[?2004h> "]
[41.9258, "o", "            \r\n\u001b[?2004l\r"]
[41.925821, "o", "\u001b[?2004h"]
[41.925844, "o", "> "]
[41.925903, "o", "            if not name:\r\n\u001b[?2004l\r"]
[41.925925, "o", "\u001b[?2004h"]
[41.925948, "o", "> "]
[41.926061, "o", "                reason.append('Missing name')\r\n\u001b[?2004l\r"]
[41.926092, "o", "\u001b[?2004h> "]
[41.92613, "o", "            \r\n\u001b[?2004l\r"]
[41.926152, "o", "\u001b[?2004h"]
[41.926175, "o", "> "]
[41.926323, "o", "            if not serial or not serial.startswith('SN-'):\r\n\u001b[?2004l\r"]
[41.92635, "o", "\u001b[?2004h> "]
[41.926549, "o", "                reason.append('Invalid or missing serial number')\r\n\u001b[?2004l\r"]
[41.926572, "o", "\u001b[?2004h"]
[41.926599, "o", "> "]
[41.926636, "o", "            \r\n\u001b[?2004l\r"]
[41.926664, "o", "\u001b[?2004h> "]
[41.926746, "o", "            # Parse purchase date\r\n\u001b[?2004l\r"]
[41.926772, "o", "\u001b[?2004h> "]
[41.926937, "o", "            purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[41.926965, "o", "\u001b[?2004h> "]
[41.927066, "o", "            if not purchase_date:\r\n\u001b[?2004l\r"]
[41.927096, "o", "\u001b[?2004h> "]
[41.927334, "o", "                reason.append(f'Invalid purchase date format: {purchase_date_raw}')\r\n\u001b[?2004l\r"]
[41.927362, "o", "\u001b[?2004h> "]
[41.927404, "o", "            \r\n\u001b[?2004l\r"]
[41.927439, "o", "\u001b[?2004h> "]
[41.927525, "o", "            # Parse price\r\n\u001b[?2004l\r"]
[41.927558, "o", "\u001b[?2004h> "]
[41.927688, "o", "            price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[41.927718, "o", "\u001b[?2004h> "]
[41.927818, "o", "            if price_cents is None:\r\n\u001b[?2004l\r"]
[41.927845, "o", "\u001b[?2004h> "]
[41.92804, "o", "                reason.append(f'Invalid price format: {price_raw}')\r\n\u001b[?2004l\r"]
[41.928071, "o", "\u001b[?2004h> "]
[41.92817, "o", "            elif price_cents <= 0:\r\n\u001b[?2004l\r"]
[41.928195, "o", "\u001b[?2004h"]
[41.928231, "o", "> "]
[41.928413, "o", "                reason.append(f'Price must be positive: {price_cents} cents')\r\n\u001b[?2004l\r"]
[41.928441, "o", "\u001b[?2004h> "]
[41.928498, "o", "            \r\n\u001b[?2004l\r"]
[41.928524, "o", "\u001b[?2004h"]
[41.928549, "o", "> "]
[41.928614, "o", "            if not location:\r\n\u001b[?2004l\r"]
[41.928643, "o", "\u001b[?2004h> "]
[41.92878, "o", "                reason.append('Missing location')\r\n\u001b[?2004l\r"]
[41.928808, "o", "\u001b[?2004h> "]
[41.928851, "o", "            \r\n\u001b[?2004l\r"]
[41.928879, "o", "\u001b[?2004h> "]
[41.929057, "o", "            # If there are validation errors, reject this record\r\n\u001b[?2004l\r"]
[41.929086, "o", "\u001b[?2004h> "]
[41.929153, "o", "            if reason:\r\n\u001b[?2004l\r"]
[41.92918, "o", "\u001b[?2004h> "]
[41.929298, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[41.929327, "o", "\u001b[?2004h> "]
[41.92948, "o", "                    'original_row': original_row,\r\n\u001b[?2004l\r"]
[41.929505, "o", "\u001b[?2004h"]
[41.92953, "o", "> "]
[41.929646, "o", "                    'reason': '; '.join(reason)\r\n\u001b[?2004l\r"]
[41.929671, "o", "\u001b[?2004h> "]
[41.92973, "o", "                })\r\n\u001b[?2004l\r"]
[41.929754, "o", "\u001b[?2004h"]
[41.929778, "o", "> "]
[41.92983, "o", "                continue\r\n\u001b[?2004l\r"]
[41.929859, "o", "\u001b[?2004h> "]
[41.929898, "o", "            \r\n\u001b[?2004l\r"]
[41.929921, "o", "\u001b[?2004h"]
[41.929948, "o", "> "]
[41.930023, "o", "            # Create valid record\r\n\u001b[?2004l\r"]
[41.930053, "o", "\u001b[?2004h> "]
[41.930122, "o", "            record = {\r\n\u001b[?2004l\r"]
[41.93015, "o", "\u001b[?2004h> "]
[41.930243, "o", "                'id': asset_id,\r\n\u001b[?2004l\r"]
[41.930268, "o", "\u001b[?2004h"]
[41.930295, "o", "> "]
[41.930361, "o", "                'name': name,\r\n\u001b[?2004l\r"]
[41.930389, "o", "\u001b[?2004h> "]
[41.930502, "o", "                'serial': serial,\r\n\u001b[?2004l\r"]
[41.930533, "o", "\u001b[?2004h> "]
[41.930668, "o", "                'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[41.930695, "o", "\u001b[?2004h> "]
[41.930818, "o", "                'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[41.930848, "o", "\u001b[?2004h> "]
[41.930951, "o", "                'location': location\r\n\u001b[?2004l\r"]
[41.930979, "o", "\u001b[?2004h> "]
[41.931022, "o", "            }\r\n\u001b[?2004l\r"]
[41.931043, "o", "\u001b[?2004h"]
[41.931067, "o", "> "]
[41.931093, "o", "            \r\n\u001b[?2004l\r"]
[41.931117, "o", "\u001b[?2004h"]
[41.931147, "o", "> "]
[41.931327, "o", "            # Handle duplicates - keep the one with latest purchase date\r\n\u001b[?2004l\r"]
[41.931356, "o", "\u001b[?2004h> "]
[41.931488, "o", "            if asset_id in valid_records:\r\n\u001b[?2004l\r"]
[41.93152, "o", "\u001b[?2004h"]
[41.931547, "o", "> "]
[41.931722, "o", "                existing_date = valid_records[asset_id]['purchase_date']\r\n\u001b[?2004l\r"]
[41.93175, "o", "\u001b[?2004h> "]
[41.931899, "o", "                if purchase_date > existing_date:\r\n\u001b[?2004l\r"]
[41.931926, "o", "\u001b[?2004h> "]
[41.932083, "o", "                    valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[41.932111, "o", "\u001b[?2004h> "]
[41.932167, "o", "            else:\r\n\u001b[?2004l\r"]
[41.932194, "o", "\u001b[?2004h> "]
[41.932337, "o", "                valid_records[asset_id] = record\r\n\u001b[?2004l\r"]
[41.932365, "o", "\u001b[?2004h> "]
[41.932393, "o", "    \r\n\u001b[?2004l\r"]
[41.932419, "o", "\u001b[?2004h> "]
[41.932535, "o", "    # Convert to list and sort by ID\r\n\u001b[?2004l\r"]
[41.932563, "o", "\u001b[?2004h> "]
[41.93276, "o", "    valid_list = sorted(valid_records.values(), key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[41.932787, "o", "\u001b[?2004h"]
[41.932817, "o", ">     \r\n\u001b[?2004l\r"]
[41.932844, "o", "\u001b[?2004h> "]
[41.93291, "o", "    # Write output files\r\n\u001b[?2004l\r"]
[41.932938, "o", "\u001b[?2004h> "]
[41.933107, "o", "    with open('/home/user/inventory/assets.json', 'w') as f:\r\n\u001b[?2004l\r"]
[41.933135, "o", "\u001b[?2004h> "]
[41.933257, "o", "        json.dump(valid_list, f, indent=2)\r\n\u001b[?2004l\r"]
[41.933285, "o", "\u001b[?2004h> "]
[41.933314, "o", "    \r\n\u001b[?2004l\r"]
[41.933341, "o", "\u001b[?2004h> "]
[41.933531, "o", "    with open('/home/user/inventory/rejected.json', 'w') as f:\r\n\u001b[?2004l\r"]
[41.933562, "o", "\u001b[?2004h> "]
[41.933691, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[41.93372, "o", "\u001b[?2004h> "]
[41.933746, "o", "    \r\n\u001b[?2004l\r"]
[41.933777, "o", "\u001b[?2004h> "]
[41.933928, "o", "    print(f'Processed {len(valid_list)} valid records')\r\n\u001b[?2004l\r"]
[41.933957, "o", "\u001b[?2004h> "]
[41.934117, "o", "    print(f'Rejected {len(rejected_records)} records')\r\n\u001b[?2004l\r"]
[41.934145, "o", "\u001b[?2004h> "]
[41.934323, "o", "    print(f'Output written to assets.json and rejected.json')\r\n\u001b[?2004l\r"]
[41.934352, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[41.934381, "o", "\u001b[?2004h> "]
[41.934472, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[41.934505, "o", "\u001b[?2004h"]
[41.934534, "o", "> "]
[41.93456, "o", "    process_csv()\r\n\u001b[?2004l\r"]
[41.934595, "o", "\u001b[?2004h> "]
[41.934624, "o", "EOF\r\n\u001b[?2004l\r"]
[41.938283, "o", "\u001b[?2004h"]
[41.938326, "o", "user@b3285ef352c6:~/inventory$ "]
[42.018133, "i", "python3 process_assets.py\n"]
[42.01825, "o", "python3 process_assets.py\r\n\u001b[?2004l\r"]
