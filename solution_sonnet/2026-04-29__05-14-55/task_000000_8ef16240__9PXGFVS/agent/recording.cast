[67.914736, "i", "cat > test_interrupt.py << 'EOF'\nimport time\nimport subprocess\nimport sys\n\n# Start the process\nproc = subprocess.Popen(['python3', 'process.py'])\n\n# Let it run for just 0.5 seconds\ntime.sleep(0.5)\n\n# Kill it\nproc.terminate()\nproc.wait()\n\nprint('Process interrupted')\nEOF\n"]
