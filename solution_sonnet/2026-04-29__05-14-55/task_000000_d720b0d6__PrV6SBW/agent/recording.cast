[52.38277, "o", "\u001b[?2004h> "]
[52.382801, "o", "    fi\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.382832, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[52.382864, "o", "> "]
[52.382985, "o", "    # Get supplementary groups for this uid\r\n\u001b[?2004l\r"]
[52.383018, "o", "\u001b[?2004h> "]
[52.383207, "o", "    supp_gids=$(grep \"^${uid} \" \"$MEMBERSHIPS_DAT\" | cut -d' ' -f2-)\r\n\u001b[?2004l\r"]
[52.383238, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[52.38327, "o", "\u001b[?2004h> "]
[52.38346, "o", "    # FIX 3: Resolve supplementary group names using colon delimiter\r\n\u001b[?2004l\r"]
[52.383501, "o", "\u001b[?2004h> "]
[52.383537, "o", "    supp_names=\"\"\r\n"]
[52.383571, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[52.383662, "o", "    for sgid in $supp_gids; do\r\n\u001b[?2004l\r"]
[52.383692, "o", "\u001b[?2004h> "]
[52.383897, "o", "        gname=$(awk -F':' -v g=\"$sgid\" '$1 == g {print $2}' \"$GROUPS_DAT\")\r\n\u001b[?2004l\r"]
[52.383929, "o", "\u001b[?2004h> "]
[52.38404, "o", "        if [ -z \"$gname\" ]; then\r\n\u001b[?2004l\r"]
[52.384072, "o", "\u001b[?2004h> "]
[52.384138, "o", "            gname=\"$sgid\"\r\n\u001b[?2004l\r"]
[52.384174, "o", "\u001b[?2004h> "]
[52.384214, "o", "        fi\r\n\u001b[?2004l\r"]
[52.38425, "o", "\u001b[?2004h> "]
[52.384342, "o", "        if [ -z \"$supp_names\" ]; then\r\n\u001b[?2004l\r"]
[52.384381, "o", "\u001b[?2004h> "]
[52.38446, "o", "            supp_names=\"$gname\"\r\n\u001b[?2004l\r"]
[52.384498, "o", "\u001b[?2004h> "]
[52.38454, "o", "        else\r\n\u001b[?2004l\r"]
[52.384573, "o", "\u001b[?2004h> "]
[52.384689, "o", "            supp_names=\"$supp_names;$gname\"\r\n\u001b[?2004l\r"]
[52.384719, "o", "\u001b[?2004h> "]
[52.38476, "o", "        fi\r\n\u001b[?2004l\r"]
[52.384791, "o", "\u001b[?2004h> "]
[52.384822, "o", "    done\r\n\u001b[?2004l\r"]
[52.384854, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[52.384884, "o", "\u001b[?2004h> "]
[52.384939, "o", "    # Output CSV line\r\n\u001b[?2004l\r"]
[52.384984, "o", "\u001b[?2004h> "]
[52.385174, "o", "    echo \"$username,$uid,$primary_group,$email,$shell,$supp_names\"\r\n\u001b[?2004l\r"]
[52.385212, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[52.385247, "o", "\u001b[?2004h> "]
[52.385395, "o", "done < \"$TMPDIR/users_sorted.tmp\" >> \"$OUTPUT_FILE\"\r\n\u001b[?2004l\r"]
[52.385426, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[52.385467, "o", "\u001b[?2004h> "]
[52.3855, "o", "exit 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.385536, "o", "> EOF\r\n\u001b[?2004l\r"]
[52.390151, "o", "\u001b[?2004h"]
[52.390185, "o", "root@7e48eccb5004:/home/user/admin# "]
