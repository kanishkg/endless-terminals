[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for results
[?2004l[?2004h> tmp_file=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for file in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$file" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handle missing values gracefully
[?2004l[?2004h>     mem_total=$(grep -E '^MemTotal:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     mem_available=$(grep -E '^MemAvailable:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Skip if either value is missing or empty
[?2004l[?2004h>     if [[ -z "$mem_total" ]] || [[ -z "$mem_available" ]]; then
[?2004l[?2004h>         continue
[?2004l[?2004h>     fi
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate percentage available (using bc for floating point)
[?2004l[?2004h>     percent=$(echo "scale=2; ($mem_available * 100) / $mem_total" | bc)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if less than 20%
[?2004l[?2004h>     is_low=$(echo "$percent < 20" | bc)
[?2004l[?2004h>     
[?2004l[?2004h>     if [[ $is_low -eq 1 ]]; then
[?2004l[?2004h>         echo -e "$hostname\t$percent" >> "$tmp_file"
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (column 2) numerically, worst first (lowest percentage)
[?2004l[?2004h> sort -t$'\t' -k2 -n "$tmp_file" > /home/user/low_memory_report.txt
[?2004l[?2004h> 
[?2004l[?2004h> # Clean up
[?2004l[?2004h> rm -f "$tmp_file"
[?2004l[?2004h> EOF
