[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for results
[?2004l[?2004h> tmp_file=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for file in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$file" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, calculate percentage, check threshold
[?2004l[?2004h>     awk -v host="$hostname" '
[?2004l[?2004h>         /^MemTotal:/ { total = $2 }
[?2004l[?2004h>         /^MemAvailable:/ { available = $2 }
[?2004l[?2004h>         END {
[?2004l[?2004h>             if (total > 0 && available != "") {
[?2004l[?2004h>                 percent = (available * 100) / total
[?2004l[?2004h>                 if (percent < 20) {
[?2004l[?2004h>                     printf "%s\t%.2f\n", host, percent
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     ' "$file" >> "$tmp_file"
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (column 2) numerically, worst first (lowest percentage)
[?2004l[?2004h> sort -t$'\t' -k2 -n "$tmp_file" > /home/user/low_memory_report.txt
[?2004l[?2004h> 
