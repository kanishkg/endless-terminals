[31.187587, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file for results\ntmp_file=$(mktemp)\n\n# Process each host file\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable, calculate percentage, check threshold\n    awk -v host=\"$hostname\" '\n        /^MemTotal:/ { total = $2 }\n        /^MemAvailable:/ { available = $2 }\n        END {\n            if (total > 0 && available != \"\") {\n                percent = (available * 100) / total\n                if (percent < 20) {\n                    printf \"%s\\t%.2f\\n\", host, percent\n                }\n            }\n        }\n    ' \"$file\" >> \"$tmp_file\"\ndone\n\n# Sort by percentage (column 2) numerically, worst first (lowest percentage)\nsort -t$'\\t' -k2 -n \"$tmp_file\" > /home/user/low_memory_report.txt\n\n# Clean up\nrm -f \"$tmp_file\"\nEOF\n"]
[31.187733, "o", "cat > process_memory.sh << 'EOF'\r\n"]
