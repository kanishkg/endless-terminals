[21.100955, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file for results\ntmp_file=$(mktemp)\n\n# Process each host file\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handle missing values gracefully\n    mem_total=$(grep -E '^MemTotal:' \"$file\" 2>/dev/null | awk '{print $2}')\n    mem_available=$(grep -E '^MemAvailable:' \"$file\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty\n    if [[ -z \"$mem_total\" ]] || [[ -z \"$mem_available\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available (using bc for floating point)\n    percent=$(echo \"scale=2; ($mem_available * 100) / $mem_total\" | bc)\n    \n    # Check if less than 20%\n    is_low=$(echo \"$percent < 20\" | bc)\n    \n    if [[ $is_low -eq 1 ]]; then\n        echo -e \"$hostname\\t$percent\" >> \"$tmp_file\"\n    fi\ndone\n\n# Sort by percentage (column 2) numerically, worst first (lowest percentage)\nsort -t$'\\t' -k2 -n \"$tmp_file\" > /home/"]
[21.101116, "i", "user/low_memory_report.txt\n\n# Clean up\nrm -f \"$tmp_file\"\nEOF\n"]
