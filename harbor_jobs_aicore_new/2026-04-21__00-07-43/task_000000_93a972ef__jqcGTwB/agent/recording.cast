[33.956815, "o", "\u001b[?2004l\r"]
[33.957692, "o", "# Uptime checker daemon configuration\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 200\r\nmethod = \"GET\"\r\ncritical = true\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n\r\n[[endpoints]]\r\nname = \"payment-service\"\r\nurl = \"https://payments.internal.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\n\r\n[endpoints.headers]\r\nAuthorization = \"Bearer ${PAYMENTS_TOKEN}\"\r\n\r\n[global]\r\ncheck_interval = 30\r\nretry_count = 3\r\nlog_level = \"info\""]
[33.957776, "o", "\r\ntimeout = 10\r\n"]
[33.957889, "o", "\u001b[?2004h"]
[33.957923, "o", "root@06617a386d72:/home/user# "]
[41.885766, "i", "cat > /etc/monitoring/uptime.toml << 'EOF'\n# Uptime checker daemon configuration\n\n[global]\ncheck_interval = 30\nretry_count = 3\nlog_level = \"info\"\ntimeout = 10\n\n[[endpoints]]\nname = \"api-gateway\"\nurl = \"https://api.example.com/health\"\nexpected_status = 200\nmethod = \"GET\"\ncritical = true\n\n[[endpoints]]\nname = \"auth-service\"\nurl = \"https://auth.internal.example.com/ping\"\nexpected_status = 200\ncritical = false\n\n[[endpoints]]\nname = \"frontend\"\nurl = \"https://www.example.com\"\nexpected_status = 200\n\n[[endpoints]]\nname = \"payment-service\"\nurl = \"https://payments.internal.example.com/health\"\nexpected_status = 200\ncritical = true\nheaders = { Authorization = \"Bearer ${PAYMENTS_TOKEN}\" }\nEOF\n"]
[41.885955, "o", "cat > /etc/monitoring/uptime.toml << 'EOF'\r\n\u001b[?2004l\r"]
[41.886018, "o", "\u001b[?2004h"]
[41.886061, "o", "> "]
[41.886127, "o", "# Uptime checker daemon configuration\r\n\u001b[?2004l\r"]
