[38.287749, "i", "awk -F'\\t' '\n{\n  size = $1\n  path = $2\n  # Skip directory entries (size 4096)\n  if (size == 4096) next\n  # Extract immediate subdirectory of /var/data\n  # Path format: /var/data/subdir/...\n  if (match(path, /^\\/var\\/data\\/([^\\/]+)/, arr)) {\n    subdir = arr[1]\n  } else {\n    # Handle edge case - split manually\n    n = split(path, parts, \"/\")\n    if (n >= 4) subdir = parts[4]\n    else next\n  }\n  totals[subdir] += size\n  grand_total += size\n}\nEND {\n  for (dir in totals) {\n    pct = (totals[dir] / grand_total) * 100\n    printf \"%s %d %.1f%%\\n\", dir, totals[dir], pct\n  }\n}\n' /home/user/disk_inventory.txt | sort -t' ' -k2 -rn > /home/user/reports/directory_rollup.txt\n"]
