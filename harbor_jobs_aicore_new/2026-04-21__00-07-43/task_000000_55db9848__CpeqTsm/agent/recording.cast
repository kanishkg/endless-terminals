[29.316612, "i", "awk -F'\\t' '\nBEGIN { OFS=\",\" }\n{\n  size = $1\n  path = $2\n  # Skip directory entries (they end with a dir name that appears elsewhere as prefix)\n  if (size == 4096 && path ~ /\\/var\\/data(\\/[^\\/]+)*$/) {\n    # Check if this is a directory by seeing if path has no extension-like ending\n    n = split(path, parts, \"/\")\n    fname = parts[n]\n    if (fname !~ /\\./) next  # likely a directory\n  }\n  # Get filename\n  n = split(path, parts, \"/\")\n  fname = parts[n]\n  # Get extension\n  if (fname ~ /\\./) {\n    m = split(fname, extparts, \".\")\n    ext = tolower(extparts[m])\n  } else {\n    ext = \"NO_EXTENSION\"\n  }\n  totals[ext] += size\n}\nEND {\n  print \"extension,total_bytes\"\n  for (ext in totals) {\n    print ext, totals[ext]\n  }\n}\n' /home/user/disk_inventory.txt | head -1 > /home/user/reports/extension_summary.csv && awk -F'\\t' '\n{\n  size = $1\n  path = $2\n  if (size == 4096) next\n  n = split(path, parts, \"/\")\n  fname = parts[n]\n  if (fname ~ /\\./) {\n    m = split(fname, extparts, \".\")\n    ext = tolower(extparts[m])\n  } else {\n"]
[29.316665, "i", "    ext = \"NO_EXTENSION\"\n  }\n  totals[ext] += size\n}\nEND {\n  for (ext in totals) {\n    print totals[ext], ext\n  }\n}\n' /home/user/disk_inventory.txt | sort -rn | awk '{print $2\",\"$1}' >> /home/user/reports/extension_summary.csv\n"]
