[32.559581, "o", "        return (False, 'invalid_format', f\"invalid amount format: {record['amount']}\")\r\n\u001b[?2004l\r"]
[32.55962, "o", "\u001b[?2004h> "]
[32.55965, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[32.559681, "o", "> "]
[32.559888, "o", "    # Validate currency (exactly 3 uppercase letters)\r\n\u001b[?2004l\r"]
[32.559926, "o", "\u001b[?2004h> "]
[32.560299, "o", "    if not isinstance(record['currency'], str) or not CURRENCY_PATTERN.match(record['currency']):\r\n\u001b[?2004l\r"]
[32.560333, "o", "\u001b[?2004h> "]
[32.560682, "o", "        return (False, 'invalid_format', f\"invalid currency format: {record['currency']}\")\r\n\u001b[?2004l\r"]
[32.56073, "o", "\u001b[?2004h>     "]
[32.560764, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[32.560795, "o", "> "]
[32.560974, "o", "    # Validate status (one of valid values)\r\n\u001b[?2004l\r"]
[32.561008, "o", "\u001b[?2004h> "]
[32.561364, "o", "    if not isinstance(record['status'], str) or record['status'] not in VALID_STATUSES:\r\n\u001b[?2004l\r"]
[32.561399, "o", "\u001b[?2004h> "]
[32.561718, "o", "        return (False, 'invalid_value', f\"invalid status value: {record['status']}\")\r\n\u001b[?2004l\r"]
[32.561753, "o", "\u001b[?2004h>     \r\n"]
[32.561786, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[32.56189, "o", "    return (True, None, None)\r\n\u001b[?2004l\r"]
[32.561923, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[32.561956, "o", "\u001b[?2004h> "]
[32.562053, "o", "def compute_integrity_hash(record):\r\n\u001b[?2004l\r"]
[32.562084, "o", "\u001b[?2004h> "]
[32.56222, "o", "    \"\"\"Compute SHA-256 hash of canonical form\"\"\"\r\n\u001b[?2004l\r"]
[32.56226, "o", "\u001b[?2004h> "]
[32.562369, "o", "    amount_str = f\"{record['amount']:.2f}\"\r\n\u001b[?2004l\r"]
[32.562406, "o", "\u001b[?2004h> "]
[32.562805, "o", "    canonical = f\"{record['transaction_id']}|{record['timestamp']}|{record['account_id']}|{amount_str}|{record['currency']}|{record['status']}\"\r\n\u001b[?2004l\r"]
[32.562858, "o", "\u001b[?2004h> "]
[32.563023, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[32.563058, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[32.56309, "o", "\u001b[?2004h> "]
[32.563124, "o", "def main():\r\n\u001b[?2004l\r"]
[32.563156, "o", "\u001b[?2004h> "]
[32.563214, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[32.563262, "o", "\u001b[?2004h> "]
[32.563309, "o", "    error_records = []\r\n\u001b[?2004l\r"]
[32.56334, "o", "\u001b[?2004h> "]
[32.5634, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[32.563438, "o", "\u001b[?2004h> "]
[32.563513, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[32.563544, "o", "\u001b[?2004h> "]
[32.563623, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[32.563654, "o", "\u001b[?2004h> "]
[32.563735, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[32.563765, "o", "\u001b[?2004h> "]
[32.563857, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[32.563893, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[32.563934, "o", "\u001b[?2004h> "]
[32.563966, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[32.564197, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[32.564229, "o", "\u001b[?2004h> "]
[32.564258, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[32.564289, "o", "> "]
[32.564367, "o", "    # Read and process input file\r\n\u001b[?2004l\r"]
[32.564399, "o", "\u001b[?2004h> "]
[32.5645, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[32.564532, "o", "\u001b[?2004h> "]
[32.564662, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[32.564693, "o", "\u001b[?2004h> "]
[32.564815, "o", "            raw_content = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[32.564858, "o", "\u001b[?2004h> "]
[32.564994, "o", "            truncated_content = raw_content[:200]\r\n\u001b[?2004l\r"]
[32.565028, "o", "\u001b[?2004h> "]
[32.565061, "o", "            \r\n\u001b[?2004l\r"]
[32.565102, "o", "\u001b[?2004h> "]
[32.565196, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[32.565227, "o", "\u001b[?2004h> "]
[32.565269, "o", "            try:\r\n\u001b[?2004l\r"]
[32.565313, "o", "\u001b[?2004h> "]
[32.565436, "o", "                record = json.loads(raw_content)\r\n\u001b[?2004l\r"]
[32.565472, "o", "\u001b[?2004h> "]
[32.565583, "o", "            except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[32.565615, "o", "\u001b[?2004h> "]
[32.565756, "o", "                error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[32.565787, "o", "\u001b[?2004h> "]
[32.565908, "o", "                error_records.append({\r\n\u001b[?2004l\r"]
[32.565953, "o", "\u001b[?2004h> "]
[32.566061, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[32.566094, "o", "\u001b[?2004h> "]
[32.566232, "o", "                    'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[32.566276, "o", "\u001b[?2004h> "]
[32.566431, "o", "                    'error_detail': 'failed to parse JSON',\r\n\u001b[?2004l\r"]
[32.566475, "o", "\u001b[?2004h> "]
[32.566607, "o", "                    'raw_content': truncated_content\r\n\u001b[?2004l\r"]
[32.566642, "o", "\u001b[?2004h> "]
[32.566686, "o", "                })\r\n\u001b[?2004l\r"]
[32.566733, "o", "\u001b[?2004h> "]
[32.566792, "o", "                continue\r\n\u001b[?2004l\r"]
[32.566824, "o", "\u001b[?2004h> "]
[32.56688, "o", "            \r\n\u001b[?2004l\r"]
[32.566912, "o", "\u001b[?2004h> "]
[32.566988, "o", "            # Validate record\r\n\u001b[?2004l\r"]
[32.567019, "o", "\u001b[?2004h> "]
[32.567217, "o", "            is_valid, error_type, error_detail = validate_record(record)\r\n\u001b[?2004l\r"]
[32.567249, "o", "\u001b[?2004h> "]
[32.567288, "o", "            \r\n\u001b[?2004l\r"]
[32.567319, "o", "\u001b[?2004h> "]
[32.567401, "o", "            if not is_valid:\r\n\u001b[?2004l\r"]
[32.567431, "o", "\u001b[?2004h> "]
[32.567561, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[32.567593, "o", "\u001b[?2004h> "]
[32.567699, "o", "                error_records.append({\r\n\u001b[?2004l\r"]
[32.567731, "o", "\u001b[?2004h> "]
[32.567872, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[32.567909, "o", "\u001b[?2004h> "]
[32.568027, "o", "                    'error_type': error_type,\r\n\u001b[?2004l\r"]
[32.568073, "o", "\u001b[?2004h> "]
[32.568194, "o", "                    'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[32.568233, "o", "\u001b[?2004h> "]
[32.568368, "o", "                    'raw_content': truncated_content\r\n\u001b[?2004l\r"]
[32.568408, "o", "\u001b[?2004h> "]
[32.568451, "o", "                })\r\n\u001b[?2004l\r"]
[32.568484, "o", "\u001b[?2004h> "]
[32.568556, "o", "                continue\r\n\u001b[?2004l\r"]
[32.5686, "o", "\u001b[?2004h> "]
[32.568635, "o", "            \r\n\u001b[?2004l\r"]
[32.568671, "o", "\u001b[?2004h> "]
[32.568848, "o", "            # Record is valid - compute hash and prepare output\r\n\u001b[?2004l\r"]
[32.568882, "o", "\u001b[?2004h> "]
[32.569039, "o", "            integrity_hash = compute_integrity_hash(record)\r\n\u001b[?2004l\r"]
[32.569076, "o", "\u001b[?2004h> "]
[32.569164, "o", "            output_record = {\r\n\u001b[?2004l\r"]
[32.569197, "o", "\u001b[?2004h> "]
[32.56936, "o", "                'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[32.569392, "o", "\u001b[?2004h> "]
[32.56953, "o", "                'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[32.569561, "o", "\u001b[?2004h> "]
[32.569705, "o", "                'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[32.569737, "o", "\u001b[?2004h> "]
[32.56987, "o", "                'amount': record['amount'],\r\n\u001b[?2004l\r"]
[32.569891, "o", "\u001b[?2004h> "]
[32.570025, "o", "                'currency': record['currency'],\r\n\u001b[?2004l\r"]
[32.570064, "o", "\u001b[?2004h> "]
[32.570179, "o", "                'status': record['status'],\r\n\u001b[?2004l\r"]
[32.570227, "o", "\u001b[?2004h> "]
[32.570352, "o", "                'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[32.570385, "o", "\u001b[?2004h> "]
[32.570516, "o", "                'processed_at': processing_time\r\n\u001b[?2004l\r"]
[32.57055, "o", "\u001b[?2004h> "]
[32.570588, "o", "            }\r\n\u001b[?2004l\r"]
[32.570627, "o", "\u001b[?2004h> "]
[32.57075, "o", "            valid_records.append(output_record)\r\n\u001b[?2004l\r"]
[32.570783, "o", "\u001b[?2004h> "]
[32.570828, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[32.570945, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[32.570976, "o", "\u001b[?2004h> "]
[32.571121, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[32.571164, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[32.571195, "o", "\u001b[?2004h> "]
[32.571282, "o", "    # Write clean audit output\r\n\u001b[?2004l\r"]
[32.571324, "o", "\u001b[?2004h> "]
[32.571419, "o", "    with open(CLEAN_OUTPUT, 'w') as f:\r\n\u001b[?2004l\r"]
[32.57145, "o", "\u001b[?2004h> "]
[32.571555, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[32.571587, "o", "\u001b[?2004h> "]
[32.571714, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[32.571757, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[32.571798, "o", "\u001b[?2004h> "]
[32.571866, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[32.571911, "o", "\u001b[?2004h> "]
[32.571993, "o", "    with open(ERROR_LOG, 'w') as f:\r\n\u001b[?2004l\r"]
[32.572024, "o", "\u001b[?2004h> "]
[32.572123, "o", "        for error in error_records:\r\n\u001b[?2004l\r"]
[32.572155, "o", "\u001b[?2004h> "]
[32.572281, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[32.572312, "o", "\u001b[?2004h> "]
[32.572343, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[32.57238, "o", "> "]
[32.572434, "o", "    # Calculate statistics\r\n\u001b[?2004l\r"]
[32.572473, "o", "\u001b[?2004h> "]
[32.572626, "o", "    total_lines = len(valid_records) + len(error_records)\r\n\u001b[?2004l\r"]
[32.572658, "o", "\u001b[?2004h> "]
[32.572915, "o", "    success_rate = (len(valid_records) / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[32.572954, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[32.572984, "o", "\u001b[?2004h> "]
[32.573063, "o", "    # Write summary report\r\n\u001b[?2004l\r"]
[32.573105, "o", "\u001b[?2004h> "]
[32.573209, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[32.573241, "o", "\u001b[?2004h> "]
[32.573367, "o", "        f.write('AUDIT PROCESSING SUMMARY\\n')\r\n\u001b[?2004l\r"]
[32.573397, "o", "\u001b[?2004h> "]
[32.573525, "o", "        f.write('========================\\n')\r\n\u001b[?2004l\r"]
[32.573557, "o", "\u001b[?2004h> "]
[32.573688, "o", "        f.write(f'Input file: {INPUT_FILE}\\n')\r\n\u001b[?2004l\r"]
[32.57372, "o", "\u001b[?2004h> "]
[32.573892, "o", "        f.write(f'Total lines processed: {total_lines}\\n')\r\n\u001b[?2004l\r"]
[32.573928, "o", "\u001b[?2004h> "]
[32.574095, "o", "        f.write(f'Valid transactions: {len(valid_records)}\\n')\r\n\u001b[?2004l\r"]
[32.574134, "o", "\u001b[?2004h> "]
[32.574293, "o", "        f.write(f'Failed records: {len(error_records)}\\n')\r\n\u001b[?2004l\r"]
[32.574339, "o", "\u001b[?2004h> "]
[32.574477, "o", "        f.write(f'Success rate: {success_rate:.2f}%\\n')\r\n\u001b[?2004l\r"]
[32.574507, "o", "\u001b[?2004h> "]
[32.574572, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[32.574605, "o", "\u001b[?2004h> "]
[32.574703, "o", "        f.write('Errors by type:\\n')\r\n\u001b[?2004l\r"]
[32.574733, "o", "\u001b[?2004h> "]
[32.574949, "o", "        f.write(f\"  malformed_json: {error_counts['malformed_json']}\\n\")\r\n\u001b[?2004l\r"]
[32.574996, "o", "\u001b[?2004h> "]
[32.575176, "o", "        f.write(f\"  missing_field: {error_counts['missing_field']}\\n\")\r\n\u001b[?2004l\r"]
[32.575209, "o", "\u001b[?2004h> "]
[32.575405, "o", "        f.write(f\"  invalid_format: {error_counts['invalid_format']}\\n\")\r\n\u001b[?2004l\r"]
[32.575439, "o", "\u001b[?2004h> "]
[32.575629, "o", "        f.write(f\"  invalid_value: {error_counts['invalid_value']}\\n\")\r\n\u001b[?2004l\r"]
[32.575663, "o", "\u001b[?2004h> "]
[32.575719, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[32.57575, "o", "\u001b[?2004h> "]
[32.57594, "o", "        f.write(f'Processing completed at: {processing_time}\\n')\r\n\u001b[?2004l\r"]
[32.575984, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[32.576016, "o", "\u001b[?2004h> "]
[32.576121, "o", "    print(f'Processing complete!')\r\n\u001b[?2004l\r"]
[32.57616, "o", "\u001b[?2004h> "]
[32.576352, "o", "    print(f'Valid: {len(valid_records)}, Errors: {len(error_records)}')\r\n\u001b[?2004l\r"]
[32.576397, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[32.576441, "o", "> "]
[32.576488, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[32.576531, "o", "\u001b[?2004h> "]
[32.57656, "o", "    main()\r\n\u001b[?2004l\r"]
[32.576595, "o", "\u001b[?2004h> SCRIPT\r\n"]
[32.576625, "o", "\u001b[?2004l\r"]
[32.581524, "o", "\u001b[?2004hroot@6468b2f4c7ec:/home/user# "]
[33.54535, "i", "python3 /home/user/audit/process_audit.py\n"]
[33.545517, "o", "python3 /home/user/audit/process_audit.py\r\n\u001b[?2004l\r"]
[33.572317, "o", "Processing complete!\r\nValid: 13, Errors: 12\r\n"]
[33.576177, "o", "\u001b[?2004h"]
[33.576211, "o", "root@6468b2f4c7ec:/home/user# "]
[41.234416, "i", "cat /home/user/audit/processing_summary.txt\n"]
[41.234595, "o", "cat /home/user/audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[41.235444, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T00:13:36Z\r\n"]
[41.235625, "o", "\u001b[?2004h"]
[41.23566, "o", "root@6468b2f4c7ec:/home/user# "]
[41.73331, "i", "cat /home/user/audit/clean_audit.jsonl\n"]
[41.733464, "o", "cat /home/user/audit/clean_audit.jsonl\r\n"]
