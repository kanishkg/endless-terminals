[?2004l[?2004h> import os
[?2004l[?2004h> from datetime import datetime
[?2004l[?2004h> 
[?2004l[?2004h> def parse_log_file(filepath):
[?2004l[?2004h>     entries = []
[?2004l[?2004h>     with open(filepath, 'r') as f:
[?2004l[?2004h>         for line in f:
[?2004l[?2004h>             line = line.strip()
[?2004l[?2004h>             if not line:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             # Parse: [TIMESTAMP] SERVICE_NAME | OLD_KEY_ID | NEW_KEY_ID | STATUS | ROTATED_BY
[?2004l[?2004h>             timestamp_end = line.find(']')
[?2004l[?2004h>             timestamp = line[1:timestamp_end]
[?2004l[?2004h>             rest = line[timestamp_end+1:].strip()
[?2004l[?2004h>             parts = [p.strip() for p in rest.split('|')]
[?2004l[?2004h>             if len(parts) == 5:
[?2004l[?2004h>                 entries.append({
[?2004l[?2004h>                     'timestamp': timestamp,
[?2004l[?2004h>                     'service': parts[0],
[?2004l[?2004h>                     'old_key': parts[1],
[?2004l[?2004h>                     'new_key': parts[2],
[?2004l[?2004h>                     'status': parts[3],
[?2004l[?2004h>                     'rotated_by': parts[4]
[?2004l[?2004h>                 })
[?2004l[?2004h>     return entries
[?2004l[?2004h> 
[?2004l[?2004h> # Parse all log files
[?2004l[?2004h> aws_entries = parse_log_file('aws-rotation.log')
[?2004l[?2004h> db_entries = parse_log_file('db-rotation.log')
[?2004l[?2004h> api_entries = parse_log_file('api-keys.log')
[?2004l[?2004h> 
[?2004l[?2004h> # Sort alphabetically by service name
[?2004l[?2004h> aws_entries.sort(key=lambda x: x['service'].lower())
[?2004l[?2004h> db_entries.sort(key=lambda x: x['service'].lower())
[?2004l[?2004h> api_entries.sort(key=lambda x: x['service'].lower())
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate statistics
[?2004l[?2004h> def calc_stats(entries):
[?2004l[?2004h>     total = len(entries)
[?2004l[?2004h>     success = sum(1 for e in entries if e['status'] == 'SUCCESS')
[?2004l[?2004h>     failed = total - success
[?2004l[?2004h>     return total, success, failed
[?2004l[?2004h> 
[?2004l[?2004h> aws_stats = calc_stats(aws_entries)
[?2004l[?2004h> db_stats = calc_stats(db_entries)
[?2004l[?2004h> api_stats = calc_stats(api_entries)
[?2004l[?2004h> 
[?2004l[?2004h> total_rotated = aws_stats[0] + db_stats[0] + api_stats[0]
[?2004l[?2004h> 
[?2004l[?2004h> # Get failed rotations
[?2004l[?2004h> failed_rotations = []
[?2004l[?2004h> for e in aws_entries:
[?2004l[?2004h>     if e['status'] == 'FAILED':
[?2004l[?2004h>         failed_rotations.append((e['service'], 'AWS IAM'))
[?2004l[?2004h> for e in db_entries:
[?2004l[?2004h>     if e['status'] == 'FAILED':
[?2004l[?2004h>         failed_rotations.append((e['service'], 'Database'))
[?2004l[?2004h> for e in api_entries:
[?2004l[?2004h>     if e['status'] == 'FAILED':
[?2004l[?2004h>         failed_rotations.append((e['service'], 'API Keys'))
[?2004l[?2004h> 
[?2004l[?2004h> # Generate timestamp
[?2004l[?2004h> generated_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
[?2004l[?2004h> 
[?2004l[?2004h> # Generate markdown
[?2004l[?2004h> def generate_table_rows(entries):
[?2004l[?2004h>     rows = []
[?2004l[?2004h>     for e in entries:
[?2004l[?2004h>         rows.append(f"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |")
[?2004l[?2004h>     return '\n'.join(rows)
[?2004l[?2004h> 
[?2004l[?2004h> report = f"""# Credential Rotation Report
[?2004l[?2004h> 
[?2004l[?2004h> **Generated:** {generated_time}
