[24.873098, "i", "cat > generate_report.py << 'EOF'\nimport os\nfrom datetime import datetime\n\ndef parse_log_file(filepath):\n    entries = []\n    with open(filepath, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            # Parse: [TIMESTAMP] SERVICE_NAME | OLD_KEY_ID | NEW_KEY_ID | STATUS | ROTATED_BY\n            timestamp_end = line.find(']')\n            timestamp = line[1:timestamp_end]\n            rest = line[timestamp_end+1:].strip()\n            parts = [p.strip() for p in rest.split('|')]\n            if len(parts) == 5:\n                entries.append({\n                    'timestamp': timestamp,\n                    'service': parts[0],\n                    'old_key': parts[1],\n                    'new_key': parts[2],\n                    'status': parts[3],\n                    'rotated_by': parts[4]\n                })\n    return entries\n\n# Parse all log files\naws_entries = parse_log_file('aws-rotation.log')\ndb_entries = parse_log_file('db-rotation.log')\n"]
[24.873222, "i", "api_entries = parse_log_file('api-keys.log')\n\n# Sort alphabetically by service name\naws_entries.sort(key=lambda x: x['service'].lower())\ndb_entries.sort(key=lambda x: x['service'].lower())\napi_entries.sort(key=lambda x: x['service'].lower())\n\n# Calculate statistics\ndef calc_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = total - success\n    return total, success, failed\n\naws_stats = calc_stats(aws_entries)\ndb_stats = calc_stats(db_entries)\napi_stats = calc_stats(api_entries)\n\ntotal_rotated = aws_stats[0] + db_stats[0] + api_stats[0]\n\n# Get failed rotations\nfailed_rotations = []\nfor e in aws_entries:\n    if e['status'] == 'FAILED':\n        failed_rotations.append((e['service'], 'AWS IAM'))\nfor e in db_entries:\n    if e['status'] == 'FAILED':\n        failed_rotations.append((e['service'], 'Database'))\nfor e in api_entries:\n    if e['status'] == 'FAILED':\n        failed_rotations.append((e['service'], 'API Keys'))\n\n# Generate timestamp\ngener"]
[24.873269, "i", "ated_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\n# Generate markdown\ndef generate_table_rows(entries):\n    rows = []\n    for e in entries:\n        rows.append(f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\")\n    return '\\n'.join(rows)\n\nreport = f\"\"\"# Credential Rotation Report\n\n**Generated:** {generated_time}\n**Total Credentials Rotated:** {total_rotated}\n\n## Summary by Category\n\n| Category | Count | Success | Failed |\n|----------|-------|---------|--------|\n| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\n| Database | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\n| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\n\n## Detailed Rotation Log\n\n### AWS IAM Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n{generate_table_rows(aws_entries)}\n\n### Database Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|--"]
[24.873308, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\r"]
[24.873366, "i", "----------|--------|------------|\n{generate_table_rows(db_entries)}\n\n### API Keys\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n{generate_table_rows(api_entries)}\n\n## Failed Rotations\n\n\"\"\"\n\nif failed_rotations:\n    report += \"> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n\"\n    for service, category in failed_rotations:\n        report += f\"- {service} ({category}): Rotation failed\\n\"\nelse:\n    report += \"> No failed rotations. All credentials rotated successfully.\\n\"\n\nreport += \"\"\"\n## Sign-off\n\n- [ ] All successful rotations verified\n- [ ] Failed rotations escalated\n- [ ] Old credentials scheduled for deletion\n\"\"\"\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write(report)\n\nprint(\"Report generated successfully!\")\nEOF\n"]
