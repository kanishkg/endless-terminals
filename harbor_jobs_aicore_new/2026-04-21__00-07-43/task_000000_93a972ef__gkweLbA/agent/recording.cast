[23.134562, "i", "python3 << 'EOF'\nimport sys\n\n# Read the YAML file\nwith open('/etc/monitoring/alerts.yaml', 'r') as f:\n    lines = f.readlines()\n\n# Process YAML - we'll do this line by line to preserve comments and structure\noutput_lines = []\ni = 0\nwhile i < len(lines):\n    line = lines[i]\n    \n    # Check for HighLatency alert and modify the 'for' duration\n    if 'alert: HighLatency' in line:\n        output_lines.append(line)\n        i += 1\n        # Process until we find and modify the 'for' field\n        while i < len(lines) and not lines[i].strip().startswith('- alert:'):\n            if lines[i].strip().startswith('for:'):\n                indent = len(lines[i]) - len(lines[i].lstrip())\n                output_lines.append(' ' * indent + 'for: 3m\\n')\n            else:\n                output_lines.append(lines[i])\n            i += 1\n        continue\n    \n    # Check for ServiceDown alert and add escalation_level label\n    elif 'alert: ServiceDown' in line:\n        output_lines.append(line)\n        i += 1\n        in_labels = "]
[23.134702, "i", "False\n        labels_indent = 0\n        while i < len(lines) and not lines[i].strip().startswith('- alert:'):\n            if lines[i].strip().startswith('labels:'):\n                in_labels = True\n                output_lines.append(lines[i])\n                i += 1\n                continue\n            elif in_labels and lines[i].strip() and not lines[i].strip().startswith('#'):\n                # Check if we're still in labels section\n                current_indent = len(lines[i]) - len(lines[i].lstrip())\n                if labels_indent == 0:\n                    labels_indent = current_indent\n                if current_indent >= labels_indent and ':' in lines[i] and not lines[i].strip().startswith('annotations'):\n                    output_lines.append(lines[i])\n                    # Check if next line exits labels section\n                    if i + 1 < len(lines):\n                        next_line = lines[i + 1]\n                        next_stripped = next_line.strip()\n                        if next_stripp"]
[23.134755, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[23.134796, "i", "ed.startswith('annotations:') or next_stripped.startswith('- alert:'):\n                            # Add escalation_level before leaving labels\n                            output_lines.append(' ' * labels_indent + 'escalation_level: critical\\n')\n                            in_labels = False\n                else:\n                    if in_labels:\n                        output_lines.append(' ' * labels_indent + 'escalation_level: critical\\n')\n                        in_labels = False\n                    output_lines.append(lines[i])\n            else:\n                output_lines.append(lines[i])\n            i += 1\n        continue\n    \n    output_lines.append(line)\n    i += 1\n\n# Add the new DiskSpaceLow alert at the end\nnew_alert = '''\\n      - alert: DiskSpaceLow\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\n        for: 10m\n        labels:\n          severity: warning\n          team: infrastructure\n        annotations:\n          summary: \"Disk spa"]
[23.134828, "o", "> import sys\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[23.134867, "i", "ce below 10% on {{ $labels.instance }}\"\n'''\n\noutput_lines.append(new_alert)\n\nwith open('/etc/monitoring/alerts.yaml', 'w') as f:\n    f.writelines(output_lines)\n\nprint('YAML file updated')\nEOF\n"]
