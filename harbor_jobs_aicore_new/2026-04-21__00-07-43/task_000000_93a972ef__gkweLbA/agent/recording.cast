[42.293304, "i", "python3 << 'EOF'\n# Read the TOML file\nwith open('/etc/monitoring/uptime.toml', 'r') as f:\n    lines = f.readlines()\n\noutput_lines = []\ni = 0\nin_global = False\nin_api_gateway = False\nglobal_timeout_added = False\napi_gateway_critical_added = False\n\nwhile i < len(lines):\n    line = lines[i]\n    stripped = line.strip()\n    \n    # Track sections\n    if stripped == '[global]':\n        in_global = True\n        in_api_gateway = False\n        output_lines.append(line)\n        i += 1\n        continue\n    elif stripped == '[[endpoints]]':\n        # Before leaving global section, check if we need to add timeout\n        if in_global and not global_timeout_added:\n            output_lines.append('timeout = 10\\n')\n            global_timeout_added = True\n        in_global = False\n        # Check if we were in api-gateway and need to add critical\n        if in_api_gateway and not api_gateway_critical_added:\n            output_lines.append('critical = true\\n')\n            api_gateway_critical_added = True\n        in_api_gateway"]
[42.293361, "i", " = False\n        output_lines.append(line)\n        i += 1\n        continue\n    \n    # In global section\n    if in_global:\n        if stripped.startswith('check_interval'):\n            output_lines.append('check_interval = 30\\n')\n            i += 1\n            continue\n        elif stripped.startswith('timeout'):\n            output_lines.append('timeout = 10\\n')\n            global_timeout_added = True\n            i += 1\n            continue\n    \n    # Check for api-gateway endpoint\n    if 'name = \"api-gateway\"' in stripped:\n        in_api_gateway = True\n        output_lines.append(line)\n        i += 1\n        continue\n    \n    # In api-gateway section\n    if in_api_gateway:\n        if stripped.startswith('expected_status'):\n            output_lines.append('expected_status = 200\\n')\n            i += 1\n            continue\n        elif stripped.startswith('critical'):\n            output_lines.append('critical = true\\n')\n            api_gateway_critical_added = True\n            i += 1\n            continue\n       "]
[42.293492, "i", " elif stripped.startswith('method'):\n            # Add critical before method if not added\n            if not api_gateway_critical_added:\n                output_lines.append('critical = true\\n')\n                api_gateway_critical_added = True\n            output_lines.append(line)\n            i += 1\n            continue\n    \n    output_lines.append(line)\n    i += 1\n\n# Add new payment-service endpoint at the end\nnew_endpoint = '''\\n[[endpoints]]\nname = \"payment-service\"\nurl = \"https://payments.internal.example.com/health\"\nexpected_status = 200\ncritical = true\n\n[endpoints.headers]\nAuthorization = \"Bearer ${PAYMENTS_TOKEN}\"\n'''\n\noutput_lines.append(new_endpoint)\n\nwith open('/etc/monitoring/uptime.toml', 'w') as f:\n    f.writelines(output_lines)\n\nprint('TOML file updated')\nEOF\n"]
