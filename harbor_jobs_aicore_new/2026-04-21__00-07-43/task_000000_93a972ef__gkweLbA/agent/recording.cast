[79.257487, "i", "cat /etc/monitoring/alerts.yaml\n"]
[79.25763, "o", "cat /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[79.258544, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 3m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n          escalation_level: critical\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n\r\n      - alert: DiskSpaceLow\r\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\r\n        for: 10m\r\n        labels:"]
[79.258623, "o", "\r\n          severity: warning\r\n          team: infrastructure\r\n        annotations:\r\n          summary: \"Disk space below 10% on {{ $labels.instance }}\"\r\n"]
[79.258711, "o", "\u001b[?2004h"]
[79.258749, "o", "root@beec0d9caecb:/home/user# "]
[79.754474, "i", "cat /etc/monitoring/uptime.toml\n"]
[79.754613, "o", "cat /etc/monitoring/uptime.toml\r\n"]
[79.754665, "o", "\u001b[?2004l\r"]
[79.755476, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 30\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\ntimeout = 10\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\n"]
[79.755548, "o", "name = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n\r\n[[endpoints]]\r\nname = \"payment-service\"\r\nurl = \"https://payments.internal.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\n\r\n[endpoints.headers]\r\nAuthorization = \"Bearer ${PAYMENTS_TOKEN}\"\r\n"]
[79.75567, "o", "\u001b[?2004h"]
[79.755708, "o", "root@beec0d9caecb:/home/user# "]
