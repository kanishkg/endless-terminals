[35.47159, "o", "    return True, None, None\r\n\u001b[?2004l\r"]
[35.471621, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[35.471653, "o", "\u001b[?2004h> "]
[35.471721, "o", "def compute_hash(record):\r\n\u001b[?2004l\r"]
[35.471753, "o", "\u001b[?2004h> "]
[35.471899, "o", "    \"\"\"Compute SHA-256 hash of canonical form\"\"\"\r\n\u001b[?2004l\r"]
[35.471932, "o", "\u001b[?2004h> "]
[35.472046, "o", "    amount_str = f\"{record['amount']:.2f}\"\r\n\u001b[?2004l\r"]
[35.472077, "o", "\u001b[?2004h> "]
[35.472469, "o", "    canonical = f\"{record['transaction_id']}|{record['timestamp']}|{record['account_id']}|{amount_str}|{record['currency']}|{record['status']}\"\r\n\u001b[?2004l\r"]
[35.472504, "o", "\u001b[?2004h> "]
[35.472678, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[35.472706, "o", "\u001b[?2004h> "]
[35.472733, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.472764, "o", "> "]
[35.472837, "o", "def truncate(s, max_len=200):\r\n\u001b[?2004l\r"]
[35.472868, "o", "\u001b[?2004h> "]
[35.473001, "o", "    \"\"\"Truncate string to max_len characters\"\"\"\r\n\u001b[?2004l\r"]
[35.473032, "o", "\u001b[?2004h> "]
[35.473169, "o", "    return s[:max_len] if len(s) > max_len else s\r\n\u001b[?2004l\r"]
[35.4732, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[35.473231, "o", "\u001b[?2004h> "]
[35.473268, "o", "def main():\r\n\u001b[?2004l\r"]
[35.473299, "o", "\u001b[?2004h> "]
[35.473362, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[35.473393, "o", "\u001b[?2004h> "]
[35.473438, "o", "    errors = []\r\n\u001b[?2004l\r"]
[35.473468, "o", "\u001b[?2004h> "]
[35.473526, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[35.473557, "o", "\u001b[?2004h> "]
[35.473639, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[35.473669, "o", "\u001b[?2004h> "]
[35.473748, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[35.473777, "o", "\u001b[?2004h> "]
[35.473868, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[35.473899, "o", "\u001b[?2004h> "]
[35.473975, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[35.474006, "o", "\u001b[?2004h> "]
[35.474033, "o", "    }\r\n\u001b[?2004l\r"]
[35.474073, "o", "\u001b[?2004h> "]
[35.474099, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.47413, "o", "> "]
[35.474333, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[35.474364, "o", "\u001b[?2004h> "]
[35.474396, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.474427, "o", "> "]
[35.47451, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[35.474541, "o", "\u001b[?2004h> "]
[35.474672, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[35.474704, "o", "\u001b[?2004h> "]
[35.474827, "o", "            raw_line = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[35.474859, "o", "\u001b[?2004h> "]
[35.474891, "o", "            \r\n"]
[35.474921, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[35.475012, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[35.475043, "o", "\u001b[?2004h> "]
[35.475091, "o", "            try:\r\n\u001b[?2004l\r"]
[35.475121, "o", "\u001b[?2004h> "]
[35.475249, "o", "                record = json.loads(raw_line)\r\n\u001b[?2004l\r"]
[35.475281, "o", "\u001b[?2004h> "]
[35.475394, "o", "            except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[35.475425, "o", "\u001b[?2004h> "]
[35.475513, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[35.475545, "o", "\u001b[?2004h> "]
[35.475666, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[35.475697, "o", "\u001b[?2004h> "]
[35.475851, "o", "                    'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[35.475881, "o", "\u001b[?2004h> "]
[35.476044, "o", "                    'error_detail': 'failed to parse JSON',\r\n\u001b[?2004l\r"]
[35.476076, "o", "\u001b[?2004h> "]
[35.476221, "o", "                    'raw_content': truncate(raw_line)\r\n\u001b[?2004l\r"]
[35.476251, "o", "\u001b[?2004h> "]
[35.476306, "o", "                })\r\n\u001b[?2004l\r"]
[35.476334, "o", "\u001b[?2004h> "]
[35.476481, "o", "                error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[35.476513, "o", "\u001b[?2004h> "]
[35.476581, "o", "                continue\r\n\u001b[?2004l\r"]
[35.476613, "o", "\u001b[?2004h> "]
[35.476651, "o", "            \r\n\u001b[?2004l\r"]
[35.476683, "o", "\u001b[?2004h> "]
[35.476764, "o", "            # Validate record\r\n\u001b[?2004l\r"]
[35.476802, "o", "\u001b[?2004h> "]
[35.477003, "o", "            is_valid, error_type, error_detail = validate_record(record)\r\n\u001b[?2004l\r"]
[35.477036, "o", "\u001b[?2004h> "]
[35.47707, "o", "            \r\n\u001b[?2004l\r"]
[35.477101, "o", "\u001b[?2004h> "]
[35.47718, "o", "            if not is_valid:\r\n\u001b[?2004l\r"]
[35.477211, "o", "\u001b[?2004h> "]
[35.477302, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[35.477333, "o", "\u001b[?2004h> "]
[35.477461, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[35.477493, "o", "\u001b[?2004h> "]
[35.47762, "o", "                    'error_type': error_type,\r\n\u001b[?2004l\r"]
[35.477651, "o", "\u001b[?2004h> "]
[35.477815, "o", "                    'error_detail': error_detail,\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.477847, "o", "> "]
[35.477974, "o", "                    'raw_content': truncate(raw_line)\r\n\u001b[?2004l\r"]
[35.478002, "o", "\u001b[?2004h> "]
[35.478071, "o", "                })\r\n\u001b[?2004l\r"]
[35.478104, "o", "\u001b[?2004h> "]
[35.478226, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[35.478254, "o", "\u001b[?2004h> "]
[35.478328, "o", "                continue\r\n\u001b[?2004l\r"]
[35.478356, "o", "\u001b[?2004h> "]
[35.478396, "o", "            \r\n\u001b[?2004l\r"]
[35.478427, "o", "\u001b[?2004h> "]
[35.478589, "o", "            # Valid record - compute hash and add metadata\r\n\u001b[?2004l\r"]
[35.478621, "o", "\u001b[?2004h> "]
[35.478706, "o", "            output_record = {\r\n\u001b[?2004l\r"]
[35.47874, "o", "\u001b[?2004h> "]
[35.478906, "o", "                'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[35.478937, "o", "\u001b[?2004h> "]
[35.479071, "o", "                'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[35.479097, "o", "\u001b[?2004h"]
[35.479132, "o", "> "]
[35.479246, "o", "                'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[35.479272, "o", "\u001b[?2004h> "]
[35.479396, "o", "                'amount': record['amount'],\r\n\u001b[?2004l\r"]
[35.479424, "o", "\u001b[?2004h> "]
[35.479556, "o", "                'currency': record['currency'],\r\n\u001b[?2004l\r"]
[35.479579, "o", "\u001b[?2004h"]
[35.479606, "o", "> "]
[35.47971, "o", "                'status': record['status'],\r\n\u001b[?2004l\r"]
[35.479738, "o", "\u001b[?2004h"]
[35.479764, "o", "> "]
[35.479914, "o", "                'integrity_hash': compute_hash(record),\r\n\u001b[?2004l\r"]
[35.479947, "o", "\u001b[?2004h> "]
[35.480077, "o", "                'processed_at': processing_time\r\n\u001b[?2004l\r"]
[35.480104, "o", "\u001b[?2004h"]
[35.480135, "o", "> "]
[35.480166, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.480197, "o", "> "]
[35.480311, "o", "            valid_records.append(output_record)\r\n\u001b[?2004l\r"]
[35.48034, "o", "\u001b[?2004h> "]
[35.480369, "o", "    \r\n\u001b[?2004l\r"]
[35.4804, "o", "\u001b[?2004h> "]
[35.480494, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[35.480526, "o", "\u001b[?2004h> "]
[35.480672, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[35.480703, "o", "\u001b[?2004h> "]
[35.480734, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.480765, "o", "> "]
[35.48084, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[35.480871, "o", "\u001b[?2004h> "]
[35.480976, "o", "    with open(OUTPUT_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.481007, "o", "\u001b[?2004h> "]
[35.48111, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[35.481142, "o", "\u001b[?2004h> "]
[35.48127, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[35.481302, "o", "\u001b[?2004h> "]
[35.481331, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.481364, "o", "> "]
[35.481406, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[35.481437, "o", "\u001b[?2004h> "]
[35.481539, "o", "    with open(ERROR_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.481569, "o", "\u001b[?2004h> "]
[35.48165, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[35.481681, "o", "\u001b[?2004h> "]
[35.481817, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[35.481849, "o", "\u001b[?2004h> "]
[35.481879, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.481907, "o", "> "]
[35.481969, "o", "    # Calculate statistics\r\n\u001b[?2004l\r"]
[35.481999, "o", "\u001b[?2004h> "]
[35.48215, "o", "    total_lines = len(valid_records) + len(errors)\r\n\u001b[?2004l\r"]
[35.48218, "o", "\u001b[?2004h> "]
[35.482422, "o", "    success_rate = (len(valid_records) / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[35.482454, "o", "\u001b[?2004h> "]
[35.482481, "o", "    \r\n\u001b[?2004l\r"]
[35.482512, "o", "\u001b[?2004h> "]
[35.482582, "o", "    # Write summary report\r\n\u001b[?2004l\r"]
[35.482613, "o", "\u001b[?2004h> "]
[35.482722, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.48275, "o", "\u001b[?2004h> "]
[35.482892, "o", "        f.write('AUDIT PROCESSING SUMMARY\\n')\r\n\u001b[?2004l\r"]
[35.482923, "o", "\u001b[?2004h> "]
[35.48305, "o", "        f.write('========================\\n')\r\n\u001b[?2004l\r"]
[35.48308, "o", "\u001b[?2004h> "]
[35.483211, "o", "        f.write(f'Input file: {INPUT_FILE}\\n')\r\n\u001b[?2004l\r"]
[35.483247, "o", "\u001b[?2004h> "]
[35.483405, "o", "        f.write(f'Total lines processed: {total_lines}\\n')\r\n\u001b[?2004l\r"]
[35.483437, "o", "\u001b[?2004h> "]
[35.48361, "o", "        f.write(f'Valid transactions: {len(valid_records)}\\n')\r\n\u001b[?2004l\r"]
[35.483642, "o", "\u001b[?2004h> "]
[35.483797, "o", "        f.write(f'Failed records: {len(errors)}\\n')\r\n\u001b[?2004l\r"]
[35.483829, "o", "\u001b[?2004h> "]
[35.483978, "o", "        f.write(f'Success rate: {success_rate:.2f}%\\n')\r\n\u001b[?2004l\r"]
[35.484003, "o", "\u001b[?2004h"]
[35.484033, "o", "> "]
[35.484072, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[35.484102, "o", "\u001b[?2004h> "]
[35.484206, "o", "        f.write('Errors by type:\\n')\r\n\u001b[?2004l\r"]
[35.484233, "o", "\u001b[?2004h> "]
[35.484436, "o", "        f.write(f\"  malformed_json: {error_counts['malformed_json']}\\n\")\r\n\u001b[?2004l\r"]
[35.48446, "o", "\u001b[?2004h"]
[35.484489, "o", "> "]
[35.484661, "o", "        f.write(f\"  missing_field: {error_counts['missing_field']}\\n\")\r\n\u001b[?2004l\r"]
[35.48469, "o", "\u001b[?2004h> "]
[35.484906, "o", "        f.write(f\"  invalid_format: {error_counts['invalid_format']}\\n\")\r\n\u001b[?2004l\r"]
[35.484935, "o", "\u001b[?2004h> "]
[35.485127, "o", "        f.write(f\"  invalid_value: {error_counts['invalid_value']}\\n\")\r\n\u001b[?2004l\r"]
[35.485154, "o", "\u001b[?2004h> "]
[35.485217, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[35.485248, "o", "\u001b[?2004h> "]
[35.485424, "o", "        f.write(f'Processing completed at: {processing_time}\\n')\r\n\u001b[?2004l\r"]
[35.48546, "o", "\u001b[?2004h> "]
[35.485492, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.48552, "o", "> "]
[35.485597, "o", "    print(f'Processing complete!')\r\n\u001b[?2004l\r"]
[35.485628, "o", "\u001b[?2004h> "]
[35.485767, "o", "    print(f'Valid records: {len(valid_records)}')\r\n\u001b[?2004l\r"]
[35.485806, "o", "\u001b[?2004h> "]
[35.485909, "o", "    print(f'Errors: {len(errors)}')\r\n\u001b[?2004l\r"]
[35.485941, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[35.485973, "o", "\u001b[?2004h> "]
[35.486062, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[35.486094, "o", "\u001b[?2004h> "]
[35.486125, "o", "    main()\r\n\u001b[?2004l\r"]
[35.486156, "o", "\u001b[?2004h> "]
[35.486187, "o", "SCRIPT\r\n\u001b[?2004l\r"]
[35.494343, "o", "\u001b[?2004h"]
[35.494384, "o", "root@f158477b3c7b:/home/user# "]
[36.453143, "i", "python3 /home/user/audit/process_audit.py\n"]
[36.453308, "o", "python3 /home/user/audit/process_audit.py\r\n\u001b[?2004l\r"]
[36.477047, "o", "Processing complete!\r\nValid records: 13\r\nErrors: 12\r\n"]
[36.480325, "o", "\u001b[?2004h"]
[36.480362, "o", "root@f158477b3c7b:/home/user# "]
[44.144691, "i", "cat /home/user/audit/processing_summary.txt\n"]
[44.144882, "o", "cat /home/user/audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[44.145757, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T00:37:46Z\r\n"]
[44.145943, "o", "\u001b[?2004h"]
[44.145999, "o", "root@f158477b3c7b:/home/user# "]
[44.641557, "i", "cat /home/user/audit/clean_audit.jsonl\n"]
[44.641719, "o", "cat /home/user/audit/clean_audit.jsonl\r\n\u001b[?2004l\r"]
