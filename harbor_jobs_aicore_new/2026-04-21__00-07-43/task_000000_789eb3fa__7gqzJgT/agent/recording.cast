[27.338376, "i", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\n#!/bin/bash\n\nMANIFEST=\"/home/user/docs_workspace/permissions_manifest.txt\"\n\ncheck_perm() {\n    local path=\"$1\"\n    local expected=\"$2\"\n    local actual=$(stat -c \"%a\" \"$path\" 2>/dev/null)\n    if [ \"$actual\" != \"$expected\" ]; then\n        echo \"FAIL: $path\"\n        exit 1\n    fi\n}\n\n# Check directory permissions\ncheck_perm \"/home/user/docs_workspace/public\" \"755\"\ncheck_perm \"/home/user/docs_workspace/drafts\" \"700\"\ncheck_perm \"/home/user/docs_workspace/templates\" \"755\"\ncheck_perm \"/home/user/docs_workspace/archive\" \"750\"\n\n# Check file permissions\ncheck_perm \"/home/user/docs_workspace/public/index.md\" \"644\"\ncheck_perm \"/home/user/docs_workspace/drafts/wip-feature.md\" \"600\"\ncheck_perm \"/home/user/docs_workspace/templates/article-template.md\" \"444\"\ncheck_perm \"/home/user/docs_workspace/archive/v1-notes.md\" \"440\"\n\necho \"PASS\"\nEOF\n"]
