[33.372876, "o", "        return False, 'invalid_format', f'invalid currency format: {currency}'\r\n\u001b[?2004l\r"]
[33.372902, "o", "\u001b[?2004h> "]
[33.37293, "o", "    \r\n\u001b[?2004l\r"]
[33.372959, "o", "\u001b[?2004h> "]
[33.373013, "o", "    # Validate status\r\n\u001b[?2004l\r"]
[33.373044, "o", "\u001b[?2004h> "]
[33.373127, "o", "    status = record['status']\r\n\u001b[?2004l\r"]
[33.373159, "o", "\u001b[?2004h> "]
[33.373347, "o", "    if not isinstance(status, str) or status not in VALID_STATUSES:\r\n\u001b[?2004l\r"]
[33.373376, "o", "\u001b[?2004h> "]
[33.373589, "o", "        return False, 'invalid_value', f'invalid status value: {status}'\r\n\u001b[?2004l\r"]
[33.373619, "o", "\u001b[?2004h> "]
[33.37365, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.373679, "o", "> "]
[33.373743, "o", "    return True, None, None\r\n\u001b[?2004l\r"]
[33.373773, "o", "\u001b[?2004h> "]
[33.373811, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[33.373899, "o", "def process_transactions():\r\n\u001b[?2004l\r"]
[33.373931, "o", "\u001b[?2004h> "]
[33.373997, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[33.374031, "o", "\u001b[?2004h> "]
[33.374074, "o", "    errors = []\r\n\u001b[?2004l\r"]
[33.374105, "o", "\u001b[?2004h> "]
[33.374164, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[33.374195, "o", "\u001b[?2004h> "]
[33.374276, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[33.37431, "o", "\u001b[?2004h> "]
[33.374385, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[33.374418, "o", "\u001b[?2004h> "]
[33.374497, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[33.374528, "o", "\u001b[?2004h> "]
[33.374614, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[33.374647, "o", "\u001b[?2004h> "]
[33.374679, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[33.37471, "o", ">     \r\n\u001b[?2004l\r"]
[33.374741, "o", "\u001b[?2004h> "]
[33.374962, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[33.374995, "o", "\u001b[?2004h> "]
[33.375025, "o", "    \r\n\u001b[?2004l\r"]
[33.375058, "o", "\u001b[?2004h> "]
[33.375153, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[33.375186, "o", "\u001b[?2004h> "]
[33.375272, "o", "        lines = f.readlines()\r\n\u001b[?2004l\r"]
[33.375308, "o", "\u001b[?2004h> "]
[33.375343, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.375377, "o", "> "]
[33.375433, "o", "    total_lines = len(lines)\r\n\u001b[?2004l\r"]
[33.375464, "o", "\u001b[?2004h> "]
[33.375495, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.375527, "o", "> "]
[33.37565, "o", "    for line_num, line in enumerate(lines, 1):\r\n\u001b[?2004l\r"]
[33.375678, "o", "\u001b[?2004h"]
[33.375708, "o", "> "]
[33.375794, "o", "        raw_content = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[33.375827, "o", "\u001b[?2004h> "]
[33.375952, "o", "        truncated_content = raw_content[:200]\r\n\u001b[?2004l\r"]
[33.375983, "o", "\u001b[?2004h> "]
[33.376016, "o", "        \r\n\u001b[?2004l\r"]
[33.376049, "o", "\u001b[?2004h> "]
[33.376121, "o", "        # Try to parse JSON\r\n\u001b[?2004l\r"]
[33.376154, "o", "\u001b[?2004h> "]
[33.376187, "o", "        try:\r\n\u001b[?2004l\r"]
[33.376219, "o", "\u001b[?2004h> "]
[33.376325, "o", "            record = json.loads(line)\r\n\u001b[?2004l\r"]
[33.376358, "o", "\u001b[?2004h> "]
[33.37646, "o", "        except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[33.376493, "o", "\u001b[?2004h> "]
[33.376582, "o", "            errors.append({\r\n\u001b[?2004l\r"]
[33.376615, "o", "\u001b[?2004h> "]
[33.376729, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.376761, "o", "\u001b[?2004h> "]
[33.376893, "o", "                'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[33.376925, "o", "\u001b[?2004h> "]
[33.377076, "o", "                'error_detail': 'invalid JSON syntax',\r\n\u001b[?2004l\r"]
[33.377109, "o", "\u001b[?2004h> "]
[33.377249, "o", "                'raw_content': truncated_content\r\n\u001b[?2004l\r"]
[33.37728, "o", "\u001b[?2004h> "]
[33.377326, "o", "            })\r\n\u001b[?2004l\r"]
[33.377357, "o", "\u001b[?2004h> "]
[33.377494, "o", "            error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[33.377527, "o", "\u001b[?2004h> "]
[33.377594, "o", "            continue\r\n\u001b[?2004l\r"]
[33.377628, "o", "\u001b[?2004h> "]
[33.377655, "o", "        \r\n\u001b[?2004l\r"]
[33.377686, "o", "\u001b[?2004h> "]
[33.377761, "o", "        # Validate record\r\n\u001b[?2004l\r"]
[33.377793, "o", "\u001b[?2004h> "]
[33.377996, "o", "        is_valid, error_type, error_detail = validate_record(record)\r\n\u001b[?2004l\r"]
[33.378029, "o", "\u001b[?2004h> "]
[33.37806, "o", "        \r\n\u001b[?2004l\r"]
[33.378093, "o", "\u001b[?2004h> "]
[33.378155, "o", "        if not is_valid:\r\n\u001b[?2004l\r"]
[33.378191, "o", "\u001b[?2004h> "]
[33.378265, "o", "            errors.append({\r\n\u001b[?2004l\r"]
[33.378296, "o", "\u001b[?2004h> "]
[33.378409, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.378442, "o", "\u001b[?2004h> "]
[33.378569, "o", "                'error_type': error_type,\r\n\u001b[?2004l\r"]
[33.378597, "o", "\u001b[?2004h> "]
[33.378734, "o", "                'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[33.378762, "o", "\u001b[?2004h"]
[33.378791, "o", "> "]
[33.378903, "o", "                'raw_content': truncated_content\r\n\u001b[?2004l\r"]
[33.37893, "o", "\u001b[?2004h> "]
[33.378978, "o", "            })\r\n\u001b[?2004l\r"]
[33.379007, "o", "\u001b[?2004h> "]
[33.379128, "o", "            error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[33.379159, "o", "\u001b[?2004h> "]
[33.37922, "o", "            continue\r\n\u001b[?2004l\r"]
[33.379253, "o", "\u001b[?2004h> "]
[33.379285, "o", "        \r\n\u001b[?2004l\r"]
[33.379316, "o", "\u001b[?2004h> "]
[33.379445, "o", "        # Compute hash and create output record\r\n\u001b[?2004l\r"]
[33.379476, "o", "\u001b[?2004h> "]
[33.379619, "o", "        integrity_hash = compute_hash(record)\r\n\u001b[?2004l\r"]
[33.379634, "o", "\u001b[?2004h"]
[33.379671, "o", "> "]
[33.379722, "o", "        output_record = {\r\n\u001b[?2004l\r"]
[33.379752, "o", "\u001b[?2004h> "]
[33.379909, "o", "            'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[33.379942, "o", "\u001b[?2004h> "]
[33.380068, "o", "            'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[33.3801, "o", "\u001b[?2004h> "]
[33.380231, "o", "            'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[33.380265, "o", "\u001b[?2004h> "]
[33.380373, "o", "            'amount': record['amount'],\r\n\u001b[?2004l\r"]
[33.380406, "o", "\u001b[?2004h> "]
[33.380526, "o", "            'currency': record['currency'],\r\n\u001b[?2004l\r"]
[33.380571, "o", "\u001b[?2004h> "]
[33.380679, "o", "            'status': record['status'],\r\n\u001b[?2004l\r"]
[33.38071, "o", "\u001b[?2004h> "]
[33.38084, "o", "            'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[33.380871, "o", "\u001b[?2004h> "]
[33.380991, "o", "            'processed_at': processing_time\r\n\u001b[?2004l\r"]
[33.381023, "o", "\u001b[?2004h> "]
[33.381055, "o", "        }\r\n\u001b[?2004l\r"]
[33.381087, "o", "\u001b[?2004h> "]
[33.381205, "o", "        valid_records.append(output_record)\r\n\u001b[?2004l\r"]
[33.381236, "o", "\u001b[?2004h> "]
[33.381268, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.381301, "o", "> "]
[33.381387, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[33.381416, "o", "\u001b[?2004h> "]
[33.381578, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[33.381603, "o", "\u001b[?2004h"]
[33.381633, "o", ">     \r\n\u001b[?2004l\r"]
[33.381665, "o", "\u001b[?2004h> "]
[33.38174, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[33.381771, "o", "\u001b[?2004h> "]
[33.381888, "o", "    with open(OUTPUT_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.381921, "o", "\u001b[?2004h> "]
[33.382025, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[33.382056, "o", "\u001b[?2004h> "]
[33.382186, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[33.382212, "o", "\u001b[?2004h"]
[33.382239, "o", ">     \r\n\u001b[?2004l\r"]
[33.382268, "o", "\u001b[?2004h> "]
[33.382334, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[33.382356, "o", "\u001b[?2004h"]
[33.382385, "o", "> "]
[33.382469, "o", "    with open(ERROR_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.382497, "o", "\u001b[?2004h> "]
[33.382595, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[33.382619, "o", "\u001b[?2004h"]
[33.38265, "o", "> "]
[33.382753, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[33.382776, "o", "\u001b[?2004h"]
[33.382802, "o", ">     \r\n\u001b[?2004l\r"]
[33.382829, "o", "\u001b[?2004h> "]
[33.382912, "o", "    # Calculate success rate\r\n\u001b[?2004l\r"]
[33.382939, "o", "\u001b[?2004h> "]
[33.383047, "o", "    valid_count = len(valid_records)\r\n\u001b[?2004l\r"]
[33.38308, "o", "\u001b[?2004h> "]
[33.383165, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[33.383195, "o", "\u001b[?2004h> "]
[33.383421, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[33.383452, "o", "\u001b[?2004h"]
[33.383481, "o", ">     \r\n\u001b[?2004l\r"]
[33.383508, "o", "\u001b[?2004h> "]
[33.383588, "o", "    # Write summary report\r\n\u001b[?2004l\r"]
[33.383619, "o", "\u001b[?2004h> "]
[33.383738, "o", "    summary = f\"\"\"AUDIT PROCESSING SUMMARY\r\n\u001b[?2004l\r"]
[33.383771, "o", "\u001b[?2004h> "]
[33.383839, "o", "========================\r\n\u001b[?2004l\r"]
[33.383872, "o", "\u001b[?2004h> "]
[33.38394, "o", "Input file: {INPUT_FILE}\r\n\u001b[?2004l\r"]
[33.383973, "o", "\u001b[?2004h> "]
[33.384074, "o", "Total lines processed: {total_lines}\r\n\u001b[?2004l\r"]
[33.384107, "o", "\u001b[?2004h> "]
[33.3842, "o", "Valid transactions: {valid_count}\r\n\u001b[?2004l\r"]
[33.384233, "o", "\u001b[?2004h> "]
[33.384318, "o", "Failed records: {failed_count}\r\n\u001b[?2004l\r"]
[33.384351, "o", "\u001b[?2004h> "]
[33.384444, "o", "Success rate: {success_rate:.2f}%\r\n\u001b[?2004l\r"]
[33.384477, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.38451, "o", "\u001b[?2004h> "]
[33.384564, "o", "Errors by type:\r\n\u001b[?2004l\r"]
[33.384595, "o", "\u001b[?2004h> "]
[33.384741, "o", "  malformed_json: {error_counts['malformed_json']}\r\n\u001b[?2004l\r"]
[33.384773, "o", "\u001b[?2004h> "]
[33.38491, "o", "  missing_field: {error_counts['missing_field']}\r\n\u001b[?2004l\r"]
[33.384937, "o", "\u001b[?2004h> "]
[33.385082, "o", "  invalid_format: {error_counts['invalid_format']}\r\n\u001b[?2004l\r"]
[33.385111, "o", "\u001b[?2004h> "]
[33.385253, "o", "  invalid_value: {error_counts['invalid_value']}\r\n\u001b[?2004l\r"]
[33.385278, "o", "\u001b[?2004h> "]
[33.385308, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[33.385339, "o", "> "]
[33.385435, "o", "Processing completed at: {processing_time}\r\n\u001b[?2004l\r"]
[33.385464, "o", "\u001b[?2004h> "]
[33.385495, "o", "\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[33.385524, "o", ">     \r\n"]
[33.385564, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[33.385675, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.385707, "o", "\u001b[?2004h> "]
[33.385779, "o", "        f.write(summary)\r\n\u001b[?2004l\r"]
[33.385823, "o", "\u001b[?2004h> "]
[33.385855, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.385887, "o", "> "]
[33.385969, "o", "    print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[33.386001, "o", "\u001b[?2004h> "]
[33.386168, "o", "    print(f\"Valid: {valid_count}, Errors: {failed_count}\")\r\n\u001b[?2004l\r"]
[33.386201, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.386234, "o", "\u001b[?2004h> "]
[33.38631, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[33.386338, "o", "\u001b[?2004h"]
[33.386364, "o", "> "]
[33.38642, "o", "    process_transactions()\r\n\u001b[?2004l\r"]
[33.386451, "o", "\u001b[?2004h> "]
[33.386484, "o", "EOF\r\n\u001b[?2004l\r"]
[33.396069, "o", "\u001b[?2004h"]
[33.396105, "o", "root@d14d5ea28f52:/home/user# "]
[34.362044, "i", "python3 /home/user/audit/process_audit.py\n"]
[34.362226, "o", "python3 /home/user/audit/process_audit.py\r\n\u001b[?2004l\r"]
[34.388766, "o", "Processing complete!\r\nValid: 13, Errors: 12\r\n"]
[34.392564, "o", "\u001b[?2004h"]
[34.392608, "o", "root@d14d5ea28f52:/home/user# "]
[41.375275, "i", "cat /home/user/audit/processing_summary.txt\n"]
[41.375447, "o", "cat /home/user/audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[41.376447, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T00:21:35Z\r\n"]
[41.376604, "o", "\u001b[?2004h"]
[41.376655, "o", "root@d14d5ea28f52:/home/user# "]
[41.874928, "i", "cat /home/user/audit/clean_audit.jsonl\n"]
[41.87508, "o", "cat /home/user/audit/clean_audit.jsonl\r\n"]
