[?2004l[?2004h>   if [ -n "$info" ]; then
[?2004l[?2004h>     echo "$info"
[?2004l[?2004h>   else
[?2004l[?2004h>     # Try apt-cache show as fallback
[?2004l[?2004h>     ver=$(apt-cache show "$pkg" 2>/dev/null | grep -m1 '^Version:' | cut -d' ' -f2)
[?2004l[?2004h>     size=$(apt-cache show "$pkg" 2>/dev/null | grep -m1 '^Installed-Size:' | cut -d' ' -f2)
[?2004l[?2004h>     echo "$pkg|${ver:-unknown}|${size:-0}"
[?2004l[?2004h>   fi
[?2004l[?2004h> done >> package_info.txt
