[25.374746, "i", "# Get all dependencies for required packages\necho '' > all_deps.txt\nfor pkg in $(cat required_packages.txt); do\n  echo \"Checking deps for: $pkg\" >&2\n  get_deps \"$pkg\" 1 >> all_deps.txt\ndone\nsort -u all_deps.txt > all_deps_unique.txt\nwc -l all_deps_unique.txt\n"]
