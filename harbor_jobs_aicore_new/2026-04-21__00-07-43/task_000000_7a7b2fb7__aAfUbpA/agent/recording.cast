[279.246719, "i", "# Get package info for removable packages (version and size)\necho \"Package|Version|Size_KB\" > package_info.txt\nfor pkg in $(cat removable_packages.txt); do\n  info=$(dpkg-query -W -f='${Package}|${Version}|${Installed-Size}' \"$pkg\" 2>/dev/null)\n  if [ -n \"$info\" ]; then\n    echo \"$info\"\n  else\n    # Try apt-cache show as fallback\n    ver=$(apt-cache show \"$pkg\" 2>/dev/null | grep -m1 '^Version:' | cut -d' ' -f2)\n    size=$(apt-cache show \"$pkg\" 2>/dev/null | grep -m1 '^Installed-Size:' | cut -d' ' -f2)\n    echo \"$pkg|${ver:-unknown}|${size:-0}\"\n  fi\ndone >> package_info.txt\ncat package_info.txt\n"]
