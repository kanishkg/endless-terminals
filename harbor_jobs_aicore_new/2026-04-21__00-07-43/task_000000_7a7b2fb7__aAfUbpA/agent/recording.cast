[240.81856, "i", "# For each protected package, find which required packages need it\nfor pkg in $(cat protected_packages.txt); do\n  echo \"=== $pkg is required by ===\"\n  for req in $(cat required_packages.txt); do\n    if apt-cache depends \"$req\" 2>/dev/null | grep -qE \"(Depends|PreDepends):.*$pkg\"; then\n      echo \"  - $req (direct)\"\n    fi\n  done\ndone\n"]
