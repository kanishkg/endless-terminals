[24.858557, "i", "# Function to get dependencies up to 3 levels deep\nget_deps() {\n  local pkg=$1\n  local level=$2\n  if [ $level -gt 3 ]; then return; fi\n  apt-cache depends \"$pkg\" 2>/dev/null | grep -E \"^\\s*(Depends|PreDepends):\" | sed 's/.*: //' | sed 's/<\\|>//g' | while read dep; do\n    echo \"$dep\"\n    get_deps \"$dep\" $((level+1))\n  done\n}\n"]
