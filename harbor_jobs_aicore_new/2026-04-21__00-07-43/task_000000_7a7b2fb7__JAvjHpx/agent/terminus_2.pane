[?2004l[?2004h>         
[?2004l[?2004h>         # If candidate differs from installed and security pocket is involved
[?2004l[?2004h>         if candidate and installed and candidate != installed:
[?2004l[?2004h>             if installed == '(none)':
[?2004l[?2004h>                 # Not installed, check if candidate comes from security
