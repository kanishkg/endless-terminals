[?2004l[?2004h>                 for i, line in enumerate(lines):
[?2004l[?2004h>                     if candidate in line and i+1 < len(lines):
[?2004l[?2004h>                         if 'security' in lines[i+1].lower():
[?2004l[?2004h>                             return True
[?2004l[?2004h>             return 'security' in output.lower()
[?2004l[?2004h>         
[?2004l[?2004h>         return False
