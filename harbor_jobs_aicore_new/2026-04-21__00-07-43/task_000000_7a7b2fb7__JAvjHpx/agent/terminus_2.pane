[?2004l[?2004h> def find_required_by(package, required_packages):
[?2004l[?2004h>     """Find which required packages need this as a dependency"""
[?2004l[?2004h>     required_by = []
[?2004l[?2004h>     for req in required_packages:
[?2004l[?2004h>         try:
[?2004l[?2004h>             result = subprocess.run(['apt-cache', 'depends', req],
[?2004l[?2004h>                                     capture_output=True, text=True, timeout=10)
[?2004l[?2004h>             if package in result.stdout:
[?2004l[?2004h>                 required_by.append(req)
[?2004l[?2004h>         except:
[?2004l[?2004h>             pass
[?2004l[?2004h>     return required_by
