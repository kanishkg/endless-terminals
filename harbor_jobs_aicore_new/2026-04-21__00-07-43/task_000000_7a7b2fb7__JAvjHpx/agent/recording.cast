[246.706577, "o", "        if 'security' not in output.lower():\r\n\u001b[?2004l\r"]
[246.706609, "o", "\u001b[?2004h> "]
[246.706709, "o", "            return False\r\n\u001b[?2004l\r"]
[246.706741, "o", "\u001b[?2004h> "]
[246.706781, "o", "        \r\n\u001b[?2004l\r"]
[246.706814, "o", "\u001b[?2004h> "]
[246.706954, "o", "        candidate = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[246.707062, "o", "        installed = None\r\n\u001b[?2004l\r"]
[246.707093, "o", "\u001b[?2004h> "]
[246.707134, "o", "        \r\n\u001b[?2004l\r"]
[246.707164, "o", "\u001b[?2004h> "]
[246.707336, "o", "        for line in output.split('\\n'):\r\n\u001b[?2004l\r"]
[246.707367, "o", "\u001b[?2004h> "]
[246.707516, "o", "            if 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[246.707545, "o", "\u001b[?2004h> "]
[246.707768, "o", "                candidate = line.split(':')[1].strip()\r\n\u001b[?2004l\r"]
[246.707798, "o", "\u001b[?2004h> "]
[246.707965, "o", "            elif 'Installed:' in line:\r\n\u001b[?2004l\r"]
[246.707998, "o", "\u001b[?2004h> "]
[246.708212, "o", "                installed = line.split(':')[1].strip()\r\n\u001b[?2004l\r"]
[246.708241, "o", "\u001b[?2004h> "]
[246.708286, "o", "        \r\n\u001b[?2004l\r"]
[246.708317, "o", "\u001b[?2004h> "]
[246.708627, "o", "        # If candidate differs from installed and security pocket is involved\r\n\u001b[?2004l\r"]
[246.70866, "o", "\u001b[?2004h> "]
[246.708908, "o", "        if candidate and installed and candidate != installed:\r\n\u001b[?2004l\r"]
[246.708957, "o", "\u001b[?2004h> "]
[246.709104, "o", "            if installed == '(none)':\r\n\u001b[?2004l\r"]
[246.709136, "o", "\u001b[?2004h> "]
[246.709416, "o", "                # Not installed, check if candidate comes from security\r\n\u001b[?2004l\r"]
[246.709449, "o", "\u001b[?2004h> "]
[246.709566, "o", "                lines = output.split('\\n')\r\n\u001b[?2004l\r"]
[246.709595, "o", "\u001b[?2004h> "]
[246.709733, "o", "                for i, line in enumerate(lines):\r\n\u001b[?2004l\r"]
[246.709764, "o", "\u001b[?2004h> "]
[246.709949, "o", "                    if candidate in line and i+1 < len(lines):\r\n\u001b[?2004l\r"]
[246.709983, "o", "\u001b[?2004h> "]
[246.710139, "o", "                        if 'security' in lines[i+1].lower():\r\n\u001b[?2004l\r"]
[246.710168, "o", "\u001b[?2004h> "]
[246.71028, "o", "                            return True\r\n\u001b[?2004l\r"]
[246.710311, "o", "\u001b[?2004h> "]
[246.710442, "o", "            return 'security' in output.lower()\r\n\u001b[?2004l\r"]
[246.71047, "o", "\u001b[?2004h> "]
[246.7105, "o", "        \r\n\u001b[?2004l\r"]
[246.710531, "o", "\u001b[?2004h> "]
[246.71059, "o", "        return False\r\n\u001b[?2004l\r"]
[246.710621, "o", "\u001b[?2004h> "]
[246.710658, "o", "    except:\r\n\u001b[?2004l\r"]
[246.71069, "o", "\u001b[?2004h> "]
[246.710744, "o", "        return False\r\n\u001b[?2004l\r"]
[246.710777, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.710807, "o", "\u001b[?2004h> "]
[246.710954, "o", "def find_required_by(package, required_packages):\r\n\u001b[?2004l\r"]
[246.710988, "o", "\u001b[?2004h> "]
[246.711162, "o", "    \"\"\"Find which required packages need this as a dependency\"\"\"\r\n\u001b[?2004l\r"]
[246.711205, "o", "\u001b[?2004h> "]
[246.711258, "o", "    required_by = []\r\n\u001b[?2004l\r"]
[246.711289, "o", "\u001b[?2004h> "]
[246.711386, "o", "    for req in required_packages:\r\n\u001b[?2004l\r"]
[246.711417, "o", "\u001b[?2004h> "]
[246.711456, "o", "        try:\r\n\u001b[?2004l\r"]
[246.711488, "o", "\u001b[?2004h> "]
[246.711668, "o", "            result = subprocess.run(['apt-cache', 'depends', req],\r\n\u001b[?2004l\r"]
[246.711696, "o", "\u001b[?2004h> "]
[246.711928, "o", "                                    capture_output=True, text=True, timeout=10)\r\n\u001b[?2004l\r"]
[246.711968, "o", "\u001b[?2004h"]
[246.711995, "o", "> "]
[246.712069, "o", "            if package in result.stdout:\r\n\u001b[?2004l\r"]
[246.712098, "o", "\u001b[?2004h> "]
[246.712208, "o", "                required_by.append(req)\r\n\u001b[?2004l\r"]
[246.712238, "o", "\u001b[?2004h> "]
[246.712285, "o", "        except:\r\n\u001b[?2004l\r"]
[246.712314, "o", "\u001b[?2004h> "]
[246.712361, "o", "            pass\r\n\u001b[?2004l\r"]
[246.712392, "o", "\u001b[?2004h> "]
[246.712456, "o", "    return required_by\r\n\u001b[?2004l\r"]
[246.712487, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.712515, "o", "\u001b[?2004h> "]
[246.712558, "o", "# Main logic\r\n\u001b[?2004l\r"]
[246.712588, "o", "\u001b[?2004h> "]
[246.712789, "o", "installed = read_packages('/home/user/migration/installed_packages.txt')\r\n\u001b[?2004l\r"]
[246.71282, "o", "\u001b[?2004h> "]
[246.713025, "o", "required = read_packages('/home/user/migration/required_packages.txt')\r\n\u001b[?2004l\r"]
[246.713058, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.71309, "o", "\u001b[?2004h> "]
[246.713207, "o", "print(f\"Total installed: {len(installed)}\")\r\n\u001b[?2004l\r"]
[246.713238, "o", "\u001b[?2004h> "]
[246.713354, "o", "print(f\"Total required: {len(required)}\")\r\n\u001b[?2004l\r"]
[246.713384, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.713415, "o", "\u001b[?2004h> "]
[246.713506, "o", "# Find packages not in required\r\n\u001b[?2004l\r"]
[246.713537, "o", "\u001b[?2004h> "]
[246.713699, "o", "not_required = [p for p in installed if p not in required]\r\n\u001b[?2004l\r"]
[246.713728, "o", "\u001b[?2004h> "]
[246.713872, "o", "print(f\"Not in required list: {len(not_required)}\")\r\n\u001b[?2004l\r"]
[246.713892, "o", "\u001b[?2004h"]
[246.713943, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[246.713975, "o", "> "]
[246.714118, "o", "# Get all dependencies of required packages (up to 3 levels)\r\n\u001b[?2004l\r"]
[246.714149, "o", "\u001b[?2004h> "]
[246.714307, "o", "print(\"Collecting dependencies of required packages...\")\r\n\u001b[?2004l\r"]
[246.714338, "o", "\u001b[?2004h> "]
[246.714377, "o", "all_deps = {}\r\n\u001b[?2004l\r"]
[246.714406, "o", "\u001b[?2004h> "]
[246.714466, "o", "for req in required:\r\n\u001b[?2004l\r"]
[246.714496, "o", "\u001b[?2004h> "]
[246.714592, "o", "    print(f\"  Processing: {req}\")\r\n\u001b[?2004l\r"]
[246.714622, "o", "\u001b[?2004h> "]
[246.714732, "o", "    deps = get_dependencies(req, 1, 3)\r\n\u001b[?2004l\r"]
[246.714761, "o", "\u001b[?2004h> "]
[246.714835, "o", "    all_deps.update(deps)\r\n\u001b[?2004l\r"]
[246.714865, "o", "\u001b[?2004h> "]
[246.714896, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[246.714932, "o", "> "]
[246.715053, "o", "print(f\"Total dependencies found: {len(all_deps)}\")\r\n\u001b[?2004l\r"]
[246.715082, "o", "\u001b[?2004h> "]
[246.715115, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[246.715226, "o", "# Separate removable from protected\r\n\u001b[?2004l\r"]
[246.715258, "o", "\u001b[?2004h> "]
[246.715302, "o", "removable = []\r\n\u001b[?2004l\r"]
[246.715332, "o", "\u001b[?2004h> "]
[246.715376, "o", "protected = []\r\n\u001b[?2004l\r"]
[246.715405, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.715435, "o", "\u001b[?2004h> "]
[246.715506, "o", "for pkg in not_required:\r\n\u001b[?2004l\r"]
[246.715534, "o", "\u001b[?2004h> "]
[246.715604, "o", "    if pkg in all_deps:\r\n\u001b[?2004l\r"]
[246.715632, "o", "\u001b[?2004h> "]
[246.715718, "o", "        protected.append(pkg)\r\n\u001b[?2004l\r"]
[246.715747, "o", "\u001b[?2004h> "]
[246.715777, "o", "    else:\r\n\u001b[?2004l\r"]
[246.715806, "o", "\u001b[?2004h> "]
[246.715891, "o", "        removable.append(pkg)\r\n\u001b[?2004l\r"]
[246.715937, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.715966, "o", "\u001b[?2004h> "]
[246.716012, "o", "removable.sort()\r\n\u001b[?2004l\r"]
[246.716042, "o", "\u001b[?2004h> "]
[246.716089, "o", "protected.sort()\r\n\u001b[?2004l\r"]
[246.716121, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.71615, "o", "\u001b[?2004h> "]
[246.716254, "o", "print(f\"Removable: {len(removable)}\")\r\n\u001b[?2004l\r"]
[246.716282, "o", "\u001b[?2004h> "]
[246.716391, "o", "print(f\"Protected: {len(protected)}\")\r\n\u001b[?2004l\r"]
[246.716417, "o", "\u001b[?2004h> \r\n"]
[246.716444, "o", "\u001b[?2004l\r\u001b[?2004h"]
[246.71647, "o", "> "]
[246.71654, "o", "# Build removable packages info\r\n\u001b[?2004l\r"]
[246.71657, "o", "\u001b[?2004h> "]
[246.716664, "o", "print(\"Getting package info...\")\r\n\u001b[?2004l\r"]
[246.716695, "o", "\u001b[?2004h> "]
[246.716763, "o", "removable_packages = []\r\n\u001b[?2004l\r"]
[246.716791, "o", "\u001b[?2004h> "]
[246.716837, "o", "total_size = 0\r\n\u001b[?2004l\r"]
[246.716869, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.716897, "o", "\u001b[?2004h> "]
[246.716969, "o", "for pkg in removable:\r\n\u001b[?2004l\r"]
[246.717003, "o", "\u001b[?2004h> "]
[246.717128, "o", "    version, size_kb = get_apt_cache_info(pkg)\r\n\u001b[?2004l\r"]
[246.717156, "o", "\u001b[?2004h> "]
[246.717286, "o", "    has_security = check_security_update(pkg)\r\n\u001b[?2004l\r"]
[246.717318, "o", "\u001b[?2004h> "]
[246.71739, "o", "    total_size += size_kb\r\n\u001b[?2004l\r"]
[246.717419, "o", "\u001b[?2004h> "]
[246.717452, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[246.717483, "o", "> "]
[246.717552, "o", "    removable_packages.append({\r\n\u001b[?2004l\r"]
[246.717582, "o", "\u001b[?2004h> "]
[246.717643, "o", "        \"name\": pkg,\r\n\u001b[?2004l\r"]
[246.717672, "o", "\u001b[?2004h> "]
[246.717779, "o", "        \"installed_version\": version,\r\n\u001b[?2004l\r"]
[246.717808, "o", "\u001b[?2004h> "]
[246.717887, "o", "        \"size_kb\": size_kb,\r\n\u001b[?2004l\r"]
[246.717927, "o", "\u001b[?2004h> "]
[246.718051, "o", "        \"has_security_update\": has_security\r\n\u001b[?2004l\r"]
[246.718079, "o", "\u001b[?2004h> "]
[246.718111, "o", "    })\r\n\u001b[?2004l\r"]
[246.718141, "o", "\u001b[?2004h> "]
[246.718332, "o", "    print(f\"  {pkg}: {version}, {size_kb}KB, security={has_security}\")\r\n\u001b[?2004l\r"]
[246.718363, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.718395, "o", "\u001b[?2004h> "]
[246.718483, "o", "# Build protected packages info\r\n\u001b[?2004l\r"]
[246.718514, "o", "\u001b[?2004h> "]
[246.718634, "o", "print(\"Getting protected package info...\")\r\n\u001b[?2004l\r"]
[246.718665, "o", "\u001b[?2004h> "]
[246.718737, "o", "dependency_protected = []\r\n\u001b[?2004l\r"]
[246.718767, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.718798, "o", "\u001b[?2004h> "]
[246.718862, "o", "for pkg in protected:\r\n\u001b[?2004l\r"]
[246.718895, "o", "\u001b[?2004h> "]
[246.719027, "o", "    req_by = find_required_by(pkg, required)\r\n\u001b[?2004l\r"]
[246.719061, "o", "\u001b[?2004h> "]
[246.71911, "o", "    if not req_by:\r\n\u001b[?2004l\r"]
[246.719141, "o", "\u001b[?2004h> "]
[246.71927, "o", "        # Use the stored dependency chain\r\n\u001b[?2004l\r"]
[246.719306, "o", "\u001b[?2004h> "]
[246.719434, "o", "        req_by = [all_deps.get(pkg, \"unknown\")]\r\n\u001b[?2004l\r"]
[246.719466, "o", "\u001b[?2004h> "]
[246.719497, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[246.719517, "o", "> "]
[246.719606, "o", "    dependency_protected.append({\r\n\u001b[?2004l\r"]
[246.719639, "o", "\u001b[?2004h> "]
[246.719694, "o", "        \"name\": pkg,\r\n\u001b[?2004l\r"]
[246.719725, "o", "\u001b[?2004h> "]
[246.719805, "o", "        \"required_by\": req_by\r\n\u001b[?2004l\r"]
[246.719835, "o", "\u001b[?2004h> "]
[246.719865, "o", "    })\r\n\u001b[?2004l\r"]
[246.719895, "o", "\u001b[?2004h> "]
[246.720021, "o", "    print(f\"  {pkg}: required by {req_by}\")\r\n\u001b[?2004l\r"]
[246.720055, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[246.720085, "o", "\u001b[?2004h> "]
[246.720145, "o", "# Build final report\r\n\u001b[?2004l\r"]
[246.720176, "o", "\u001b[?2004h> "]
[246.720208, "o", "report = {\r\n\u001b[?2004l\r"]
[246.720239, "o", "\u001b[?2004h> "]
[246.720286, "o", "    \"summary\": {\r\n\u001b[?2004l\r"]
[246.720318, "o", "\u001b[?2004h> "]
[246.720437, "o", "        \"total_installed\": len(installed),\r\n\u001b[?2004l\r"]
[246.72047, "o", "\u001b[?2004h> "]
[246.720582, "o", "        \"total_required\": len(required),\r\n\u001b[?2004l\r"]
[246.720611, "o", "\u001b[?2004h> "]
[246.720731, "o", "        \"removable_count\": len(removable),\r\n\u001b[?2004l\r"]
[246.720762, "o", "\u001b[?2004h> "]
[246.720895, "o", "        \"kept_as_dependencies\": len(protected),\r\n\u001b[?2004l\r"]
[246.72094, "o", "\u001b[?2004h> "]
[246.721058, "o", "        \"total_space_savings_kb\": total_size\r\n\u001b[?2004l\r"]
[246.721089, "o", "\u001b[?2004h> "]
[246.721121, "o", "    },\r\n\u001b[?2004l\r"]
[246.721152, "o", "\u001b[?2004h> "]
[246.721266, "o", "    \"removable_packages\": removable_packages,\r\n\u001b[?2004l\r"]
[246.721296, "o", "\u001b[?2004h> "]
[246.72143, "o", "    \"dependency_protected\": dependency_protected\r\n\u001b[?2004l\r"]
[246.721459, "o", "\u001b[?2004h> "]
[246.721487, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[246.721513, "o", "> \r\n\u001b[?2004l\r"]
[246.721545, "o", "\u001b[?2004h> "]
[246.721593, "o", "# Write JSON report\r\n\u001b[?2004l\r"]
[246.721625, "o", "\u001b[?2004h> "]
[246.721804, "o", "with open('/home/user/migration/removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[246.721836, "o", "\u001b[?2004h> "]
[246.721943, "o", "    json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[246.721973, "o", "\u001b[?2004h> "]
[246.722004, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[246.722121, "o", "print(\"\\nGenerated removal_report.json\")\r\n\u001b[?2004l\r"]
[246.722149, "o", "\u001b[?2004h> "]
[246.722181, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[246.722257, "o", "# Generate removal script\r\n\u001b[?2004l\r"]
[246.722288, "o", "\u001b[?2004h> "]
[246.722461, "o", "with open('/home/user/migration/remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[246.722488, "o", "\u001b[?2004h> "]
[246.722572, "o", "    f.write(\"#!/bin/bash\\n\")\r\n\u001b[?2004l\r"]
[246.722603, "o", "\u001b[?2004h> "]
[246.722798, "o", "    f.write(\"# Auto-generated script to remove unnecessary packages\\n\")\r\n\u001b[?2004l\r"]
[246.722828, "o", "\u001b[?2004h> "]
[246.723031, "o", "    f.write(\"# Removable packages identified by migration audit\\n\\n\")\r\n\u001b[?2004l\r"]
[246.723061, "o", "\u001b[?2004h> "]
[246.723221, "o", "    f.write(f'PACKAGES=\"{\" \".join(removable)}\"\\n\\n')\r\n\u001b[?2004l\r"]
[246.723251, "o", "\u001b[?2004h> "]
[246.723429, "o", "    f.write('echo \"The following packages will be removed:\"\\n')\r\n\u001b[?2004l\r"]
[246.723459, "o", "\u001b[?2004h> "]
[246.723556, "o", "    f.write('echo \"$PACKAGES\"\\n')\r\n\u001b[?2004l\r"]
[246.723586, "o", "\u001b[?2004h> "]
[246.723658, "o", "    f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[246.723688, "o", "\u001b[?2004h> "]
[246.723833, "o", "    f.write('echo \"Performing dry-run first...\"\\n')\r\n\u001b[?2004l\r"]
[246.723861, "o", "\u001b[?2004h> "]
[246.724023, "o", "    f.write('apt-get remove --dry-run $PACKAGES\\n\\n')\r\n\u001b[?2004l\r"]
[246.724054, "o", "\u001b[?2004h> "]
[246.724123, "o", "    f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[246.724153, "o", "\u001b[?2004h> "]
[246.724312, "o", "    f.write('echo \"Proceeding with actual removal...\"\\n')\r\n\u001b[?2004l\r"]
[246.724344, "o", "\u001b[?2004h> "]
[246.724481, "o", "    f.write('sudo apt-get remove -y $PACKAGES\\n')\r\n\u001b[?2004l\r"]
