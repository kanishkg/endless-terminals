[37.637646, "o", "    # Get installed version\r\n\u001b[?2004l\r"]
[37.637677, "o", "\u001b[?2004h> "]
[37.637901, "o", "    version=$(dpkg-query -W -f='${Version}' \"$pkg\" 2>/dev/null || echo \"unknown\")\r\n\u001b[?2004l\r"]
[37.637946, "o", "\u001b[?2004h> "]
[37.637979, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.63801, "o", "> "]
[37.638077, "o", "    # Get installed size in KB\r\n\u001b[?2004l\r"]
[37.638113, "o", "\u001b[?2004h> "]
[37.638328, "o", "    size=$(dpkg-query -W -f='${Installed-Size}' \"$pkg\" 2>/dev/null || echo \"0\")\r\n\u001b[?2004l\r"]
[37.638367, "o", "\u001b[?2004h> "]
[37.638446, "o", "    [[ -z \"$size\" ]] && size=0\r\n\u001b[?2004l\r"]
[37.638477, "o", "\u001b[?2004h> "]
[37.638581, "o", "    total_size=$((total_size + size))\r\n\u001b[?2004l\r"]
[37.63861, "o", "\u001b[?2004h> "]
[37.638642, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.63867, "o", "> "]
[37.638747, "o", "    # Check for security updates\r\n\u001b[?2004l\r"]
[37.638776, "o", "\u001b[?2004h> "]
[37.638848, "o", "    has_security=\"false\"\r\n\u001b[?2004l\r"]
[37.638878, "o", "\u001b[?2004h> "]
[37.639029, "o", "    policy=$(apt-cache policy \"$pkg\" 2>/dev/null)\r\n\u001b[?2004l\r"]
[37.639067, "o", "\u001b[?2004h> "]
[37.639208, "o", "    if echo \"$policy\" | grep -q \"security\"; then\r\n\u001b[?2004l\r"]
[37.639238, "o", "\u001b[?2004h> "]
[37.639445, "o", "        candidate=$(echo \"$policy\" | grep \"Candidate:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[37.63947, "o", "\u001b[?2004h"]
[37.6395, "o", "> "]
[37.639682, "o", "        installed=$(echo \"$policy\" | grep \"Installed:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[37.639709, "o", "\u001b[?2004h> "]
[37.640037, "o", "        if [[ \"$candidate\" != \"$installed\" ]] && echo \"$policy\" | grep -A1 \"$candidate\" | grep -q \"security\"; then\r\n\u001b[?2004l\r"]
[37.640067, "o", "\u001b[?2004h"]
[37.640096, "o", "> "]
[37.640158, "o", "            has_security=\"true\"\r\n\u001b[?2004l\r"]
[37.640186, "o", "\u001b[?2004h"]
[37.640216, "o", ">         fi\r\n"]
[37.640246, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[37.640276, "o", "    fi\r\n\u001b[?2004l\r"]
[37.640306, "o", "\u001b[?2004h> "]
[37.640336, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.640366, "o", "> "]
[37.64084, "o", "    REMOVABLE_JSON+=(\"    {\\n      \\\"name\\\": \\\"$pkg\\\",\\n      \\\"installed_version\\\": \\\"$version\\\",\\n      \\\"size_kb\\\": $size,\\n      \\\"has_security_update\\\": $has_security\\n    }\")\r\n\u001b[?2004l\r"]
[37.640885, "o", "\u001b[?2004h> "]
[37.641105, "o", "    echo \"  $pkg: version=$version, size=${size}KB, security_update=$has_security\"\r\n\u001b[?2004l\r"]
[37.64113, "o", "\u001b[?2004h"]
[37.641157, "o", "> "]
[37.641188, "o", "done\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[37.641218, "o", "\u001b[?2004h> "]
[37.641311, "o", "# Build dependency protected JSON\r\n\u001b[?2004l\r"]
[37.641341, "o", "\u001b[?2004h> "]
[37.641416, "o", "declare -a PROTECTED_JSON\r\n\u001b[?2004l\r"]
[37.641446, "o", "\u001b[?2004h> "]
[37.641626, "o", "PROTECTED_KEYS=($(echo \"${!PROTECTED[@]}\" | tr ' ' '\\n' | sort))\r\n\u001b[?2004l\r"]
[37.641657, "o", "\u001b[?2004h> "]
[37.641687, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.641795, "o", "for pkg in \"${PROTECTED_KEYS[@]}\"; do\r\n\u001b[?2004l\r"]
[37.641825, "o", "\u001b[?2004h> "]
[37.641999, "o", "    # Find all required packages that need this dependency\r\n\u001b[?2004l\r"]
[37.64203, "o", "\u001b[?2004h> "]
[37.64208, "o", "    required_by=\"\"\r\n\u001b[?2004l\r"]
[37.642108, "o", "\u001b[?2004h> "]
[37.642211, "o", "    for req in \"${REQUIRED[@]}\"; do\r\n\u001b[?2004l\r"]
[37.642238, "o", "\u001b[?2004h> "]
[37.642523, "o", "        deps=$(apt-cache depends \"$req\" 2>/dev/null | grep -E \"Depends:|PreDepends:\" | grep -w \"$pkg\")\r\n\u001b[?2004l\r"]
[37.642548, "o", "\u001b[?2004h"]
[37.642574, "o", "> "]
[37.642652, "o", "        if [[ -n \"$deps\" ]]; then\r\n\u001b[?2004l\r"]
[37.64268, "o", "\u001b[?2004h> "]
[37.642841, "o", "            [[ -n \"$required_by\" ]] && required_by+=\", \"\r\n\u001b[?2004l\r"]
[37.642865, "o", "\u001b[?2004h"]
[37.642889, "o", "> "]
[37.642981, "o", "            required_by+=\"\\\"$req\\\"\"\r\n\u001b[?2004l\r"]
[37.643006, "o", "\u001b[?2004h"]
[37.64303, "o", "> "]
[37.64306, "o", "        fi\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.643089, "o", "> "]
[37.643121, "o", "    done\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.643149, "o", "> "]
[37.643288, "o", "    # If not direct, use the stored dependency chain\r\n\u001b[?2004l\r"]
[37.643319, "o", "\u001b[?2004h> "]
[37.643424, "o", "    if [[ -z \"$required_by\" ]]; then\r\n\u001b[?2004l\r"]
[37.643455, "o", "\u001b[?2004h> "]
[37.64358, "o", "        required_by=\"\\\"${PROTECTED[$pkg]}\\\"\"\r\n\u001b[?2004l\r"]
[37.64361, "o", "\u001b[?2004h> "]
[37.643637, "o", "    fi\r\n\u001b[?2004l\r"]
[37.643668, "o", "\u001b[?2004h> "]
[37.643954, "o", "    PROTECTED_JSON+=(\"    {\\n      \\\"name\\\": \\\"$pkg\\\",\\n      \\\"required_by\\\": [$required_by]\\n    }\")\r\n\u001b[?2004l\r"]
[37.643989, "o", "\u001b[?2004h> "]
[37.644018, "o", "done\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.644047, "o", "> \r\n\u001b[?2004l\r"]
[37.644078, "o", "\u001b[?2004h> "]
[37.644132, "o", "# Generate JSON report\r\n\u001b[?2004l\r"]
[37.644163, "o", "\u001b[?2004h> "]
[37.644194, "o", "echo \"\"\r\n\u001b[?2004l\r"]
[37.644221, "o", "\u001b[?2004h> "]
[37.644333, "o", "echo \"Generating removal_report.json...\"\r\n\u001b[?2004l\r"]
[37.644361, "o", "\u001b[?2004h"]
[37.644387, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.644416, "o", "> "]
[37.644609, "o", "removable_json_str=$(IFS=','; echo \"${REMOVABLE_JSON[*]}\" | sed 's/,/,\\n/g')\r\n\u001b[?2004l\r"]
[37.644642, "o", "\u001b[?2004h> "]
[37.64485, "o", "protected_json_str=$(IFS=','; echo \"${PROTECTED_JSON[*]}\" | sed 's/,/,\\n/g')\r\n\u001b[?2004l\r"]
[37.644878, "o", "\u001b[?2004h> "]
[37.64491, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.645014, "o", "cat > removal_report.json << EOF\r\n\u001b[?2004l\r"]
[37.645045, "o", "\u001b[?2004h> "]
[37.645075, "o", "{\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.645104, "o", "> "]
[37.645134, "o", "  \"summary\": {\r\n\u001b[?2004l\r"]
[37.645165, "o", "\u001b[?2004h> "]
[37.645273, "o", "    \"total_installed\": ${#INSTALLED[@]},\r\n\u001b[?2004l\r"]
[37.645305, "o", "\u001b[?2004h> "]
[37.64541, "o", "    \"total_required\": ${#REQUIRED[@]},\r\n\u001b[?2004l\r"]
[37.64544, "o", "\u001b[?2004h> "]
[37.645551, "o", "    \"removable_count\": ${#REMOVABLE[@]},\r\n\u001b[?2004l\r"]
[37.645577, "o", "\u001b[?2004h> "]
[37.645708, "o", "    \"kept_as_dependencies\": ${#PROTECTED[@]},\r\n\u001b[?2004l\r"]
[37.645738, "o", "\u001b[?2004h> "]
[37.645854, "o", "    \"total_space_savings_kb\": $total_size\r\n\u001b[?2004l\r"]
[37.645881, "o", "\u001b[?2004h> "]
[37.645907, "o", "  },\r\n\u001b[?2004l\r"]
[37.645944, "o", "\u001b[?2004h> "]
[37.646015, "o", "  \"removable_packages\": [\r\n\u001b[?2004l\r"]
[37.646041, "o", "\u001b[?2004h> "]
[37.646223, "o", "$(IFS=','; echo -e \"${REMOVABLE_JSON[*]}\" | sed 's/},{/},\\n{/g')\r\n\u001b[?2004l\r"]
[37.646246, "o", "\u001b[?2004h"]
[37.646275, "o", ">   ],\r\n\u001b[?2004l\r"]
[37.646302, "o", "\u001b[?2004h> "]
[37.646384, "o", "  \"dependency_protected\": [\r\n\u001b[?2004l\r"]
[37.646414, "o", "\u001b[?2004h> "]
[37.646592, "o", "$(IFS=','; echo -e \"${PROTECTED_JSON[*]}\" | sed 's/},{/},\\n{/g')\r\n\u001b[?2004l\r"]
[37.646622, "o", "\u001b[?2004h> "]
[37.646652, "o", "  ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.64668, "o", "> }\r\n\u001b[?2004l\r"]
[37.646709, "o", "\u001b[?2004h> "]
[37.646739, "o", "EOF\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.646769, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.6468, "o", "> "]
[37.646853, "o", "# Generate removal script\r\n\u001b[?2004l\r"]
[37.646884, "o", "\u001b[?2004h> "]
[37.647003, "o", "echo \"Generating remove_packages.sh...\"\r\n\u001b[?2004l\r"]
[37.647036, "o", "\u001b[?2004h> "]
[37.647126, "o", "cat > remove_packages.sh << EOF2\r\n\u001b[?2004l\r"]
[37.647152, "o", "\u001b[?2004h> "]
[37.6472, "o", "#!/bin/bash\r\n\u001b[?2004l\r"]
[37.647231, "o", "\u001b[?2004h> "]
[37.647383, "o", "# Auto-generated script to remove unnecessary packages\r\n\u001b[?2004l\r"]
[37.64741, "o", "\u001b[?2004h> "]
[37.647483, "o", "# Generated on: $(date)\r\n\u001b[?2004l\r"]
[37.647512, "o", "\u001b[?2004h> "]
[37.647542, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.647642, "o", "PACKAGES=\"${REMOVABLE_SORTED[*]}\"\r\n\u001b[?2004l\r"]
[37.647668, "o", "\u001b[?2004h"]
[37.647694, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.64772, "o", "> "]
[37.647836, "o", "echo \"The following packages will be removed:\"\r\n\u001b[?2004l\r"]
[37.647862, "o", "\u001b[?2004h"]
[37.647888, "o", "> "]
[37.647925, "o", "echo \"\\$PACKAGES\"\r\n"]
[37.64796, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[37.64799, "o", "echo \"\"\r\n\u001b[?2004l\r"]
[37.648019, "o", "\u001b[?2004h> "]
[37.648109, "o", "echo \"Performing dry-run first...\"\r\n\u001b[?2004l\r"]
[37.648139, "o", "\u001b[?2004h> "]
[37.64824, "o", "apt-get remove --dry-run \\$PACKAGES\r\n\u001b[?2004l\r"]
[37.648266, "o", "\u001b[?2004h> "]
[37.648296, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.648326, "o", "> echo \"\"\r\n\u001b[?2004l\r"]
[37.648356, "o", "\u001b[?2004h> "]
[37.64847, "o", "echo \"Proceeding with actual removal...\"\r\n\u001b[?2004l\r"]
[37.648501, "o", "\u001b[?2004h> "]
[37.648584, "o", "apt-get remove -y \\$PACKAGES\r\n\u001b[?2004l\r"]
[37.648614, "o", "\u001b[?2004h> "]
[37.648643, "o", "EOF2\r\n\u001b[?2004l\r"]
[37.648674, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[37.6487, "o", "\u001b[?2004h> "]
[37.64878, "o", "chmod +x remove_packages.sh\r\n\u001b[?2004l\r"]
[37.648811, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[37.648842, "o", "\u001b[?2004h> "]
[37.648868, "o", "echo \"\"\r\n\u001b[?2004l\r"]
[37.648894, "o", "\u001b[?2004h> "]
[37.648988, "o", "echo \"Done! Files created:\"\r\n\u001b[?2004l\r"]
[37.649019, "o", "\u001b[?2004h> "]
[37.649149, "o", "ls -la removal_report.json remove_packages.sh\r\n\u001b[?2004l\r"]
[37.649178, "o", "\u001b[?2004h> "]
[37.649204, "o", "SCRIPT\r\n\u001b[?2004l\r"]
