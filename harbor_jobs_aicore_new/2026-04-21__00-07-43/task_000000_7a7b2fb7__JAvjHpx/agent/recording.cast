[37.626869, "i", "cat > /home/user/migration/analyze_packages.sh << 'SCRIPT'\n#!/bin/bash\n\ncd /home/user/migration\n\n# Read package lists\nmapfile -t INSTALLED < installed_packages.txt\nmapfile -t REQUIRED < required_packages.txt\n\necho \"Total installed: ${#INSTALLED[@]}\"\necho \"Total required: ${#REQUIRED[@]}\"\n\n# Find packages not in required list\ndeclare -a NOT_REQUIRED\nfor pkg in \"${INSTALLED[@]}\"; do\n    found=0\n    for req in \"${REQUIRED[@]}\"; do\n        if [[ \"$pkg\" == \"$req\" ]]; then\n            found=1\n            break\n        fi\n    done\n    if [[ $found -eq 0 ]]; then\n        NOT_REQUIRED+=(\"$pkg\")\n    fi\ndone\n\necho \"Packages not in required list: ${#NOT_REQUIRED[@]}\"\necho \"${NOT_REQUIRED[@]}\"\n\n# Get dependencies of required packages (up to 3 levels deep)\ndeclare -A ALL_DEPS\n\nget_deps() {\n    local pkg=\"$1\"\n    local level=\"$2\"\n    if [[ $level -gt 3 ]]; then\n        return\n    fi\n    \n    # Get direct dependencies using apt-cache depends\n    local deps=$(apt-cache depends \"$pkg\" 2>/dev/null | grep -E \"^\\s*(Depends|PreDep"]
[37.627003, "i", "ends):\" | sed 's/.*: //' | sed 's/<[^>]*>//g' | tr -d ' ')\n    \n    for dep in $deps; do\n        # Skip empty or virtual packages\n        [[ -z \"$dep\" ]] && continue\n        [[ \"$dep\" == *\"|\"* ]] && continue\n        \n        if [[ -z \"${ALL_DEPS[$dep]}\" ]]; then\n            ALL_DEPS[\"$dep\"]=\"$pkg\"\n            get_deps \"$dep\" $((level + 1))\n        fi\n    done\n}\n\necho \"\"\necho \"Collecting dependencies of required packages (up to 3 levels)...\"\nfor req in \"${REQUIRED[@]}\"; do\n    echo \"  Processing: $req\"\n    get_deps \"$req\" 1\ndone\n\necho \"\"\necho \"Total unique dependencies found: ${#ALL_DEPS[@]}\"\n\n# Separate removable from dependency-protected\ndeclare -a REMOVABLE\ndeclare -A PROTECTED\n\nfor pkg in \"${NOT_REQUIRED[@]}\"; do\n    if [[ -n \"${ALL_DEPS[$pkg]}\" ]]; then\n        PROTECTED[\"$pkg\"]=\"${ALL_DEPS[$pkg]}\"\n    else\n        REMOVABLE+=(\"$pkg\")\n    fi\ndone\n\necho \"\"\necho \"Removable packages: ${#REMOVABLE[@]}\"\necho \"Dependency-protected packages: ${#PROTECTED[@]}\"\n\n# Sort removable packages\nIFS=$'\\n' REMOVABLE_SORTED"]
[37.627056, "i", "=($(sort <<<\"${REMOVABLE[*]}\"))\nunset IFS\n\n# Get package info for removable packages\necho \"\"\necho \"Getting package info...\"\n\ndeclare -a REMOVABLE_JSON\ntotal_size=0\n\nfor pkg in \"${REMOVABLE_SORTED[@]}\"; do\n    # Get installed version\n    version=$(dpkg-query -W -f='${Version}' \"$pkg\" 2>/dev/null || echo \"unknown\")\n    \n    # Get installed size in KB\n    size=$(dpkg-query -W -f='${Installed-Size}' \"$pkg\" 2>/dev/null || echo \"0\")\n    [[ -z \"$size\" ]] && size=0\n    total_size=$((total_size + size))\n    \n    # Check for security updates\n    has_security=\"false\"\n    policy=$(apt-cache policy \"$pkg\" 2>/dev/null)\n    if echo \"$policy\" | grep -q \"security\"; then\n        candidate=$(echo \"$policy\" | grep \"Candidate:\" | awk '{print $2}')\n        installed=$(echo \"$policy\" | grep \"Installed:\" | awk '{print $2}')\n        if [[ \"$candidate\" != \"$installed\" ]] && echo \"$policy\" | grep -A1 \"$candidate\" | grep -q \"security\"; then\n            has_security=\"true\"\n        fi\n    fi\n    \n    REMOVABLE_JSON+=(\"    {\\n      \\\"name\\"]
[37.627102, "i", "\": \\\"$pkg\\\",\\n      \\\"installed_version\\\": \\\"$version\\\",\\n      \\\"size_kb\\\": $size,\\n      \\\"has_security_update\\\": $has_security\\n    }\")\n    echo \"  $pkg: version=$version, size=${size}KB, security_update=$has_security\"\ndone\n\n# Build dependency protected JSON\ndeclare -a PROTECTED_JSON\nPROTECTED_KEYS=($(echo \"${!PROTECTED[@]}\" | tr ' ' '\\n' | sort))\n\nfor pkg in \"${PROTECTED_KEYS[@]}\"; do\n    # Find all required packages that need this dependency\n    required_by=\"\"\n    for req in \"${REQUIRED[@]}\"; do\n        deps=$(apt-cache depends \"$req\" 2>/dev/null | grep -E \"Depends:|PreDepends:\" | grep -w \"$pkg\")\n        if [[ -n \"$deps\" ]]; then\n            [[ -n \"$required_by\" ]] && required_by+=\", \"\n            required_by+=\"\\\"$req\\\"\"\n        fi\n    done\n    # If not direct, use the stored dependency chain\n    if [[ -z \"$required_by\" ]]; then\n        required_by=\"\\\"${PROTECTED[$pkg]}\\\"\"\n    fi\n    PROTECTED_JSON+=(\"    {\\n      \\\"name\\\": \\\"$pkg\\\",\\n      \\\"required_by\\\": [$required_by]\\n    }\")\ndone\n\n# Generate JSON r"]
[37.627141, "o", "cat > /home/user/migration/analyze_packages.sh << 'SCRIPT'\r\n\u001b[?2004l\r"]
[37.627197, "i", "eport\necho \"\"\necho \"Generating removal_report.json...\"\n\nremovable_json_str=$(IFS=','; echo \"${REMOVABLE_JSON[*]}\" | sed 's/,/,\\n/g')\nprotected_json_str=$(IFS=','; echo \"${PROTECTED_JSON[*]}\" | sed 's/,/,\\n/g')\n\ncat > removal_report.json << EOF\n{\n  \"summary\": {\n    \"total_installed\": ${#INSTALLED[@]},\n    \"total_required\": ${#REQUIRED[@]},\n    \"removable_count\": ${#REMOVABLE[@]},\n    \"kept_as_dependencies\": ${#PROTECTED[@]},\n    \"total_space_savings_kb\": $total_size\n  },\n  \"removable_packages\": [\n$(IFS=','; echo -e \"${REMOVABLE_JSON[*]}\" | sed 's/},{/},\\n{/g')\n  ],\n  \"dependency_protected\": [\n$(IFS=','; echo -e \"${PROTECTED_JSON[*]}\" | sed 's/},{/},\\n{/g')\n  ]\n}\nEOF\n\n# Generate removal script\necho \"Generating remove_packages.sh...\"\ncat > remove_packages.sh << EOF2\n#!/bin/bash\n# Auto-generated script to remove unnecessary packages\n# Generated on: $(date)\n\nPACKAGES=\"${REMOVABLE_SORTED[*]}\"\n\necho \"The following packages will be removed:\"\necho \"\\$PACKAGES\"\necho \"\"\necho \"Performing dry-run first...\"\napt-get remove "]
[37.627208, "o", "\u001b[?2004h> "]
[37.627242, "i", "--dry-run \\$PACKAGES\n\necho \"\"\necho \"Proceeding with actual removal...\"\napt-get remove -y \\$PACKAGES\nEOF2\n\nchmod +x remove_packages.sh\n\necho \"\"\necho \"Done! Files created:\"\nls -la removal_report.json remove_packages.sh\nSCRIPT\n"]
