[25.31159, "i", "cat > generate_report.py << 'EOF'\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\n# Parse log files\ndef parse_log(filename, category):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            # Parse: [TIMESTAMP] SERVICE_NAME | OLD_KEY_ID | NEW_KEY_ID | STATUS | ROTATED_BY\n            match = re.match(r'\\[([^\\]]+)\\]\\s*([^|]+)\\|([^|]+)\\|([^|]+)\\|([^|]+)\\|(.+)', line)\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                entries.append({\n                    'timestamp': timestamp.strip(),\n                    'service': service.strip(),\n                    'old_key': old_key.strip(),\n                    'new_key': new_key.strip(),\n                    'status': status.strip(),\n                    'rotated_by': rotated_by.strip(),\n                    'category': category\n                })\n    return en"]
[25.311643, "i", "tries\n\n# Parse all logs\naws_entries = parse_log('aws-rotation.log', 'AWS IAM')\ndb_entries = parse_log('db-rotation.log', 'Database')\napi_entries = parse_log('api-keys.log', 'API Keys')\n\nall_entries = aws_entries + db_entries + api_entries\n\n# Sort each category alphabetically by service name\naws_entries.sort(key=lambda x: x['service'].lower())\ndb_entries.sort(key=lambda x: x['service'].lower())\napi_entries.sort(key=lambda x: x['service'].lower())\n\n# Calculate statistics\ndef calc_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = total - success\n    return total, success, failed\n\naws_stats = calc_stats(aws_entries)\ndb_stats = calc_stats(db_entries)\napi_stats = calc_stats(api_entries)\ntotal_rotated = len(all_entries)\n\n# Get failed entries\nfailed_entries = [e for e in all_entries if e['status'] == 'FAILED']\n\n# Generate timestamp\ngenerated_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\n# Build markdown\ndef build_table(entries):\n    lines = "]
[25.311769, "i", "[]\n    lines.append('| Service | Old Key ID | New Key ID | Status | Rotated By |')\n    lines.append('|---------|------------|------------|--------|------------|')\n    for e in entries:\n        lines.append(f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\")\n    return '\\n'.join(lines)\n\nmd = f\"\"\"# Credential Rotation Report\n\n**Generated:** {generated_time}\n**Total Credentials Rotated:** {total_rotated}\n\n## Summary by Category\n\n| Category | Count | Success | Failed |\n|----------|-------|---------|--------|\n| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\n| Database | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\n| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\n\n## Detailed Rotation Log\n\n### AWS IAM Credentials\n\n{build_table(aws_entries)}\n\n### Database Credentials\n\n{build_table(db_entries)}\n\n### API Keys\n\n{build_table(api_entries)}\n\n## Failed Rotations\n\n\"\"\"\n\nif failed_entries:\n    md += \"> **Action Required:** The following credentials faile"]
