[25.403009, "i", "cat > generate_report.py << 'EOF'\nimport os\nfrom datetime import datetime\n\n# Parse log files\ndef parse_log(filename, category):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            # Parse: [TIMESTAMP] SERVICE_NAME | OLD_KEY_ID | NEW_KEY_ID | STATUS | ROTATED_BY\n            timestamp_end = line.index(']')\n            rest = line[timestamp_end+1:].strip()\n            parts = [p.strip() for p in rest.split('|')]\n            entries.append({\n                'service': parts[0],\n                'old_key': parts[1],\n                'new_key': parts[2],\n                'status': parts[3],\n                'rotated_by': parts[4],\n                'category': category\n            })\n    return entries\n\n# Parse all logs\naws_entries = parse_log('aws-rotation.log', 'AWS IAM')\ndb_entries = parse_log('db-rotation.log', 'Database')\napi_entries = parse_log('api-keys.log', 'API Keys')\n\n# Sort alphabetically by se"]
[25.403197, "i", "rvice name\naws_entries.sort(key=lambda x: x['service'])\ndb_entries.sort(key=lambda x: x['service'])\napi_entries.sort(key=lambda x: x['service'])\n\nall_entries = aws_entries + db_entries + api_entries\n\n# Calculate stats\ndef calc_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = total - success\n    return total, success, failed\n\naws_stats = calc_stats(aws_entries)\ndb_stats = calc_stats(db_entries)\napi_stats = calc_stats(api_entries)\n\ntotal_rotated = len(all_entries)\n\n# Get failed entries\nfailed_entries = [e for e in all_entries if e['status'] == 'FAILED']\n\n# Generate timestamp\ngenerated_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\n# Build markdown\nmd = f\"\"\"# Credential Rotation Report\n\n**Generated:** {generated_time}\n**Total Credentials Rotated:** {total_rotated}\n\n## Summary by Category\n\n| Category | Count | Success | Failed |\n|----------|-------|---------|--------|\n| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\n| Datab"]
[25.40325, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\rrvice name\r\naws_entries.sort(key=lambda x: x['service'])\r\ndb_entries.sort(key=lambda x: x['service'])\r\napi_entries.sort(key=lambda x: x["]
[25.403333, "i", "ase | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\n| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\n\n## Detailed Rotation Log\n\n### AWS IAM Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in aws_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n### Database Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in db_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n### API Keys\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in api_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n## Failed Rotations\n\n\"\"\"\n\nif "]
[25.403377, "o", "'service'])\r\n\r\nall_entries = aws_entries + db_entries + api_entries\r\n\r\n# Calculate stats\r\ndef calc_stats(entries):\r\n    total = len(entries)\r\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\r\n    failed = total - success\r\n    return total, success, failed\r\n\r\naws_stats = calc_stats(aws_entries)\r\ndb_stats = calc_stats(db_entries)\r\napi_stats = calc_stats(api_entries)\r\n\r\ntotal_rotated = len(all_entries)\r\n\r\n# Get failed en"]
[25.403409, "i", "failed_entries:\n    md += \"> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n\"\n    for e in failed_entries:\n        md += f\"- {e['service']} ({e['category']}): Rotation failed\\n\"\nelse:\n    md += \"> No failed rotations. All credentials rotated successfully.\\n\"\n\nmd += \"\"\"\n## Sign-off\n\n- [ ] All successful rotations verified\n- [ ] Failed rotations escalated\n- [ ] Old credentials scheduled for deletion\n\"\"\"\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write(md)\n\nprint(\"Report generated successfully!\")\nEOF\n"]
