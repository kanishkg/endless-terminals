[56.35647, "i", "python3 -c \"\nimport sqlite3\nimport json\n\nconn = sqlite3.connect('employees.db')\ncursor = conn.cursor()\n\ncursor.execute('''SELECT department, COUNT(*) as count, ROUND(AVG(salary), 2) as avg_salary, MIN(hire_date) as oldest_hire, MAX(hire_date) as newest_hire FROM employees GROUP BY department ORDER BY department''')\n\nresult = {}\nfor row in cursor.fetchall():\n    dept, count, avg_salary, oldest_hire, newest_hire = row\n    result[dept] = {\n        'count': count,\n        'avg_salary': avg_salary,\n        'oldest_hire': oldest_hire,\n        'newest_hire': newest_hire\n    }\n\nconn.close()\n\nwith open('/home/user/company/dept_summary.json', 'w') as f:\n    json.dump(result, f, indent=2, sort_keys=True)\n\nprint('Done')\n\"\n"]
