[34.81245, "i", "sqlite3 -separator ',' employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(d.avg_sal, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_sal FROM employees GROUP BY department) d ON e.department = d.department WHERE e.salary > 1.2 * d.avg_sal ORDER BY e.department ASC, e.salary DESC;\" >> /home/user/company/salary_outliers.csv\n"]
[34.813547, "o", "sqlite3 -separator ',' employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(d.avg_sal, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_sal FROM employees GROUP BY department) d ON e.department = d.department WHERE e.salary > 1.2 * d.avg_sal ORDER BY e.department ASC, e.salary DESC;\" >> /home/user/company/salary_outliers.csv\r\n\u001b[?2004l\r"]
