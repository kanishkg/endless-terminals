[47.026589, "i", "awk -F'\\t' '\n{\n  path = $2\n  bytes = $1\n  # Skip directory entries themselves\n  if (path == \"/var/data\" || path == \"/var/data/logs\" || path == \"/var/data/backups\" || path == \"/var/data/cache\" || path == \"/var/data/cache/thumbnails\" || path == \"/var/data/uploads\" || path == \"/var/data/archives\") next\n  \n  # Extract immediate subdirectory of /var/data\n  # Path format: /var/data/SUBDIR/...\n  if (match(path, /^\\/var\\/data\\/([^\\/]+)/, arr)) {\n    subdir = arr[1]\n    totals[subdir] += bytes\n    grand_total += bytes\n  }\n}\nEND {\n  for (dir in totals) {\n    pct = (totals[dir] / grand_total) * 100\n    printf \"%s %d %.1f\\n\", dir, totals[dir], pct\n  }\n}' /home/user/disk_inventory.txt | sort -t' ' -k2,2nr | awk '{printf \"%s %s %s%%\\n\", $1, $2, $3}' > /home/user/reports/directory_rollup.txt\n"]
