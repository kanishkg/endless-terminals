[37.508214, "i", "awk -F'\\t' '\nBEGIN { OFS=\",\" }\n{\n  path = $2\n  bytes = $1\n  # Skip directory entries\n  if (path == \"/var/data\" || path == \"/var/data/logs\" || path == \"/var/data/backups\" || path == \"/var/data/cache\" || path == \"/var/data/cache/thumbnails\" || path == \"/var/data/uploads\" || path == \"/var/data/archives\") next\n  \n  # Get filename (after last /)\n  n = split(path, parts, \"/\")\n  filename = parts[n]\n  \n  # Get extension (after last dot)\n  if (index(filename, \".\") > 0) {\n    m = split(filename, dots, \".\")\n    ext = tolower(dots[m])\n  } else {\n    ext = \"NO_EXTENSION\"\n  }\n  \n  totals[ext] += bytes\n}\nEND {\n  print \"extension,total_bytes\"\n  for (ext in totals) {\n    print ext, totals[ext]\n  }\n}' /home/user/disk_inventory.txt | head -1 > /home/user/reports/extension_summary.csv && awk -F'\\t' '\n{\n  path = $2\n  bytes = $1\n  if (path == \"/var/data\" || path == \"/var/data/logs\" || path == \"/var/data/backups\" || path == \"/var/data/cache\" || path == \"/var/data/cache/thumbnails\" || path == \"/var/data/uploads\" || path == \"/var/dat"]
