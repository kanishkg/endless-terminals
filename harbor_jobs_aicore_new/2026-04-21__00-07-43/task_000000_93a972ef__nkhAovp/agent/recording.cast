[32.923568, "i", "cat > /tmp/fix_yaml.py << 'EOF'\nimport yaml\n\n# Custom representer to handle multi-line strings and preserve formatting\ndef str_representer(dumper, data):\n    if '\\n' in data:\n        return dumper.represent_scalar('tag:yaml.org,2002:str', data, style='|')\n    return dumper.represent_scalar('tag:yaml.org,2002:str', data)\n\nyaml.add_representer(str, str_representer)\n\nwith open('/etc/monitoring/alerts.yaml', 'r') as f:\n    data = yaml.safe_load(f)\n\n# Find and modify rules\nfor group in data['groups']:\n    if group['name'] == 'service_alerts':\n        for rule in group['rules']:\n            if rule['alert'] == 'HighLatency':\n                rule['for'] = '3m'\n            elif rule['alert'] == 'ServiceDown':\n                rule['labels']['escalation_level'] = 'critical'\n        \n        # Add new DiskSpaceLow alert\n        new_alert = {\n            'alert': 'DiskSpaceLow',\n            'expr': 'node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1',\n            'for': '10m',\n"]
[32.923697, "i", "            'labels': {\n                'severity': 'warning',\n                'team': 'infrastructure'\n            },\n            'annotations': {\n                'summary': 'Disk space below 10% on {{ $labels.instance }}'\n            }\n        }\n        group['rules'].append(new_alert)\n\n# Write back with comment preserved manually\nwith open('/etc/monitoring/alerts.yaml', 'w') as f:\n    f.write('# Prometheus alerting rules\\n')\n    yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)\n\nprint('YAML updated successfully')\nEOF\n"]
