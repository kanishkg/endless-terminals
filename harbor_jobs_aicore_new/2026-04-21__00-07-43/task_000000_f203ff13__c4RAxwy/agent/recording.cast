[30.903992, "o", "sqlite3 /home/user/company/employees.db \"SELECT department, COUNT(*) as count, ROUND(AVG(salary), 2) as avg_salary, MIN(hire_date) as oldest_hire, MAX(hire_date) as newest_hire FROM employees GROUP BY department ORDER BY department;\"\r\n\u001b[?2004l\r"]
