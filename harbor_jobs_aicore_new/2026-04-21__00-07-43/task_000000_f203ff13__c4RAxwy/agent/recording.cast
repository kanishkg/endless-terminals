[38.577171, "i", "python3 << 'EOF'\nimport sqlite3\nimport json\n\nconn = sqlite3.connect('/home/user/company/employees.db')\ncursor = conn.cursor()\n\ncursor.execute('''\n    SELECT department, COUNT(*) as count, ROUND(AVG(salary), 2) as avg_salary,\n           MIN(hire_date) as oldest_hire, MAX(hire_date) as newest_hire\n    FROM employees\n    GROUP BY department\n    ORDER BY department\n''')\n\nresult = {}\nfor row in cursor.fetchall():\n    dept, count, avg_salary, oldest_hire, newest_hire = row\n    result[dept] = {\n        \"count\": count,\n        \"avg_salary\": avg_salary,\n        \"oldest_hire\": oldest_hire,\n        \"newest_hire\": newest_hire\n    }\n\nconn.close()\n\nwith open('/home/user/company/dept_summary.json', 'w') as f:\n    json.dump(result, f, indent=2)\n\nprint(\"Done\")\nEOF\n"]
