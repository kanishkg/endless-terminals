[44.204712, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T00:45:51Z\r\n"]
