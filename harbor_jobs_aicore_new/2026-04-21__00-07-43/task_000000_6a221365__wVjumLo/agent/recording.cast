[35.840651, "o", "\u001b[?2004h> "]
[35.840967, "o", "    if not isinstance(record['account_id'], str) or record['account_id'] == '':\r\n\u001b[?2004l\r"]
[35.841013, "o", "\u001b[?2004h"]
[35.841058, "o", "> "]
[35.841303, "o", "        return {'line_number': line_num, 'error_type': 'invalid_value',\r\n\u001b[?2004l\r"]
[35.841343, "o", "\u001b[?2004h> "]
[35.841771, "o", "                'error_detail': f\"invalid account_id: empty or not a string\", 'raw_content': truncate(raw_line)}\r\n\u001b[?2004l\r"]
[35.841808, "o", "\u001b[?2004h> "]
[35.841845, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.841858, "o", "> "]
[35.841997, "o", "    # Validate amount (number)\r\n\u001b[?2004l\r"]
[35.842035, "o", "\u001b[?2004h> "]
[35.842418, "o", "    if not isinstance(record['amount'], (int, float)) or isinstance(record['amount'], bool):\r\n\u001b[?2004l\r"]
[35.842459, "o", "\u001b[?2004h> "]
[35.842747, "o", "        return {'line_number': line_num, 'error_type': 'invalid_format',\r\n\u001b[?2004l\r"]
[35.842786, "o", "\u001b[?2004h> "]
[35.843202, "o", "                'error_detail': f\"invalid amount format: {record['amount']}\", 'raw_content': truncate(raw_line)}\r\n\u001b[?2004l\r"]
[35.843242, "o", "\u001b[?2004h> "]
[35.843301, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.843429, "o", "    # Validate currency (3 uppercase letters)\r\n\u001b[?2004l\r"]
[35.843467, "o", "\u001b[?2004h> "]
[35.843729, "o", "    if not isinstance(record['currency'], str) or not CURRENCY_PATTERN.match(record['currency']):\r\n\u001b[?2004l\r"]
[35.843774, "o", "\u001b[?2004h> "]
[35.843961, "o", "        return {'line_number': line_num, 'error_type': 'invalid_format',\r\n\u001b[?2004l\r"]
[35.843997, "o", "\u001b[?2004h> "]
[35.844325, "o", "                'error_detail': f\"invalid currency format: {record['currency']}\", 'raw_content': truncate(raw_line)}\r\n\u001b[?2004l\r"]
[35.844364, "o", "\u001b[?2004h> "]
[35.84441, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.844466, "o", "    # Validate status\r\n\u001b[?2004l\r"]
[35.844503, "o", "\u001b[?2004h"]
[35.844543, "o", "> "]
[35.844743, "o", "    if not isinstance(record['status'], str) or record['status'] not in VALID_STATUSES:\r\n\u001b[?2004l\r"]
[35.84478, "o", "\u001b[?2004h> "]
[35.844972, "o", "        return {'line_number': line_num, 'error_type': 'invalid_value',\r\n\u001b[?2004l\r"]
[35.84501, "o", "\u001b[?2004h> "]
[35.845326, "o", "                'error_detail': f\"invalid status value: {record['status']}\", 'raw_content': truncate(raw_line)}\r\n\u001b[?2004l\r"]
[35.845367, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[35.845409, "o", "\u001b[?2004h> "]
[35.845481, "o", "    return None  # No errors\r\n\u001b[?2004l\r"]
[35.845517, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[35.845559, "o", "\u001b[?2004h> "]
[35.845598, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.845641, "o", "> "]
[35.84568, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[35.84572, "o", "\u001b[?2004h> "]
[35.845768, "o", "    error_records = []\r\n\u001b[?2004l\r"]
[35.845803, "o", "\u001b[?2004h> "]
[35.846079, "o", "    error_counts = {'malformed_json': 0, 'missing_field': 0, 'invalid_format': 0, 'invalid_value': 0}\r\n\u001b[?2004l\r"]
[35.846108, "o", "\u001b[?2004h"]
[35.846147, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.846184, "o", "> "]
[35.846398, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[35.846438, "o", "\u001b[?2004h> "]
[35.846458, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.846505, "o", "> "]
[35.846588, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[35.846635, "o", "\u001b[?2004h> "]
[35.846707, "o", "        lines = f.readlines()\r\n\u001b[?2004l\r"]
[35.846745, "o", "\u001b[?2004h> "]
[35.846786, "o", "    \r\n\u001b[?2004l\r"]
[35.846828, "o", "\u001b[?2004h> "]
[35.846864, "o", "    total_lines = len(lines)\r\n\u001b[?2004l\r"]
[35.846901, "o", "\u001b[?2004h> "]
[35.846941, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.847088, "o", "    for line_num, raw_line in enumerate(lines, 1):\r\n\u001b[?2004l\r"]
[35.847124, "o", "\u001b[?2004h> "]
[35.847231, "o", "        raw_line = raw_line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[35.847287, "o", "\u001b[?2004h> "]
[35.847338, "o", "        \r\n\u001b[?2004l\r"]
[35.847379, "o", "\u001b[?2004h> "]
[35.847483, "o", "        # Skip empty lines - treat as malformed JSON\r\n\u001b[?2004l\r"]
[35.847531, "o", "\u001b[?2004h> "]
[35.847612, "o", "        if raw_line.strip() == '':\r\n"]
[35.847653, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[35.847857, "o", "            error = {'line_number': line_num, 'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[35.847873, "o", "\u001b[?2004h"]
[35.847925, "o", "> "]
[35.848121, "o", "                    'error_detail': 'empty line', 'raw_content': truncate(raw_line)}\r\n\u001b[?2004l\r"]
[35.848158, "o", "\u001b[?2004h> "]
[35.848278, "o", "            error_records.append(error)\r\n\u001b[?2004l\r"]
[35.84832, "o", "\u001b[?2004h> "]
[35.848448, "o", "            error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[35.848488, "o", "\u001b[?2004h> "]
[35.848539, "o", "            continue\r\n\u001b[?2004l\r"]
[35.848579, "o", "\u001b[?2004h> "]
[35.848621, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.848701, "o", "        # Try to parse JSON\r\n\u001b[?2004l\r"]
[35.848737, "o", "\u001b[?2004h> "]
[35.848773, "o", "        try:\r\n\u001b[?2004l\r"]
[35.848813, "o", "\u001b[?2004h> "]
[35.848919, "o", "            record = json.loads(raw_line)\r\n\u001b[?2004l\r"]
[35.848957, "o", "\u001b[?2004h> "]
[35.849066, "o", "        except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[35.849103, "o", "\u001b[?2004h> "]
[35.849329, "o", "            error = {'line_number': line_num, 'error_type': 'malformed_json',\r\n"]
[35.849375, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[35.849668, "o", "                    'error_detail': f'JSON parse error: {str(e)[:100]}', 'raw_content': truncate(raw_line)}\r\n\u001b[?2004l\r"]
[35.849707, "o", "\u001b[?2004h> "]
[35.849801, "o", "            error_records.append(error)\r\n\u001b[?2004l\r"]
[35.849835, "o", "\u001b[?2004h> "]
[35.849964, "o", "            error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[35.849995, "o", "\u001b[?2004h> "]
[35.850055, "o", "            continue\r\n\u001b[?2004l\r"]
[35.850089, "o", "\u001b[?2004h> "]
[35.850117, "o", "        \r\n\u001b[?2004l\r"]
[35.850147, "o", "\u001b[?2004h> "]
[35.850217, "o", "        # Validate record\r\n\u001b[?2004l\r"]
[35.850247, "o", "\u001b[?2004h> "]
[35.850459, "o", "        validation_error = validate_record(record, line_num, raw_line)\r\n\u001b[?2004l\r"]
[35.850494, "o", "\u001b[?2004h> "]
[35.850583, "o", "        if validation_error:\r\n\u001b[?2004l\r"]
[35.850613, "o", "\u001b[?2004h> "]
[35.850759, "o", "            error_records.append(validation_error)\r\n\u001b[?2004l\r"]
[35.850792, "o", "\u001b[?2004h> "]
[35.85096, "o", "            error_counts[validation_error['error_type']] += 1\r\n\u001b[?2004l\r"]
[35.850993, "o", "\u001b[?2004h> "]
[35.85105, "o", "            continue\r\n\u001b[?2004l\r"]
[35.851079, "o", "\u001b[?2004h> "]
[35.851107, "o", "        \r\n\u001b[?2004l\r"]
[35.851137, "o", "\u001b[?2004h> "]
[35.851319, "o", "        # Record is valid - compute hash and prepare output\r\n\u001b[?2004l\r"]
[35.851356, "o", "\u001b[?2004h> "]
[35.851476, "o", "        integrity_hash = compute_hash(record)\r\n\u001b[?2004l\r"]
[35.851503, "o", "\u001b[?2004h> "]
[35.851583, "o", "        output_record = {\r\n\u001b[?2004l\r"]
[35.851612, "o", "\u001b[?2004h> "]
[35.851768, "o", "            'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[35.851798, "o", "\u001b[?2004h> "]
[35.851927, "o", "            'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[35.851956, "o", "\u001b[?2004h> "]
[35.85209, "o", "            'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[35.852119, "o", "\u001b[?2004h> "]
[35.852233, "o", "            'amount': record['amount'],\r\n\u001b[?2004l\r"]
[35.852274, "o", "\u001b[?2004h> "]
[35.852404, "o", "            'currency': record['currency'],\r\n\u001b[?2004l\r"]
[35.852435, "o", "\u001b[?2004h> "]
[35.852545, "o", "            'status': record['status'],\r\n\u001b[?2004l\r"]
[35.852572, "o", "\u001b[?2004h> "]
[35.852701, "o", "            'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[35.852728, "o", "\u001b[?2004h> "]
[35.852852, "o", "            'processed_at': processing_time\r\n\u001b[?2004l\r"]
[35.852885, "o", "\u001b[?2004h> "]
[35.852914, "o", "        }\r\n\u001b[?2004l\r"]
[35.852947, "o", "\u001b[?2004h> "]
[35.853066, "o", "        valid_records.append(output_record)\r\n\u001b[?2004l\r"]
[35.853097, "o", "\u001b[?2004h> "]
[35.85314, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.853246, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[35.853296, "o", "\u001b[?2004h> "]
[35.853439, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[35.853467, "o", "\u001b[?2004h> "]
[35.853496, "o", "    \r\n\u001b[?2004l\r"]
[35.853529, "o", "\u001b[?2004h> "]
[35.853604, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[35.853634, "o", "\u001b[?2004h> "]
[35.85374, "o", "    with open(OUTPUT_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.853769, "o", "\u001b[?2004h> "]
[35.853875, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[35.853909, "o", "\u001b[?2004h> "]
[35.854037, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[35.85407, "o", "\u001b[?2004h> "]
[35.854104, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.854135, "o", "> "]
[35.854175, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[35.854208, "o", "\u001b[?2004h> "]
[35.854324, "o", "    with open(ERROR_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.854357, "o", "\u001b[?2004h> "]
[35.854454, "o", "        for error in error_records:\r\n\u001b[?2004l\r"]
[35.854484, "o", "\u001b[?2004h> "]
[35.854626, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[35.854656, "o", "\u001b[?2004h> "]
[35.854684, "o", "    \r\n\u001b[?2004l\r"]
[35.854718, "o", "\u001b[?2004h> "]
[35.854782, "o", "    # Calculate success rate\r\n\u001b[?2004l\r"]
[35.854817, "o", "\u001b[?2004h> "]
[35.854916, "o", "    valid_count = len(valid_records)\r\n\u001b[?2004l\r"]
[35.854951, "o", "\u001b[?2004h> "]
[35.855052, "o", "    failed_count = len(error_records)\r\n\u001b[?2004l\r"]
[35.855086, "o", "\u001b[?2004h> "]
[35.855322, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[35.855363, "o", "\u001b[?2004h> "]
[35.855394, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.855457, "o", "    # Write summary\r\n\u001b[?2004l\r"]
[35.85549, "o", "\u001b[?2004h> "]
[35.855607, "o", "    summary = f\"\"\"AUDIT PROCESSING SUMMARY\r\n\u001b[?2004l\r"]
[35.855639, "o", "\u001b[?2004h> "]
[35.855706, "o", "========================\r\n\u001b[?2004l\r"]
[35.855739, "o", "\u001b[?2004h> "]
[35.855807, "o", "Input file: {INPUT_FILE}\r\n\u001b[?2004l\r"]
[35.855841, "o", "\u001b[?2004h> "]
[35.855941, "o", "Total lines processed: {total_lines}\r\n\u001b[?2004l\r"]
[35.85597, "o", "\u001b[?2004h> "]
[35.856066, "o", "Valid transactions: {valid_count}\r\n\u001b[?2004l\r"]
[35.856095, "o", "\u001b[?2004h> "]
[35.856182, "o", "Failed records: {failed_count}\r\n\u001b[?2004l\r"]
[35.856211, "o", "\u001b[?2004h> "]
[35.856323, "o", "Success rate: {success_rate:.2f}%\r\n\u001b[?2004l\r"]
[35.856349, "o", "\u001b[?2004h> "]
[35.85639, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.856434, "o", "Errors by type:\r\n\u001b[?2004l\r"]
[35.856459, "o", "\u001b[?2004h"]
[35.856489, "o", "> "]
[35.856612, "o", "  malformed_json: {error_counts['malformed_json']}\r\n\u001b[?2004l\r"]
[35.85664, "o", "\u001b[?2004h> "]
[35.856781, "o", "  missing_field: {error_counts['missing_field']}\r\n\u001b[?2004l\r"]
[35.856813, "o", "\u001b[?2004h> "]
[35.856951, "o", "  invalid_format: {error_counts['invalid_format']}\r\n\u001b[?2004l\r"]
[35.856982, "o", "\u001b[?2004h> "]
[35.857119, "o", "  invalid_value: {error_counts['invalid_value']}\r\n\u001b[?2004l\r"]
[35.857152, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[35.857184, "o", "\u001b[?2004h> "]
[35.857321, "o", "Processing completed at: {processing_time}\r\n\u001b[?2004l\r"]
[35.857352, "o", "\u001b[?2004h> "]
[35.857379, "o", "\"\"\"\r\n\u001b[?2004l\r"]
[35.857409, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[35.857443, "o", "\u001b[?2004h> "]
[35.857552, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.857581, "o", "\u001b[?2004h> "]
[35.857653, "o", "        f.write(summary)\r\n\u001b[?2004l\r"]
[35.857687, "o", "\u001b[?2004h> "]
[35.857717, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.857749, "o", "> "]
[35.857828, "o", "    print(f\"Processing complete.\")\r\n\u001b[?2004l\r"]
[35.857863, "o", "\u001b[?2004h> "]
[35.858025, "o", "    print(f\"Valid: {valid_count}, Errors: {failed_count}\")\r\n\u001b[?2004l\r"]
[35.858057, "o", "\u001b[?2004h> \r\n"]
[35.858089, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[35.858169, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[35.858199, "o", "\u001b[?2004h> "]
[35.858229, "o", "    main()\r\n\u001b[?2004l\r"]
[35.858257, "o", "\u001b[?2004h> "]
[35.858298, "o", "EOF\r\n\u001b[?2004l\r"]
[35.866567, "o", "\u001b[?2004h"]
