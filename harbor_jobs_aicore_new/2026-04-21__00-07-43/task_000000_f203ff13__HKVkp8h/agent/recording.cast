[29.065315, "i", "python3 -c \"\nimport sqlite3\nimport json\n\nconn = sqlite3.connect('employees.db')\ncursor = conn.cursor()\ncursor.execute('''SELECT department, COUNT(*) as count, ROUND(AVG(salary), 2) as avg_salary, MIN(hire_date) as oldest_hire, MAX(hire_date) as newest_hire FROM employees GROUP BY department ORDER BY department''')\n\nresult = {}\nfor row in cursor.fetchall():\n    dept, count, avg_sal, oldest, newest = row\n    result[dept] = {\n        'count': count,\n        'avg_salary': avg_sal,\n        'oldest_hire': oldest,\n        'newest_hire': newest\n    }\n\nconn.close()\n\nwith open('dept_summary.json', 'w') as f:\n    json.dump(result, f, indent=2)\n\nprint('Done')\n\"\n"]
