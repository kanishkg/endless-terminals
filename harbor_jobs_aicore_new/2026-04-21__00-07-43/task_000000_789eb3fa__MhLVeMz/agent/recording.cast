[27.624047, "i", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\n#!/bin/bash\n\nMANIFEST=\"/home/user/docs_workspace/permissions_manifest.txt\"\n\nwhile IFS=: read -r path expected_perm; do\n    # Skip header lines and empty lines\n    [[ \"$path\" == \"DIRECTORY_PERMISSIONS\" ]] && continue\n    [[ \"$path\" == \"FILE_PERMISSIONS\" ]] && continue\n    [[ -z \"$path\" ]] && continue\n    \n    # Get actual permissions in octal\n    actual_perm=$(stat -c \"%a\" \"$path\" 2>/dev/null)\n    \n    if [[ \"$actual_perm\" != \"$expected_perm\" ]]; then\n        echo \"FAIL: $path\"\n        exit 1\n    fi\ndone < \"$MANIFEST\"\n\necho \"PASS\"\nexit 0\nEOF\n"]
