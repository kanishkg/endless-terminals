[31.026954, "i", "python3 << 'EOF'\nimport toml\n\n# Read the TOML file\nwith open('/etc/monitoring/uptime.toml', 'r') as f:\n    content = f.read()\n\n# Parse TOML\ndata = toml.loads(content)\n\n# Modify global section\ndata['global']['check_interval'] = 30\ndata['global']['timeout'] = 10\n\n# Find and modify api-gateway endpoint\nfor endpoint in data.get('endpoints', []):\n    if endpoint.get('name') == 'api-gateway':\n        endpoint['expected_status'] = 200\n        endpoint['critical'] = True\n\n# Add new payment-service endpoint\nnew_endpoint = {\n    'name': 'payment-service',\n    'url': 'https://payments.internal.example.com/health',\n    'expected_status': 200,\n    'critical': True,\n    'headers': {\n        'Authorization': 'Bearer ${PAYMENTS_TOKEN}'\n    }\n}\ndata['endpoints'].append(new_endpoint)\n\n# Write back\nwith open('/etc/monitoring/uptime.toml', 'w') as f:\n    f.write('# Uptime checker daemon configuration\\n\\n')\n    toml.dump(data, f)\n\nprint('TOML file updated successfully')\nEOF\n"]
