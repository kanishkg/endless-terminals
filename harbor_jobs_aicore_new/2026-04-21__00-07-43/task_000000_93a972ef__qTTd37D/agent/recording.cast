[50.132756, "i", "cat > /etc/monitoring/uptime.toml << 'EOF'\n# Uptime checker daemon configuration\n\n[global]\ncheck_interval = 30\nretry_count = 3\nlog_level = \"info\"\ntimeout = 10\n\n[[endpoints]]\nname = \"api-gateway\"\nurl = \"https://api.example.com/health\"\nexpected_status = 200\nmethod = \"GET\"\ncritical = true\n\n[[endpoints]]\nname = \"auth-service\"\nurl = \"https://auth.internal.example.com/ping\"\nexpected_status = 200\ncritical = false\n\n[[endpoints]]\nname = \"frontend\"\nurl = \"https://www.example.com\"\nexpected_status = 200\n\n[[endpoints]]\nname = \"payment-service\"\nurl = \"https://payments.internal.example.com/health\"\nexpected_status = 200\ncritical = true\nheaders = { Authorization = \"Bearer \\${PAYMENTS_TOKEN}\" }\nEOF\n"]
