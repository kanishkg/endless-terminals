[22.529689, "o", "cat /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[22.530586, "o", "# Prometheus alerting rules\r\ngroups:\r\n- name: service_alerts\r\n  rules:\r\n  - alert: HighLatency\r\n    expr: http_request_duration_seconds > 0.5\r\n    for: 3m\r\n    labels:\r\n      severity: warning\r\n    annotations:\r\n      summary: High latency detected on {{ $labels.instance }}\r\n  - alert: ServiceDown\r\n    expr: up == 0\r\n    for: 1m\r\n    labels:\r\n      severity: critical\r\n      team: platform\r\n      escalation_level: critical\r\n    annotations:\r\n      summary: Service {{ $labels.job }} is down\r\n  - alert: HighMemoryUsage\r\n    expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n    for: 5m\r\n    labels:\r\n      severity: warning\r\n    annotations:\r\n      summary: Memory usage critical on {{ $labels.instance }}\r\n  - alert: DiskSpaceLow\r\n    expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}\r\n      < 0.1\r\n    for: 10m\r\n    labels:\r\n      severity: warning\r\n      team: infrastructure\r\n    annotations:\r\n      summary: Disk space below 10% on {{ $labels.insta"]
[22.530638, "o", "nce }}\r\n"]
