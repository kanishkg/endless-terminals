[49.355908, "i", "cat > /tmp/analyze.sh << 'ENDSCRIPT'\n#!/bin/bash\ncd /home/user/migration\nmapfile -t INSTALLED < installed_packages.txt\nmapfile -t REQUIRED < required_packages.txt\ndeclare -A IS_REQUIRED IS_INSTALLED IS_DEPENDENCY DEP_OF\nfor pkg in \"${INSTALLED[@]}\"; do IS_INSTALLED[\"$pkg\"]=1; done\nfor pkg in \"${REQUIRED[@]}\"; do IS_REQUIRED[\"$pkg\"]=1; done\nget_deps() {\n    local pkg=\"$1\" level=\"$2\" parent=\"$3\"\n    [ \"$level\" -gt 3 ] && return\n    local deps=$(apt-cache depends \"$pkg\" 2>/dev/null | grep -E \"^  Depends:\" | sed 's/.*Depends: //' | sed 's/<.*//' | tr -d ' ')\n    for dep in $deps; do\n        [ -z \"$dep\" ] && continue\n        if [ -n \"${IS_INSTALLED[$dep]}\" ]; then\n            IS_DEPENDENCY[\"$dep\"]=1\n            if [ -z \"${DEP_OF[$dep]}\" ]; then\n                DEP_OF[\"$dep\"]=\"$parent\"\n            elif [[ ! \"${DEP_OF[$dep]}\" =~ \"$parent\" ]]; then\n                DEP_OF[\"$dep\"]=\"${DEP_OF[$dep]},$parent\"\n            fi\n            get_deps \"$dep\" $((level + 1)) \"$parent\"\n        fi\n    done\n}\necho \"Analyzing dependen"]
[49.356045, "i", "cies...\" >&2\nfor pkg in \"${REQUIRED[@]}\"; do\n    echo \"  Checking: $pkg\" >&2\n    get_deps \"$pkg\" 1 \"$pkg\"\ndone\ndeclare -a REMOVABLE PROTECTED\nfor pkg in \"${INSTALLED[@]}\"; do\n    if [ -z \"${IS_REQUIRED[$pkg]}\" ]; then\n        if [ -n \"${IS_DEPENDENCY[$pkg]}\" ]; then\n            PROTECTED+=(\"$pkg\")\n        else\n            REMOVABLE+=(\"$pkg\")\n        fi\n    fi\ndone\nIFS=$'\\n' REMOVABLE=($(sort <<<\"${REMOVABLE[*]}\")); unset IFS\nIFS=$'\\n' PROTECTED=($(sort <<<\"${PROTECTED[*]}\")); unset IFS\necho \"Removable: ${REMOVABLE[*]}\" >&2\necho \"Protected: ${PROTECTED[*]}\" >&2\nENDSCRIPT\nchmod +x /tmp/analyze.sh\n"]
