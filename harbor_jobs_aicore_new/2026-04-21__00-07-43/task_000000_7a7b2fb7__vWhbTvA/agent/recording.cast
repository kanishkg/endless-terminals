[104.180681, "i", "cat > /tmp/gen_report.py << 'PYEND'\nimport subprocess\nimport json\nimport re\n\ninstalled = open('/home/user/migration/installed_packages.txt').read().strip().split('\\n')\nrequired = open('/home/user/migration/required_packages.txt').read().strip().split('\\n')\n\nremovable = ['apache2', 'dnsutils', 'git', 'htop', 'iputils-ping', 'lsof', 'mysql-client', 'nano', 'ncdu', 'netcat-openbsd', 'nodejs', 'npm', 'postgresql-client', 'redis-tools', 'strace', 'tcpdump', 'tree', 'vim', 'wget']\nprotected = ['libc6', 'libssl3', 'zlib1g']\nprotected_by = {\n    'libc6': ['bash', 'coreutils', 'curl', 'python3', 'nginx', 'openssl'],\n    'libssl3': ['curl', 'openssl', 'nginx', 'python3'],\n    'zlib1g': ['curl', 'nginx', 'python3']\n}\n\ndef get_pkg_info(pkg):\n    version = 'unknown'\n    size = 0\n    has_security = False\n    \n    try:\n        result = subprocess.run(['dpkg-query', '-W', '-f', '${Version} ${Installed-Size}', pkg], \n                                capture_output=True, text=True, timeout=5)\n        if result.returncode == 0:\n"]
[104.180823, "i", "            parts = result.stdout.strip().split()\n            if len(parts) >= 1:\n                version = parts[0]\n            if len(parts) >= 2:\n                try:\n                    size = int(parts[1])\n                except:\n                    size = 0\n    except:\n        pass\n    \n    if version == 'unknown' or size == 0:\n        try:\n            result = subprocess.run(['apt-cache', 'show', pkg], capture_output=True, text=True, timeout=5)\n            for line in result.stdout.split('\\n'):\n                if line.startswith('Version:') and version == 'unknown':\n                    version = line.split(':', 1)[1].strip()\n                if line.startswith('Installed-Size:') and size == 0:\n                    try:\n                        size = int(line.split(':', 1)[1].strip())\n                    except:\n                        pass\n        except:\n            pass\n    \n    try:\n        result = subprocess.run(['apt-cache', 'policy', pkg], capture_output=True, text=True, timeout=5)\n        output "]
[104.180883, "i", "= result.stdout\n        installed_ver = None\n        candidate_ver = None\n        for line in output.split('\\n'):\n            if 'Installed:' in line:\n                installed_ver = line.split(':', 1)[1].strip()\n            if 'Candidate:' in line:\n                candidate_ver = line.split(':', 1)[1].strip()\n        if installed_ver and candidate_ver and installed_ver != candidate_ver and candidate_ver != '(none)':\n            if 'security' in output.lower():\n                has_security = True\n    except:\n        pass\n    \n    return version, size, has_security\n\nremovable_packages = []\ntotal_space = 0\n\nfor pkg in sorted(removable):\n    version, size, has_sec = get_pkg_info(pkg)\n    total_space += size\n    removable_packages.append({\n        'name': pkg,\n        'installed_version': version,\n        'size_kb': size,\n        'has_security_update': has_sec\n    })\n\ndep_protected = []\nfor pkg in sorted(protected):\n    req_by = sorted(list(set(protected_by.get(pkg, []))))\n    dep_protected.append({\n        'name"]
