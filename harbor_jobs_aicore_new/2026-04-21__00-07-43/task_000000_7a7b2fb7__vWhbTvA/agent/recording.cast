[168.88012, "o", "#!/bin/bash\r\n# Auto-generated script to remove unnecessary packages\r\n# Generated for container migration cleanup\r\n\r\nPACKAGES=\"apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\"\r\n\r\necho \"=== Container Package Removal Script ===\"\r\necho \"The following packages will be removed:\"\r\necho \"$PACKAGES\"\r\necho \"\"\r\n\r\n# Dry-run to show what would be removed\r\necho \"Performing dry-run...\"\r\nsudo apt-get remove --dry-run $PACKAGES\r\n\r\necho \"\"\r\necho \"Proceeding with actual removal...\"\r\nsudo apt-get remove -y $PACKAGES\r\n"]
