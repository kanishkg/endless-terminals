[5.745791, "i", "cat /etc/monitoring/alerts.yaml\n"]
[5.74593, "o", "cat /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[5.746879, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1"]
[5.746922, "o", "\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n"]
[5.747053, "o", "\u001b[?2004h"]
[5.747084, "o", "root@2eb2d9595fba:/home/user# "]
[10.741763, "i", "cat /etc/monitoring/uptime.toml\n"]
[10.741899, "o", "cat /etc/monitoring/uptime.toml\r\n\u001b[?2004l\r"]
[10.742823, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 60\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 204\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n"]
[10.742992, "o", "\u001b[?2004h"]
[10.743037, "o", "root@2eb2d9595fba:/home/user# "]
[26.322834, "i", "cat > /tmp/update_configs.py << 'SCRIPT'\nimport re\n\n# Read the YAML file\nwith open('/etc/monitoring/alerts.yaml', 'r') as f:\n    yaml_content = f.read()\n\n# 1. Change HighLatency 'for' duration from 5m to 3m\nyaml_content = re.sub(\n    r'(- alert: HighLatency\\n.*?for: )\\d+m',\n    r'\\g<1>3m',\n    yaml_content,\n    flags=re.DOTALL\n)\n\n# 2. Add escalation_level: critical to ServiceDown labels\n# Find ServiceDown and add the new label after existing labels\nyaml_content = re.sub(\n    r'(- alert: ServiceDown\\n.*?labels:\\n.*?severity: critical\\n.*?team: platform)',\n    r'\\1\\n          escalation_level: critical',\n    yaml_content,\n    flags=re.DOTALL\n)\n\n# 3. Add new DiskSpaceLow alert rule before the last alert or at the end of rules\nnew_alert = '''      - alert: DiskSpaceLow\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\n        for: 10m\n        labels:\n          severity: warning\n          team: infrastructure\n        annotations:\n          summary: \"Disk s"]
[26.322976, "i", "pace below 10% on {{ $labels.instance }}\"'''\n\n# Add before HighMemoryUsage\nyaml_content = yaml_content.replace(\n    '      - alert: HighMemoryUsage',\n    new_alert + '\\n\\n      - alert: HighMemoryUsage'\n)\n\n# Write back YAML\nwith open('/etc/monitoring/alerts.yaml', 'w') as f:\n    f.write(yaml_content)\n\nprint(\"YAML file updated\")\n\n# Now handle TOML file\nwith open('/etc/monitoring/uptime.toml', 'r') as f:\n    toml_content = f.read()\n\n# 1. Change check_interval from 60 to 30\ntoml_content = re.sub(r'check_interval = \\d+', 'check_interval = 30', toml_content)\n\n# 2. Add timeout = 10 after check_interval line\ntoml_content = re.sub(\n    r'(check_interval = 30\\n)',\n    r'\\1timeout = 10\\n',\n    toml_content\n)\n\n# 3. Modify api-gateway: change expected_status to 200 and add critical = true\n# Find the api-gateway block and modify it\ntoml_content = re.sub(\n    r'(\\[\\[endpoints\\]\\]\\nname = \"api-gateway\"\\nurl = \"https://api.example.com/health\"\\n)expected_status = 204',\n    r'\\1expected_status = 200\\ncritical = true',\n    toml"]
[26.323045, "o", "cat > /tmp/update_configs.py << 'SCRIPT'\r\n\u001b[?2004l\r"]
[26.323091, "i", "_content\n)\n\n# 4. Add new payment-service endpoint at the end\nnew_endpoint = '''\n[[endpoints]]\nname = \"payment-service\"\nurl = \"https://payments.internal.example.com/health\"\nexpected_status = 200\ncritical = true\nheaders = { Authorization = \"Bearer \\${PAYMENTS_TOKEN}\" }\n'''\n\ntoml_content = toml_content.rstrip() + '\\n' + new_endpoint\n\n# Write back TOML\nwith open('/etc/monitoring/uptime.toml', 'w') as f:\n    f.write(toml_content)\n\nprint(\"TOML file updated\")\nSCRIPT\n"]
[26.323148, "o", "\u001b[?2004h> import re\r\n\u001b[?2004l\r_content\r\n)\r\n\r\n# 4. Add new payment-service endpoint at the end\r\nnew_endpoint = '''\r\n[[endpoints]]\r\nname = \"payment-service\"\r\nurl ="]
[26.323194, "o", " \"https://payments.internal.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\nheaders = {"]
[26.323268, "o", " Authorization = \"Bearer \\${PAYMENTS_TOKEN}\" }\r\n'''\r\n\r\ntoml_content = toml_content.rstrip() + '\\n' + new_endpoint\r\n\r\n# Write back TOML\r\nwith open('/etc/monitoring/uptime.toml', 'w') "]
[26.323315, "o", "as f:\r\n    f.write(toml_content)\r\n\r\nprint(\"TOML file updated\")\r\nSCRIPT\r\n\u001b[?2004h"]
