[31.075769, "o", "s://api.example.com/health\"\\n)expected_status = 204',\r\n    r'\\1expected_status = 200\\ncritical = true',\r\n    toml_content\r\n)\r\n\r\n# 4. Add new payment-service endpoint at the end\r\nnew_endpoint = '''\r\n[[endpoints]]\r\nname = \"payment-service\"\r\nurl = \"https://payments.internal.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\nheaders = { Authorization = \"Bearer \\${PAYMENTS_TOKEN}\" }\r\n'''\r\n\r\ntoml_content = toml_content.rstrip() + '\\n' + new_endpoint\r\n\r\n# Write back TOML\r\nwith open('/etc/monitoring/uptime.toml', 'w') as f:\r\n    f.write(toml_content)\r\n\r\nprint(\"TOML file updated\")\r\n"]
