[38.266202, "i", "awk -F'\\t' '\n{\n  path = $2\n  bytes = $1\n  \n  # Skip the /var/data root entry\n  if (path == \"/var/data\") next\n  \n  # Skip directory entries (4096 bytes entries that are just directory markers)\n  if (path == \"/var/data/logs\" || path == \"/var/data/backups\" || path == \"/var/data/cache\" || path == \"/var/data/cache/thumbnails\" || path == \"/var/data/uploads\" || path == \"/var/data/archives\") next\n  \n  # Extract the immediate subdirectory name\n  sub(/^\\/var\\/data\\//, \"\", path)\n  split(path, parts, \"/\")\n  subdir = parts[1]\n  \n  dir_totals[subdir] += bytes\n  grand_total += bytes\n}\nEND {\n  for (dir in dir_totals) {\n    pct = (dir_totals[dir] / grand_total) * 100\n    printf \"%s %d %.1f\\n\", dir, dir_totals[dir], pct\n  }\n}' /home/user/disk_inventory.txt | sort -t' ' -k2,2nr | awk '{print $1\" \"$2\" \"$3\"%\"}' > /home/user/reports/directory_rollup.txt\n"]
