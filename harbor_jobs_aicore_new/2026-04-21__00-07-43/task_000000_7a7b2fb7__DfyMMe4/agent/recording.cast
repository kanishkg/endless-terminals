[118.757333, "o", "> "]
[118.757363, "o", "set -e\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.757403, "o", "\u001b[?2004h> "]
[118.757536, "o", "echo \"The following packages will be removed:\"\r\n\u001b[?2004l\r"]
