[118.75877, "o", "\u001b[?2004h> "]
[118.758797, "o", "\"\"\"\r\n\u001b[?2004l\r"]
[118.758823, "o", "\u001b[?2004h> "]
[118.759009, "o", "    with open('/home/user/migration/remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[118.759036, "o", "\u001b[?2004h> "]
