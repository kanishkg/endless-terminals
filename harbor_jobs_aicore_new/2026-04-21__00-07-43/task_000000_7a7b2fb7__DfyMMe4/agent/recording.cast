[118.730495, "i", "cat > /tmp/analyze.py << 'PYEOF'\nimport subprocess\nimport json\nimport re\n\ndef get_direct_deps(pkg):\n    \"\"\"Get direct dependencies of a package\"\"\"\n    try:\n        result = subprocess.run(['apt-cache', 'depends', pkg], \n                               capture_output=True, text=True, timeout=10)\n        deps = set()\n        for line in result.stdout.split('\\n'):\n            # Match Depends: and PreDepends: lines\n            match = re.match(r'\\s+(?:Pre)?Depends:\\s+<?([^>\\s]+)>?', line)\n            if match:\n                dep = match.group(1)\n                # Skip virtual packages (those in angle brackets that aren't resolved)\n                if not dep.startswith('<'):\n                    deps.add(dep.split(':')[0])  # Remove :any suffix\n        return deps\n    except:\n        return set()\n\ndef get_all_deps(pkg, max_depth=3, current_depth=1, seen=None):\n    \"\"\"Recursively get all dependencies up to max_depth levels\"\"\"\n    if seen is None:\n        seen = set()\n    if current_depth > max_depth or pkg in seen:\n"]
[118.730625, "i", "        return set()\n    \n    seen.add(pkg)\n    all_deps = set()\n    direct = get_direct_deps(pkg)\n    all_deps.update(direct)\n    \n    if current_depth < max_depth:\n        for dep in direct:\n            if dep not in seen:\n                all_deps.update(get_all_deps(dep, max_depth, current_depth + 1, seen))\n    \n    return all_deps\n\ndef get_package_size(pkg):\n    \"\"\"Get installed size in KB\"\"\"\n    try:\n        result = subprocess.run(['dpkg-query', '-W', '-f=${Installed-Size}', pkg],\n                               capture_output=True, text=True, timeout=10)\n        if result.returncode == 0 and result.stdout.strip():\n            return int(result.stdout.strip())\n    except:\n        pass\n    # Fallback to apt-cache show\n    try:\n        result = subprocess.run(['apt-cache', 'show', pkg],\n                               capture_output=True, text=True, timeout=10)\n        for line in result.stdout.split('\\n'):\n            if line.startswith('Installed-Size:'):\n                return int(line.split(':')[1].stri"]
