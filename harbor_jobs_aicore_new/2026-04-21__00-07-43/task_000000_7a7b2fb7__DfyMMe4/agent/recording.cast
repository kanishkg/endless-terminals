[289.258009, "o", "#!/bin/bash\r\n# Auto-generated script to remove unnecessary packages\r\n# Generated for cloud migration cleanup\r\n\r\nset -e\r\n\r\necho \"The following packages will be removed:\"\r\necho \"apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\"\r\necho \"\"\r\necho \"Dry run (no changes will be made):\"\r\napt-get remove --dry-run apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\r\n\r\necho \"\"\r\necho \"To actually remove these packages, run:\"\r\necho \"sudo apt-get remove -y apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\"\r\n\r\n# Uncomment the following line to perform actual removal:\r\n# apt-get remove -y apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tre"]
