[118.756581, "o", "\u001b[?2004h> "]
[118.756624, "o", "if removable:\r\n\u001b[?2004l\r"]
[118.756655, "o", "\u001b[?2004h> "]
[118.756807, "o", "    pkg_names = ' '.join(p['name'] for p in removable)\r\n\u001b[?2004l\r"]
[118.756839, "o", "\u001b[?2004h> "]
[118.75692, "o", "    script = f\"\"\"#!/bin/bash\r\n\u001b[?2004l\r"]
[118.756952, "o", "\u001b[?2004h> "]
[118.757103, "o", "# Auto-generated script to remove unnecessary packages\r\n\u001b[?2004l\r"]
[118.757133, "o", "\u001b[?2004h> "]
