[118.748813, "o", "\u001b[?2004h> "]
[118.748843, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.74887, "o", "> "]
[118.749017, "o", "# Get all dependencies of required packages (up to 3 levels)\r\n\u001b[?2004l\r"]
[118.749048, "o", "\u001b[?2004h> "]
[118.749124, "o", "all_required_deps = set()\r\n\u001b[?2004l\r"]
[118.749154, "o", "\u001b[?2004h> "]
[118.749351, "o", "dep_to_required_by = {}  # Track which required package needs each dep\r\n\u001b[?2004l\r"]
[118.749393, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.749431, "o", "\u001b[?2004h> "]
[118.749486, "o", "for pkg in required:\r\n\u001b[?2004l\r"]
[118.749517, "o", "\u001b[?2004h> "]
[118.749632, "o", "    deps = get_all_deps(pkg, max_depth=3)\r\n\u001b[?2004l\r"]
[118.749658, "o", "\u001b[?2004h> "]
[118.749721, "o", "    for dep in deps:\r\n\u001b[?2004l\r"]
[118.749751, "o", "\u001b[?2004h> "]
[118.749849, "o", "        all_required_deps.add(dep)\r\n\u001b[?2004l\r"]
[118.749879, "o", "\u001b[?2004h> "]
[118.749995, "o", "        if dep not in dep_to_required_by:\r\n\u001b[?2004l\r"]
[118.750025, "o", "\u001b[?2004h> "]
[118.750139, "o", "            dep_to_required_by[dep] = []\r\n\u001b[?2004l\r"]
[118.75017, "o", "\u001b[?2004h> "]
[118.750291, "o", "        dep_to_required_by[dep].append(pkg)\r\n\u001b[?2004l\r"]
[118.750323, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.750353, "o", "\u001b[?2004h> "]
[118.750569, "o", "print(f\"All dependencies of required packages: {len(all_required_deps)}\")\r\n\u001b[?2004l\r"]
[118.750596, "o", "\u001b[?2004h> "]
[118.750621, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.750647, "o", "> "]
[118.750777, "o", "# Find extra packages (installed but not required)\r\n\u001b[?2004l\r"]
[118.750803, "o", "\u001b[?2004h> "]
[118.750887, "o", "extra = installed - required\r\n\u001b[?2004l\r"]
[118.750917, "o", "\u001b[?2004h> "]
[118.751024, "o", "print(f\"Extra packages: {len(extra)}\")\r\n\u001b[?2004l\r"]
[118.751054, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.751084, "o", "\u001b[?2004h> "]
[118.751237, "o", "# Split extra into removable and dependency-protected\r\n\u001b[?2004l\r"]
[118.751267, "o", "\u001b[?2004h> "]
[118.751312, "o", "removable = []\r\n\u001b[?2004l\r"]
[118.751342, "o", "\u001b[?2004h> "]
[118.751426, "o", "dependency_protected = []\r\n\u001b[?2004l\r"]
[118.751462, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.751493, "o", "\u001b[?2004h> "]
[118.751542, "o", "for pkg in extra:\r\n\u001b[?2004l\r"]
[118.751572, "o", "\u001b[?2004h> "]
[118.751675, "o", "    if pkg in all_required_deps:\r\n\u001b[?2004l\r"]
[118.751707, "o", "\u001b[?2004h> "]
[118.751812, "o", "        dependency_protected.append({\r\n\u001b[?2004l\r"]
[118.751842, "o", "\u001b[?2004h> "]
[118.751914, "o", "            'name': pkg,\r\n\u001b[?2004l\r"]
[118.751944, "o", "\u001b[?2004h> "]
[118.752129, "o", "            'required_by': sorted(dep_to_required_by.get(pkg, []))\r\n\u001b[?2004l\r"]
[118.752159, "o", "\u001b[?2004h> "]
[118.75219, "o", "        })\r\n\u001b[?2004l\r"]
[118.752219, "o", "\u001b[?2004h> "]
[118.752252, "o", "    else:\r\n\u001b[?2004l\r"]
[118.752282, "o", "\u001b[?2004h> "]
[118.752397, "o", "        size = get_package_size(pkg)\r\n\u001b[?2004l\r"]
[118.752425, "o", "\u001b[?2004h> "]
[118.752556, "o", "        version = get_installed_version(pkg)\r\n\u001b[?2004l\r"]
[118.752582, "o", "\u001b[?2004h> "]
[118.752712, "o", "        security = has_security_update(pkg)\r\n\u001b[?2004l\r"]
[118.752742, "o", "\u001b[?2004h> "]
[118.75282, "o", "        removable.append({\r\n\u001b[?2004l\r"]
[118.752848, "o", "\u001b[?2004h> "]
[118.752923, "o", "            'name': pkg,\r\n\u001b[?2004l\r"]
[118.752954, "o", "\u001b[?2004h> "]
[118.753073, "o", "            'installed_version': version,\r\n\u001b[?2004l\r"]
[118.753103, "o", "\u001b[?2004h> "]
[118.753188, "o", "            'size_kb': size,\r\n\u001b[?2004l\r"]
[118.753218, "o", "\u001b[?2004h> "]
[118.753343, "o", "            'has_security_update': security\r\n\u001b[?2004l\r"]
[118.753383, "o", "\u001b[?2004h> "]
[118.753416, "o", "        })\r\n\u001b[?2004l\r"]
[118.753446, "o", "\u001b[?2004h> "]
[118.753472, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.753503, "o", "> "]
[118.753545, "o", "# Sort alphabetically\r\n\u001b[?2004l\r"]
[118.753572, "o", "\u001b[?2004h"]
[118.753598, "o", "> "]
[118.753692, "o", "removable.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[118.753724, "o", "\u001b[?2004h> "]
[118.75387, "o", "dependency_protected.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[118.753898, "o", "\u001b[?2004h> "]
[118.753927, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.753953, "o", "> "]
[118.754028, "o", "# Calculate total space savings\r\n\u001b[?2004l\r"]
[118.754054, "o", "\u001b[?2004h> "]
[118.754209, "o", "total_savings = sum(p['size_kb'] for p in removable)\r\n\u001b[?2004l\r"]
[118.754235, "o", "\u001b[?2004h> "]
[118.754261, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.754292, "o", "> "]
[118.754319, "o", "# Build report\r\n\u001b[?2004l\r"]
[118.754349, "o", "\u001b[?2004h> "]
[118.754392, "o", "report = {\r\n\u001b[?2004l\r"]
[118.754423, "o", "\u001b[?2004h> "]
[118.754473, "o", "    'summary': {\r\n\u001b[?2004l\r"]
[118.754504, "o", "\u001b[?2004h> "]
[118.754623, "o", "        'total_installed': len(installed),\r\n\u001b[?2004l\r"]
[118.75465, "o", "\u001b[?2004h> "]
[118.754767, "o", "        'total_required': len(required),\r\n\u001b[?2004l\r"]
[118.754798, "o", "\u001b[?2004h> "]
[118.754919, "o", "        'removable_count': len(removable),\r\n\u001b[?2004l\r"]
[118.754949, "o", "\u001b[?2004h> "]
[118.755114, "o", "        'kept_as_dependencies': len(dependency_protected),\r\n\u001b[?2004l\r"]
[118.755144, "o", "\u001b[?2004h> "]
[118.755276, "o", "        'total_space_savings_kb': total_savings\r\n\u001b[?2004l\r"]
[118.755307, "o", "\u001b[?2004h> "]
[118.755336, "o", "    },\r\n\u001b[?2004l\r"]
[118.755377, "o", "\u001b[?2004h> "]
[118.755477, "o", "    'removable_packages': removable,\r\n\u001b[?2004l\r"]
[118.755501, "o", "\u001b[?2004h"]
[118.75553, "o", "> "]
[118.755659, "o", "    'dependency_protected': dependency_protected\r\n\u001b[?2004l\r"]
[118.755688, "o", "\u001b[?2004h> "]
[118.755718, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.755748, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[118.755778, "o", "> "]
