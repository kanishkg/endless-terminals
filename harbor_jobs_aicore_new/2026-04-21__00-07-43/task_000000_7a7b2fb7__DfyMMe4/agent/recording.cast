[18.172123, "i", "cat > /tmp/analyze_deps.sh << 'EOF'\n#!/bin/bash\n\n# Get all dependencies of a package up to 3 levels deep\nget_deps() {\n    local pkg=$1\n    local level=$2\n    local max_level=3\n    \n    if [ $level -gt $max_level ]; then\n        return\n    fi\n    \n    # Get direct dependencies\n    local deps=$(apt-cache depends \"$pkg\" 2>/dev/null | grep -E \"^\\s+Depends:\" | sed 's/.*Depends: //' | sed 's/<\\|>//g' | cut -d':' -f1)\n    \n    for dep in $deps; do\n        echo \"$dep\"\n        get_deps \"$dep\" $((level + 1))\n    done\n}\n\n# Read required packages and collect all their dependencies\nwhile read -r pkg; do\n    [ -z \"$pkg\" ] && continue\n    get_deps \"$pkg\" 1\ndone < /home/user/migration/required_packages.txt | sort -u\nEOF\nchmod +x /tmp/analyze_deps.sh\n"]
