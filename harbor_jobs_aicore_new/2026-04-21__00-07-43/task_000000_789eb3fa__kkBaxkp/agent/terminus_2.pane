[?2004huser@2f983a41787b:~$ cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> MANIFEST="/home/user/docs_workspace/permissions_manifest.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Function to get octal permissions
[?2004l[?2004h> get_perms() {
[?2004l[?2004h>     stat -c "%a" "$1" 2>/dev/null
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # Check directory permissions
[?2004l[?2004h> while IFS=: read -r path expected; do
[?2004l[?2004h>     if [[ -z "$path" ]] || [[ "$path" == "DIRECTORY_PERMISSIONS" ]] || [[ "$path" == "FILE_PERMISSIONS" ]]; then
[?2004l[?2004h>         continue
[?2004l[?2004h>     fi
[?2004l[?2004h>     actual=$(get_perms "$path")
[?2004l[?2004h>     if [[ "$actual" != "$expected" ]]; then
[?2004l[?2004h>         echo "FAIL: $path"
[?2004l[?2004h>         exit 1
[?2004l[?2004h>     fi
[?2004l[?2004h> done < "$MANIFEST"
[?2004l[?2004h> 
[?2004l[?2004h> echo "PASS"
[?2004l[?2004h> EOF
