[27.376872, "i", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\n#!/bin/bash\n\nMANIFEST=\"/home/user/docs_workspace/permissions_manifest.txt\"\n\n# Function to get octal permissions\nget_perms() {\n    stat -c \"%a\" \"$1\" 2>/dev/null\n}\n\n# Check directory permissions\nwhile IFS=: read -r path expected; do\n    if [[ -z \"$path\" ]] || [[ \"$path\" == \"DIRECTORY_PERMISSIONS\" ]] || [[ \"$path\" == \"FILE_PERMISSIONS\" ]]; then\n        continue\n    fi\n    actual=$(get_perms \"$path\")\n    if [[ \"$actual\" != \"$expected\" ]]; then\n        echo \"FAIL: $path\"\n        exit 1\n    fi\ndone < \"$MANIFEST\"\n\necho \"PASS\"\nEOF\n"]
