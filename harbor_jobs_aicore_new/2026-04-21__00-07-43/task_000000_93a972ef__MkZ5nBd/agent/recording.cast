[6.312995, "i", "cat /etc/monitoring/alerts.yaml\n"]
[6.313133, "o", "cat /etc/monitoring/alerts.yaml\r\n"]
[6.313185, "o", "\u001b[?2004l\r"]
[6.314078, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n"]
[6.314252, "o", "\u001b[?2004h"]
[6.314286, "o", "root@a83f93e8a085:/home/user# "]
[6.809996, "i", "cat /etc/monitoring/uptime.toml\n"]
[6.810176, "o", "cat /etc/monitoring/uptime.toml\r\n"]
[6.810214, "o", "\u001b[?2004l\r"]
[6.811043, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 60\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 204\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n"]
[6.81121, "o", "\u001b[?2004h"]
[6.811283, "o", "root@a83f93e8a085:/home/user# "]
[17.598516, "i", "python3 << 'EOF'\nimport yaml\n\n# Read the YAML file\nwith open('/etc/monitoring/alerts.yaml', 'r') as f:\n    content = f.read()\n    \n# Parse YAML\ndata = yaml.safe_load(content)\n\n# Find and modify the rules\nfor group in data['groups']:\n    if group['name'] == 'service_alerts':\n        for rule in group['rules']:\n            # Change HighLatency 'for' duration to 3m\n            if rule['alert'] == 'HighLatency':\n                rule['for'] = '3m'\n            # Add escalation_level to ServiceDown\n            elif rule['alert'] == 'ServiceDown':\n                rule['labels']['escalation_level'] = 'critical'\n        \n        # Add new DiskSpaceLow alert\n        new_alert = {\n            'alert': 'DiskSpaceLow',\n            'expr': 'node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1',\n            'for': '10m',\n            'labels': {\n                'severity': 'warning',\n                'team': 'infrastructure'\n            },\n            'annotations': {\n                '"]
[17.598662, "i", "summary': 'Disk space below 10% on {{ $labels.instance }}'\n            }\n        }\n        group['rules'].append(new_alert)\n\n# Write back with preserved structure\nwith open('/etc/monitoring/alerts.yaml', 'w') as f:\n    f.write('# Prometheus alerting rules\\n')\n    yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)\n\nprint('YAML file updated successfully')\nEOF\n"]
