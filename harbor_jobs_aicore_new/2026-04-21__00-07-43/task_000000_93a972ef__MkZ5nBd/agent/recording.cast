[30.674885, "o", "cat /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[30.675805, "o", "# Prometheus alerting rules\r\ngroups:\r\n- name: service_alerts\r\n  rules:\r\n  - alert: HighLatency\r\n    expr: http_request_duration_seconds > 0.5\r\n    for: 3m\r\n    labels:\r\n      severity: warning\r\n    annotations:\r\n      summary: High latency detected on {{ $labels.instance }}\r\n  - alert: ServiceDown\r\n    expr: up == 0\r\n    for: 1m\r\n    labels:\r\n      severity: critical\r\n      team: platform\r\n      escalation_level: critical\r\n    annotations:\r\n      summary: Service {{ $labels.job }} is down\r\n  - alert: HighMemoryUsage\r\n    expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n    for: 5m\r\n    labels:\r\n      severity: warning\r\n    annotations:\r\n      summary: Memory usage critical on {{ $labels.instance }}\r\n  - alert: DiskSpaceLow\r\n    expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}\r\n      < 0.1\r\n    for: 10m\r\n    labels:\r\n      severity: warning"]
[30.675879, "o", "\r\n      team: infrastructure\r\n    annotations:\r\n      summary: Disk space below 10% on {{ $labels.instance }}\r\n"]
[30.67597, "o", "\u001b[?2004h"]
[30.675992, "o", "root@a83f93e8a085:/home/user# "]
[31.18906, "i", "cat /etc/monitoring/uptime.toml\n"]
[31.189196, "o", "cat /etc/monitoring/uptime.toml\r\n"]
[31.189251, "o", "\u001b[?2004l\r"]
[31.190124, "o", "# Uptime checker daemon configuration\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 200\r\nmethod = \"GET\"\r\ncritical = true\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n\r\n[[endpoints]]\r\n"]
[31.190226, "o", "name = \"payment-service\"\r\nurl = \"https://payments.internal.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\n\r\n[endpoints.headers]\r\nAuthorization = \"Bearer ${PAYMENTS_TOKEN}\"\r\n\r\n[global]\r\ncheck_interval = 30\r\nretry_count = 3\r\nlog_level = \"info\"\r\ntimeout = 10\r\n"]
[31.190315, "o", "\u001b[?2004h"]
[31.190352, "o", "root@a83f93e8a085:/home/user# "]
[40.415792, "i", "cat > /etc/monitoring/uptime.toml << 'EOF'\n# Uptime checker daemon configuration\n\n[global]\ncheck_interval = 30\nretry_count = 3\nlog_level = \"info\"\ntimeout = 10\n\n[[endpoints]]\nname = \"api-gateway\"\nurl = \"https://api.example.com/health\"\nexpected_status = 200\nmethod = \"GET\"\ncritical = true\n\n[[endpoints]]\nname = \"auth-service\"\nurl = \"https://auth.internal.example.com/ping\"\nexpected_status = 200\ncritical = false\n\n[[endpoints]]\nname = \"frontend\"\nurl = \"https://www.example.com\"\nexpected_status = 200\n\n[[endpoints]]\nname = \"payment-service\"\nurl = \"https://payments.internal.example.com/health\"\nexpected_status = 200\ncritical = true\nheaders = { Authorization = \"Bearer ${PAYMENTS_TOKEN}\" }\nEOF\n"]
[40.415987, "o", "cat > /etc/monitoring/uptime.toml << 'EOF'\r\n\u001b[?2004l\r"]
