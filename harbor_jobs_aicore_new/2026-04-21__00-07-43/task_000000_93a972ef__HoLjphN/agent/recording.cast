[6.548179, "i", "cat /etc/monitoring/alerts.yaml\n"]
[6.548333, "o", "cat /etc/monitoring/alerts.yaml\r\n"]
[6.548395, "o", "\u001b[?2004l\r"]
[6.549221, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:"]
[6.549288, "o", "\r\n          severity: critical\r\n          team: platform\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n"]
[6.54941, "o", "\u001b[?2004h"]
[6.549441, "o", "root@1a21b5f76bff:/home/user# "]
[7.04759, "i", "cat /etc/monitoring/uptime.toml\n"]
[7.047729, "o", "cat /etc/monitoring/uptime.toml\r\n\u001b[?2004l\r"]
[7.048578, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 60\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 204\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n"]
[7.048736, "o", "\u001b[?2004h"]
[7.048776, "o", "root@1a21b5f76bff:/home/user# "]
[18.87767, "i", "python3 << 'EOF'\nimport yaml\nimport sys\n\n# Read the YAML file\nwith open('/etc/monitoring/alerts.yaml', 'r') as f:\n    content = f.read()\n    \n# Parse YAML\ndata = yaml.safe_load(content)\n\n# Find the rules list\nrules = data['groups'][0]['rules']\n\n# 1. Change HighLatency 'for' duration to 3m\nfor rule in rules:\n    if rule.get('alert') == 'HighLatency':\n        rule['for'] = '3m'\n        print('Updated HighLatency for duration')\n    \n    # 2. Add escalation_level to ServiceDown\n    if rule.get('alert') == 'ServiceDown':\n        rule['labels']['escalation_level'] = 'critical'\n        print('Added escalation_level to ServiceDown')\n\n# 3. Add new DiskSpaceLow alert\nnew_alert = {\n    'alert': 'DiskSpaceLow',\n    'expr': 'node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1',\n    'for': '10m',\n    'labels': {\n        'severity': 'warning',\n        'team': 'infrastructure'\n    },\n    'annotations': {\n        'summary': 'Disk space below 10% on {{ $labels.instance }}'\n    }\n}\nrul"]
[18.8778, "i", "es.append(new_alert)\nprint('Added DiskSpaceLow alert')\n\n# Write back with preserved structure\nwith open('/etc/monitoring/alerts.yaml', 'w') as f:\n    f.write('# Prometheus alerting rules\\n')\n    yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)\n\nprint('YAML file updated successfully')\nEOF\n"]
[18.877834, "o", "python3 << 'EOF'\r\n\u001b[?2004l\res.append(new_alert)\r\nprint('Added DiskSpaceLow alert')\r\n\r\n# Write back with preserved structure\r\nwith open('/etc/monitori"]
[18.877869, "o", "ng/alerts.yaml', 'w') as f:\r\n    f.write('# Prometheus alerting rules\\n')\r\n    yaml.dump(data, f, default_flow_style=False, sort"]
[18.877898, "o", "_keys=False, allow_unicode=True)\r\n\r\nprint('YAML file updated successfully')\r\nEOF\r\n\u001b[?2004h"]
[18.877938, "o", "> import yaml\r\n"]
