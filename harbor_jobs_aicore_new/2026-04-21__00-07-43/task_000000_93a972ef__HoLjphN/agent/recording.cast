[86.703933, "o", "\u001b[?2004l\r"]
[86.704791, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 30\r\nretry_count = 3\r\nlog_level = \"info\"\r\ntimeout = 10\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 200\r\nmethod = \"GET\"\r\ncritical = true\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n\r\n[[endpoints]]\r\nname = \"payment-service\"\r\nurl = \"https://payments.internal.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\n\r\n[endpoints.headers]\r\nAuthorization = \"Bearer ${PAYMENTS_TOKEN}\"\r\n"]
