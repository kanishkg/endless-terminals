[40.216341, "i", "python3 << 'EOF'\nimport toml\n\n# Read the TOML file\nwith open('/etc/monitoring/uptime.toml', 'r') as f:\n    data = toml.load(f)\n\n# 1. Change global.check_interval to 30\ndata['global']['check_interval'] = 30\nprint('Updated check_interval to 30')\n\n# 2. Add global.timeout = 10\ndata['global']['timeout'] = 10\nprint('Added timeout = 10')\n\n# 3. Find api-gateway and modify it\nfor endpoint in data['endpoints']:\n    if endpoint.get('name') == 'api-gateway':\n        endpoint['expected_status'] = 200\n        endpoint['critical'] = True\n        print('Modified api-gateway endpoint')\n        break\n\n# 4. Add new payment-service endpoint\nnew_endpoint = {\n    'name': 'payment-service',\n    'url': 'https://payments.internal.example.com/health',\n    'expected_status': 200,\n    'critical': True,\n    'headers': {\n        'Authorization': 'Bearer ${PAYMENTS_TOKEN}'\n    }\n}\ndata['endpoints'].append(new_endpoint)\nprint('Added payment-service endpoint')\n\n# Write back with comment preserved\nwith open('/etc/monitoring/uptime.toml', 'w')"]
[40.216466, "i", " as f:\n    f.write('# Uptime checker daemon configuration\\n\\n')\n    toml.dump(data, f)\n\nprint('TOML file updated successfully')\nEOF\n"]
