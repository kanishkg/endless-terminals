[25.774016, "o", "cat /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[25.774923, "o", "# Prometheus alerting rules\r\ngroups:\r\n- name: service_alerts\r\n  rules:\r\n  - alert: HighLatency\r\n    expr: http_request_duration_seconds > 0.5\r\n    for: 3m\r\n    labels:\r\n      severity: warning\r\n    annotations:\r\n      summary: High latency detected on {{ $labels.instance }}\r\n  - alert: ServiceDown\r\n    expr: up == 0\r\n    for: 1m\r\n    labels:\r\n      severity: critical\r\n      team: platform\r\n      escalation_level: critical\r\n    annotations:\r\n      summary: Service {{ $labels.job }} is down\r\n  - alert: HighMemoryUsage\r\n    expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n    for: 5m\r\n    labels:\r\n      severity: warning\r\n    annotations:\r\n      summary: Memory usage critical on {{ $labels.instance }}\r\n  - alert: DiskSpaceLow\r\n    expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}\r\n      < 0.1\r\n    for: 10m\r\n    labels:\r\n      severity: warning\r\n      team: infrastructure\r\n    annotations:\r\n"]
[25.774972, "o", "      summary: Disk space below 10% on {{ $labels.instance }}\r\n"]
[25.775084, "o", "\u001b[?2004h"]
[25.775117, "o", "root@1a21b5f76bff:/home/user# "]
[32.080834, "i", "python3 -c \"import toml; print('toml available')\" 2>/dev/null || python3 -c \"import tomllib; print('tomllib available')\" 2>/dev/null || echo \"no toml library\"\n"]
[32.08137, "o", "python3 -c \"import toml; print('toml available')\" 2>/dev/null || python3 -c \"import tomllib; print('tomllib available')\" 2>/dev/null || echo \"no toml library\"\r\n\u001b[?2004l\r"]
