[31.816433, "o", "\u001b[?2004h> "]
[31.816463, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.816494, "o", "> "]
[31.816534, "o", "    # Validate status\r\n\u001b[?2004l\r"]
[31.816565, "o", "\u001b[?2004h> "]
[31.816801, "o", "    if not isinstance(record['status'], str) or record['status'] not in VALID_STATUSES:\r\n\u001b[?2004l\r"]
[31.816833, "o", "\u001b[?2004h> "]
[31.817063, "o", "        return False, 'invalid_value', f\"invalid status value: {record['status']}\"\r\n\u001b[?2004l\r"]
[31.817096, "o", "\u001b[?2004h> "]
[31.817125, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.817157, "o", "> "]
[31.817218, "o", "    return True, None, None\r\n\u001b[?2004l\r"]
[31.817251, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.817281, "o", "\u001b[?2004h> "]
[31.817372, "o", "def process_transactions():\r\n\u001b[?2004l\r"]
[31.817402, "o", "\u001b[?2004h> "]
[31.817465, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[31.817497, "o", "\u001b[?2004h> "]
[31.817541, "o", "    errors = []\r\n\u001b[?2004l\r"]
[31.817572, "o", "\u001b[?2004h> "]
[31.81763, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[31.817662, "o", "\u001b[?2004h> "]
[31.817741, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[31.817769, "o", "\u001b[?2004h> "]
[31.817849, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[31.81788, "o", "\u001b[?2004h> "]
[31.81796, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[31.817987, "o", "\u001b[?2004h> "]
[31.818064, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[31.818095, "o", "\u001b[?2004h> "]
[31.818122, "o", "    }\r\n\u001b[?2004l\r"]
[31.818153, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[31.818179, "o", "\u001b[?2004h"]
[31.818205, "o", "> "]
[31.818418, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[31.818451, "o", "\u001b[?2004h> "]
[31.818478, "o", "    \r\n\u001b[?2004l\r"]
[31.818508, "o", "\u001b[?2004h> "]
[31.818598, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[31.818629, "o", "\u001b[?2004h> "]
[31.818713, "o", "        lines = f.readlines()\r\n\u001b[?2004l\r"]
[31.818745, "o", "\u001b[?2004h> "]
[31.818776, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.818807, "o", "> "]
[31.818872, "o", "    total_lines = len(lines)\r\n\u001b[?2004l\r"]
[31.818903, "o", "\u001b[?2004h> "]
[31.818935, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.818962, "o", "> "]
[31.819075, "o", "    for line_num, line in enumerate(lines, 1):\r\n\u001b[?2004l\r"]
[31.819107, "o", "\u001b[?2004h> "]
[31.819246, "o", "        raw_content = truncate(line.rstrip('\\n'))\r\n\u001b[?2004l\r"]
[31.81928, "o", "\u001b[?2004h> "]
[31.819309, "o", "        \r\n\u001b[?2004l\r"]
[31.819351, "o", "\u001b[?2004h> "]
[31.819422, "o", "        # Try to parse JSON\r\n\u001b[?2004l\r"]
[31.819449, "o", "\u001b[?2004h"]
[31.819475, "o", "> "]
[31.819502, "o", "        try:\r\n\u001b[?2004l\r"]
[31.819532, "o", "\u001b[?2004h> "]
[31.81964, "o", "            record = json.loads(line)\r\n\u001b[?2004l\r"]
[31.819674, "o", "\u001b[?2004h> "]
[31.819773, "o", "        except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[31.819804, "o", "\u001b[?2004h> "]
[31.819935, "o", "            error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[31.819968, "o", "\u001b[?2004h> "]
[31.820043, "o", "            errors.append({\r\n\u001b[?2004l\r"]
[31.820074, "o", "\u001b[?2004h> "]
[31.820186, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.820215, "o", "\u001b[?2004h> "]
[31.820358, "o", "                'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[31.820393, "o", "\u001b[?2004h> "]
[31.820538, "o", "                'error_detail': 'invalid JSON syntax',\r\n\u001b[?2004l\r"]
[31.82057, "o", "\u001b[?2004h> "]
[31.820686, "o", "                'raw_content': raw_content\r\n\u001b[?2004l\r"]
[31.820714, "o", "\u001b[?2004h"]
[31.820742, "o", "> "]
[31.820772, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.8208, "o", "> "]
[31.820847, "o", "            continue\r\n\u001b[?2004l\r"]
[31.820876, "o", "\u001b[?2004h> "]
[31.820905, "o", "        \r\n\u001b[?2004l\r"]
[31.820935, "o", "\u001b[?2004h> "]
[31.821021, "o", "        # Validate the record\r\n\u001b[?2004l\r"]
[31.82105, "o", "\u001b[?2004h> "]
[31.82124, "o", "        is_valid, error_type, error_detail = validate_record(record)\r\n\u001b[?2004l\r"]
[31.821272, "o", "\u001b[?2004h> "]
[31.821306, "o", "        \r\n\u001b[?2004l\r"]
[31.821348, "o", "\u001b[?2004h> "]
[31.821404, "o", "        if not is_valid:\r\n\u001b[?2004l\r"]
[31.821437, "o", "\u001b[?2004h> "]
[31.821554, "o", "            error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[31.821584, "o", "\u001b[?2004h> "]
[31.821662, "o", "            errors.append({\r\n\u001b[?2004l\r"]
[31.82169, "o", "\u001b[?2004h> "]
[31.821804, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.821838, "o", "\u001b[?2004h> "]
[31.821951, "o", "                'error_type': error_type,\r\n\u001b[?2004l\r"]
[31.821977, "o", "\u001b[?2004h> "]
[31.822108, "o", "                'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[31.822137, "o", "\u001b[?2004h> "]
[31.822256, "o", "                'raw_content': raw_content\r\n\u001b[?2004l\r"]
[31.822286, "o", "\u001b[?2004h> "]
[31.822343, "o", "            })\r\n\u001b[?2004l\r"]
[31.822377, "o", "\u001b[?2004h> "]
[31.822431, "o", "            continue\r\n\u001b[?2004l\r"]
[31.822458, "o", "\u001b[?2004h> "]
[31.82249, "o", "        \r\n\u001b[?2004l\r"]
[31.822518, "o", "\u001b[?2004h> "]
[31.822678, "o", "        # Record is valid - compute hash and add metadata\r\n\u001b[?2004l\r"]
[31.82271, "o", "\u001b[?2004h> "]
[31.822783, "o", "        output_record = {\r\n\u001b[?2004l\r"]
[31.822814, "o", "\u001b[?2004h> "]
[31.822966, "o", "            'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[31.822995, "o", "\u001b[?2004h> "]
[31.823122, "o", "            'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[31.823151, "o", "\u001b[?2004h> "]
[31.823286, "o", "            'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[31.823328, "o", "\u001b[?2004h> "]
[31.823435, "o", "            'amount': record['amount'],\r\n\u001b[?2004l\r"]
[31.823467, "o", "\u001b[?2004h> "]
[31.823594, "o", "            'currency': record['currency'],\r\n\u001b[?2004l\r"]
[31.823625, "o", "\u001b[?2004h> "]
[31.823734, "o", "            'status': record['status'],\r\n\u001b[?2004l\r"]
[31.823765, "o", "\u001b[?2004h> "]
[31.823906, "o", "            'integrity_hash': compute_hash(record),\r\n\u001b[?2004l\r"]
[31.823935, "o", "\u001b[?2004h> "]
[31.824056, "o", "            'processed_at': processing_time\r\n\u001b[?2004l\r"]
[31.824088, "o", "\u001b[?2004h> "]
[31.824119, "o", "        }\r\n\u001b[?2004l\r"]
[31.82415, "o", "\u001b[?2004h> "]
[31.824265, "o", "        valid_records.append(output_record)\r\n\u001b[?2004l\r"]
[31.824297, "o", "\u001b[?2004h> "]
[31.824339, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.824374, "o", "> "]
[31.824458, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[31.82449, "o", "\u001b[?2004h> "]
[31.824634, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[31.824666, "o", "\u001b[?2004h> "]
[31.824697, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.824727, "o", "> "]
[31.824789, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[31.824819, "o", "\u001b[?2004h> "]
[31.824925, "o", "    with open(OUTPUT_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[31.824955, "o", "\u001b[?2004h> "]
[31.825057, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[31.825089, "o", "\u001b[?2004h> "]
[31.825222, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[31.825252, "o", "\u001b[?2004h> "]
[31.825283, "o", "    \r\n\u001b[?2004l\r"]
[31.825325, "o", "\u001b[?2004h> "]
[31.825375, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[31.825403, "o", "\u001b[?2004h> "]
[31.825507, "o", "    with open(ERROR_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[31.825541, "o", "\u001b[?2004h> "]
[31.825619, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[31.82565, "o", "\u001b[?2004h> "]
[31.825777, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[31.82581, "o", "\u001b[?2004h> "]
[31.825843, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.825873, "o", "> "]
[31.825936, "o", "    # Calculate success rate\r\n\u001b[?2004l\r"]
[31.825965, "o", "\u001b[?2004h> "]
[31.82607, "o", "    valid_count = len(valid_records)\r\n\u001b[?2004l\r"]
[31.826101, "o", "\u001b[?2004h> "]
[31.826189, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[31.82622, "o", "\u001b[?2004h> "]
[31.82645, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[31.826484, "o", "\u001b[?2004h> "]
[31.826517, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.826548, "o", "> "]
[31.826599, "o", "    # Write summary report\r\n\u001b[?2004l\r"]
[31.826631, "o", "\u001b[?2004h> "]
[31.82675, "o", "    summary = f\"\"\"AUDIT PROCESSING SUMMARY\r\n\u001b[?2004l\r"]
[31.826781, "o", "\u001b[?2004h> "]
[31.82685, "o", "========================\r\n\u001b[?2004l\r"]
[31.82688, "o", "\u001b[?2004h> "]
[31.826953, "o", "Input file: {INPUT_FILE}\r\n\u001b[?2004l\r"]
[31.826985, "o", "\u001b[?2004h> "]
[31.827085, "o", "Total lines processed: {total_lines}\r\n\u001b[?2004l\r"]
[31.827118, "o", "\u001b[?2004h> "]
[31.827209, "o", "Valid transactions: {valid_count}\r\n\u001b[?2004l\r"]
[31.827242, "o", "\u001b[?2004h> "]
[31.827336, "o", "Failed records: {failed_count}\r\n\u001b[?2004l\r"]
[31.827362, "o", "\u001b[?2004h"]
[31.827393, "o", "> "]
[31.82746, "o", "Success rate: {success_rate:.2f}%\r\n\u001b[?2004l\r"]
[31.827484, "o", "\u001b[?2004h"]
[31.8275, "o", "> \r\n\u001b[?2004l\r"]
[31.827536, "o", "\u001b[?2004h> "]
[31.827577, "o", "Errors by type:\r\n\u001b[?2004l\r"]
[31.827607, "o", "\u001b[?2004h> "]
[31.827748, "o", "  malformed_json: {error_counts['malformed_json']}\r\n\u001b[?2004l\r"]
[31.82778, "o", "\u001b[?2004h> "]
[31.827917, "o", "  missing_field: {error_counts['missing_field']}\r\n\u001b[?2004l\r"]
[31.827947, "o", "\u001b[?2004h> "]
[31.82809, "o", "  invalid_format: {error_counts['invalid_format']}\r\n\u001b[?2004l\r"]
[31.828122, "o", "\u001b[?2004h> "]
[31.828257, "o", "  invalid_value: {error_counts['invalid_value']}\r\n\u001b[?2004l\r"]
[31.828282, "o", "\u001b[?2004h"]
[31.828326, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.828357, "o", "> "]
[31.828451, "o", "Processing completed at: {processing_time}\r\n\u001b[?2004l\r"]
[31.828483, "o", "\u001b[?2004h> "]
[31.828514, "o", "\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.828545, "o", ">     \r\n\u001b[?2004l\r"]
[31.828576, "o", "\u001b[?2004h> "]
[31.828685, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[31.828718, "o", "\u001b[?2004h> "]
[31.82879, "o", "        f.write(summary)\r\n\u001b[?2004l\r"]
[31.828823, "o", "\u001b[?2004h> "]
[31.828857, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.828887, "o", "> "]
[31.828966, "o", "    print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[31.828997, "o", "\u001b[?2004h> "]
[31.82916, "o", "    print(f\"Valid: {valid_count}, Errors: {failed_count}\")\r\n\u001b[?2004l\r"]
[31.829192, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.829225, "o", "\u001b[?2004h> "]
[31.829302, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[31.829345, "o", "\u001b[?2004h> "]
[31.829417, "o", "    process_transactions()\r\n\u001b[?2004l\r"]
[31.829448, "o", "\u001b[?2004h> "]
[31.829489, "o", "PYTHON_SCRIPT\r\n\u001b[?2004l\r"]
[31.838369, "o", "\u001b[?2004h"]
[31.838407, "o", "root@428e4ecce9c0:/home/user# "]
[32.801286, "i", "python3 /home/user/audit/process_audit.py\n"]
[32.801471, "o", "python3 /home/user/audit/process_audit.py\r\n\u001b[?2004l\r"]
[32.828475, "o", "Processing complete!\r\nValid: 13, Errors: 12\r\n"]
[32.832191, "o", "\u001b[?2004h"]
[32.832233, "o", "root@428e4ecce9c0:/home/user# "]
[40.245844, "i", "cat /home/user/audit/processing_summary.txt\n"]
[40.246019, "o", "cat /home/user/audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[40.246904, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T01:03:06Z\r\n"]
[40.24704, "o", "\u001b[?2004h"]
[40.247074, "o", "root@428e4ecce9c0:/home/user# "]
[40.740922, "i", "cat /home/user/audit/clean_audit.jsonl\n"]
[40.741077, "o", "cat /home/user/audit/clean_audit.jsonl\r\n\u001b[?2004l\r"]
