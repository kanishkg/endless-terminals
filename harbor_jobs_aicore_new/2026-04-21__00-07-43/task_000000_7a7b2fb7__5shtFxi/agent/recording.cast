[144.130781, "i", "cat > /tmp/analyze.py << 'PYEOF'\nimport subprocess\nimport json\nimport re\nfrom collections import defaultdict\n\ndef run_cmd(cmd):\n    try:\n        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)\n        return result.stdout\n    except:\n        return \"\"\n\n# Read package lists\nwith open('/home/user/migration/installed_packages.txt') as f:\n    installed = [line.strip() for line in f if line.strip()]\n\nwith open('/home/user/migration/required_packages.txt') as f:\n    required = set(line.strip() for line in f if line.strip())\n\nprint(f\"Installed: {len(installed)}, Required: {len(required)}\")\n\n# Cache for dependencies\ndep_cache = {}\n\ndef get_deps(pkg):\n    if pkg in dep_cache:\n        return dep_cache[pkg]\n    output = run_cmd(f\"apt-cache depends {pkg} 2>/dev/null\")\n    deps = set()\n    for line in output.split('\\n'):\n        if 'Depends:' in line or 'PreDepends:' in line:\n            match = re.search(r':\\s*<?([^>\\s]+)>?', line)\n            if match:\n                dep = match.gro"]
[144.130932, "i", "up(1)\n                if dep and not dep.startswith('<'):\n                    deps.add(dep)\n    dep_cache[pkg] = deps\n    return deps\n\n# Build dependency tree up to 3 levels for required packages\nprint(\"Building dependency tree...\")\nall_deps = {}  # dep -> set of required packages that need it\n\nfor req_pkg in required:\n    print(f\"  Processing {req_pkg}...\")\n    # Level 1\n    level1 = get_deps(req_pkg)\n    for dep1 in level1:\n        if dep1 not in all_deps:\n            all_deps[dep1] = set()\n        all_deps[dep1].add(req_pkg)\n        # Level 2\n        level2 = get_deps(dep1)\n        for dep2 in level2:\n            if dep2 not in all_deps:\n                all_deps[dep2] = set()\n            all_deps[dep2].add(req_pkg)\n            # Level 3\n            level3 = get_deps(dep2)\n            for dep3 in level3:\n                if dep3 not in all_deps:\n                    all_deps[dep3] = set()\n                all_deps[dep3].add(req_pkg)\n\nprint(f\"Found {len(all_deps)} dependencies\")\n\n# Find extra packages\nextra = ["]
[144.130969, "o", "cat > /tmp/analyze.py << 'PYEOF'\r\n\u001b[?2004l\r"]
[144.131014, "i", "pkg for pkg in installed if pkg not in required]\nprint(f\"Extra packages: {len(extra)}\")\n\n# Categorize\nremovable = []\nprotected = []\n\nfor pkg in extra:\n    if pkg in all_deps:\n        protected.append((pkg, sorted(all_deps[pkg])))\n    else:\n        removable.append(pkg)\n\nremovable.sort()\nprotected.sort(key=lambda x: x[0])\n\nprint(f\"Removable: {len(removable)}, Protected: {len(protected)}\")\n\n# Get package info\ndef get_pkg_info(pkg):\n    # Get size\n    output = run_cmd(f\"apt-cache show {pkg} 2>/dev/null\")\n    size = 0\n    version = \"\"\n    for line in output.split('\\n'):\n        if line.startswith('Installed-Size:'):\n            try:\n                size = int(line.split(':')[1].strip())\n            except:\n                pass\n        if line.startswith('Version:') and not version:\n            version = line.split(':', 1)[1].strip()\n    \n    # Check security updates\n    policy = run_cmd(f\"apt-cache policy {pkg} 2>/dev/null\")\n    has_security = 'security' in policy.lower()\n    \n    return version, size, has_securi"]
[144.131043, "o", "\u001b[?2004h> "]
[144.131077, "i", "ty\n\nprint(\"Getting package info...\")\nremovable_info = []\ntotal_size = 0\n\nfor pkg in removable:\n    version, size, has_security = get_pkg_info(pkg)\n    total_size += size\n    removable_info.append({\n        \"name\": pkg,\n        \"installed_version\": version,\n        \"size_kb\": size,\n        \"has_security_update\": has_security\n    })\n    print(f\"  {pkg}: {size}KB, security={has_security}\")\n\nprotected_info = [\n    {\"name\": pkg, \"required_by\": req_by}\n    for pkg, req_by in protected\n]\n\n# Build report\nreport = {\n    \"summary\": {\n        \"total_installed\": len(installed),\n        \"total_required\": len(required),\n        \"removable_count\": len(removable),\n        \"kept_as_dependencies\": len(protected),\n        \"total_space_savings_kb\": total_size\n    },\n    \"removable_packages\": removable_info,\n    \"dependency_protected\": protected_info\n}\n\nwith open('/home/user/migration/removal_report.json', 'w') as f:\n    json.dump(report, f, indent=2)\n\nprint(\"Report written to removal_report.json\")\n\n# Generate removal script\nwith"]
[144.131107, "o", "import subprocess\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.131135, "i", " open('/home/user/migration/remove_packages.sh', 'w') as f:\n    pkg_list = ' '.join(removable)\n    f.write('''#!/bin/bash\n\n# Dry-run: showing packages that would be removed\necho \"The following packages will be removed: ''' + pkg_list + '''\"\n\n# Actual removal command\nsudo apt-get remove -y ''' + pkg_list + '''\\n''')\n\nimport os\nos.chmod('/home/user/migration/remove_packages.sh', 0o755)\nprint(\"Removal script written to remove_packages.sh\")\nPYEOF\n"]
