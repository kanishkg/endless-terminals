[54.613854, "o", "                    # Level 3\r\n\u001b[?2004l\r"]
[54.613881, "o", "\u001b[?2004h> "]
[54.614039, "o", "                    for dep3 in $(get_deps \"$dep2\"); do\r\n\u001b[?2004l\r"]
[54.614062, "o", "\u001b[?2004h"]
[54.614089, "o", "> "]
[54.614218, "o", "                        if [[ -n \"$dep3\" ]]; then\r\n\u001b[?2004l\r"]
[54.614248, "o", "\u001b[?2004h> "]
[54.61438, "o", "                            all_deps[\"$dep3\"]=1\r\n\u001b[?2004l\r"]
[54.614409, "o", "\u001b[?2004h> "]
[54.614613, "o", "                            if [[ -z \"${dep_required_by[$dep3]}\" ]]; then\r\n\u001b[?2004l\r"]
[54.614645, "o", "\u001b[?2004h> "]
[54.614829, "o", "                                dep_required_by[\"$dep3\"]=\"$req_pkg\"\r\n\u001b[?2004l\r"]
[54.61486, "o", "\u001b[?2004h> "]
[54.614951, "o", "                            else\r\n\u001b[?2004l\r"]
[54.614984, "o", "\u001b[?2004h> "]
[54.615248, "o", "                                dep_required_by[\"$dep3\"]=\"${dep_required_by[$dep3]},$req_pkg\"\r\n\u001b[?2004l\r"]
[54.615277, "o", "\u001b[?2004h> "]
[54.615364, "o", "                            fi\r\n\u001b[?2004l\r"]
[54.615386, "o", "\u001b[?2004h"]
[54.615417, "o", "> "]
[54.615473, "o", "                        fi\r\n\u001b[?2004l\r"]
[54.615498, "o", "\u001b[?2004h"]
[54.615529, "o", "> "]
[54.615576, "o", "                    done\r\n\u001b[?2004l\r"]
[54.615606, "o", "\u001b[?2004h> "]
[54.615662, "o", "                fi\r\n\u001b[?2004l\r"]
[54.615691, "o", "\u001b[?2004h> "]
[54.61574, "o", "            done\r\n\u001b[?2004l\r"]
[54.61577, "o", "\u001b[?2004h> "]
[54.615801, "o", "        fi\r\n\u001b[?2004l\r"]
[54.615831, "o", "\u001b[?2004h> "]
[54.615862, "o", "    done\r\n\u001b[?2004l\r"]
[54.615894, "o", "\u001b[?2004h> "]
[54.615925, "o", "done\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.615958, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.615989, "o", "> "]
[54.616061, "o", "echo \"Analyzing packages...\" >&2\r\n\u001b[?2004l\r"]
[54.616091, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[54.616122, "o", "\u001b[?2004h> "]
[54.616274, "o", "# Find extra packages (installed but not required)\r\n\u001b[?2004l\r"]
[54.616304, "o", "\u001b[?2004h> "]
[54.616369, "o", "declare -a extra_pkgs\r\n\u001b[?2004l\r"]
[54.6164, "o", "\u001b[?2004h> "]
[54.616494, "o", "for pkg in \"${INSTALLED[@]}\"; do\r\n\u001b[?2004l\r"]
[54.616525, "o", "\u001b[?2004h> "]
[54.616654, "o", "    if [[ -z \"${required_map[$pkg]}\" ]]; then\r\n\u001b[?2004l\r"]
[54.616684, "o", "\u001b[?2004h> "]
[54.616766, "o", "        extra_pkgs+=(\"$pkg\")\r\n\u001b[?2004l\r"]
[54.616796, "o", "\u001b[?2004h> "]
[54.616827, "o", "    fi\r\n\u001b[?2004l\r"]
[54.616858, "o", "\u001b[?2004h> "]
[54.616889, "o", "done\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.61692, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.616951, "o", "> "]
[54.61701, "o", "# Categorize extra packages\r\n\u001b[?2004l\r"]
[54.61704, "o", "\u001b[?2004h> "]
[54.617115, "o", "declare -a removable_pkgs\r\n\u001b[?2004l\r"]
[54.617145, "o", "\u001b[?2004h> "]
[54.617229, "o", "declare -a protected_pkgs\r\n\u001b[?2004l\r"]
[54.617262, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[54.617294, "o", "\u001b[?2004h> "]
[54.617388, "o", "for pkg in \"${extra_pkgs[@]}\"; do\r\n\u001b[?2004l\r"]
[54.617419, "o", "\u001b[?2004h> "]
[54.617545, "o", "    if [[ -n \"${all_deps[$pkg]}\" ]]; then\r\n\u001b[?2004l\r"]
[54.617576, "o", "\u001b[?2004h> "]
[54.617669, "o", "        protected_pkgs+=(\"$pkg\")\r\n\u001b[?2004l\r"]
[54.6177, "o", "\u001b[?2004h> "]
[54.617728, "o", "    else\r\n\u001b[?2004l\r"]
[54.617752, "o", "\u001b[?2004h"]
[54.617783, "o", "> "]
[54.617849, "o", "        removable_pkgs+=(\"$pkg\")\r\n\u001b[?2004l\r"]
[54.61788, "o", "\u001b[?2004h> "]
[54.61791, "o", "    fi\r\n\u001b[?2004l\r"]
[54.61794, "o", "\u001b[?2004h> "]
[54.617966, "o", "done\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.617996, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.618027, "o", "> "]
[54.618053, "o", "# Sort arrays\r\n\u001b[?2004l\r"]
[54.61808, "o", "\u001b[?2004h> "]
[54.61829, "o", "IFS=$'\\n' removable_pkgs=($(sort <<<\"${removable_pkgs[*]}\")); unset IFS\r\n\u001b[?2004l\r"]
[54.618322, "o", "\u001b[?2004h> "]
[54.618524, "o", "IFS=$'\\n' protected_pkgs=($(sort <<<\"${protected_pkgs[*]}\")); unset IFS\r\n\u001b[?2004l\r"]
[54.618555, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[54.618584, "o", "\u001b[?2004h"]
[54.618615, "o", "> "]
[54.618693, "o", "# Function to get package size in KB\r\n\u001b[?2004l\r"]
[54.618724, "o", "\u001b[?2004h> "]
[54.61877, "o", "get_size_kb() {\r\n\u001b[?2004l\r"]
[54.6188, "o", "\u001b[?2004h> "]
[54.618856, "o", "    local pkg=\"$1\"\r\n\u001b[?2004l\r"]
[54.618886, "o", "\u001b[?2004h> "]
[54.619162, "o", "    local size=$(apt-cache show \"$pkg\" 2>/dev/null | grep -m1 \"^Installed-Size:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[54.619207, "o", "\u001b[?2004h> "]
[54.619267, "o", "    echo \"${size:-0}\"\r\n\u001b[?2004l\r"]
[54.6193, "o", "\u001b[?2004h> "]
[54.619331, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.619361, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.619392, "o", "> "]
[54.619473, "o", "# Function to get installed version\r\n\u001b[?2004l\r"]
[54.619503, "o", "\u001b[?2004h> "]
[54.619577, "o", "get_installed_version() {\r\n\u001b[?2004l\r"]
[54.619608, "o", "\u001b[?2004h> "]
[54.619663, "o", "    local pkg=\"$1\"\r\n\u001b[?2004l\r"]
[54.619693, "o", "\u001b[?2004h> "]
[54.62006, "o", "    dpkg-query -W -f='${Version}' \"$pkg\" 2>/dev/null || apt-cache policy \"$pkg\" 2>/dev/null | grep -m1 \"Candidate:\" | awk '{print $2}'\r\n\u001b[?2004l\r"]
[54.620093, "o", "\u001b[?2004h> "]
[54.620123, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.620154, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.620185, "o", "> "]
[54.620288, "o", "# Function to check for security updates\r\n\u001b[?2004l\r"]
[54.62032, "o", "\u001b[?2004h> "]
[54.620389, "o", "has_security_update() {\r\n\u001b[?2004l\r"]
[54.620421, "o", "\u001b[?2004h> "]
[54.620476, "o", "    local pkg=\"$1\"\r\n\u001b[?2004l\r"]
[54.620505, "o", "\u001b[?2004h> "]
[54.620756, "o", "    apt-cache policy \"$pkg\" 2>/dev/null | grep -q \"security\" && echo \"true\" || echo \"false\"\r\n\u001b[?2004l\r"]
[54.620787, "o", "\u001b[?2004h> "]
[54.620817, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.620849, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.620881, "o", "> "]
[54.620912, "o", "# Calculate totals\r\n\u001b[?2004l\r"]
[54.620944, "o", "\u001b[?2004h> "]
[54.62104, "o", "total_installed=${#INSTALLED[@]}\r\n\u001b[?2004l\r"]
[54.62107, "o", "\u001b[?2004h> "]
[54.621158, "o", "total_required=${#REQUIRED[@]}\r\n\u001b[?2004l\r"]
[54.621189, "o", "\u001b[?2004h> "]
[54.621308, "o", "removable_count=${#removable_pkgs[@]}\r\n\u001b[?2004l\r"]
[54.62134, "o", "\u001b[?2004h> "]
[54.621435, "o", "kept_as_deps=${#protected_pkgs[@]}\r\n\u001b[?2004l\r"]
[54.621474, "o", "\u001b[?2004h> "]
[54.621504, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.621536, "o", "> "]
[54.62167, "o", "# Build removable packages JSON and calculate total size\r\n\u001b[?2004l\r"]
[54.6217, "o", "\u001b[?2004h> "]
[54.621739, "o", "total_size=0\r\n\u001b[?2004l\r"]
[54.621768, "o", "\u001b[?2004h> "]
[54.621821, "o", "removable_json=\"\"\r\n\u001b[?2004l\r"]
[54.621854, "o", "\u001b[?2004h> "]
[54.621958, "o", "for pkg in \"${removable_pkgs[@]}\"; do\r\n\u001b[?2004l\r"]
[54.621989, "o", "\u001b[?2004h> "]
[54.622111, "o", "    version=$(get_installed_version \"$pkg\")\r\n\u001b[?2004l\r"]
[54.622141, "o", "\u001b[?2004h> "]
[54.622239, "o", "    size=$(get_size_kb \"$pkg\")\r\n\u001b[?2004l\r"]
[54.622271, "o", "\u001b[?2004h> "]
[54.622388, "o", "    security=$(has_security_update \"$pkg\")\r\n\u001b[?2004l\r"]
[54.622418, "o", "\u001b[?2004h> "]
[54.622523, "o", "    total_size=$((total_size + size))\r\n\u001b[?2004l\r"]
[54.622554, "o", "\u001b[?2004h> "]
[54.622587, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.622625, "o", "> "]
[54.622711, "o", "    if [[ -n \"$removable_json\" ]]; then\r\n\u001b[?2004l\r"]
[54.622741, "o", "\u001b[?2004h> "]
[54.622819, "o", "        removable_json+=\",\"\r\n\u001b[?2004l\r"]
[54.62285, "o", "\u001b[?2004h> "]
[54.622881, "o", "    fi\r\n\u001b[?2004l\r"]
[54.622913, "o", "\u001b[?2004h> "]
[54.622966, "o", "    removable_json+=\"\r\n\u001b[?2004l\r"]
[54.622998, "o", "\u001b[?2004h> "]
[54.62303, "o", "    {\r\n\u001b[?2004l\r"]
[54.62306, "o", "\u001b[?2004h> "]
[54.623125, "o", "      \\\"name\\\": \\\"$pkg\\\",\r\n\u001b[?2004l\r"]
[54.623157, "o", "\u001b[?2004h> "]
[54.623287, "o", "      \\\"installed_version\\\": \\\"$version\\\",\r\n\u001b[?2004l\r"]
[54.623318, "o", "\u001b[?2004h> "]
[54.623393, "o", "      \\\"size_kb\\\": $size,\r\n\u001b[?2004l\r"]
[54.62342, "o", "\u001b[?2004h> "]
[54.623538, "o", "      \\\"has_security_update\\\": $security\r\n\u001b[?2004l\r"]
[54.623568, "o", "\u001b[?2004h> "]
[54.623595, "o", "    }\"\r\n\u001b[?2004l\r"]
[54.623622, "o", "\u001b[?2004h> "]
[54.623648, "o", "done\r\n\u001b[?2004l\r"]
[54.623678, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[54.623708, "o", "\u001b[?2004h> "]
[54.623796, "o", "# Build protected packages JSON\r\n\u001b[?2004l\r"]
[54.623825, "o", "\u001b[?2004h> "]
[54.623877, "o", "protected_json=\"\"\r\n\u001b[?2004l\r"]
[54.623907, "o", "\u001b[?2004h> "]
[54.624014, "o", "for pkg in \"${protected_pkgs[@]}\"; do\r\n\u001b[?2004l\r"]
[54.624043, "o", "\u001b[?2004h> "]
[54.624139, "o", "    # Get unique required_by list\r\n\u001b[?2004l\r"]
[54.624169, "o", "\u001b[?2004h> "]
[54.624288, "o", "    req_by=\"${dep_required_by[$pkg]}\"\r\n\u001b[?2004l\r"]
[54.624318, "o", "\u001b[?2004h> "]
[54.62444, "o", "    IFS=',' read -ra req_arr <<< \"$req_by\"\r\n\u001b[?2004l\r"]
[54.624465, "o", "\u001b[?2004h"]
[54.624495, "o", "> "]
[54.624655, "o", "    IFS=$'\\n' req_arr=($(sort -u <<<\"${req_arr[*]}\")); unset IFS\r\n\u001b[?2004l\r"]
[54.624683, "o", "\u001b[?2004h> "]
[54.624711, "o", "    \r\n\u001b[?2004l\r"]
[54.62474, "o", "\u001b[?2004h> "]
[54.624789, "o", "    req_by_json=\"\"\r\n\u001b[?2004l\r"]
[54.624817, "o", "\u001b[?2004h> "]
[54.624913, "o", "    for r in \"${req_arr[@]}\"; do\r\n\u001b[?2004l\r"]
[54.624943, "o", "\u001b[?2004h> "]
[54.625061, "o", "        if [[ -n \"$req_by_json\" ]]; then\r\n\u001b[?2004l\r"]
[54.625094, "o", "\u001b[?2004h> "]
[54.625175, "o", "            req_by_json+=\", \"\r\n\u001b[?2004l\r"]
[54.625216, "o", "\u001b[?2004h> "]
[54.625251, "o", "        fi\r\n\u001b[?2004l\r"]
[54.625282, "o", "\u001b[?2004h> "]
[54.625366, "o", "        req_by_json+=\"\\\"$r\\\"\"\r\n\u001b[?2004l\r"]
[54.625397, "o", "\u001b[?2004h> "]
[54.625425, "o", "    done\r\n\u001b[?2004l\r"]
[54.625456, "o", "\u001b[?2004h> "]
[54.6255, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[54.62553, "o", "> "]
[54.625623, "o", "    if [[ -n \"$protected_json\" ]]; then\r\n\u001b[?2004l\r"]
[54.625654, "o", "\u001b[?2004h> "]
[54.625732, "o", "        protected_json+=\",\"\r\n\u001b[?2004l\r"]
[54.625763, "o", "\u001b[?2004h> "]
[54.625795, "o", "    fi\r\n\u001b[?2004l\r"]
[54.625826, "o", "\u001b[?2004h> "]
[54.625878, "o", "    protected_json+=\"\r\n\u001b[?2004l\r"]
[54.625911, "o", "\u001b[?2004h> "]
[54.625937, "o", "    {\r\n\u001b[?2004l\r"]
[54.625967, "o", "\u001b[?2004h> "]
[54.626029, "o", "      \\\"name\\\": \\\"$pkg\\\",\r\n\u001b[?2004l\r"]
[54.626062, "o", "\u001b[?2004h> "]
[54.626168, "o", "      \\\"required_by\\\": [$req_by_json]\r\n\u001b[?2004l\r"]
[54.626212, "o", "\u001b[?2004h> "]
[54.626245, "o", "    }\"\r\n\u001b[?2004l\r"]
[54.626276, "o", "\u001b[?2004h> done\r\n"]
[54.626307, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[54.626336, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.626367, "o", "> "]
[54.626408, "o", "# Generate JSON report\r\n\u001b[?2004l\r"]
[54.626439, "o", "\u001b[?2004h> "]
[54.626588, "o", "cat > /home/user/migration/removal_report.json << EOF\r\n\u001b[?2004l\r"]
[54.626615, "o", "\u001b[?2004h> "]
[54.626647, "o", "{\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.626678, "o", "> "]
[54.626709, "o", "  \"summary\": {\r\n\u001b[?2004l\r"]
[54.626741, "o", "\u001b[?2004h> "]
[54.626846, "o", "    \"total_installed\": $total_installed,\r\n\u001b[?2004l\r"]
[54.626879, "o", "\u001b[?2004h> "]
[54.626986, "o", "    \"total_required\": $total_required,\r\n\u001b[?2004l\r"]
[54.627017, "o", "\u001b[?2004h> "]
[54.627128, "o", "    \"removable_count\": $removable_count,\r\n\u001b[?2004l\r"]
[54.627159, "o", "\u001b[?2004h> "]
[54.627288, "o", "    \"kept_as_dependencies\": $kept_as_deps,\r\n\u001b[?2004l\r"]
[54.627317, "o", "\u001b[?2004h> "]
[54.627435, "o", "    \"total_space_savings_kb\": $total_size\r\n\u001b[?2004l\r"]
[54.627466, "o", "\u001b[?2004h> "]
[54.627491, "o", "  },\r\n\u001b[?2004l\r"]
[54.627517, "o", "\u001b[?2004h> "]
[54.627627, "o", "  \"removable_packages\": [$removable_json\r\n\u001b[?2004l\r"]
[54.627651, "o", "\u001b[?2004h> "]
[54.627681, "o", "  ],\r\n\u001b[?2004l\r"]
[54.627712, "o", "\u001b[?2004h> "]
[54.62782, "o", "  \"dependency_protected\": [$protected_json\r\n\u001b[?2004l\r"]
[54.627851, "o", "\u001b[?2004h> "]
[54.627884, "o", "  ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[54.627916, "o", "> }\r\n\u001b[?2004l\r"]
[54.627947, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[54.627977, "o", "\u001b[?2004h> "]
[54.628008, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[54.628084, "o", "# Generate removal script\r\n\u001b[?2004l\r"]
[54.628114, "o", "\u001b[?2004h> "]
[54.628245, "o", "remove_list=$(echo \"${removable_pkgs[@]}\")\r\n\u001b[?2004l\r"]
[54.628277, "o", "\u001b[?2004h> "]
[54.62842, "o", "cat > /home/user/migration/remove_packages.sh << EOF\r\n\u001b[?2004l\r"]
[54.628451, "o", "\u001b[?2004h> "]
[54.628484, "o", "#!/bin/bash\r\n\u001b[?2004l\r"]
[54.628513, "o", "\u001b[?2004h> "]
[54.628543, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[54.628685, "o", "# Dry-run: showing packages that would be removed\r\n\u001b[?2004l\r"]
[54.628717, "o", "\u001b[?2004h> "]
[54.628883, "o", "echo \"The following packages will be removed: $remove_list\"\r\n\u001b[?2004l\r"]
[54.628913, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[54.628944, "o", "\u001b[?2004h> "]
[54.629018, "o", "# Actual removal command\r\n\u001b[?2004l\r"]
[54.629049, "o", "\u001b[?2004h> "]
[54.629153, "o", "sudo apt-get remove -y $remove_list\r\n\u001b[?2004l\r"]
[54.629186, "o", "\u001b[?2004h> "]
[54.629237, "o", "EOF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[54.629271, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
