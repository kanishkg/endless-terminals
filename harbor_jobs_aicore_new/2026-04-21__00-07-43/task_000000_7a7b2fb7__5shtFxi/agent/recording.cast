[144.143881, "o", "            except:\r\n\u001b[?2004l\r"]
[144.143911, "o", "\u001b[?2004h> "]
[144.143988, "o", "                pass\r\n\u001b[?2004l\r"]
[144.144017, "o", "\u001b[?2004h"]
[144.144054, "o", "> "]
[144.144217, "o", "        if line.startswith('Version:') and not version:\r\n\u001b[?2004l\r"]
[144.144251, "o", "\u001b[?2004h"]
[144.144283, "o", "> "]
[144.14444, "o", "            version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[144.144471, "o", "\u001b[?2004h> "]
[144.144501, "o", "    \r\n\u001b[?2004l\r"]
[144.144531, "o", "\u001b[?2004h> "]
[144.144606, "o", "    # Check security updates\r\n\u001b[?2004l\r"]
[144.144637, "o", "\u001b[?2004h> "]
[144.144801, "o", "    policy = run_cmd(f\"apt-cache policy {pkg} 2>/dev/null\")\r\n\u001b[?2004l\r"]
[144.144831, "o", "\u001b[?2004h> "]
[144.144965, "o", "    has_security = 'security' in policy.lower()\r\n\u001b[?2004l\r"]
[144.144996, "o", "\u001b[?2004h> "]
[144.145023, "o", "    \r\n\u001b[?2004l\r"]
[144.145054, "o", "\u001b[?2004h> "]
[144.145154, "o", "    return version, size, has_security\r\n\u001b[?2004l\r"]
[144.145183, "o", "\u001b[?2004h> "]
[144.145225, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.14532, "o", "print(\"Getting package info...\")\r\n\u001b[?2004l\r"]
[144.14535, "o", "\u001b[?2004h> "]
[144.145408, "o", "removable_info = []\r\n\u001b[?2004l\r"]
[144.145439, "o", "\u001b[?2004h> "]
[144.145494, "o", "total_size = 0\r\n\u001b[?2004l\r"]
[144.145525, "o", "\u001b[?2004h> "]
[144.145553, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[144.145583, "o", "> "]
[144.145621, "o", "for pkg in removable:\r\n\u001b[?2004l\r"]
[144.145652, "o", "\u001b[?2004h"]
[144.145683, "o", "> "]
[144.145833, "o", "    version, size, has_security = get_pkg_info(pkg)\r\n\u001b[?2004l\r"]
[144.145862, "o", "\u001b[?2004h"]
[144.145892, "o", "> "]
[144.145952, "o", "    total_size += size\r\n\u001b[?2004l\r"]
[144.145983, "o", "\u001b[?2004h"]
[144.146014, "o", "> "]
[144.146085, "o", "    removable_info.append({\r\n\u001b[?2004l\r"]
[144.146114, "o", "\u001b[?2004h> "]
[144.146182, "o", "        \"name\": pkg,\r\n\u001b[?2004l\r"]
[144.146224, "o", "\u001b[?2004h"]
[144.146258, "o", "> "]
[144.146375, "o", "        \"installed_version\": version,\r\n"]
[144.146405, "o", "\u001b[?2004l\r"]
[144.146436, "o", "\u001b[?2004h> "]
[144.146525, "o", "        \"size_kb\": size,\r\n\u001b[?2004l\r"]
[144.146554, "o", "\u001b[?2004h"]
[144.146583, "o", "> "]
[144.146696, "o", "        \"has_security_update\": has_security\r\n\u001b[?2004l\r"]
[144.146726, "o", "\u001b[?2004h> "]
[144.146756, "o", "    })\r\n\u001b[?2004l\r"]
[144.146777, "o", "\u001b[?2004h"]
[144.14682, "o", "> "]
[144.146945, "o", "    print(f\"  {pkg}: {size}KB, security={has_security}\")\r\n\u001b[?2004l\r"]
[144.146975, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[144.147006, "o", "\u001b[?2004h> "]
[144.147061, "o", "protected_info = [\r\n\u001b[?2004l\r"]
[144.147092, "o", "\u001b[?2004h> "]
[144.147225, "o", "    {\"name\": pkg, \"required_by\": req_by}\r\n\u001b[?2004l\r"]
[144.14726, "o", "\u001b[?2004h> "]
[144.147344, "o", "    for pkg, req_by in protected\r\n\u001b[?2004l\r"]
[144.147376, "o", "\u001b[?2004h> "]
[144.147407, "o", "]\r\n\u001b[?2004l\r\u001b[?2004h"]
[144.147437, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[144.147468, "o", "> "]
[144.147499, "o", "# Build report\r\n\u001b[?2004l\r"]
[144.147531, "o", "\u001b[?2004h> "]
[144.147561, "o", "report = {\r\n\u001b[?2004l\r"]
[144.147581, "o", "\u001b[?2004h"]
[144.147619, "o", "> "]
[144.147646, "o", "    \"summary\": {\r\n\u001b[?2004l\r"]
[144.147677, "o", "\u001b[?2004h> "]
[144.147782, "o", "        \"total_installed\": len(installed),\r\n\u001b[?2004l\r"]
[144.147813, "o", "\u001b[?2004h> "]
[144.147925, "o", "        \"total_required\": len(required),\r\n\u001b[?2004l\r"]
[144.147957, "o", "\u001b[?2004h> "]
[144.148074, "o", "        \"removable_count\": len(removable),\r\n\u001b[?2004l\r"]
[144.148103, "o", "\u001b[?2004h> "]
[144.148248, "o", "        \"kept_as_dependencies\": len(protected),\r\n\u001b[?2004l\r"]
[144.148279, "o", "\u001b[?2004h"]
[144.148309, "o", "> "]
[144.148403, "o", "        \"total_space_savings_kb\": total_size\r\n\u001b[?2004l\r"]
[144.14843, "o", "\u001b[?2004h> "]
[144.148455, "o", "    },\r\n\u001b[?2004l\r"]
[144.148482, "o", "\u001b[?2004h"]
[144.148511, "o", "> "]
[144.148598, "o", "    \"removable_packages\": removable_info,\r\n\u001b[?2004l\r"]
[144.148629, "o", "\u001b[?2004h> "]
[144.148748, "o", "    \"dependency_protected\": protected_info\r\n\u001b[?2004l\r"]
[144.148779, "o", "\u001b[?2004h> "]
[144.148809, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[144.14884, "o", "> \r\n\u001b[?2004l\r"]
[144.148871, "o", "\u001b[?2004h> "]
[144.149047, "o", "with open('/home/user/migration/removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[144.149077, "o", "\u001b[?2004h> "]
[144.149178, "o", "    json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[144.149222, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[144.149252, "o", "\u001b[?2004h> "]
[144.149386, "o", "print(\"Report written to removal_report.json\")\r\n\u001b[?2004l\r"]
[144.149412, "o", "\u001b[?2004h"]
[144.149452, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[144.149482, "o", "> "]
[144.149535, "o", "# Generate removal script\r\n\u001b[?2004l\r"]
[144.149567, "o", "\u001b[?2004h> "]
[144.149746, "o", "with open('/home/user/migration/remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[144.14978, "o", "\u001b[?2004h> "]
[144.149872, "o", "    pkg_list = ' '.join(removable)\r\n\u001b[?2004l\r"]
[144.149906, "o", "\u001b[?2004h> "]
[144.14998, "o", "    f.write('''#!/bin/bash\r\n\u001b[?2004l\r"]
[144.150014, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[144.150044, "o", "\u001b[?2004h> "]
[144.150185, "o", "# Dry-run: showing packages that would be removed\r\n\u001b[?2004l\r"]
[144.150228, "o", "\u001b[?2004h> "]
[144.150414, "o", "echo \"The following packages will be removed: ''' + pkg_list + '''\"\r\n\u001b[?2004l\r"]
[144.150443, "o", "\u001b[?2004h> "]
[144.150472, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[144.150505, "o", "> "]
[144.150551, "o", "# Actual removal command\r\n\u001b[?2004l\r"]
[144.150581, "o", "\u001b[?2004h> "]
[144.150721, "o", "sudo apt-get remove -y ''' + pkg_list + '''\\n''')\r\n\u001b[?2004l\r"]
[144.150753, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[144.150782, "o", "\u001b[?2004h> "]
[144.150817, "o", "import os\r\n\u001b[?2004l\r"]
[144.150846, "o", "\u001b[?2004h> "]
[144.151031, "o", "os.chmod('/home/user/migration/remove_packages.sh', 0o755)\r\n\u001b[?2004l\r"]
[144.151062, "o", "\u001b[?2004h"]
[144.151096, "o", "> "]
[144.151238, "o", "print(\"Removal script written to remove_packages.sh\")\r\n\u001b[?2004l\r"]
[144.151271, "o", "\u001b[?2004h> "]
[144.151306, "o", "PYEOF\r\n\u001b[?2004l\r"]
[144.152459, "o", "\u001b[?2004h"]
[144.152493, "o", "user@d45c39d4259a:~/migration$ "]
