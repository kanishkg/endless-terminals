[54.604628, "i", "cat > /tmp/analyze.sh << 'SCRIPT'\n#!/bin/bash\n\ncd /home/user/migration\n\n# Read package lists\nmapfile -t INSTALLED < installed_packages.txt\nmapfile -t REQUIRED < required_packages.txt\n\n# Create associative arrays\ndeclare -A required_map\ndeclare -A installed_map\ndeclare -A dep_map\ndeclare -A dep_required_by\n\nfor pkg in \"${REQUIRED[@]}\"; do\n    required_map[\"$pkg\"]=1\ndone\n\nfor pkg in \"${INSTALLED[@]}\"; do\n    installed_map[\"$pkg\"]=1\ndone\n\n# Function to get dependencies of a package\nget_deps() {\n    local pkg=\"$1\"\n    apt-cache depends \"$pkg\" 2>/dev/null | grep -E \"^\\s*(Depends|PreDepends):\" | sed 's/.*: //' | sed 's/<\\|>//g' | sort -u\n}\n\n# Build dependency tree up to 3 levels for required packages\necho \"Building dependency tree...\" >&2\ndeclare -A all_deps\n\nfor req_pkg in \"${REQUIRED[@]}\"; do\n    # Level 1\n    for dep1 in $(get_deps \"$req_pkg\"); do\n        if [[ -n \"$dep1\" ]]; then\n            all_deps[\"$dep1\"]=1\n            if [[ -z \"${dep_required_by[$dep1]}\" ]]; then\n                dep_required_by[\"$dep1\"]=\"$"]
[54.604791, "i", "req_pkg\"\n            else\n                dep_required_by[\"$dep1\"]=\"${dep_required_by[$dep1]},$req_pkg\"\n            fi\n            # Level 2\n            for dep2 in $(get_deps \"$dep1\"); do\n                if [[ -n \"$dep2\" ]]; then\n                    all_deps[\"$dep2\"]=1\n                    if [[ -z \"${dep_required_by[$dep2]}\" ]]; then\n                        dep_required_by[\"$dep2\"]=\"$req_pkg\"\n                    else\n                        dep_required_by[\"$dep2\"]=\"${dep_required_by[$dep2]},$req_pkg\"\n                    fi\n                    # Level 3\n                    for dep3 in $(get_deps \"$dep2\"); do\n                        if [[ -n \"$dep3\" ]]; then\n                            all_deps[\"$dep3\"]=1\n                            if [[ -z \"${dep_required_by[$dep3]}\" ]]; then\n                                dep_required_by[\"$dep3\"]=\"$req_pkg\"\n                            else\n                                dep_required_by[\"$dep3\"]=\"${dep_required_by[$dep3]},$req_pkg\"\n                            fi\n         "]
