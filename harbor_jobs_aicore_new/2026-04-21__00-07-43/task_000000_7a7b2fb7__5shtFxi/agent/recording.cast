[54.60489, "i", "               fi\n                    done\n                fi\n            done\n        fi\n    done\ndone\n\necho \"Analyzing packages...\" >&2\n\n# Find extra packages (installed but not required)\ndeclare -a extra_pkgs\nfor pkg in \"${INSTALLED[@]}\"; do\n    if [[ -z \"${required_map[$pkg]}\" ]]; then\n        extra_pkgs+=(\"$pkg\")\n    fi\ndone\n\n# Categorize extra packages\ndeclare -a removable_pkgs\ndeclare -a protected_pkgs\n\nfor pkg in \"${extra_pkgs[@]}\"; do\n    if [[ -n \"${all_deps[$pkg]}\" ]]; then\n        protected_pkgs+=(\"$pkg\")\n    else\n        removable_pkgs+=(\"$pkg\")\n    fi\ndone\n\n# Sort arrays\nIFS=$'\\n' removable_pkgs=($(sort <<<\"${removable_pkgs[*]}\")); unset IFS\nIFS=$'\\n' protected_pkgs=($(sort <<<\"${protected_pkgs[*]}\")); unset IFS\n\n# Function to get package size in KB\nget_size_kb() {\n    local pkg=\"$1\"\n    local size=$(apt-cache show \"$pkg\" 2>/dev/null | grep -m1 \"^Installed-Size:\" | awk '{print $2}')\n    echo \"${size:-0}\"\n}\n\n# Function to get installed version\nget_installed_version() {\n    local pkg=\"$1\"\n    dpkg"]
