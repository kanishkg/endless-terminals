[26.106158, "i", "cat > generate_report.py << 'EOF'\nimport datetime\nimport re\n\ndef parse_log_file(filename):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            # Parse: [TIMESTAMP] SERVICE_NAME | OLD_KEY_ID | NEW_KEY_ID | STATUS | ROTATED_BY\n            match = re.match(r'\\[([^\\]]+)\\]\\s+([^|]+)\\|([^|]+)\\|([^|]+)\\|([^|]+)\\|(.+)', line)\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                entries.append({\n                    'timestamp': timestamp.strip(),\n                    'service': service.strip(),\n                    'old_key': old_key.strip(),\n                    'new_key': new_key.strip(),\n                    'status': status.strip(),\n                    'rotated_by': rotated_by.strip()\n                })\n    return entries\n\n# Parse all log files\naws_entries = parse_log_file('aws-rotation.log')\ndb_entries = parse_log_file('db-rotat"]
[26.106287, "i", "ion.log')\napi_entries = parse_log_file('api-keys.log')\n\n# Sort alphabetically by service name\naws_entries.sort(key=lambda x: x['service'].lower())\ndb_entries.sort(key=lambda x: x['service'].lower())\napi_entries.sort(key=lambda x: x['service'].lower())\n\n# Calculate statistics\ndef calc_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = sum(1 for e in entries if e['status'] == 'FAILED')\n    return total, success, failed\n\naws_stats = calc_stats(aws_entries)\ndb_stats = calc_stats(db_entries)\napi_stats = calc_stats(api_entries)\n\ntotal_rotated = len(aws_entries) + len(db_entries) + len(api_entries)\n\n# Get current timestamp\nnow = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\n# Generate failed rotations list\nfailed_rotations = []\nfor e in aws_entries:\n    if e['status'] == 'FAILED':\n        failed_rotations.append((e['service'], 'AWS IAM'))\nfor e in db_entries:\n    if e['status'] == 'FAILED':\n        failed_rotations.append((e['service'], 'D"]
[26.106372, "i", "atabase'))\nfor e in api_entries:\n    if e['status'] == 'FAILED':\n        failed_rotations.append((e['service'], 'API Keys'))\n\n# Generate markdown\ndef generate_table_rows(entries):\n    rows = []\n    for e in entries:\n        rows.append(f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\")\n    return '\\n'.join(rows)\n\nreport = f\"\"\"# Credential Rotation Report\n\n**Generated:** {now}\n**Total Credentials Rotated:** {total_rotated}\n\n## Summary by Category\n\n| Category | Count | Success | Failed |\n|----------|-------|---------|--------|\n| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\n| Database | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\n| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\n\n## Detailed Rotation Log\n\n### AWS IAM Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n{generate_table_rows(aws_entries)}\n\n### Database Credentials\n\n| Service | Old Key ID | New "]
[26.106429, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\ratabase'))\r\nfor e in api_entries:\r\n    if e['status'] == 'FAILED':\r\n        failed_rotations.append((e['service'], 'API Keys'))\r\n\r\n# Generate markdown\r\ndef generate_table_rows(entries):\r\n    rows = []\r\n    for e in entries:\r\n        rows.append(f\""]
