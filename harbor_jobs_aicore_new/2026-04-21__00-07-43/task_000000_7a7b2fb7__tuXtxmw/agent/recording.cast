[294.525885, "o", "echo \"The following packages will be removed:\"\r\necho \"apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\"\r\necho \"\"\r\necho \"Dry run (no changes):\"\r\napt-get remove --dry-run apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\r\necho \"\"\r\necho \"Executing removal...\"\r\napt-get remove -y apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\r\n"]
[294.526057, "o", "\u001b[?2004h"]
[294.526088, "o", "user@dfe663bd4b25:~/migration$ "]
