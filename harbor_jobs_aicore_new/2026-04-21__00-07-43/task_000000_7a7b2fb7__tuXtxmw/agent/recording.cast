[66.252804, "i", "cat > /home/user/migration/analyze.py << 'SCRIPT'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport re\n\ndef get_direct_deps(package):\n    \"\"\"Get direct dependencies of a package\"\"\"\n    try:\n        result = subprocess.run(\n            ['apt-cache', 'depends', package],\n            capture_output=True, text=True, timeout=10\n        )\n        deps = set()\n        for line in result.stdout.split('\\n'):\n            if 'Depends:' in line or 'PreDepends:' in line:\n                # Extract package name, removing version constraints and <>\n                match = re.search(r'(?:Depends|PreDepends):\\s*<?([a-zA-Z0-9][a-zA-Z0-9+.-]*)>?', line)\n                if match:\n                    dep = match.group(1)\n                    if dep and not dep.startswith('<'):\n                        deps.add(dep)\n        return deps\n    except:\n        return set()\n\ndef get_deps_recursive(packages, max_depth=3):\n    \"\"\"Get all dependencies up to max_depth levels\"\"\"\n    all_deps = {}  # package -> set of packages that nee"]
[66.252954, "i", "d it\n    visited = set()\n    \n    def recurse(pkg, depth, required_by):\n        if depth > max_depth or pkg in visited:\n            return\n        visited.add(pkg)\n        deps = get_direct_deps(pkg)\n        for dep in deps:\n            if dep not in all_deps:\n                all_deps[dep] = set()\n            all_deps[dep].add(required_by)\n            recurse(dep, depth + 1, required_by)\n    \n    for pkg in packages:\n        visited.clear()\n        recurse(pkg, 1, pkg)\n    \n    return all_deps\n\ndef get_package_info(package):\n    \"\"\"Get installed version and size of a package\"\"\"\n    version = None\n    size_kb = 0\n    \n    # Try dpkg-query first for installed size\n    try:\n        result = subprocess.run(\n            ['dpkg-query', '-W', '-f=${Version}\\n${Installed-Size}\\n', package],\n            capture_output=True, text=True, timeout=10\n        )\n        if result.returncode == 0:\n            lines = result.stdout.strip().split('\\n')\n            if len(lines) >= 2:\n                version = lines[0]\n         "]
[66.252988, "i", "       try:\n                    size_kb = int(lines[1])\n                except:\n                    pass\n    except:\n        pass\n    \n    # Fallback to apt-cache show\n    if not version:\n        try:\n            result = subprocess.run(\n                ['apt-cache', 'show', package],\n                capture_output=True, text=True, timeout=10\n            )\n            for line in result.stdout.split('\\n'):\n                if line.startswith('Version:'):\n                    version = line.split(':', 1)[1].strip()\n                elif line.startswith('Installed-Size:'):\n                    try:\n                        size_kb = int(line.split(':', 1)[1].strip())\n                    except:\n                        pass\n        except:\n            pass\n    \n    return version or 'unknown', size_kb\n\ndef check_security_update(package):\n    \"\"\"Check if package has a security update available\"\"\"\n    try:\n        result = subprocess.run(\n            ['apt-cache', 'policy', package],\n            capture_output=True, te"]
