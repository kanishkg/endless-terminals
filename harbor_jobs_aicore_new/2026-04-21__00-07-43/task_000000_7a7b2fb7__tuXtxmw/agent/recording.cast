[66.26052, "o", "\u001b[?2004h> "]
[66.26055, "o", "    \r\n\u001b[?2004l\r"]
[66.260582, "o", "\u001b[?2004h> "]
[66.260679, "o", "    for pkg in packages:\r\n\u001b[?2004l\r"]
[66.260705, "o", "\u001b[?2004h"]
[66.260735, "o", "> "]
[66.260806, "o", "        visited.clear()\r\n\u001b[?2004l\r"]
[66.260837, "o", "\u001b[?2004h> "]
[66.260968, "o", "        recurse(pkg, 1, pkg)\r\n\u001b[?2004l\r"]
[66.261001, "o", "\u001b[?2004h> "]
[66.261034, "o", "    \r\n\u001b[?2004l\r"]
[66.261067, "o", "\u001b[?2004h> "]
[66.261129, "o", "    return all_deps\r\n\u001b[?2004l\r"]
[66.261162, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.261195, "o", "\u001b[?2004h> "]
[66.261325, "o", "def get_package_info(package):\r\n\u001b[?2004l\r"]
[66.261358, "o", "\u001b[?2004h> "]
[66.261575, "o", "    \"\"\"Get installed version and size of a package\"\"\"\r\n\u001b[?2004l\r"]
[66.261607, "o", "\u001b[?2004h> "]
[66.261686, "o", "    version = None\r\n\u001b[?2004l\r"]
[66.26172, "o", "\u001b[?2004h> "]
[66.261794, "o", "    size_kb = 0\r\n\u001b[?2004l\r"]
[66.261827, "o", "\u001b[?2004h> "]
[66.261862, "o", "    \r\n\u001b[?2004l\r"]
[66.261895, "o", "\u001b[?2004h> "]
[66.26208, "o", "    # Try dpkg-query first for installed size\r\n\u001b[?2004l\r"]
[66.262112, "o", "\u001b[?2004h> "]
[66.262154, "o", "    try:\r\n\u001b[?2004l\r"]
[66.262187, "o", "\u001b[?2004h> "]
[66.26232, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[66.262352, "o", "\u001b[?2004h> "]
[66.262677, "o", "            ['dpkg-query', '-W', '-f=${Version}\\n${Installed-Size}\\n', package],\r\n\u001b[?2004l\r"]
[66.262718, "o", "\u001b[?2004h> "]
[66.262948, "o", "            capture_output=True, text=True, timeout=10\r\n\u001b[?2004l\r"]
[66.262982, "o", "\u001b[?2004h> "]
[66.263023, "o", "        )\r\n"]
[66.263061, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[66.263216, "o", "        if result.returncode == 0:\r\n\u001b[?2004l\r"]
[66.263248, "o", "\u001b[?2004h> "]
[66.263445, "o", "            lines = result.stdout.strip().split('\\n')\r\n\u001b[?2004l\r"]
[66.263477, "o", "\u001b[?2004h> "]
[66.263615, "o", "            if len(lines) >= 2:\r\n\u001b[?2004l\r"]
[66.26365, "o", "\u001b[?2004h> "]
[66.26379, "o", "                version = lines[0]\r\n\u001b[?2004l\r"]
[66.263817, "o", "\u001b[?2004h"]
[66.263845, "o", "> "]
[66.263911, "o", "                try:\r\n\u001b[?2004l\r"]
[66.263959, "o", "\u001b[?2004h> "]
[66.264128, "o", "                    size_kb = int(lines[1])\r\n\u001b[?2004l\r"]
[66.264163, "o", "\u001b[?2004h> "]
[66.26426, "o", "                except:\r\n\u001b[?2004l\r"]
[66.264295, "o", "\u001b[?2004h> "]
[66.264398, "o", "                    pass\r\n\u001b[?2004l\r"]
[66.264432, "o", "\u001b[?2004h> "]
[66.264484, "o", "    except:\r\n\u001b[?2004l\r"]
[66.264519, "o", "\u001b[?2004h> "]
[66.264571, "o", "        pass\r\n\u001b[?2004l\r"]
[66.264606, "o", "\u001b[?2004h> "]
[66.26464, "o", "    \r\n\u001b[?2004l\r"]
[66.264675, "o", "\u001b[?2004h> "]
[66.264799, "o", "    # Fallback to apt-cache show\r\n\u001b[?2004l\r"]
[66.264833, "o", "\u001b[?2004h> "]
[66.264925, "o", "    if not version:\r\n\u001b[?2004l\r"]
[66.26496, "o", "\u001b[?2004h> "]
[66.265012, "o", "        try:\r\n\u001b[?2004l\r"]
[66.265043, "o", "\u001b[?2004h> "]
[66.265193, "o", "            result = subprocess.run(\r\n\u001b[?2004l\r"]
[66.265227, "o", "\u001b[?2004h> "]
[66.265422, "o", "                ['apt-cache', 'show', package],\r\n\u001b[?2004l\r"]
[66.265456, "o", "\u001b[?2004h> "]
[66.26569, "o", "                capture_output=True, text=True, timeout=10\r\n\u001b[?2004l\r"]
[66.265726, "o", "\u001b[?2004h> "]
[66.26578, "o", "            )\r\n"]
[66.265815, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[66.266029, "o", "            for line in result.stdout.split('\\n'):\r\n\u001b[?2004l\r"]
[66.266064, "o", "\u001b[?2004h> "]
[66.266258, "o", "                if line.startswith('Version:'):\r\n\u001b[?2004l\r"]
[66.266293, "o", "\u001b[?2004h> "]
[66.266513, "o", "                    version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[66.266542, "o", "\u001b[?2004h> "]
[66.266703, "o", "                elif line.startswith('Installed-Size:'):\r\n\u001b[?2004l\r"]
[66.266735, "o", "\u001b[?2004h> "]
[66.266803, "o", "                    try:\r\n\u001b[?2004l\r"]
[66.266834, "o", "\u001b[?2004h> "]
[66.267032, "o", "                        size_kb = int(line.split(':', 1)[1].strip())\r\n\u001b[?2004l\r"]
[66.267066, "o", "\u001b[?2004h> "]
[66.267141, "o", "                    except:\r\n\u001b[?2004l\r"]
[66.267183, "o", "\u001b[?2004h> "]
[66.267262, "o", "                        pass\r\n\u001b[?2004l\r"]
[66.26729, "o", "\u001b[?2004h"]
[66.267322, "o", "> "]
[66.267353, "o", "        except:\r\n\u001b[?2004l\r"]
[66.267385, "o", "\u001b[?2004h> "]
[66.267416, "o", "            pass\r\n\u001b[?2004l\r"]
[66.267449, "o", "\u001b[?2004h> "]
[66.267481, "o", "    \r\n\u001b[?2004l\r"]
[66.267514, "o", "\u001b[?2004h> "]
[66.26761, "o", "    return version or 'unknown', size_kb\r\n\u001b[?2004l\r"]
[66.267645, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.267679, "o", "\u001b[?2004h> "]
[66.267776, "o", "def check_security_update(package):\r\n\u001b[?2004l\r"]
[66.267808, "o", "\u001b[?2004h> "]
[66.267981, "o", "    \"\"\"Check if package has a security update available\"\"\"\r\n\u001b[?2004l\r"]
[66.268014, "o", "\u001b[?2004h> "]
[66.268048, "o", "    try:\r\n\u001b[?2004l\r"]
[66.26808, "o", "\u001b[?2004h> "]
[66.268162, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[66.268196, "o", "\u001b[?2004h> "]
[66.268322, "o", "            ['apt-cache', 'policy', package],\r\n\u001b[?2004l\r"]
[66.268356, "o", "\u001b[?2004h> "]
[66.268503, "o", "            capture_output=True, text=True, timeout=10\r\n\u001b[?2004l\r"]
[66.268538, "o", "\u001b[?2004h> "]
[66.268569, "o", "        )\r\n\u001b[?2004l\r"]
[66.268602, "o", "\u001b[?2004h> "]
[66.268685, "o", "        output = result.stdout\r\n\u001b[?2004l\r"]
[66.268718, "o", "\u001b[?2004h> "]
[66.268888, "o", "        # Check if there's a security pocket version available\r\n\u001b[?2004l\r"]
[66.268931, "o", "\u001b[?2004h> "]
[66.269027, "o", "        if '-security' in output:\r\n\u001b[?2004l\r"]
[66.269063, "o", "\u001b[?2004h> "]
[66.26918, "o", "            # Parse installed vs candidate\r\n\u001b[?2004l\r"]
[66.269214, "o", "\u001b[?2004h> "]
[66.269295, "o", "            installed = None\r\n\u001b[?2004l\r"]
[66.269329, "o", "\u001b[?2004h> "]
[66.269408, "o", "            candidate = None\r\n\u001b[?2004l\r"]
[66.269442, "o", "\u001b[?2004h> "]
[66.269562, "o", "            for line in output.split('\\n'):\r\n\u001b[?2004l\r"]
[66.269597, "o", "\u001b[?2004h> "]
[66.269701, "o", "                if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[66.269733, "o", "\u001b[?2004h> "]
[66.269902, "o", "                    installed = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[66.269947, "o", "\u001b[?2004h> "]
[66.270064, "o", "                elif 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[66.270097, "o", "\u001b[?2004h> "]
[66.270267, "o", "                    candidate = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[66.270299, "o", "\u001b[?2004h> "]
[66.27048, "o", "            if installed and candidate and installed != candidate:\r\n\u001b[?2004l\r"]
[66.270514, "o", "\u001b[?2004h> "]
[66.270669, "o", "                # Check if candidate comes from security\r\n\u001b[?2004l\r"]
[66.270704, "o", "\u001b[?2004h> "]
[66.270971, "o", "                if '-security' in output.split(candidate)[1] if candidate in output else False:\r\n\u001b[?2004l\r"]
[66.271005, "o", "\u001b[?2004h> "]
[66.271092, "o", "                    return True\r\n\u001b[?2004l\r"]
[66.271124, "o", "\u001b[?2004h> "]
[66.271191, "o", "        return False\r\n\u001b[?2004l\r"]
[66.271226, "o", "\u001b[?2004h> "]
[66.27126, "o", "    except:\r\n\u001b[?2004l\r"]
[66.271294, "o", "\u001b[?2004h> "]
[66.27135, "o", "        return False\r\n\u001b[?2004l\r"]
[66.271384, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.271418, "o", "\u001b[?2004h> "]
[66.271477, "o", "# Read package lists\r\n\u001b[?2004l\r"]
[66.271509, "o", "\u001b[?2004h> "]
[66.271681, "o", "with open('/home/user/migration/installed_packages.txt') as f:\r\n\u001b[?2004l\r"]
[66.271713, "o", "\u001b[?2004h> "]
[66.271888, "o", "    installed = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[66.271932, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.271966, "o", "\u001b[?2004h> "]
[66.272131, "o", "with open('/home/user/migration/required_packages.txt') as f:\r\n\u001b[?2004l\r"]
[66.272166, "o", "\u001b[?2004h> "]
[66.272333, "o", "    required = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[66.27237, "o", "\u001b[?2004h"]
[66.272404, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.272536, "o", "# Find extra packages (installed but not required)\r\n\u001b[?2004l\r"]
[66.27257, "o", "\u001b[?2004h> "]
[66.272647, "o", "extra = installed - required\r\n\u001b[?2004l\r"]
[66.272681, "o", "\u001b[?2004h> "]
[66.272713, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.272882, "o", "# Get all dependencies of required packages (up to 3 levels)\r\n\u001b[?2004l\r"]
[66.272925, "o", "\u001b[?2004h> "]
[66.273081, "o", "print(\"Analyzing dependencies (up to 3 levels deep)...\")\r\n\u001b[?2004l\r"]
[66.273114, "o", "\u001b[?2004h> "]
[66.273258, "o", "dep_map = get_deps_recursive(required, max_depth=3)\r\n\u001b[?2004l\r"]
[66.273293, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.273326, "o", "\u001b[?2004h> "]
[66.273401, "o", "# Categorize extra packages\r\n\u001b[?2004l\r"]
[66.273436, "o", "\u001b[?2004h> "]
[66.273478, "o", "removable = []\r\n\u001b[?2004l\r"]
[66.273511, "o", "\u001b[?2004h> "]
[66.27358, "o", "dependency_protected = []\r\n\u001b[?2004l\r"]
[66.273614, "o", "\u001b[?2004h> "]
[66.273646, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.273721, "o", "for pkg in sorted(extra):\r\n\u001b[?2004l\r"]
[66.273753, "o", "\u001b[?2004h> "]
[66.273818, "o", "    if pkg in dep_map:\r\n\u001b[?2004l\r"]
[66.273852, "o", "\u001b[?2004h> "]
[66.273966, "o", "        dependency_protected.append({\r\n\u001b[?2004l\r"]
[66.274002, "o", "\u001b[?2004h> "]
[66.274068, "o", "            'name': pkg,\r\n\u001b[?2004l\r"]
[66.274101, "o", "\u001b[?2004h> "]
[66.274249, "o", "            'required_by': sorted(list(dep_map[pkg]))\r\n\u001b[?2004l\r"]
[66.274283, "o", "\u001b[?2004h> "]
[66.274318, "o", "        })\r\n\u001b[?2004l\r"]
[66.27435, "o", "\u001b[?2004h> "]
[66.274383, "o", "    else:\r\n\u001b[?2004l\r"]
[66.274416, "o", "\u001b[?2004h> "]
[66.274539, "o", "        version, size_kb = get_package_info(pkg)\r\n\u001b[?2004l\r"]
[66.274573, "o", "\u001b[?2004h> "]
[66.274706, "o", "        has_security = check_security_update(pkg)\r\n\u001b[?2004l\r"]
[66.274738, "o", "\u001b[?2004h> "]
[66.274813, "o", "        removable.append({\r\n\u001b[?2004l\r"]
[66.274847, "o", "\u001b[?2004h> "]
[66.274927, "o", "            'name': pkg,\r\n\u001b[?2004l\r"]
[66.274965, "o", "\u001b[?2004h> "]
[66.275072, "o", "            'installed_version': version,\r\n\u001b[?2004l\r"]
[66.275105, "o", "\u001b[?2004h> "]
[66.275201, "o", "            'size_kb': size_kb,\r\n\u001b[?2004l\r"]
[66.275234, "o", "\u001b[?2004h> "]
[66.275363, "o", "            'has_security_update': has_security\r\n\u001b[?2004l\r"]
[66.275397, "o", "\u001b[?2004h> "]
[66.275431, "o", "        })\r\n\u001b[?2004l\r"]
[66.275465, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.275498, "o", "\u001b[?2004h> "]
[66.275537, "o", "# Sort results\r\n\u001b[?2004l\r"]
[66.27557, "o", "\u001b[?2004h> "]
[66.275679, "o", "removable.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[66.275715, "o", "\u001b[?2004h> "]
[66.27585, "o", "dependency_protected.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[66.275883, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.275927, "o", "\u001b[?2004h> "]
[66.275981, "o", "# Calculate totals\r\n\u001b[?2004l\r"]
[66.276016, "o", "\u001b[?2004h> "]
[66.276179, "o", "total_space_savings = sum(p['size_kb'] for p in removable)\r\n\u001b[?2004l\r"]
[66.276213, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.276244, "o", "\u001b[?2004h> "]
[66.276288, "o", "# Build report\r\n\u001b[?2004l\r"]
[66.276321, "o", "\u001b[?2004h> "]
[66.276355, "o", "report = {\r\n\u001b[?2004l\r"]
[66.276386, "o", "\u001b[?2004h> "]
[66.276435, "o", "    'summary': {\r\n\u001b[?2004l\r"]
[66.276469, "o", "\u001b[?2004h> "]
[66.276579, "o", "        'total_installed': len(installed),\r\n\u001b[?2004l\r"]
[66.276613, "o", "\u001b[?2004h> "]
[66.276722, "o", "        'total_required': len(required),\r\n\u001b[?2004l\r"]
[66.276756, "o", "\u001b[?2004h> "]
[66.276873, "o", "        'removable_count': len(removable),\r\n\u001b[?2004l\r"]
[66.276905, "o", "\u001b[?2004h> "]
[66.277076, "o", "        'kept_as_dependencies': len(dependency_protected),\r\n\u001b[?2004l\r"]
[66.277111, "o", "\u001b[?2004h> "]
[66.277257, "o", "        'total_space_savings_kb': total_space_savings\r\n\u001b[?2004l\r"]
[66.277291, "o", "\u001b[?2004h> "]
[66.277321, "o", "    },\r\n\u001b[?2004l\r"]
[66.277355, "o", "\u001b[?2004h> "]
[66.277438, "o", "    'removable_packages': removable,\r\n\u001b[?2004l\r"]
[66.277469, "o", "\u001b[?2004h> "]
[66.277602, "o", "    'dependency_protected': dependency_protected\r\n\u001b[?2004l\r"]
[66.277635, "o", "\u001b[?2004h> "]
[66.277667, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.277699, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[66.277734, "o", "> "]
[66.277768, "o", "# Write JSON report\r\n\u001b[?2004l\r"]
[66.277802, "o", "\u001b[?2004h> "]
[66.277985, "o", "with open('/home/user/migration/removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[66.27802, "o", "\u001b[?2004h> "]
[66.278109, "o", "    json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[66.278142, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.278177, "o", "\u001b[?2004h> "]
[66.27836, "o", "print(f\"Report written to /home/user/migration/removal_report.json\")\r\n\u001b[?2004l\r"]
[66.278393, "o", "\u001b[?2004h> "]
[66.278511, "o", "print(f\"Total installed: {len(installed)}\")\r\n\u001b[?2004l\r"]
[66.278545, "o", "\u001b[?2004h> "]
[66.278659, "o", "print(f\"Total required: {len(required)}\")\r\n\u001b[?2004l\r"]
[66.278693, "o", "\u001b[?2004h> "]
[66.278795, "o", "print(f\"Removable: {len(removable)}\")\r\n\u001b[?2004l\r"]
[66.278827, "o", "\u001b[?2004h> "]
[66.279018, "o", "print(f\"Protected as dependencies: {len(dependency_protected)}\")\r\n\u001b[?2004l\r"]
[66.279052, "o", "\u001b[?2004h> "]
[66.279194, "o", "print(f\"Space savings: {total_space_savings} KB\")\r\n\u001b[?2004l\r"]
[66.279227, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[66.279259, "o", "\u001b[?2004h> "]
[66.279322, "o", "# Create removal script\r\n\u001b[?2004l\r"]
[66.279351, "o", "\u001b[?2004h"]
[66.279384, "o", "> "]
[66.279418, "o", "if removable:\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.279451, "o", "> "]
