[20.918523, "i", "sqlite3 employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(d.avg_sal, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_sal FROM employees GROUP BY department) d ON e.department = d.department WHERE e.salary > d.avg_sal * 1.2 ORDER BY e.department ASC, e.salary DESC;\"\n"]
