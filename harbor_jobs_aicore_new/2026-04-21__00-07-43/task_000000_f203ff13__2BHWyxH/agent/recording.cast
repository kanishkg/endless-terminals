[53.507912, "i", "python3 << 'EOF'\nimport sqlite3\nimport json\nfrom collections import OrderedDict\n\nconn = sqlite3.connect('employees.db')\ncursor = conn.cursor()\n\ncursor.execute(\"\"\"\n    SELECT department, COUNT(*) as count, ROUND(AVG(salary), 2) as avg_salary,\n           MIN(hire_date) as oldest_hire, MAX(hire_date) as newest_hire\n    FROM employees GROUP BY department ORDER BY department\n\"\"\")\n\nresult = OrderedDict()\nfor row in cursor.fetchall():\n    dept, count, avg_sal, oldest, newest = row\n    result[dept] = OrderedDict([\n        (\"count\", count),\n        (\"avg_salary\", avg_sal),\n        (\"oldest_hire\", oldest),\n        (\"newest_hire\", newest)\n    ])\n\nconn.close()\n\nwith open('dept_summary.json', 'w') as f:\n    json.dump(result, f, indent=2)\n\nprint(\"Done\")\nEOF\n"]
