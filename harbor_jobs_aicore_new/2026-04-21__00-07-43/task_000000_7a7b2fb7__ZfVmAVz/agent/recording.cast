[33.983383, "i", "cat > /home/user/migration/analyze.py << 'SCRIPT'\nimport subprocess\nimport json\nimport re\n\n# Read package lists\nwith open('installed_packages.txt') as f:\n    installed = [line.strip() for line in f if line.strip()]\n\nwith open('required_packages.txt') as f:\n    required = [line.strip() for line in f if line.strip()]\n\nprint(f\"Installed: {len(installed)} packages\")\nprint(f\"Required: {len(required)} packages\")\n\n# Find packages not in required\nextra_packages = [p for p in installed if p not in required]\nprint(f\"Extra packages: {len(extra_packages)}\")\nprint(f\"Extra: {extra_packages}\")\n\n# Get dependencies of required packages up to 3 levels deep\ndef get_dependencies(package, depth=3, visited=None):\n    if visited is None:\n        visited = set()\n    if depth == 0 or package in visited:\n        return set()\n    visited.add(package)\n    deps = set()\n    try:\n        result = subprocess.run(['apt-cache', 'depends', package], \n                              capture_output=True, text=True, timeout=10)\n        for line in "]
[33.983515, "i", "result.stdout.split('\\n'):\n            line = line.strip()\n            if line.startswith('Depends:') or line.startswith('PreDepends:'):\n                dep = line.split(':', 1)[1].strip()\n                # Remove version constraints and alternatives\n                dep = dep.split()[0].strip('<>=')\n                if dep and not dep.startswith('<'):\n                    deps.add(dep)\n                    # Recurse for transitive deps\n                    deps.update(get_dependencies(dep, depth-1, visited))\n    except Exception as e:\n        print(f\"Error getting deps for {package}: {e}\")\n    return deps\n\nprint(\"\\nGathering dependencies of required packages (3 levels deep)...\")\nall_required_deps = set()\nfor pkg in required:\n    print(f\"  Checking {pkg}...\")\n    deps = get_dependencies(pkg, depth=3)\n    all_required_deps.update(deps)\n\nprint(f\"\\nTotal dependencies found: {len(all_required_deps)}\")\n\n# Determine which extra packages are protected as dependencies\ndependency_protected = []\nremovable = []\n\nfor pkg in e"]
[33.983533, "i", "xtra_packages:\n    if pkg in all_required_deps:\n        # Find which required packages need this\n        required_by = []\n        for req in required:\n            deps = get_dependencies(req, depth=3)\n            if pkg in deps:\n                required_by.append(req)\n        dependency_protected.append({'name': pkg, 'required_by': sorted(required_by)})\n    else:\n        removable.append(pkg)\n\nprint(f\"\\nRemovable: {len(removable)}\")\nprint(f\"Protected as deps: {len(dependency_protected)}\")\n\n# Get package info (size, version, security updates)\ndef get_package_info(package):\n    info = {'name': package, 'installed_version': 'unknown', 'size_kb': 0, 'has_security_update': False}\n    \n    # Get installed version and size\n    try:\n        result = subprocess.run(['dpkg-query', '-W', '-f', '${Version}\\t${Installed-Size}', package],\n                              capture_output=True, text=True, timeout=10)\n        if result.returncode == 0:\n            parts = result.stdout.strip().split('\\t')\n            if len(parts"]
[33.983663, "i", ") >= 1:\n                info['installed_version'] = parts[0]\n            if len(parts) >= 2:\n                try:\n                    info['size_kb'] = int(parts[1])\n                except:\n                    pass\n    except Exception as e:\n        print(f\"Error getting dpkg info for {package}: {e}\")\n    \n    # Check for security updates\n    try:\n        result = subprocess.run(['apt-cache', 'policy', package],\n                              capture_output=True, text=True, timeout=10)\n        output = result.stdout\n        if 'security' in output.lower():\n            # Check if there's a newer version in security pocket\n            lines = output.split('\\n')\n            installed_ver = None\n            candidate_ver = None\n            has_security_source = False\n            for line in lines:\n                if 'Installed:' in line:\n                    installed_ver = line.split(':')[1].strip()\n                elif 'Candidate:' in line:\n                    candidate_ver = line.split(':')[1].strip()\n          "]
[33.983674, "o", "cat > /home/user/migration/analyze.py << 'SCRIPT'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[33.983719, "i", "      elif 'security' in line.lower() and '***' not in line:\n                    has_security_source = True\n            if installed_ver and candidate_ver and installed_ver != candidate_ver and has_security_source:\n                info['has_security_update'] = True\n    except Exception as e:\n        print(f\"Error checking security for {package}: {e}\")\n    \n    return info\n\nprint(\"\\nGathering package info...\")\nremovable_info = []\ntotal_size = 0\nfor pkg in sorted(removable):\n    print(f\"  Getting info for {pkg}...\")\n    info = get_package_info(pkg)\n    removable_info.append(info)\n    total_size += info['size_kb']\n\n# Build report\nreport = {\n    'summary': {\n        'total_installed': len(installed),\n        'total_required': len(required),\n        'removable_count': len(removable),\n        'kept_as_dependencies': len(dependency_protected),\n        'total_space_savings_kb': total_size\n    },\n    'removable_packages': removable_info,\n    'dependency_protected': sorted(dependency_protected, key=lambda x: x['name'])"]
[33.983753, "o", "import subprocess\r\n\u001b[?2004l\r"]
[33.983788, "i", "\n}\n\n# Write JSON report\nwith open('removal_report.json', 'w') as f:\n    json.dump(report, f, indent=2)\n\nprint(f\"\\nReport written to removal_report.json\")\n\n# Create removal script\nif removable:\n    pkg_list = ' '.join(sorted(removable))\n    script = f\"\"\"#!/bin/bash\n# Auto-generated package removal script for container migration\n# Removes {len(removable)} unnecessary packages\n\necho \"The following packages will be removed:\"\necho \"{pkg_list}\"\necho \"\"\necho \"Dry run (no changes):\" \napt-get remove --dry-run {pkg_list}\necho \"\"\necho \"Executing removal...\"\napt-get remove -y {pkg_list}\n\"\"\"\n    with open('remove_packages.sh', 'w') as f:\n        f.write(script)\n    subprocess.run(['chmod', '+x', 'remove_packages.sh'])\n    print(\"Removal script written to remove_packages.sh\")\n\nprint(\"\\nDone!\")\nSCRIPT\n"]
