[33.99801, "o", "                    pass\r\n\u001b[?2004l\r"]
[33.998039, "o", "\u001b[?2004h> "]
[33.998119, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[33.99815, "o", "\u001b[?2004h> "]
[33.998319, "o", "        print(f\"Error getting dpkg info for {package}: {e}\")\r\n\u001b[?2004l\r"]
[33.99835, "o", "\u001b[?2004h> "]
[33.998381, "o", "    \r\n\u001b[?2004l\r"]
[33.998412, "o", "\u001b[?2004h> "]
[33.998495, "o", "    # Check for security updates\r\n\u001b[?2004l\r"]
[33.998525, "o", "\u001b[?2004h> "]
[33.998553, "o", "    try:\r\n\u001b[?2004l\r"]
[33.998603, "o", "\u001b[?2004h> "]
[33.998775, "o", "        result = subprocess.run(['apt-cache', 'policy', package],\r\n\u001b[?2004l\r"]
[33.998806, "o", "\u001b[?2004h> "]
[33.99901, "o", "                              capture_output=True, text=True, timeout=10)\r\n\u001b[?2004l\r"]
[33.99904, "o", "\u001b[?2004h> "]
[33.999129, "o", "        output = result.stdout\r\n\u001b[?2004l\r"]
[33.999159, "o", "\u001b[?2004h> "]
[33.999276, "o", "        if 'security' in output.lower():\r\n\u001b[?2004l\r"]
[33.999306, "o", "\u001b[?2004h> "]
[33.999491, "o", "            # Check if there's a newer version in security pocket\r\n\u001b[?2004l\r"]
[33.999523, "o", "\u001b[?2004h> "]
[33.99964, "o", "            lines = output.split('\\n')\r\n\u001b[?2004l\r"]
[33.999672, "o", "\u001b[?2004h> "]
[33.999761, "o", "            installed_ver = None\r\n\u001b[?2004l\r"]
[33.999793, "o", "\u001b[?2004h> "]
[33.999885, "o", "            candidate_ver = None\r\n\u001b[?2004l\r"]
[33.999917, "o", "\u001b[?2004h> "]
[34.000028, "o", "            has_security_source = False\r\n\u001b[?2004l\r"]
[34.000058, "o", "\u001b[?2004h> "]
[34.000145, "o", "            for line in lines:\r\n\u001b[?2004l\r"]
[34.000165, "o", "\u001b[?2004h"]
[34.000201, "o", "> "]
[34.00029, "o", "                if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[34.000321, "o", "\u001b[?2004h> "]
[34.000494, "o", "                    installed_ver = line.split(':')[1].strip()\r\n\u001b[?2004l\r"]
[34.000527, "o", "\u001b[?2004h> "]
[34.000655, "o", "                elif 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[34.000687, "o", "\u001b[?2004h> "]
[34.000867, "o", "                    candidate_ver = line.split(':')[1].strip()\r\n\u001b[?2004l\r"]
[34.0009, "o", "\u001b[?2004h> "]
[34.001093, "o", "                elif 'security' in line.lower() and '***' not in line:\r\n\u001b[?2004l\r"]
[34.001127, "o", "\u001b[?2004h> "]
[34.001258, "o", "                    has_security_source = True\r\n\u001b[?2004l\r"]
[34.001286, "o", "\u001b[?2004h"]
[34.001314, "o", "> "]
[34.001597, "o", "            if installed_ver and candidate_ver and installed_ver != candidate_ver and has_security_source:\r\n\u001b[?2004l\r"]
[34.001619, "o", "\u001b[?2004h> "]
[34.001766, "o", "                info['has_security_update'] = True\r\n\u001b[?2004l\r"]
[34.001797, "o", "\u001b[?2004h> "]
[34.001872, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[34.001901, "o", "\u001b[?2004h> "]
[34.002071, "o", "        print(f\"Error checking security for {package}: {e}\")\r\n\u001b[?2004l\r"]
[34.002103, "o", "\u001b[?2004h> "]
[34.002134, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[34.002164, "o", "> "]
[34.002196, "o", "    return info\r\n\u001b[?2004l\r"]
[34.002226, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.002256, "o", "\u001b[?2004h> "]
[34.002361, "o", "print(\"\\nGathering package info...\")\r\n\u001b[?2004l\r"]
[34.002391, "o", "\u001b[?2004h> "]
[34.00245, "o", "removable_info = []\r\n\u001b[?2004l\r"]
[34.002482, "o", "\u001b[?2004h> "]
[34.002527, "o", "total_size = 0\r\n\u001b[?2004l\r"]
[34.002558, "o", "\u001b[?2004h> "]
[34.002653, "o", "for pkg in sorted(removable):\r\n\u001b[?2004l\r"]
[34.002686, "o", "\u001b[?2004h> "]
[34.002802, "o", "    print(f\"  Getting info for {pkg}...\")\r\n\u001b[?2004l\r"]
[34.002833, "o", "\u001b[?2004h> "]
[34.002927, "o", "    info = get_package_info(pkg)\r\n\u001b[?2004l\r"]
[34.002959, "o", "\u001b[?2004h> "]
[34.00305, "o", "    removable_info.append(info)\r\n\u001b[?2004l\r"]
[34.003083, "o", "\u001b[?2004h> "]
[34.003179, "o", "    total_size += info['size_kb']\r\n\u001b[?2004l\r"]
[34.003211, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.003242, "o", "\u001b[?2004h> "]
[34.003288, "o", "# Build report\r\n\u001b[?2004l\r"]
[34.003319, "o", "\u001b[?2004h> "]
[34.003351, "o", "report = {\r\n\u001b[?2004l\r"]
[34.003381, "o", "\u001b[?2004h> "]
[34.00343, "o", "    'summary': {\r\n\u001b[?2004l\r"]
[34.003461, "o", "\u001b[?2004h> "]
[34.003593, "o", "        'total_installed': len(installed),\r\n\u001b[?2004l\r"]
[34.003625, "o", "\u001b[?2004h> "]
[34.00374, "o", "        'total_required': len(required),\r\n\u001b[?2004l\r"]
[34.003772, "o", "\u001b[?2004h> "]
[34.003892, "o", "        'removable_count': len(removable),\r\n\u001b[?2004l\r"]
[34.003925, "o", "\u001b[?2004h> "]
[34.004086, "o", "        'kept_as_dependencies': len(dependency_protected),\r\n\u001b[?2004l\r"]
[34.004118, "o", "\u001b[?2004h> "]
[34.004241, "o", "        'total_space_savings_kb': total_size\r\n\u001b[?2004l\r"]
[34.004273, "o", "\u001b[?2004h> "]
[34.004304, "o", "    },\r\n\u001b[?2004l\r"]
[34.004338, "o", "\u001b[?2004h> "]
[34.004441, "o", "    'removable_packages': removable_info,\r\n\u001b[?2004l\r"]
[34.004472, "o", "\u001b[?2004h> "]
[34.004707, "o", "    'dependency_protected': sorted(dependency_protected, key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[34.004739, "o", "\u001b[?2004h> "]
[34.00477, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[34.004802, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[34.004839, "o", "> "]
[34.004878, "o", "# Write JSON report\r\n\u001b[?2004l\r"]
[34.004908, "o", "\u001b[?2004h"]
[34.00494, "o", "> "]
[34.005034, "o", "with open('removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[34.005065, "o", "\u001b[?2004h> "]
[34.005163, "o", "    json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[34.005195, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.005225, "o", "\u001b[?2004h> "]
[34.005367, "o", "print(f\"\\nReport written to removal_report.json\")\r\n\u001b[?2004l\r"]
[34.005399, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.005431, "o", "\u001b[?2004h> "]
[34.005504, "o", "# Create removal script\r\n\u001b[?2004l\r"]
[34.005533, "o", "\u001b[?2004h> "]
[34.005587, "o", "if removable:\r\n\u001b[?2004l\r"]
[34.005618, "o", "\u001b[?2004h"]
[34.005645, "o", "> "]
[34.005739, "o", "    pkg_list = ' '.join(sorted(removable))\r\n\u001b[?2004l\r"]
[34.005769, "o", "\u001b[?2004h> "]
[34.005854, "o", "    script = f\"\"\"#!/bin/bash\r\n\u001b[?2004l\r"]
[34.005885, "o", "\u001b[?2004h> "]
[34.006063, "o", "# Auto-generated package removal script for container migration\r\n\u001b[?2004l\r"]
[34.006093, "o", "\u001b[?2004h> "]
[34.006227, "o", "# Removes {len(removable)} unnecessary packages\r\n\u001b[?2004l\r"]
[34.006258, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.006289, "o", "\u001b[?2004h> "]
[34.006421, "o", "echo \"The following packages will be removed:\"\r\n\u001b[?2004l\r"]
[34.006449, "o", "\u001b[?2004h> "]
[34.006502, "o", "echo \"{pkg_list}\"\r\n\u001b[?2004l\r"]
[34.006533, "o", "\u001b[?2004h> "]
[34.006562, "o", "echo \"\"\r\n\u001b[?2004l\r"]
[34.006615, "o", "\u001b[?2004h> "]
[34.006683, "o", "echo \"Dry run (no changes):\" \r\n\u001b[?2004l\r"]
[34.006703, "o", "\u001b[?2004h"]
[34.006737, "o", "> "]
[34.006815, "o", "apt-get remove --dry-run {pkg_list}\r\n\u001b[?2004l\r"]
[34.006844, "o", "\u001b[?2004h> "]
[34.006875, "o", "echo \"\"\r\n\u001b[?2004l\r"]
[34.006908, "o", "\u001b[?2004h> "]
[34.00698, "o", "echo \"Executing removal...\"\r\n\u001b[?2004l\r"]
[34.007011, "o", "\u001b[?2004h> "]
[34.007093, "o", "apt-get remove -y {pkg_list}\r\n\u001b[?2004l\r"]
[34.007124, "o", "\u001b[?2004h> "]
[34.007157, "o", "\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[34.007188, "o", "> "]
[34.007298, "o", "    with open('remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[34.007327, "o", "\u001b[?2004h> "]
[34.007396, "o", "        f.write(script)\r\n\u001b[?2004l\r"]
[34.007428, "o", "\u001b[?2004h> "]
[34.007601, "o", "    subprocess.run(['chmod', '+x', 'remove_packages.sh'])\r\n\u001b[?2004l\r"]
[34.007641, "o", "\u001b[?2004h"]
[34.007667, "o", "> "]
[34.007793, "o", "    print(\"Removal script written to remove_packages.sh\")\r\n\u001b[?2004l\r"]
[34.007825, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.007856, "o", "\u001b[?2004h> "]
[34.007907, "o", "print(\"\\nDone!\")\r\n\u001b[?2004l\r"]
[34.007938, "o", "\u001b[?2004h> "]
[34.007971, "o", "SCRIPT\r\n\u001b[?2004l\r"]
[34.0126, "o", "\u001b[?2004h"]
[34.012631, "o", "user@e1514625bf70:~/migration$ "]
[34.970464, "i", "python3 /home/user/migration/analyze.py\n"]
