[33.116089, "o", "def compute_hash(record):\r\n\u001b[?2004l\r"]
[33.11612, "o", "\u001b[?2004h> "]
[33.116255, "o", "    \"\"\"Compute SHA-256 hash of canonical form\"\"\"\r\n\u001b[?2004l\r"]
[33.116286, "o", "\u001b[?2004h> "]
[33.116429, "o", "    amount_formatted = f\"{record['amount']:.2f}\"\r\n\u001b[?2004l\r"]
[33.116453, "o", "\u001b[?2004h> "]
[33.116884, "o", "    canonical = f\"{record['transaction_id']}|{record['timestamp']}|{record['account_id']}|{amount_formatted}|{record['currency']}|{record['status']}\"\r\n\u001b[?2004l\r"]
[33.116917, "o", "\u001b[?2004h> "]
[33.117103, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[33.117133, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.117166, "o", "\u001b[?2004h> "]
[33.117249, "o", "def truncate(s, max_len=200):\r\n\u001b[?2004l\r"]
[33.117283, "o", "\u001b[?2004h> "]
[33.117415, "o", "    \"\"\"Truncate string to max_len characters\"\"\"\r\n\u001b[?2004l\r"]
[33.117449, "o", "\u001b[?2004h> "]
[33.117587, "o", "    return s[:max_len] if len(s) > max_len else s\r\n\u001b[?2004l\r"]
[33.11762, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.117651, "o", "\u001b[?2004h> "]
[33.117691, "o", "def main():\r\n\u001b[?2004l\r"]
[33.117734, "o", "\u001b[?2004h> "]
[33.117793, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[33.117821, "o", "\u001b[?2004h> "]
[33.117872, "o", "    errors = []\r\n\u001b[?2004l\r"]
[33.117903, "o", "\u001b[?2004h> "]
[33.117963, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[33.118005, "o", "\u001b[?2004h> "]
[33.118087, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[33.11812, "o", "\u001b[?2004h> "]
[33.118199, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[33.118231, "o", "\u001b[?2004h> "]
[33.11831, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[33.118344, "o", "\u001b[?2004h> "]
[33.118419, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[33.118451, "o", "\u001b[?2004h> "]
[33.118481, "o", "    }\r\n\u001b[?2004l\r"]
[33.118514, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[33.118544, "o", "\u001b[?2004h> "]
[33.118778, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[33.11881, "o", "\u001b[?2004h> "]
[33.118841, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.118874, "o", "> "]
[33.11896, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[33.118994, "o", "\u001b[?2004h> "]
[33.119122, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[33.119155, "o", "\u001b[?2004h> "]
[33.119268, "o", "            raw_line = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[33.119302, "o", "\u001b[?2004h> "]
[33.119341, "o", "            \r\n\u001b[?2004l\r"]
[33.119375, "o", "\u001b[?2004h> "]
[33.119458, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[33.119492, "o", "\u001b[?2004h> "]
[33.119539, "o", "            try:\r\n\u001b[?2004l\r"]
[33.119571, "o", "\u001b[?2004h> "]
[33.119699, "o", "                record = json.loads(raw_line)\r\n\u001b[?2004l\r"]
[33.11974, "o", "\u001b[?2004h> "]
[33.119856, "o", "            except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[33.119887, "o", "\u001b[?2004h> "]
[33.119977, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[33.120009, "o", "\u001b[?2004h> "]
[33.120134, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.120166, "o", "\u001b[?2004h> "]
[33.120311, "o", "                    'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[33.120341, "o", "\u001b[?2004h> "]
[33.120509, "o", "                    'error_detail': 'failed to parse JSON',\r\n\u001b[?2004l\r"]
[33.12054, "o", "\u001b[?2004h> "]
[33.120689, "o", "                    'raw_content': truncate(raw_line)\r\n\u001b[?2004l\r"]
[33.120732, "o", "\u001b[?2004h> "]
[33.120785, "o", "                })\r\n\u001b[?2004l\r"]
[33.120816, "o", "\u001b[?2004h> "]
[33.120959, "o", "                error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[33.120989, "o", "\u001b[?2004h> "]
[33.121057, "o", "                continue\r\n\u001b[?2004l\r"]
[33.121088, "o", "\u001b[?2004h> "]
[33.121125, "o", "            \r\n\u001b[?2004l\r"]
[33.121155, "o", "\u001b[?2004h> "]
[33.121241, "o", "            # Validate record\r\n\u001b[?2004l\r"]
[33.121271, "o", "\u001b[?2004h> "]
[33.121475, "o", "            is_valid, error_type, error_detail = validate_record(record)\r\n\u001b[?2004l\r"]
[33.121504, "o", "\u001b[?2004h> "]
[33.121545, "o", "            \r\n\u001b[?2004l\r"]
[33.121575, "o", "\u001b[?2004h> "]
[33.12166, "o", "            if not is_valid:\r\n\u001b[?2004l\r"]
[33.121688, "o", "\u001b[?2004h> "]
[33.12179, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[33.121823, "o", "\u001b[?2004h> "]
[33.121944, "o", "                    'line_number': line_num,\r\n"]
[33.121977, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[33.122118, "o", "                    'error_type': error_type,\r\n\u001b[?2004l\r"]
[33.122151, "o", "\u001b[?2004h> "]
[33.122291, "o", "                    'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[33.12232, "o", "\u001b[?2004h> "]
[33.122473, "o", "                    'raw_content': truncate(raw_line)\r\n\u001b[?2004l\r"]
[33.122504, "o", "\u001b[?2004h> "]
[33.122558, "o", "                })\r\n\u001b[?2004l\r"]
[33.122591, "o", "\u001b[?2004h> "]
[33.122716, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[33.122766, "o", "\u001b[?2004h> "]
[33.122831, "o", "                continue\r\n\u001b[?2004l\r"]
[33.122864, "o", "\u001b[?2004h> "]
[33.122901, "o", "            \r\n\u001b[?2004l\r"]
[33.122932, "o", "\u001b[?2004h> "]
[33.123095, "o", "            # Valid record - compute hash and add metadata\r\n\u001b[?2004l\r"]
[33.123128, "o", "\u001b[?2004h> "]
[33.123268, "o", "            integrity_hash = compute_hash(record)\r\n\u001b[?2004l\r"]
[33.123301, "o", "\u001b[?2004h> "]
[33.123382, "o", "            clean_record = {\r\n\u001b[?2004l\r"]
[33.123415, "o", "\u001b[?2004h> "]
[33.123581, "o", "                'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[33.123612, "o", "\u001b[?2004h> "]
[33.123762, "o", "                'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[33.123795, "o", "\u001b[?2004h> "]
[33.123935, "o", "                'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[33.123969, "o", "\u001b[?2004h> "]
[33.124091, "o", "                'amount': record['amount'],\r\n\u001b[?2004l\r"]
[33.124124, "o", "\u001b[?2004h> "]
[33.124257, "o", "                'currency': record['currency'],\r\n\u001b[?2004l\r"]
[33.12429, "o", "\u001b[?2004h> "]
[33.12441, "o", "                'status': record['status'],\r\n\u001b[?2004l\r"]
[33.124444, "o", "\u001b[?2004h> "]
[33.12458, "o", "                'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[33.124613, "o", "\u001b[?2004h> "]
[33.124751, "o", "                'processed_at': processing_time\r\n\u001b[?2004l\r"]
[33.124785, "o", "\u001b[?2004h> "]
[33.124823, "o", "            }\r\n\u001b[?2004l\r"]
[33.124856, "o", "\u001b[?2004h> "]
[33.124981, "o", "            valid_records.append(clean_record)\r\n\u001b[?2004l\r"]
[33.125014, "o", "\u001b[?2004h> "]
[33.125046, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.125079, "o", "> "]
[33.125164, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[33.125197, "o", "\u001b[?2004h> "]
[33.125343, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[33.125376, "o", "\u001b[?2004h> "]
[33.125407, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.125439, "o", "> "]
[33.125503, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[33.125536, "o", "\u001b[?2004h> "]
[33.125643, "o", "    with open(CLEAN_OUTPUT, 'w') as f:\r\n\u001b[?2004l\r"]
[33.125675, "o", "\u001b[?2004h> "]
[33.125789, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[33.125822, "o", "\u001b[?2004h> "]
[33.125947, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[33.12599, "o", "\u001b[?2004h> "]
[33.126019, "o", "    \r\n\u001b[?2004l\r"]
[33.126052, "o", "\u001b[?2004h> "]
[33.1261, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[33.126134, "o", "\u001b[?2004h> "]
[33.126233, "o", "    with open(ERROR_LOG, 'w') as f:\r\n\u001b[?2004l\r"]
[33.126262, "o", "\u001b[?2004h> "]
[33.126347, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[33.12638, "o", "\u001b[?2004h> "]
[33.126506, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[33.126539, "o", "\u001b[?2004h> "]
[33.12657, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.126603, "o", "> "]
[33.12666, "o", "    # Calculate statistics\r\n\u001b[?2004l\r"]
[33.126691, "o", "\u001b[?2004h> "]
[33.126777, "o", "    total_lines = line_num\r\n\u001b[?2004l\r"]
[33.126808, "o", "\u001b[?2004h> "]
[33.126913, "o", "    valid_count = len(valid_records)\r\n\u001b[?2004l\r"]
[33.126946, "o", "\u001b[?2004h"]
[33.126972, "o", "> "]
[33.127041, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[33.127068, "o", "\u001b[?2004h> "]
[33.127294, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[33.127321, "o", "\u001b[?2004h> "]
[33.127353, "o", "    \r\n\u001b[?2004l\r"]
[33.127384, "o", "\u001b[?2004h> "]
[33.12745, "o", "    # Write summary report\r\n\u001b[?2004l\r"]
[33.127477, "o", "\u001b[?2004h> "]
[33.127589, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.12762, "o", "\u001b[?2004h> "]
[33.127761, "o", "        f.write('AUDIT PROCESSING SUMMARY\\n')\r\n\u001b[?2004l\r"]
[33.127794, "o", "\u001b[?2004h> "]
[33.12792, "o", "        f.write('========================\\n')\r\n\u001b[?2004l\r"]
[33.127949, "o", "\u001b[?2004h> "]
[33.128083, "o", "        f.write(f'Input file: {INPUT_FILE}\\n')\r\n\u001b[?2004l\r"]
[33.128117, "o", "\u001b[?2004h> "]
[33.12828, "o", "        f.write(f'Total lines processed: {total_lines}\\n')\r\n\u001b[?2004l\r"]
[33.128313, "o", "\u001b[?2004h> "]
[33.128467, "o", "        f.write(f'Valid transactions: {valid_count}\\n')\r\n\u001b[?2004l\r"]
[33.1285, "o", "\u001b[?2004h> "]
[33.128646, "o", "        f.write(f'Failed records: {failed_count}\\n')\r\n\u001b[?2004l\r"]
[33.128677, "o", "\u001b[?2004h> "]
[33.128842, "o", "        f.write(f'Success rate: {success_rate:.2f}%\\n')\r\n\u001b[?2004l\r"]
[33.128875, "o", "\u001b[?2004h> "]
[33.128944, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[33.128984, "o", "\u001b[?2004h> "]
[33.129071, "o", "        f.write('Errors by type:\\n')\r\n\u001b[?2004l\r"]
[33.129102, "o", "\u001b[?2004h> "]
[33.129304, "o", "        f.write(f\"  malformed_json: {error_counts['malformed_json']}\\n\")\r\n\u001b[?2004l\r"]
[33.129335, "o", "\u001b[?2004h> "]
[33.129531, "o", "        f.write(f\"  missing_field: {error_counts['missing_field']}\\n\")\r\n\u001b[?2004l\r"]
[33.12956, "o", "\u001b[?2004h> "]
[33.129773, "o", "        f.write(f\"  invalid_format: {error_counts['invalid_format']}\\n\")\r\n\u001b[?2004l\r"]
[33.129804, "o", "\u001b[?2004h> "]
[33.130007, "o", "        f.write(f\"  invalid_value: {error_counts['invalid_value']}\\n\")\r\n\u001b[?2004l\r"]
[33.130039, "o", "\u001b[?2004h> "]
[33.130101, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[33.130134, "o", "\u001b[?2004h> "]
[33.130312, "o", "        f.write(f'Processing completed at: {processing_time}\\n')\r\n\u001b[?2004l\r"]
[33.130345, "o", "\u001b[?2004h> "]
[33.130375, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.130403, "o", "> "]
[33.130489, "o", "    print(f'Processing complete!')\r\n\u001b[?2004l\r"]
[33.130521, "o", "\u001b[?2004h> "]
[33.130686, "o", "    print(f'Valid: {valid_count}, Errors: {failed_count}')\r\n\u001b[?2004l\r"]
[33.130718, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.130759, "o", "\u001b[?2004h> "]
[33.130842, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[33.130875, "o", "\u001b[?2004h> "]
[33.130907, "o", "    main()\r\n\u001b[?2004l\r"]
[33.130939, "o", "\u001b[?2004h> "]
[33.130969, "o", "EOF\r\n\u001b[?2004l\r"]
[33.135414, "o", "\u001b[?2004h"]
[33.135452, "o", "root@6be5dab4f914:/home/user# "]
[34.102148, "i", "python3 /home/user/audit/process_audit.py\n"]
[34.102323, "o", "python3 /home/user/audit/process_audit.py\r\n\u001b[?2004l\r"]
[34.125978, "o", "Processing complete!\r\nValid: 13, Errors: 12\r\n"]
[34.129215, "o", "\u001b[?2004h"]
[34.129252, "o", "root@6be5dab4f914:/home/user# "]
[41.561515, "i", "cat /home/user/audit/processing_summary.txt\n"]
[41.561689, "o", "cat /home/user/audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[41.562577, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T01:11:10Z\r\n"]
[41.562718, "o", "\u001b[?2004h"]
[41.562801, "o", "root@6be5dab4f914:/home/user# "]
[42.055257, "i", "cat /home/user/audit/clean_audit.jsonl\n"]
[42.055418, "o", "cat /home/user/audit/clean_audit.jsonl\r\n\u001b[?2004l\r"]
