[33.104461, "i", "Y-%m-%dT%H:%M:%SZ')\n    \n    with open(INPUT_FILE, 'r') as f:\n        for line_num, line in enumerate(f, 1):\n            raw_line = line.rstrip('\\n')\n            \n            # Try to parse JSON\n            try:\n                record = json.loads(raw_line)\n            except json.JSONDecodeError:\n                errors.append({\n                    'line_number': line_num,\n                    'error_type': 'malformed_json',\n                    'error_detail': 'failed to parse JSON',\n                    'raw_content': truncate(raw_line)\n                })\n                error_counts['malformed_json'] += 1\n                continue\n            \n            # Validate record\n            is_valid, error_type, error_detail = validate_record(record)\n            \n            if not is_valid:\n                errors.append({\n                    'line_number': line_num,\n                    'error_type': error_type,\n                    'error_detail': error_detail,\n                    'raw_content': truncate(raw_line)\n "]
[33.104506, "i", "               })\n                error_counts[error_type] += 1\n                continue\n            \n            # Valid record - compute hash and add metadata\n            integrity_hash = compute_hash(record)\n            clean_record = {\n                'transaction_id': record['transaction_id'],\n                'timestamp': record['timestamp'],\n                'account_id': record['account_id'],\n                'amount': record['amount'],\n                'currency': record['currency'],\n                'status': record['status'],\n                'integrity_hash': integrity_hash,\n                'processed_at': processing_time\n            }\n            valid_records.append(clean_record)\n    \n    # Sort valid records by timestamp\n    valid_records.sort(key=lambda x: x['timestamp'])\n    \n    # Write clean audit file\n    with open(CLEAN_OUTPUT, 'w') as f:\n        for record in valid_records:\n            f.write(json.dumps(record) + '\\n')\n    \n    # Write error log\n    with open(ERROR_LOG, 'w') as f:\n        for"]
