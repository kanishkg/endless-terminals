[36.569265, "o", "\u001b[?2004h> "]
[36.569381, "o", "        REMOVABLE_JSON=\"$REMOVABLE_JSON,\"\r\n\u001b[?2004l\r"]
[36.569412, "o", "\u001b[?2004h> "]
[36.569443, "o", "    fi\r\n\u001b[?2004l\r"]
[36.569476, "o", "\u001b[?2004h> "]
[36.569563, "o", "    REMOVABLE_JSON=\"$REMOVABLE_JSON\r\n\u001b[?2004l\r"]
[36.569594, "o", "\u001b[?2004h> "]
[36.56993, "o", "    {\\\"name\\\": \\\"$pkg\\\", \\\"installed_version\\\": \\\"$VERSION\\\", \\\"size_kb\\\": $SIZE, \\\"has_security_update\\\": $HAS_SECURITY}\"\r\n\u001b[?2004l\r"]
[36.569974, "o", "\u001b[?2004h> "]
[36.570009, "o", "done\r\n\u001b[?2004l\r"]
