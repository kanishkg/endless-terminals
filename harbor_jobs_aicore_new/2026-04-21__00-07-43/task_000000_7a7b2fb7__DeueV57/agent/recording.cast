[36.566355, "o", "\u001b[?2004h> "]
[36.566442, "o", "echo '{' > removal_report.json\r\n\u001b[?2004l\r"]
[36.566474, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[36.566507, "o", "\u001b[?2004h> "]
[36.566597, "o", "# Build removable_packages array\r\n\u001b[?2004l\r"]
