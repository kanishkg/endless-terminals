[36.567841, "o", "\u001b[?2004h> "]
[36.567927, "o", "    # Check for security updates\r\n\u001b[?2004l\r"]
[36.567972, "o", "\u001b[?2004h> "]
[36.568115, "o", "    POLICY=$(apt-cache policy \"$pkg\" 2>/dev/null)\r\n\u001b[?2004l\r"]
[36.568149, "o", "\u001b[?2004h> "]
[36.568346, "o", "    CANDIDATE=$(echo \"$POLICY\" | grep \"Candidate:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[36.568376, "o", "\u001b[?2004h> "]
[36.568449, "o", "    HAS_SECURITY=\"false\"\r\n\u001b[?2004l\r"]
[36.568481, "o", "\u001b[?2004h> "]
[36.568616, "o", "    if echo \"$POLICY\" | grep -q \"security\"; then\r\n\u001b[?2004l\r"]
[36.568648, "o", "\u001b[?2004h> "]
[36.568789, "o", "        if [[ \"$VERSION\" != \"$CANDIDATE\" ]]; then\r\n\u001b[?2004l\r"]
[36.56882, "o", "\u001b[?2004h> "]
[36.568911, "o", "            HAS_SECURITY=\"true\"\r\n\u001b[?2004l\r"]
[36.568942, "o", "\u001b[?2004h> "]
[36.56899, "o", "        fi\r\n\u001b[?2004l\r"]
[36.56902, "o", "\u001b[?2004h> "]
