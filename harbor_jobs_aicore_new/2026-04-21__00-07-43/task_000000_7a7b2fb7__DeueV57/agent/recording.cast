[36.570409, "o", "\u001b[?2004h> "]
[36.570604, "o", "    DEPS=$(echo \"${PROTECTED_BY[$pkg]}\" | xargs -n1 | sort -u | xargs)\r\n\u001b[?2004l\r"]
[36.570636, "o", "\u001b[?2004h> "]
[36.570929, "o", "    DEPS_ARRAY=$(echo \"$DEPS\" | tr ' ' '\\n' | grep -v '^$' | sed 's/.*$/\"&\"/' | tr '\\n' ',' | sed 's/,$//')\r\n\u001b[?2004l\r"]
[36.570973, "o", "\u001b[?2004h> "]
[36.570996, "o", "    \r\n\u001b[?2004l\r"]
[36.571028, "o", "\u001b[?2004h> "]
