[222.491516, "i", "cat > build_report.sh << 'EOF'\n#!/bin/bash\n\n# Lists from analysis\nREMOVABLE=(apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget)\nPROTECTED=(libc6 libssl3 zlib1g)\n\n# Get package info\nTOTAL_SIZE=0\nREMOVABLE_JSON=\"\"\n\nfor pkg in \"${REMOVABLE[@]}\"; do\n    echo \"Processing: $pkg\"\n    \n    # Try dpkg-query first, then apt-cache\n    VERSION=$(dpkg-query -W -f='${Version}' \"$pkg\" 2>/dev/null)\n    if [[ -z \"$VERSION\" ]]; then\n        VERSION=$(apt-cache show \"$pkg\" 2>/dev/null | grep -m1 \"^Version:\" | awk '{print $2}')\n    fi\n    [[ -z \"$VERSION\" ]] && VERSION=\"unknown\"\n    \n    # Get size\n    SIZE=$(dpkg-query -W -f='${Installed-Size}' \"$pkg\" 2>/dev/null)\n    if [[ -z \"$SIZE\" || \"$SIZE\" == \"\" ]]; then\n        SIZE=$(apt-cache show \"$pkg\" 2>/dev/null | grep -m1 \"^Installed-Size:\" | awk '{print $2}')\n    fi\n    [[ -z \"$SIZE\" || ! \"$SIZE\" =~ ^[0-9]+$ ]] && SIZE=0\n    \n    TOTAL_SIZE=$((TOTAL_SIZE + SIZE))\n    \n    # Check"]
[222.491646, "i", " for security updates\n    HAS_SECURITY=\"false\"\n    POLICY=$(apt-cache policy \"$pkg\" 2>/dev/null)\n    if echo \"$POLICY\" | grep -q \"security\"; then\n        INSTALLED_VER=$(echo \"$POLICY\" | grep \"Installed:\" | awk '{print $2}')\n        CANDIDATE_VER=$(echo \"$POLICY\" | grep \"Candidate:\" | awk '{print $2}')\n        if [[ \"$INSTALLED_VER\" != \"$CANDIDATE_VER\" && \"$INSTALLED_VER\" != \"(none)\" ]]; then\n            HAS_SECURITY=\"true\"\n        fi\n    fi\n    \n    [[ -n \"$REMOVABLE_JSON\" ]] && REMOVABLE_JSON=\"$REMOVABLE_JSON,\"\n    REMOVABLE_JSON=\"$REMOVABLE_JSON\n    {\\\"name\\\": \\\"$pkg\\\", \\\"installed_version\\\": \\\"$VERSION\\\", \\\"size_kb\\\": $SIZE, \\\"has_security_update\\\": $HAS_SECURITY}\"\ndone\n\necho \"Total size: $TOTAL_SIZE KB\"\n\n# Build protected JSON\nPROTECTED_JSON='\n    {\"name\": \"libc6\", \"required_by\": [\"bash\", \"ca-certificates\", \"coreutils\", \"curl\", \"jq\", \"nginx\", \"openssl\", \"python3\", \"python3-pip\"]},\n    {\"name\": \"libssl3\", \"required_by\": [\"ca-certificates\", \"curl\", \"nginx\", \"openssl\", \"python3-pip\"]},\n    {\"name\": \"zlib1g\""]
[222.491685, "i", ", \"required_by\": [\"curl\", \"nginx\", \"python3\"]}'\n\n# Write JSON\ncat > removal_report.json << ENDJSON\n{\n  \"summary\": {\n    \"total_installed\": 31,\n    \"total_required\": 9,\n    \"removable_count\": 19,\n    \"kept_as_dependencies\": 3,\n    \"total_space_savings_kb\": $TOTAL_SIZE\n  },\n  \"removable_packages\": [$REMOVABLE_JSON\n  ],\n  \"dependency_protected\": [$PROTECTED_JSON\n  ]\n}\nENDJSON\n\necho \"Done!\"\nEOF\nchmod +x build_report.sh\n"]
