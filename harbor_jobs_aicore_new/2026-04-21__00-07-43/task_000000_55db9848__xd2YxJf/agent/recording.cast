[45.850612, "i", "awk -F'\\t' '\nBEGIN { total = 0 }\n{\n  # Skip directory entries (lines where path is just a directory)\n  if ($2 == \"/var/data\" || $2 ~ /^\\/var\\/data\\/[^\\/]+$/ || $2 ~ /^\\/var\\/data\\/[^\\/]+\\/[^\\/]+$/ && $1 == 4096) {\n    # Check if it looks like a directory entry\n    n = split($2, p, \"/\");\n    fname = p[n];\n    if (fname !~ /\\./ && $1 == 4096) next;\n  }\n  \n  # Extract immediate subdirectory\n  if (match($2, /^\\/var\\/data\\/([^\\/]+)/, arr)) {\n    subdir = arr[1];\n    # Only count if this is a file (not the subdir entry itself)\n    if ($2 != \"/var/data/\" subdir) {\n      sizes[subdir] += $1;\n      total += $1;\n    } else if ($1 != 4096) {\n      sizes[subdir] += $1;\n      total += $1;\n    }\n  }\n}\nEND {\n  for (d in sizes) {\n    pct = (sizes[d] / total) * 100;\n    printf \"%s %d %.1f%%\\n\", d, sizes[d], pct;\n  }\n}' /home/user/disk_inventory.txt | sort -t' ' -k2 -nr > /home/user/reports/directory_rollup.txt\n"]
