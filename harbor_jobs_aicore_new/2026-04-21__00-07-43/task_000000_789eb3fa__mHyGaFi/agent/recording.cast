[28.094037, "i", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\n#!/bin/bash\n\n# Check directory permissions\nwhile IFS=: read -r path expected; do\n    if [[ -z \"$path\" || \"$path\" == \"DIRECTORY_PERMISSIONS\" || \"$path\" == \"FILE_PERMISSIONS\" ]]; then\n        continue\n    fi\n    actual=$(stat -c '%a' \"$path\" 2>/dev/null)\n    if [[ \"$actual\" != \"$expected\" ]]; then\n        echo \"FAIL: $path\"\n        exit 1\n    fi\ndone < <(sed -n '/^DIRECTORY_PERMISSIONS:/,/^$/p' /home/user/docs_workspace/permissions_manifest.txt)\n\n# Check file permissions\nwhile IFS=: read -r path expected; do\n    if [[ -z \"$path\" || \"$path\" == \"DIRECTORY_PERMISSIONS\" || \"$path\" == \"FILE_PERMISSIONS\" ]]; then\n        continue\n    fi\n    actual=$(stat -c '%a' \"$path\" 2>/dev/null)\n    if [[ \"$actual\" != \"$expected\" ]]; then\n        echo \"FAIL: $path\"\n        exit 1\n    fi\ndone < <(sed -n '/^FILE_PERMISSIONS:/,$p' /home/user/docs_workspace/permissions_manifest.txt)\n\necho \"PASS\"\nEOF\n"]
