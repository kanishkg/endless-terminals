[26.392737, "i", "cat > generate_report.py << 'EOF'\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_log(filename, category):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            match = re.match(r'\\[([^\\]]+)\\]\\s+([^|]+)\\|([^|]+)\\|([^|]+)\\|([^|]+)\\|(.+)', line)\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                entries.append({\n                    'timestamp': timestamp.strip(),\n                    'service': service.strip(),\n                    'old_key': old_key.strip(),\n                    'new_key': new_key.strip(),\n                    'status': status.strip(),\n                    'rotated_by': rotated_by.strip(),\n                    'category': category\n                })\n    return entries\n\n# Parse all logs\naws_entries = parse_log('aws-rotation.log', 'AWS IAM')\ndb_entries = parse_log('db-rotati"]
[26.392876, "i", "on.log', 'Database')\napi_entries = parse_log('api-keys.log', 'API Keys')\n\nall_entries = aws_entries + db_entries + api_entries\n\n# Calculate stats\ndef get_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = total - success\n    return total, success, failed\n\naws_stats = get_stats(aws_entries)\ndb_stats = get_stats(db_entries)\napi_stats = get_stats(api_entries)\n\ntotal_rotated = len(all_entries)\n\n# Sort entries alphabetically by service name\naws_entries.sort(key=lambda x: x['service'].lower())\ndb_entries.sort(key=lambda x: x['service'].lower())\napi_entries.sort(key=lambda x: x['service'].lower())\n\n# Get failed entries\nfailed_entries = [e for e in all_entries if e['status'] == 'FAILED']\n\n# Generate timestamp\nnow = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\n# Build markdown\nmd = f\"\"\"# Credential Rotation Report\n\n**Generated:** {now}\n**Total Credentials Rotated:** {total_rotated}\n\n## Summary by Category\n\n| Category | Count | Success | Failed |\n|--"]
[26.392892, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\r"]
[26.392928, "i", "--------|-------|---------|--------|\n| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\n| Database | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\n| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\n\n## Detailed Rotation Log\n\n### AWS IAM Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in aws_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n### Database Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in db_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n### API Keys\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in api_entries:\n    md += f\"| {e['service']} | {e['ol"]
[26.393044, "o", "\u001b[?2004h> import re\r\n\u001b[?2004l\r\u001b[?2004h> "]
[26.393063, "i", "d_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n## Failed Rotations\n\n\"\"\"\n\nif failed_entries:\n    md += \"> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n\"\n    for e in failed_entries:\n        md += f\"- {e['service']} ({e['category']}): Rotation failed\\n\"\nelse:\n    md += \"> No failed rotations. All credentials rotated successfully.\\n\"\n\nmd += \"\"\"\n## Sign-off\n\n- [ ] All successful rotations verified\n- [ ] Failed rotations escalated\n- [ ] Old credentials scheduled for deletion\n\"\"\"\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write(md)\n\nprint(\"Report generated successfully!\")\nEOF\n"]
