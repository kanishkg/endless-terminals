[32.416676, "o", "\u001b[?2004h"]
[32.416707, "o", "root@6423002a0639:/home/user# "]
[38.982898, "i", "cat /home/user/audit/processing_summary.txt\n"]
[38.983075, "o", "cat /home/user/audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[38.983963, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T00:54:44Z\r\n"]
[38.984108, "o", "\u001b[?2004h"]
[38.984148, "o", "root@6423002a0639:/home/user# "]
[39.084693, "i", "cat /home/user/audit/clean_audit.jsonl\n"]
[39.084864, "o", "cat /home/user/audit/clean_audit.jsonl\r\n\u001b[?2004l\r"]
