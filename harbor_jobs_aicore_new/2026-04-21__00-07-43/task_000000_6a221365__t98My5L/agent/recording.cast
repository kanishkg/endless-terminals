[31.902637, "o", "\u001b[?2004h> "]
[31.902759, "o", "    amount_str = f\"{record['amount']:.2f}\"\r\n\u001b[?2004l\r"]
[31.902794, "o", "\u001b[?2004h> "]
[31.903182, "o", "    canonical = f\"{record['transaction_id']}|{record['timestamp']}|{record['account_id']}|{amount_str}|{record['currency']}|{record['status']}\"\r\n\u001b[?2004l\r"]
[31.903215, "o", "\u001b[?2004h> "]
[31.903408, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[31.903442, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.903476, "o", "\u001b[?2004h> "]
[31.903555, "o", "def truncate(s, max_len=200):\r\n\u001b[?2004l\r"]
[31.903589, "o", "\u001b[?2004h> "]
[31.903717, "o", "    \"\"\"Truncate string to max_len characters\"\"\"\r\n\u001b[?2004l\r"]
[31.903751, "o", "\u001b[?2004h> "]
[31.903886, "o", "    return s[:max_len] if len(s) > max_len else s\r\n\u001b[?2004l\r"]
[31.90392, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.903948, "o", "\u001b[?2004h> "]
[31.903985, "o", "def main():\r\n\u001b[?2004l\r"]
[31.904021, "o", "\u001b[?2004h> "]
[31.904078, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[31.904108, "o", "\u001b[?2004h> "]
[31.904155, "o", "    errors = []\r\n\u001b[?2004l\r"]
[31.904189, "o", "\u001b[?2004h> "]
[31.904244, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[31.904276, "o", "\u001b[?2004h> "]
[31.90437, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[31.9044, "o", "\u001b[?2004h> "]
[31.904478, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[31.904511, "o", "\u001b[?2004h> "]
[31.904602, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[31.904636, "o", "\u001b[?2004h> "]
[31.904707, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[31.904737, "o", "\u001b[?2004h> "]
[31.904764, "o", "    }\r\n\u001b[?2004l\r"]
[31.904793, "o", "\u001b[?2004h> "]
[31.90482, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.904847, "o", "> "]
[31.905054, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[31.905085, "o", "\u001b[?2004h> "]
[31.905112, "o", "    \r\n\u001b[?2004l\r"]
[31.905143, "o", "\u001b[?2004h> "]
[31.905233, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[31.905266, "o", "\u001b[?2004h> "]
[31.905362, "o", "        lines = f.readlines()\r\n\u001b[?2004l\r"]
[31.905395, "o", "\u001b[?2004h> "]
[31.905425, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.905456, "o", "> "]
[31.905519, "o", "    total_lines = len(lines)\r\n\u001b[?2004l\r"]
[31.905553, "o", "\u001b[?2004h> "]
[31.905587, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.90562, "o", "> "]
[31.905726, "o", "    for line_num, line in enumerate(lines, 1):\r\n\u001b[?2004l\r"]
[31.905757, "o", "\u001b[?2004h> "]
[31.905866, "o", "        raw_content = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[31.905897, "o", "\u001b[?2004h> "]
[31.90593, "o", "        \r\n\u001b[?2004l\r"]
[31.905964, "o", "\u001b[?2004h> "]
[31.906038, "o", "        # Try to parse JSON\r\n\u001b[?2004l\r"]
[31.906068, "o", "\u001b[?2004h> "]
[31.906106, "o", "        try:\r\n\u001b[?2004l\r"]
[31.906137, "o", "\u001b[?2004h> "]
[31.90626, "o", "            record = json.loads(raw_content)\r\n\u001b[?2004l\r"]
[31.906291, "o", "\u001b[?2004h> "]
[31.906409, "o", "        except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[31.906439, "o", "\u001b[?2004h> "]
[31.906572, "o", "            error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[31.906602, "o", "\u001b[?2004h> "]
[31.90668, "o", "            errors.append({\r\n\u001b[?2004l\r"]
[31.906711, "o", "\u001b[?2004h> "]
[31.906824, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.906854, "o", "\u001b[?2004h> "]
[31.906986, "o", "                'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[31.907021, "o", "\u001b[?2004h> "]
[31.907171, "o", "                'error_detail': 'failed to parse JSON',\r\n\u001b[?2004l\r"]
[31.907202, "o", "\u001b[?2004h> "]
[31.907362, "o", "                'raw_content': truncate(raw_content)\r\n\u001b[?2004l\r"]
[31.907393, "o", "\u001b[?2004h> "]
[31.907435, "o", "            })\r\n\u001b[?2004l\r"]
[31.907467, "o", "\u001b[?2004h> "]
[31.907524, "o", "            continue\r\n\u001b[?2004l\r"]
[31.907559, "o", "\u001b[?2004h> "]
[31.907593, "o", "        \r\n\u001b[?2004l\r"]
[31.907626, "o", "\u001b[?2004h> "]
[31.907688, "o", "        # Validate record\r\n\u001b[?2004l\r"]
[31.907719, "o", "\u001b[?2004h> "]
[31.907907, "o", "        is_valid, error_type, error_detail = validate_record(record)\r\n\u001b[?2004l\r"]
[31.907941, "o", "\u001b[?2004h> "]
[31.907971, "o", "        \r\n\u001b[?2004l\r"]
[31.908, "o", "\u001b[?2004h> "]
[31.908067, "o", "        if not is_valid:\r\n\u001b[?2004l\r"]
[31.908098, "o", "\u001b[?2004h> "]
[31.908216, "o", "            error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[31.908243, "o", "\u001b[?2004h> "]
[31.908343, "o", "            errors.append({\r\n\u001b[?2004l\r"]
[31.908374, "o", "\u001b[?2004h> "]
[31.908485, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.908515, "o", "\u001b[?2004h> "]
[31.908641, "o", "                'error_type': error_type,\r\n\u001b[?2004l\r"]
[31.908673, "o", "\u001b[?2004h> "]
[31.908799, "o", "                'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[31.908833, "o", "\u001b[?2004h> "]
[31.908975, "o", "                'raw_content': truncate(raw_content)\r\n\u001b[?2004l\r"]
[31.909006, "o", "\u001b[?2004h> "]
[31.909048, "o", "            })\r\n\u001b[?2004l\r"]
[31.90908, "o", "\u001b[?2004h> "]
[31.909138, "o", "            continue\r\n\u001b[?2004l\r"]
[31.909168, "o", "\u001b[?2004h> "]
[31.909198, "o", "        \r\n\u001b[?2004l\r"]
[31.909232, "o", "\u001b[?2004h> "]
[31.909372, "o", "        # Compute hash and create clean record\r\n\u001b[?2004l\r"]
[31.909404, "o", "\u001b[?2004h> "]
[31.909528, "o", "        integrity_hash = compute_hash(record)\r\n\u001b[?2004l\r"]
[31.909563, "o", "\u001b[?2004h> "]
[31.909629, "o", "        clean_record = {\r\n\u001b[?2004l\r"]
[31.909659, "o", "\u001b[?2004h> "]
[31.909813, "o", "            'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[31.909844, "o", "\u001b[?2004h> "]
[31.90997, "o", "            'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[31.910004, "o", "\u001b[?2004h> "]
[31.910132, "o", "            'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[31.910162, "o", "\u001b[?2004h> "]
[31.910273, "o", "            'amount': record['amount'],\r\n\u001b[?2004l\r"]
[31.910303, "o", "\u001b[?2004h> "]
[31.91044, "o", "            'currency': record['currency'],\r\n\u001b[?2004l\r"]
[31.910475, "o", "\u001b[?2004h> "]
[31.910582, "o", "            'status': record['status'],\r\n\u001b[?2004l\r"]
[31.910611, "o", "\u001b[?2004h> "]
[31.910739, "o", "            'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[31.910769, "o", "\u001b[?2004h> "]
[31.910891, "o", "            'processed_at': processing_time\r\n\u001b[?2004l\r"]
[31.91092, "o", "\u001b[?2004h> "]
[31.910954, "o", "        }\r\n\u001b[?2004l\r"]
[31.910985, "o", "\u001b[?2004h> "]
[31.9111, "o", "        valid_records.append(clean_record)\r\n\u001b[?2004l\r"]
[31.911131, "o", "\u001b[?2004h> "]
[31.911159, "o", "    \r\n\u001b[?2004l\r"]
[31.911186, "o", "\u001b[?2004h> "]
[31.911281, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[31.91131, "o", "\u001b[?2004h> "]
[31.911469, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[31.911501, "o", "\u001b[?2004h> "]
[31.911537, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.911571, "o", "> "]
[31.911629, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[31.91166, "o", "\u001b[?2004h> "]
[31.911767, "o", "    with open(CLEAN_OUTPUT, 'w') as f:\r\n\u001b[?2004l\r"]
[31.911798, "o", "\u001b[?2004h> "]
[31.9119, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[31.911934, "o", "\u001b[?2004h> "]
[31.91206, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[31.912094, "o", "\u001b[?2004h> "]
[31.912124, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.912156, "o", "> "]
[31.912198, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[31.912231, "o", "\u001b[?2004h> "]
[31.912339, "o", "    with open(ERROR_LOG, 'w') as f:\r\n\u001b[?2004l\r"]
[31.91237, "o", "\u001b[?2004h> "]
[31.912451, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[31.912483, "o", "\u001b[?2004h> "]
[31.912619, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[31.912652, "o", "\u001b[?2004h> "]
[31.912684, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.912715, "o", "> "]
[31.912776, "o", "    # Calculate success rate\r\n\u001b[?2004l\r"]
[31.912806, "o", "\u001b[?2004h> "]
[31.912909, "o", "    valid_count = len(valid_records)\r\n\u001b[?2004l\r"]
[31.912938, "o", "\u001b[?2004h> "]
[31.913027, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[31.913057, "o", "\u001b[?2004h> "]
[31.913279, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[31.913325, "o", "\u001b[?2004h> "]
[31.913358, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.913388, "o", "> "]
[31.913427, "o", "    # Write summary\r\n\u001b[?2004l\r"]
[31.913457, "o", "\u001b[?2004h> "]
[31.913572, "o", "    summary = f\"\"\"AUDIT PROCESSING SUMMARY\r\n\u001b[?2004l\r"]
[31.913602, "o", "\u001b[?2004h> "]
[31.913671, "o", "========================\r\n\u001b[?2004l\r"]
[31.913701, "o", "\u001b[?2004h> "]
[31.913772, "o", "Input file: {INPUT_FILE}\r\n\u001b[?2004l\r"]
[31.913802, "o", "\u001b[?2004h> "]
[31.913904, "o", "Total lines processed: {total_lines}\r\n\u001b[?2004l\r"]
[31.913935, "o", "\u001b[?2004h> "]
[31.914029, "o", "Valid transactions: {valid_count}\r\n\u001b[?2004l\r"]
[31.914061, "o", "\u001b[?2004h> "]
[31.914149, "o", "Failed records: {failed_count}\r\n\u001b[?2004l\r"]
[31.914183, "o", "\u001b[?2004h> "]
[31.914273, "o", "Success rate: {success_rate:.2f}%\r\n\u001b[?2004l\r"]
[31.914308, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.914356, "o", "\u001b[?2004h> "]
[31.9144, "o", "Errors by type:\r\n\u001b[?2004l\r"]
[31.914427, "o", "\u001b[?2004h> "]
[31.914568, "o", "  malformed_json: {error_counts['malformed_json']}\r\n\u001b[?2004l\r"]
[31.914599, "o", "\u001b[?2004h> "]
[31.914736, "o", "  missing_field: {error_counts['missing_field']}\r\n\u001b[?2004l\r"]
[31.914772, "o", "\u001b[?2004h> "]
[31.914906, "o", "  invalid_format: {error_counts['invalid_format']}\r\n\u001b[?2004l\r"]
[31.914937, "o", "\u001b[?2004h> "]
[31.91507, "o", "  invalid_value: {error_counts['invalid_value']}\r\n\u001b[?2004l\r"]
[31.915101, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.915128, "o", "\u001b[?2004h> "]
[31.915251, "o", "Processing completed at: {processing_time}\r\n\u001b[?2004l\r"]
[31.915278, "o", "\u001b[?2004h> "]
[31.915308, "o", "\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.915351, "o", ">     \r\n\u001b[?2004l\r"]
[31.915386, "o", "\u001b[?2004h> "]
[31.915488, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[31.915516, "o", "\u001b[?2004h> "]
[31.915587, "o", "        f.write(summary)\r\n\u001b[?2004l\r"]
[31.915617, "o", "\u001b[?2004h> "]
[31.91565, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.915685, "o", "> "]
[31.915757, "o", "    print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[31.915791, "o", "\u001b[?2004h> "]
[31.915953, "o", "    print(f\"Valid: {valid_count}, Errors: {failed_count}\")\r\n\u001b[?2004l\r"]
[31.915988, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.916017, "o", "\u001b[?2004h> "]
[31.916096, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[31.91613, "o", "\u001b[?2004h> "]
[31.916159, "o", "    main()\r\n\u001b[?2004l\r"]
[31.916196, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[31.924461, "o", "\u001b[?2004h"]
[31.924497, "o", "root@6423002a0639:/home/user# "]
[32.389815, "i", "python3 /home/user/audit/process_audit.py\n"]
