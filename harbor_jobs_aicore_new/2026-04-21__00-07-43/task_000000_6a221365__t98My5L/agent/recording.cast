[62.545026, "i", "python3 -c \"\nimport json\nimport hashlib\n\n# Verify first record hash\nwith open('/home/user/audit/clean_audit.jsonl') as f:\n    first = json.loads(f.readline())\n    amount_str = f\\\"{first['amount']:.2f}\\\"\n    canonical = f\\\"{first['transaction_id']}|{first['timestamp']}|{first['account_id']}|{amount_str}|{first['currency']}|{first['status']}\\\"\n    computed = hashlib.sha256(canonical.encode()).hexdigest()\n    print(f'Canonical: {canonical}')\n    print(f'Stored hash: {first[\\\"integrity_hash\\\"]}')\n    print(f'Computed hash: {computed}')\n    print(f'Match: {computed == first[\\\"integrity_hash\\\"]}')\n\"\n"]
