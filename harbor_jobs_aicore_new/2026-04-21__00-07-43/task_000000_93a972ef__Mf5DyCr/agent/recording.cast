[32.515909, "i", "python3 << 'EOF'\nimport re\n\n# Read the TOML file\nwith open('/etc/monitoring/uptime.toml', 'r') as f:\n    toml_content = f.read()\n\n# 1. Change check_interval from 60 to 30\ntoml_content = re.sub(\n    r'check_interval = 60',\n    'check_interval = 30',\n    toml_content\n)\n\n# 2. Add timeout = 10 after check_interval line in [global] section\ntoml_content = re.sub(\n    r'(check_interval = 30\\n)',\n    r'\\1timeout = 10\\n',\n    toml_content\n)\n\n# 3. Modify api-gateway: change expected_status to 200 and add critical = true\n# Find the api-gateway block and modify it\ntoml_content = re.sub(\n    r'(\\[\\[endpoints\\]\\]\\nname = \"api-gateway\"\\nurl = \"https://api.example.com/health\"\\n)expected_status = 204(\\nmethod = \"GET\")',\n    r'\\1expected_status = 200\\ncritical = true\\2',\n    toml_content\n)\n\n# 4. Add new payment-service endpoint at the end\nnew_endpoint = '''\n[[endpoints]]\nname = \"payment-service\"\nurl = \"https://payments.internal.example.com/health\"\nexpected_status = 200\ncritical = true\nheaders = { Authorization = \"Bearer ${PAYM"]
[32.516047, "i", "ENTS_TOKEN}\" }\n'''\n\ntoml_content = toml_content.rstrip() + '\\n' + new_endpoint\n\nwith open('/etc/monitoring/uptime.toml', 'w') as f:\n    f.write(toml_content)\n\nprint(\"TOML file updated successfully\")\nEOF\n"]
[32.516117, "o", "python3 << 'EOF'\r\n\u001b[?2004l\rENTS_TOKEN}\" }\r\n'''\r\n\r\ntoml_content = toml_content.rstrip() + '\\n' + new_endpoint\r\n\r\nwith open('/etc/monitoring/uptime.toml', 'w') as f:\r\n    f.write(toml_content)\r\n\r\nprint(\"TOML file updated successfully\")\r\nEOF\r\n\u001b[?2004h"]
