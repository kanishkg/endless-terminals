[6.527219, "i", "cat /etc/monitoring/alerts.yaml\n"]
[6.527366, "o", "cat /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[6.528307, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n"]
[6.528476, "o", "\u001b[?2004h"]
[6.528518, "o", "root@9fac5ed1067a:/home/user# "]
[7.023322, "i", "cat /etc/monitoring/uptime.toml\n"]
[7.023453, "o", "cat /etc/monitoring/uptime.toml\r\n"]
[7.023495, "o", "\u001b[?2004l\r"]
[7.024283, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 60\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 204\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n"]
[7.024436, "o", "\u001b[?2004h"]
[7.024472, "o", "root@9fac5ed1067a:/home/user# "]
[18.644803, "i", "python3 << 'EOF'\nimport re\n\n# Read the YAML file\nwith open('/etc/monitoring/alerts.yaml', 'r') as f:\n    yaml_content = f.read()\n\n# 1. Change HighLatency 'for' duration from 5m to 3m\nyaml_content = re.sub(\n    r'(- alert: HighLatency\\n.*?\\n.*?for: )5m',\n    r'\\g<1>3m',\n    yaml_content,\n    flags=re.DOTALL\n)\n\n# 2. Add escalation_level: critical to ServiceDown labels\n# Find ServiceDown and add the new label after existing labels\nyaml_content = re.sub(\n    r'(- alert: ServiceDown\\n.*?labels:\\n.*?severity: critical\\n.*?team: platform)',\n    r'\\1\\n          escalation_level: critical',\n    yaml_content,\n    flags=re.DOTALL\n)\n\n# 3. Add DiskSpaceLow alert before the closing of rules list (after HighMemoryUsage)\nnew_alert = '''      - alert: DiskSpaceLow\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\n        for: 10m\n        labels:\n          severity: warning\n          team: infrastructure\n        annotations:\n          summary: \"Disk space below 10% on "]
[18.64493, "i", "{{ $labels.instance }}\"'''\n\n# Add after HighMemoryUsage alert\nyaml_content = re.sub(\n    r'(- alert: HighMemoryUsage\\n.*?summary: \"Memory usage critical on \\{\\{ \\$labels.instance \\}\\}\")',\n    r'\\1\\n\\n' + new_alert,\n    yaml_content,\n    flags=re.DOTALL\n)\n\nwith open('/etc/monitoring/alerts.yaml', 'w') as f:\n    f.write(yaml_content)\n\nprint(\"YAML file updated successfully\")\nEOF\n"]
