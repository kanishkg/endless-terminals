[64.296133, "o", "=== YAML FILE ===\r\n"]
[64.29696, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 3m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n          escalation_level: critical\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n\r\n      - alert: DiskSpaceLow\r\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\r\n        for: 10m\r\n        labels:\r\n         "]
[64.29701, "o", " severity: warning\r\n          team: infrastructure\r\n        annotations:\r\n          summary: \"Disk space below 10% on {{ $labels.instance }}\"\r\n"]
[64.297082, "o", "\r\n=== TOML FILE ===\r\n"]
[64.29788, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 30\r\ntimeout = 10\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n\r\n[[endpoints]]\r\nname = \"payment-service\"\r\nurl = \"https://payments.internal.example.com/health\"\r\nexpected_status = 200\r\ncritical = true\r\nheaders = { Authorization = \"Bearer ${PAYMENTS_TOKEN}\" }\r\n"]
[64.298014, "o", "\r\n=== VALIDATION LOG ===\r\n"]
[64.298768, "o", "YAML_CHANGES:\r\n- alerts.yaml: HighLatency for duration updated\r\n- alerts.yaml: ServiceDown escalation_level added\r\n- alerts.yaml: DiskSpaceLow alert added\r\nTOML_CHANGES:\r\n- uptime.toml: global.check_interval updated to 30\r\n- uptime.toml: global.timeout added\r\n- uptime.toml: api-gateway endpoint modified\r\n- uptime.toml: payment-service endpoint added\r\nVALIDATION: COMPLETE\r\n"]
