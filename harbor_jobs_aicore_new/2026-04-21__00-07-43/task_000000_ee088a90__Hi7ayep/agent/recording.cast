[26.685342, "i", "cat > generate_report.py << 'EOF'\nimport os\nimport re\nfrom datetime import datetime\n\n# Parse log files\ndef parse_log(filename, category):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            match = re.match(r'\\[([^\\]]+)\\]\\s+([^|]+)\\|\\s*([^|]+)\\|\\s*([^|]+)\\|\\s*([^|]+)\\|\\s*(.+)', line.strip())\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = [x.strip() for x in match.groups()]\n                entries.append({\n                    'timestamp': timestamp,\n                    'service': service,\n                    'old_key': old_key,\n                    'new_key': new_key,\n                    'status': status,\n                    'rotated_by': rotated_by,\n                    'category': category\n                })\n    return entries\n\n# Parse all logs\naws_entries = parse_log('aws-rotation.log', 'AWS IAM')\ndb_entries = parse_log('db-rotation.log', 'Database')\napi_entries = parse_log('api-keys.log', 'API Keys')\n\n# Sort each category al"]
[26.685459, "i", "phabetically by service name\naws_entries.sort(key=lambda x: x['service'].lower())\ndb_entries.sort(key=lambda x: x['service'].lower())\napi_entries.sort(key=lambda x: x['service'].lower())\n\nall_entries = aws_entries + db_entries + api_entries\n\n# Calculate stats\ndef count_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = total - success\n    return total, success, failed\n\naws_total, aws_success, aws_failed = count_stats(aws_entries)\ndb_total, db_success, db_failed = count_stats(db_entries)\napi_total, api_success, api_failed = count_stats(api_entries)\ntotal_all = len(all_entries)\n\n# Get failed entries\nfailed_entries = [e for e in all_entries if e['status'] == 'FAILED']\n\n# Generate timestamp\nnow = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\n# Build markdown\nmd = f\"\"\"# Credential Rotation Report\n\n**Generated:** {now}\n**Total Credentials Rotated:** {total_all}\n\n## Summary by Category\n\n| Category | Count | Success | Failed |\n|----------|-------|--"]
[26.68551, "i", "-------|--------|\n| AWS IAM | {aws_total} | {aws_success} | {aws_failed} |\n| Database | {db_total} | {db_success} | {db_failed} |\n| API Keys | {api_total} | {api_success} | {api_failed} |\n\n## Detailed Rotation Log\n\n### AWS IAM Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in aws_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n### Database Credentials\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in db_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['status']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n### API Keys\n\n| Service | Old Key ID | New Key ID | Status | Rotated By |\n|---------|------------|------------|--------|------------|\n\"\"\"\n\nfor e in api_entries:\n    md += f\"| {e['service']} | {e['old_key']} | {e['new_key']} | {e['statu"]
[26.685552, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\r"]
[26.685611, "i", "s']} | {e['rotated_by']} |\\n\"\n\nmd += \"\"\"\n## Failed Rotations\n\n\"\"\"\n\nif failed_entries:\n    md += \"> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n\"\n    for e in failed_entries:\n        md += f\"- {e['service']} ({e['category']}): Rotation failed\\n\"\nelse:\n    md += \"> No failed rotations. All credentials rotated successfully.\\n\"\n\nmd += \"\"\"\n## Sign-off\n\n- [ ] All successful rotations verified\n- [ ] Failed rotations escalated\n- [ ] Old credentials scheduled for deletion\n\"\"\"\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write(md)\n\nprint(\"Report generated successfully!\")\nEOF\n"]
