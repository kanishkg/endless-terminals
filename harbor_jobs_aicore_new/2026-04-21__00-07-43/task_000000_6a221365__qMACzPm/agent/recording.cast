[33.346165, "o", "\u001b[?2004h> "]
[33.346563, "o", "    canonical = f\"{record['transaction_id']}|{record['timestamp']}|{record['account_id']}|{amount_str}|{record['currency']}|{record['status']}\"\r\n\u001b[?2004l\r"]
[33.3466, "o", "\u001b[?2004h> "]
[33.346786, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[33.34682, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.346851, "o", "\u001b[?2004h> "]
[33.346883, "o", "def main():\r\n\u001b[?2004l\r"]
[33.346914, "o", "\u001b[?2004h> "]
[33.346986, "o", "    valid_records = []\r\n\u001b[?2004l\r"]
[33.347019, "o", "\u001b[?2004h> "]
[33.34706, "o", "    errors = []\r\n\u001b[?2004l\r"]
[33.347091, "o", "\u001b[?2004h> "]
[33.34715, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[33.347177, "o", "\u001b[?2004h> "]
[33.347262, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[33.34729, "o", "\u001b[?2004h> "]
[33.347372, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[33.347402, "o", "\u001b[?2004h> "]
[33.347493, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[33.34752, "o", "\u001b[?2004h> "]
[33.3476, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[33.347631, "o", "\u001b[?2004h> "]
[33.347668, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[33.347701, "o", ">     \r\n\u001b[?2004l\r"]
[33.347722, "o", "\u001b[?2004h> "]
[33.347945, "o", "    processing_time = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[33.347976, "o", "\u001b[?2004h> "]
[33.348007, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.34804, "o", "> "]
[33.348122, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[33.348153, "o", "\u001b[?2004h> "]
[33.348283, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[33.348315, "o", "\u001b[?2004h> "]
[33.348446, "o", "            raw_content = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[33.348478, "o", "\u001b[?2004h> "]
[33.348592, "o", "            truncated = raw_content[:200]\r\n\u001b[?2004l\r"]
[33.348625, "o", "\u001b[?2004h> "]
[33.34866, "o", "            \r\n\u001b[?2004l\r"]
[33.348689, "o", "\u001b[?2004h> "]
[33.348781, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[33.348815, "o", "\u001b[?2004h> "]
[33.348858, "o", "            try:\r\n\u001b[?2004l\r"]
[33.34889, "o", "\u001b[?2004h> "]
[33.349022, "o", "                record = json.loads(raw_content)\r\n\u001b[?2004l\r"]
[33.349054, "o", "\u001b[?2004h> "]
[33.349164, "o", "            except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[33.349195, "o", "\u001b[?2004h> "]
[33.349284, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[33.349316, "o", "\u001b[?2004h> "]
[33.349447, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.349479, "o", "\u001b[?2004h> "]
[33.349619, "o", "                    'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[33.34965, "o", "\u001b[?2004h"]
[33.349681, "o", "> "]
[33.349809, "o", "                    'error_detail': 'invalid JSON syntax',\r\n\u001b[?2004l\r"]
[33.34984, "o", "\u001b[?2004h> "]
[33.349963, "o", "                    'raw_content': truncated\r\n\u001b[?2004l\r"]
[33.349994, "o", "\u001b[?2004h> "]
[33.350049, "o", "                })\r\n\u001b[?2004l\r"]
[33.350079, "o", "\u001b[?2004h> "]
[33.350223, "o", "                error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[33.350254, "o", "\u001b[?2004h> "]
[33.350321, "o", "                continue\r\n\u001b[?2004l\r"]
[33.350352, "o", "\u001b[?2004h> "]
[33.350391, "o", "            \r\n\u001b[?2004l\r"]
[33.350435, "o", "\u001b[?2004h> "]
[33.350514, "o", "            # Validate record\r\n\u001b[?2004l\r"]
[33.350545, "o", "\u001b[?2004h> "]
[33.350751, "o", "            is_valid, error_type, error_detail = validate_record(record)\r\n\u001b[?2004l\r"]
[33.350785, "o", "\u001b[?2004h> "]
[33.350819, "o", "            \r\n\u001b[?2004l\r"]
[33.350848, "o", "\u001b[?2004h> "]
[33.35093, "o", "            if not is_valid:\r\n\u001b[?2004l\r"]
[33.350963, "o", "\u001b[?2004h> "]
[33.351048, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[33.351081, "o", "\u001b[?2004h> "]
[33.351203, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.351236, "o", "\u001b[?2004h> "]
[33.351358, "o", "                    'error_type': error_type,\r\n\u001b[?2004l\r"]
[33.351389, "o", "\u001b[?2004h> "]
[33.351537, "o", "                    'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[33.35157, "o", "\u001b[?2004h> "]
[33.351693, "o", "                    'raw_content': truncated\r\n\u001b[?2004l\r"]
[33.351724, "o", "\u001b[?2004h> "]
[33.351779, "o", "                })\r\n\u001b[?2004l\r"]
[33.351811, "o", "\u001b[?2004h> "]
[33.351934, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[33.351966, "o", "\u001b[?2004h> "]
[33.352033, "o", "                continue\r\n\u001b[?2004l\r"]
[33.352066, "o", "\u001b[?2004h> "]
[33.352098, "o", "            \r\n\u001b[?2004l\r"]
[33.35213, "o", "\u001b[?2004h> "]
[33.352272, "o", "            # Compute hash and add to valid records\r\n\u001b[?2004l\r"]
[33.352305, "o", "\u001b[?2004h> "]
[33.35245, "o", "            integrity_hash = compute_hash(record)\r\n\u001b[?2004l\r"]
[33.352482, "o", "\u001b[?2004h> "]
[33.352568, "o", "            output_record = {\r\n\u001b[?2004l\r"]
[33.352599, "o", "\u001b[?2004h> "]
[33.352763, "o", "                'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[33.352796, "o", "\u001b[?2004h> "]
[33.352935, "o", "                'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[33.352968, "o", "\u001b[?2004h> "]
[33.35311, "o", "                'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[33.353142, "o", "\u001b[?2004h> "]
[33.353261, "o", "                'amount': record['amount'],\r\n\u001b[?2004l\r"]
[33.353293, "o", "\u001b[?2004h> "]
[33.353438, "o", "                'currency': record['currency'],\r\n\u001b[?2004l\r"]
[33.35347, "o", "\u001b[?2004h> "]
[33.353594, "o", "                'status': record['status'],\r\n\u001b[?2004l\r"]
[33.353626, "o", "\u001b[?2004h> "]
[33.353762, "o", "                'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[33.353793, "o", "\u001b[?2004h> "]
[33.353923, "o", "                'processed_at': processing_time\r\n\u001b[?2004l\r"]
[33.353955, "o", "\u001b[?2004h> "]
[33.353993, "o", "            }\r\n\u001b[?2004l\r"]
[33.354025, "o", "\u001b[?2004h> "]
[33.354154, "o", "            valid_records.append(output_record)\r\n\u001b[?2004l\r"]
[33.354187, "o", "\u001b[?2004h"]
[33.354217, "o", ">     \r\n\u001b[?2004l\r"]
[33.35425, "o", "\u001b[?2004h> "]
[33.35432, "o", "    total_lines = line_num\r\n\u001b[?2004l\r"]
[33.354353, "o", "\u001b[?2004h> "]
[33.354384, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.354416, "o", "> "]
[33.354511, "o", "    # Sort valid records by timestamp\r\n\u001b[?2004l\r"]
[33.354541, "o", "\u001b[?2004h> "]
[33.354687, "o", "    valid_records.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[33.354721, "o", "\u001b[?2004h> "]
[33.354749, "o", "    \r\n\u001b[?2004l\r"]
[33.354781, "o", "\u001b[?2004h> "]
[33.354856, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[33.354889, "o", "\u001b[?2004h> "]
[33.354993, "o", "    with open(OUTPUT_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.355024, "o", "\u001b[?2004h> "]
[33.355127, "o", "        for record in valid_records:\r\n\u001b[?2004l\r"]
[33.35516, "o", "\u001b[?2004h> "]
[33.355285, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[33.355316, "o", "\u001b[?2004h> "]
[33.355346, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.355376, "o", "> "]
[33.355434, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[33.355466, "o", "\u001b[?2004h> "]
[33.355565, "o", "    with open(ERROR_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.355597, "o", "\u001b[?2004h> "]
[33.355676, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[33.355708, "o", "\u001b[?2004h> "]
[33.355833, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[33.355866, "o", "\u001b[?2004h> "]
[33.355898, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.355931, "o", "> "]
[33.355991, "o", "    # Calculate success rate\r\n\u001b[?2004l\r"]
[33.356025, "o", "\u001b[?2004h> "]
[33.356128, "o", "    valid_count = len(valid_records)\r\n\u001b[?2004l\r"]
[33.356156, "o", "\u001b[?2004h> "]
[33.356247, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[33.356279, "o", "\u001b[?2004h> "]
[33.356508, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[33.356538, "o", "\u001b[?2004h> "]
[33.356565, "o", "    \r\n\u001b[?2004l\r"]
[33.356595, "o", "\u001b[?2004h> "]
[33.356647, "o", "    # Write summary\r\n\u001b[?2004l\r"]
[33.356676, "o", "\u001b[?2004h> "]
[33.356785, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.356816, "o", "\u001b[?2004h> "]
[33.356943, "o", "        f.write('AUDIT PROCESSING SUMMARY\\n')\r\n\u001b[?2004l\r"]
[33.356975, "o", "\u001b[?2004h> "]
[33.357102, "o", "        f.write('========================\\n')\r\n\u001b[?2004l\r"]
[33.357133, "o", "\u001b[?2004h> "]
[33.357262, "o", "        f.write(f'Input file: {INPUT_FILE}\\n')\r\n\u001b[?2004l\r"]
[33.357295, "o", "\u001b[?2004h> "]
[33.357466, "o", "        f.write(f'Total lines processed: {total_lines}\\n')\r\n\u001b[?2004l\r"]
[33.357498, "o", "\u001b[?2004h> "]
[33.357651, "o", "        f.write(f'Valid transactions: {valid_count}\\n')\r\n\u001b[?2004l\r"]
[33.357683, "o", "\u001b[?2004h> "]
[33.357826, "o", "        f.write(f'Failed records: {failed_count}\\n')\r\n\u001b[?2004l\r"]
[33.357859, "o", "\u001b[?2004h> "]
[33.35801, "o", "        f.write(f'Success rate: {success_rate:.2f}%\\n')\r\n\u001b[?2004l\r"]
[33.358044, "o", "\u001b[?2004h> "]
[33.358105, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[33.358138, "o", "\u001b[?2004h> "]
[33.358239, "o", "        f.write('Errors by type:\\n')\r\n\u001b[?2004l\r"]
[33.35827, "o", "\u001b[?2004h> "]
[33.358478, "o", "        f.write(f\"  malformed_json: {error_counts['malformed_json']}\\n\")\r\n\u001b[?2004l\r"]
[33.35851, "o", "\u001b[?2004h> "]
[33.358719, "o", "        f.write(f\"  missing_field: {error_counts['missing_field']}\\n\")\r\n\u001b[?2004l\r"]
[33.358751, "o", "\u001b[?2004h> "]
[33.35895, "o", "        f.write(f\"  invalid_format: {error_counts['invalid_format']}\\n\")\r\n\u001b[?2004l\r"]
[33.358984, "o", "\u001b[?2004h> "]
[33.359172, "o", "        f.write(f\"  invalid_value: {error_counts['invalid_value']}\\n\")\r\n\u001b[?2004l\r"]
[33.359205, "o", "\u001b[?2004h> "]
[33.359264, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[33.359296, "o", "\u001b[?2004h> "]
[33.359484, "o", "        f.write(f'Processing completed at: {processing_time}\\n')\r\n\u001b[?2004l\r"]
[33.359515, "o", "\u001b[?2004h> "]
[33.359546, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.359578, "o", "> "]
[33.359659, "o", "    print(f'Processing complete.')\r\n\u001b[?2004l\r"]
[33.359692, "o", "\u001b[?2004h> "]
[33.359855, "o", "    print(f'Valid: {valid_count}, Errors: {failed_count}')\r\n\u001b[?2004l\r"]
[33.359886, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.359917, "o", "\u001b[?2004h> "]
[33.359996, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[33.360027, "o", "\u001b[?2004h> "]
[33.360061, "o", "    main()\r\n\u001b[?2004l\r"]
[33.360088, "o", "\u001b[?2004h> "]
[33.36012, "o", "EOF\r\n\u001b[?2004l\r"]
[33.368299, "o", "\u001b[?2004h"]
[33.368336, "o", "root@df90fbbd26d4:/home/user# "]
[34.338069, "i", "python3 /home/user/audit/process_transactions.py\n"]
[34.338256, "o", "python3 /home/user/audit/process_transactions.py\r\n\u001b[?2004l\r"]
[34.364796, "o", "Processing complete.\r\nValid: 13, Errors: 12\r\n"]
[34.368578, "o", "\u001b[?2004h"]
[34.368593, "o", "root@df90fbbd26d4:/home/user# "]
[41.537848, "i", "cat /home/user/audit/processing_summary.txt\n"]
[41.538051, "o", "cat /home/user/audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[41.538895, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-21T00:29:15Z\r\n"]
[41.539061, "o", "\u001b[?2004h"]
[41.539096, "o", "root@df90fbbd26d4:/home/user# "]
[42.039893, "i", "cat /home/user/audit/clean_audit.jsonl\n"]
[42.040049, "o", "cat /home/user/audit/clean_audit.jsonl\r\n"]
[42.040093, "o", "\u001b[?2004l\r"]
