[33.334278, "i", "n errors:\n            f.write(json.dumps(error) + '\\n')\n    \n    # Calculate success rate\n    valid_count = len(valid_records)\n    failed_count = len(errors)\n    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\n    \n    # Write summary\n    with open(SUMMARY_FILE, 'w') as f:\n        f.write('AUDIT PROCESSING SUMMARY\\n')\n        f.write('========================\\n')\n        f.write(f'Input file: {INPUT_FILE}\\n')\n        f.write(f'Total lines processed: {total_lines}\\n')\n        f.write(f'Valid transactions: {valid_count}\\n')\n        f.write(f'Failed records: {failed_count}\\n')\n        f.write(f'Success rate: {success_rate:.2f}%\\n')\n        f.write('\\n')\n        f.write('Errors by type:\\n')\n        f.write(f\"  malformed_json: {error_counts['malformed_json']}\\n\")\n        f.write(f\"  missing_field: {error_counts['missing_field']}\\n\")\n        f.write(f\"  invalid_format: {error_counts['invalid_format']}\\n\")\n        f.write(f\"  invalid_value: {error_counts['invalid_value']}\\n\")\n        f.w"]
