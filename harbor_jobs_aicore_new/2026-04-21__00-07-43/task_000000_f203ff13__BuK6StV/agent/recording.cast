[39.703103, "i", "sqlite3 employees.db \"SELECT department, COUNT(*) as count, ROUND(AVG(salary), 2) as avg_salary, MIN(hire_date) as oldest_hire, MAX(hire_date) as newest_hire FROM employees GROUP BY department ORDER BY department;\"\n"]
[39.703774, "o", "sqlite3 employees.db \"SELECT department, COUNT(*) as count, ROUND(AVG(salary), 2) as avg_salary, MIN(hire_date) as oldest_hire, MAX(hire_date) as newest_hire FROM employees GROUP BY department ORDER BY department;\"\r\n\u001b[?2004l\r"]
