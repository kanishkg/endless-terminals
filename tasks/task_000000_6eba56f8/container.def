Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install necessary packages
    apt-get update && \
    apt-get install -y python3 python3-pip && \
    pip3 install pytest

    # Create user 'artifactmgr'
    useradd -m artifactmgr

    # Create parent directory structure
    mkdir -p /home/user/artifacts

    # Set ownership of the parent directory to artifactmgr
    chown -R artifactmgr:artifactmgr /home/user/artifacts

    # Ensure the home path is correct and owned by the user
    chown artifactmgr:artifactmgr /home/user

%runscript
    chmod 755 /home/user

    echo "Container started"

%environment
    # No need to override HOME; Apptainer handles it
    export PATH=/usr/local/bin:$PATH