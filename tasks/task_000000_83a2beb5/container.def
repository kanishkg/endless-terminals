Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install necessary packages
    apt-get update && \
    apt-get install -y python3 python3-pip git

    # Install pytest and dependencies
    pip3 install pytest

    # Create user and home directory
    useradd -m user
    chown -R user:user /home/user

    # Create project directory structure and files
    mkdir -p /home/user/projects/coolapp

    # Set file permissions for user
    chown -R user:user /home/user/projects/coolapp
    chmod -R 755 /home/user/projects/coolapp

    # Create initial VERSION file with content
    echo "v1.1" > /home/user/projects/coolapp/VERSION
    chown user:user /home/user/projects/coolapp/VERSION
    chmod 644 /home/user/projects/coolapp/VERSION

    # Create initial CHANGELOG.md with content
    cat <<EOL > /home/user/projects/coolapp/CHANGELOG.md
## [v1.1.3] - 2025-03-20  
- Fixed bug in parser
EOL
    chown user:user /home/user/projects/coolapp/CHANGELOG.md
    chmod 644 /home/user/projects/coolapp/CHANGELOG.md

%environment
    chmod 755 /home/user

    # Set the user environment
    export HOME=/home/user
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    echo "Container started. Ready to perform version bumping task."