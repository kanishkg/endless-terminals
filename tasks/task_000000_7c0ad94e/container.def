Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Create the user home directory if it does not exist
    mkdir -p /home/user

    # Install required tools: git and python3
    apt-get update && \
    apt-get install -y git python3

    # Install pytest
    apt-get install -y python3-pip && \
    pip3 install pytest

%environment
    # Set up environment variables if needed
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    chmod 755 /home/user
    echo "Container started. Use 'apptainer shell' to interact."

    # Set up environment variables if needed
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    echo "Container started. Use 'apptainer shell' to interact."

%test
    # No tests included in the .def file
    # Tests will be run in the container environment