Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install necessary packages
    apt update && apt install -y python3-pip git

    # Install pytest
    pip3 install pytest

    # Create user and set up home directory
    useradd -m -s /bin/bash user
    chown -R user:user /home/user

    # Create project directory
    mkdir -p /home/user/myproject
    chown -R user:user /home/user/myproject

    # Create package.json with initial version "1.2.3"
    cat <<EOF > /home/user/myproject/package.json
{
  "name": "myproject",
  "version": "1.2.3",
  "description": "Sample project for semantic versioning"
}
EOF
    chown user:user /home/user/myproject/package.json
    chmod 664 /home/user/myproject/package.json

    # Create CHANGELOG.md with the latest entry for version 1.2.3
    cat <<EOF > /home/user/myproject/CHANGELOG.md
## [1.2.3] - 2025-04-04
- Fix issue with login form validation (#731)
- Update documentation for deployment steps
EOF
    chown user:user /home/user/myproject/CHANGELOG.md
    chmod 664 /home/user/myproject/CHANGELOG.md

%runscript
    chmod 755 /home/user

    echo "Container is ready for testing."

%environment
    # Set user environment
    export HOME=/home/user
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export USER=user
    export LOGNAME=user