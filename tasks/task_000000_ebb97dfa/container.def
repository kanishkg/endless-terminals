Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install necessary packages
    apt-get update && apt-get install -y \
        curl \
        python3-pip \
        && rm -rf /var/lib/apt/lists/*

    # Install pytest
    pip3 install pytest

    # Create the user and set up the directory structure
    useradd -m user
    chown -R user:user /home/user

    # Ensure /home/user is world-executable so apptainer shell --pwd works
    chmod 755 /home/user

    # Create the required directory structure
    mkdir -p /home/user/api_docs/requests
    chown -R user:user /home/user/api_docs
    chmod -R 755 /home/user/api_docs

%runscript
    echo "Container started. Run the API test script inside the container."

%environment
    # Set up environment variables for the user
    export HOME=/home/user
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin