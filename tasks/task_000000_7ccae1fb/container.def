Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install necessary packages
    apt-get update
    apt-get install -y python3-pip

    # Create user
    useradd -m user

    # Create the syslog file with correct content
    SYSLOG_CONTENT=$(cat <<EOF
Apr  5 16:00:15 host systemd: System start completed in 2.000s
Apr  5 16:02:32 host kernel: CPU usage at 75%
Apr  5 16:10:00 host memory: Memory usage at 50%
Apr  5 16:30:41 host memory: Memory usage at 60%
Apr  5 16:40:03 host kernel: CPU usage at 78%
Apr  5 16:55:12 host cpu: High CPU load detected on core 3
Apr  5 17:00:20 host memory: Memory usage at 62%
Apr  5 17:03:11 host kernel: CPU usage at 80%
Apr  5 17:15:00 host systemd: Starting daily cron...
Apr  5 17:22:57 host memory: Memory usage at 65%
Apr  5 17:30:11 host systemd: Finished daily cron.
Apr  5 17:45:02 host kernel: CPU usage at 85%
Apr  5 18:00:05 host kernel: CPU usage at 90%
EOF
)

    echo "$SYSLOG_CONTENT" > /var/log/syslog

    # Set correct ownership and permissions for /var/log/syslog
    chown root:root /var/log/syslog
    chmod 644 /var/log/syslog

    # Set correct ownership and permissions for /home/user
    chown -R user:user /home/user
    chmod 755 /home/user

    # Install pytest
    pip3 install pytest

%runscript
    echo "This container is for testing an incident responder task."

%labels
    Author Vimal
    Task Performance Analysis