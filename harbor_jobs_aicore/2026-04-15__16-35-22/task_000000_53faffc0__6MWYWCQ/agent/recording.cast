[23.532442, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\nOUTPUT_FILE=\"/home/user/pipeline_results.log\"\nBASE_URL=\"http://localhost:8765\"\n\n# Clear output file\n> \"$OUTPUT_FILE\"\n\n# Function to process endpoint\nprocess_endpoint() {\n    local endpoint=$1\n    local response\n    local http_code\n    \n    # Make request and capture both body and status code\n    response=$(curl -s -w \"\\n%{http_code}\" \"${BASE_URL}${endpoint}\")\n    http_code=$(echo \"$response\" | tail -n1)\n    body=$(echo \"$response\" | sed '$d')\n    \n    echo \"ENDPOINT: $endpoint\" >> \"$OUTPUT_FILE\"\n    \n    if [ \"$http_code\" -eq 200 ]; then\n        # Count items in JSON array using grep to count id occurrences\n        count=$(echo \"$body\" | grep -o '\"id\"' | wc -l)\n        echo \"STATUS: SUCCESS\" >> \"$OUTPUT_FILE\"\n        echo \"COUNT: $count\" >> \"$OUTPUT_FILE\"\n    else\n        echo \"STATUS: ERROR\" >> \"$OUTPUT_FILE\"\n        echo \"ERROR_CODE: $http_code\" >> \"$OUTPUT_FILE\"\n    fi\n    \n    echo \"\" >> \"$OUTPUT_FILE\"\n}\n\n# Process all endpoints\nprocess_endpoint \"/ap"]
[23.532549, "i", "i/users\"\nprocess_endpoint \"/api/products\"\nprocess_endpoint \"/api/orders\"\nEOF\n"]
