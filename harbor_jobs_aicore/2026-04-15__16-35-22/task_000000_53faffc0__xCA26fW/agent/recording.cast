[16.435421, "o", "[1] 451\r\n"]
[16.435489, "o", "\u001b[?2004h"]
[16.435529, "o", "root@00f8b300808c:/home/user# "]
[16.943562, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT_FILE=\"/home/user/pipeline_results.log\"\nBASE_URL=\"http://localhost:8765\"\n\n# Clear output file\n> \"$OUTPUT_FILE\"\n\n# Function to process an endpoint\nprocess_endpoint() {\n    local endpoint=\"$1\"\n    local response\n    local http_code\n    local body\n    \n    # Make request and capture both body and status code\n    response=$(curl -s -w \"\\n%{http_code}\" \"${BASE_URL}${endpoint}\")\n    http_code=$(echo \"$response\" | tail -n1)\n    body=$(echo \"$response\" | sed '$d')\n    \n    echo \"ENDPOINT: ${endpoint}\" >> \"$OUTPUT_FILE\"\n    \n    if [ \"$http_code\" -eq 200 ]; then\n        # Count items in JSON array\n        count=$(echo \"$body\" | python3 -c \"import sys, json; print(len(json.load(sys.stdin)))\")\n        echo \"STATUS: SUCCESS\" >> \"$OUTPUT_FILE\"\n        echo \"COUNT: ${count}\" >> \"$OUTPUT_FILE\"\n    else\n        echo \"STATUS: ERROR\" >> \"$OUTPUT_FILE\"\n        echo \"ERROR_CODE: ${http_code}\" >> \"$OUTPUT_FILE\"\n    fi\n    \n    echo \"\" >> \"$OUTPUT_FILE\"\n}\n"]
[16.943695, "i", "\n# Process all endpoints\nprocess_endpoint \"/api/users\"\nprocess_endpoint \"/api/products\"\nprocess_endpoint \"/api/orders\"\n\n# Remove trailing blank line\nsed -i '$ { /^$/d }' \"$OUTPUT_FILE\"\nEOF\n"]
[16.943785, "o", "cat > /home/user/data_pipeline.sh << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
