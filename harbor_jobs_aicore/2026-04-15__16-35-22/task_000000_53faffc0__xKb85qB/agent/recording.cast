[17.453833, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\nBASE_URL=\"http://localhost:8765\"\nLOG_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear the log file\n> \"$LOG_FILE\"\n\n# Function to fetch endpoint and log results\nfetch_endpoint() {\n    local endpoint=\"$1\"\n    local response\n    local http_code\n    \n    # Make request and capture both response body and HTTP status code\n    response=$(curl -s -w \"\\n%{http_code}\" \"${BASE_URL}${endpoint}\")\n    http_code=$(echo \"$response\" | tail -n1)\n    body=$(echo \"$response\" | sed '$d')\n    \n    echo \"ENDPOINT: ${endpoint}\" >> \"$LOG_FILE\"\n    \n    if [ \"$http_code\" -eq 200 ]; then\n        # Count items in JSON array\n        count=$(echo \"$body\" | python3 -c \"import sys, json; print(len(json.load(sys.stdin)))\")\n        echo \"STATUS: SUCCESS\" >> \"$LOG_FILE\"\n        echo \"COUNT: ${count}\" >> \"$LOG_FILE\"\n    else\n        echo \"STATUS: ERROR\" >> \"$LOG_FILE\"\n        echo \"ERROR_CODE: ${http_code}\" >> \"$LOG_FILE\"\n    fi\n    \n    echo \"\" >> \"$LOG_FILE\"\n}\n\n# Fetch all endpoints\nfetch_"]
[17.453955, "i", "endpoint \"/api/users\"\nfetch_endpoint \"/api/products\"\nfetch_endpoint \"/api/orders\"\n\n# Remove trailing blank line\nsed -i '$ d' \"$LOG_FILE\"\n\necho \"Pipeline completed. Results saved to $LOG_FILE\"\nEOF\n"]
