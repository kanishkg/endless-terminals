[?2004l[?2004h>     const titleElements = document.querySelectorAll('span.titleline > a');
[?2004l[?2004h>     const result = [];
[?2004l[?2004h>     for (let i = 0; i < 5 && i < titleElements.length; i++) {
[?2004l[?2004h>       result.push(titleElements[i].innerText);
[?2004l[?2004h>     }
[?2004l[?2004h>     return result;
[?2004l[?2004h>   });
[?2004l[?2004h>   
[?2004l[?2004h>   await browser.close();
[?2004l[?2004h>   
[?2004l[?2004h>   // Format and save titles
[?2004l[?2004h>   const outputDir = '/home/user/project/scraped_data';
[?2004l[?2004h>   const titlesContent = titles.map((title, i) => `${i + 1}. ${title}`).join('\n');
[?2004l[?2004h>   fs.writeFileSync(path.join(outputDir, 'hn_titles.txt'), titlesContent);
[?2004l[?2004h>   
[?2004l[?2004h>   // Create log file
