[17.282711, "o", "root@93ac3fa5c321:/home/user# "]
[17.771831, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\nBASE_URL=\"http://localhost:8765\"\nOUTPUT_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear output file\n> \"$OUTPUT_FILE\"\n\n# Function to fetch endpoint and process results\nfetch_endpoint() {\n    local endpoint=\"$1\"\n    local url=\"${BASE_URL}${endpoint}\"\n    \n    # Make request and capture response and status code\n    response=$(curl -s -w \"\\n%{http_code}\" \"$url\")\n    http_code=$(echo \"$response\" | tail -n1)\n    body=$(echo \"$response\" | sed '$d')\n    \n    echo \"ENDPOINT: $endpoint\" >> \"$OUTPUT_FILE\"\n    \n    if [ \"$http_code\" -ge 200 ] && [ \"$http_code\" -lt 300 ]; then\n        # Success - count items in JSON array\n        count=$(echo \"$body\" | python3 -c \"import sys, json; print(len(json.load(sys.stdin)))\" 2>/dev/null || echo \"0\")\n        echo \"STATUS: SUCCESS\" >> \"$OUTPUT_FILE\"\n        echo \"COUNT: $count\" >> \"$OUTPUT_FILE\"\n    else\n        # Error\n        echo \"STATUS: ERROR\" >> \"$OUTPUT_FILE\"\n        echo \"ERROR_CODE: $http_code\" >> \"$OUTPUT_FILE\"\n    fi\n"]
[17.771969, "i", "    \n    echo \"\" >> \"$OUTPUT_FILE\"\n}\n\n# Fetch all endpoints\nfetch_endpoint \"/api/users\"\nfetch_endpoint \"/api/products\"\nfetch_endpoint \"/api/orders\"\n\n# Remove trailing blank line\nsed -i '$ { /^$/d }' \"$OUTPUT_FILE\"\nEOF\n"]
[17.772013, "o", "cat > /home/user/data_pipeline.sh << 'EOF'\r\n\u001b[?2004l\r"]
