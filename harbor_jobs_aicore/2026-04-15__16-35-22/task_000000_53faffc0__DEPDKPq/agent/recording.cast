[22.181332, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\nBASE_URL=\"http://localhost:8765\"\nRESULTS_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear results file\n> \"$RESULTS_FILE\"\n\n# Function to process endpoint\nprocess_endpoint() {\n    local endpoint=$1\n    local response_file=$(mktemp)\n    \n    # Make request and capture HTTP status code\n    http_code=$(curl -s -w \"%{http_code}\" -o \"$response_file\" \"${BASE_URL}${endpoint}\")\n    \n    echo \"ENDPOINT: $endpoint\" >> \"$RESULTS_FILE\"\n    \n    if [ \"$http_code\" -eq 200 ]; then\n        echo \"STATUS: SUCCESS\" >> \"$RESULTS_FILE\"\n        # Count items in JSON array using grep to count id fields\n        count=$(cat \"$response_file\" | python3 -c \"import sys, json; print(len(json.load(sys.stdin)))\")\n        echo \"COUNT: $count\" >> \"$RESULTS_FILE\"\n    else\n        echo \"STATUS: ERROR\" >> \"$RESULTS_FILE\"\n        echo \"ERROR_CODE: $http_code\" >> \"$RESULTS_FILE\"\n    fi\n    \n    rm -f \"$response_file\"\n}\n\n# Process all endpoints\nprocess_endpoint \"/api/users\"\necho \"\" >> \"$RESULTS_F"]
[22.181455, "i", "ILE\"\n\nprocess_endpoint \"/api/products\"\necho \"\" >> \"$RESULTS_FILE\"\n\nprocess_endpoint \"/api/orders\"\nEOF\n"]
