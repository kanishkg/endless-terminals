[17.229877, "i", "awk -F',' 'NR==1 {header=$0; split(header,h,\",\"); next} ($3==\"critical\" || $3==\"high\") && $5==\"open\" {incidents[NR]=$0; services[$4]=1; count++} END {print \"[\" > \"/home/user/incidents/priority_incidents.json\"; first=1; for(i in incidents) {if(!first) print \",\" >> \"/home/user/incidents/priority_incidents.json\"; first=0; split(incidents[i],f,\",\"); printf \"  {\\\"incident_id\\\": \\\"%s\\\", \\\"timestamp\\\": \\\"%s\\\", \\\"severity\\\": \\\"%s\\\", \\\"service\\\": \\\"%s\\\", \\\"status\\\": \\\"%s\\\", \\\"assigned_to\\\": \\\"%s\\\"}\" >> \"/home/user/incidents/priority_incidents.json\", f[1],f[2],f[3],f[4],f[5],f[6]} print \"\\n]\" >> \"/home/user/incidents/priority_incidents.json\"; print \"Priority Incidents Report\" > \"/home/user/incidents/triage_summary.txt\"; print \"Total critical/high open incidents: \" count >> \"/home/user/incidents/triage_summary.txt\"; print \"\" >> \"/home/user/incidents/triage_summary.txt\"; n=asorti(services,sorted); for(i=1;i<=n;i++) print sorted[i] >> \"/home/user/incidents/triage_summary.txt\"}' /home/user/incidents/incident_log.csv\n"]
