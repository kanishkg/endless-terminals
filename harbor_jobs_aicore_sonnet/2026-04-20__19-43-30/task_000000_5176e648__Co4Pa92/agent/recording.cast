[20.578303, "i", "cat > process_builds.py << 'EOF'\nimport json\nimport csv\n\n# Read and process iOS builds\nios_failed = []\nwith open('ios_builds.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    for row in reader:\n        if row['status'] == 'FAILED':\n            ios_failed.append({\n                'platform': 'ios',\n                'build_id': row['build_id'],\n                'app_name': row['app_name'],\n                'duration_minutes': round(float(row['build_time_seconds']) / 60, 2),\n                'branch': row['branch']\n            })\n\n# Read and process Android builds\nandroid_failed = []\nwith open('android_builds.json', 'r') as f:\n    android_builds = json.load(f)\n    for build in android_builds:\n        if build['result'] == 'FAILED':\n            android_failed.append({\n                'platform': 'android',\n                'build_id': build['buildId'],\n                'app_name': build['appName'],\n                'duration_minutes': round(float(build['buildDuration']) / 60, 2),\n                'branch': build['branc"]
[20.578439, "i", "h']\n            })\n\n# Combine and sort\nall_failed = ios_failed + android_failed\nall_failed.sort(key=lambda x: (x['app_name'], x['build_id']))\n\n# Write JSON report\nwith open('failed_builds_report.json', 'w') as f:\n    json.dump(all_failed, f, indent=2)\n\n# Write summary\nwith open('failure_summary.txt', 'w') as f:\n    f.write(f'Total failed builds: {len(all_failed)}\\n')\n    f.write(f'iOS failures: {len(ios_failed)}\\n')\n    f.write(f'Android failures: {len(android_failed)}\\n')\n\nprint(f'Processed {len(ios_failed)} iOS failures and {len(android_failed)} Android failures')\nprint(f'Total: {len(all_failed)} failed builds')\nEOF\n"]
