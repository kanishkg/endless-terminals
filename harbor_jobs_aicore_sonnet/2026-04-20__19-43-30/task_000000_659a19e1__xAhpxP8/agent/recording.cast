[17.568408, "o", "#!/bin/bash\r\n\r\n# Get current timestamp\r\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\r\n\r\n# Get disk usage percentage for root filesystem\r\n# Using df -h /, extracting the usage percentage (removing the % sign)\r\nUSAGE_PERCENT=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')\r\n\r\n# Filesystem mount point\r\nFILESYSTEM=\"/\"\r\n\r\n# Determine status based on usage threshold\r\nif [ \"$USAGE_PERCENT\" -ge 80 ]; then\r\n    STATUS=\"WARNING\"\r\nelse\r\n    STATUS=\"OK\"\r\nfi\r\n\r\n# Write to log file\r\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE_PERCENT}|${STATUS}\" > /home/user/logs/disk_status.log\r\n"]
