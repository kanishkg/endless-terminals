[73.609931, "o", "const puppeteer = require('puppeteer');\r\n\u001b[?2004l\r"]
[73.609977, "o", "\u001b[?2004h> "]
[73.610034, "o", "const fs = require('fs');\r\n\u001b[?2004l\r"]
[73.610067, "o", "\u001b[?2004h> "]
[73.610165, "o", "const path = require('path');\r\n\u001b[?2004l\r"]
[73.610201, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[73.61023, "o", "\u001b[?2004h> "]
[73.610273, "o", "(async () => {\r\n\u001b[?2004l\r"]
[73.610304, "o", "\u001b[?2004h> "]
[73.610423, "o", "  const browser = await puppeteer.launch({\r\n\u001b[?2004l\r"]
[73.610463, "o", "\u001b[?2004h> "]
[73.610516, "o", "    headless: 'new',\r\n\u001b[?2004l\r"]
[73.610549, "o", "\u001b[?2004h> "]
[73.610699, "o", "    args: ['--no-sandbox', '--disable-setuid-sandbox']\r\n\u001b[?2004l\r"]
[73.610732, "o", "\u001b[?2004h> "]
[73.61076, "o", "  });\r\n\u001b[?2004l\r"]
[73.610797, "o", "\u001b[?2004h> "]
[73.61083, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[73.610933, "o", "  const page = await browser.newPage();\r\n\u001b[?2004l\r"]
[73.610967, "o", "\u001b[?2004h> "]
[73.611202, "o", "  await page.goto('https://news.ycombinator.com', { waitUntil: 'networkidle2' });\r\n\u001b[?2004l\r"]
[73.611246, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[73.61128, "o", "\u001b[?2004h> "]
[73.611367, "o", "  // Extract top 5 story titles\r\n\u001b[?2004l\r"]
[73.611396, "o", "\u001b[?2004h> "]
[73.611522, "o", "  const titles = await page.evaluate(() => {\r\n\u001b[?2004l\r"]
[73.611555, "o", "\u001b[?2004h> "]
[73.611749, "o", "    const titleElements = document.querySelectorAll('.titleline > a');\r\n\u001b[?2004l\r"]
[73.611793, "o", "\u001b[?2004h> "]
[73.611856, "o", "    const topTitles = [];\r\n\u001b[?2004l\r"]
[73.611888, "o", "\u001b[?2004h> "]
[73.61207, "o", "    for (let i = 0; i < Math.min(5, titleElements.length); i++) {\r\n\u001b[?2004l\r"]
[73.612102, "o", "\u001b[?2004h> "]
[73.612275, "o", "      topTitles.push(titleElements[i].textContent.trim());\r\n\u001b[?2004l\r"]
[73.61231, "o", "\u001b[?2004h> "]
[73.612342, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[73.612375, "o", "> "]
[73.612426, "o", "    return topTitles;\r\n\u001b[?2004l\r"]
[73.612458, "o", "\u001b[?2004h> "]
[73.612489, "o", "  });\r\n\u001b[?2004l\r\u001b[?2004h"]
[73.612519, "o", ">   \r\n\u001b[?2004l\r"]
[73.61255, "o", "\u001b[?2004h> "]
[73.61262, "o", "  await browser.close();\r\n\u001b[?2004l\r"]
[73.612652, "o", "\u001b[?2004h> "]
[73.612683, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[73.612714, "o", "> "]
[73.61277, "o", "  // Format and save titles\r\n\u001b[?2004l\r"]
[73.612801, "o", "\u001b[?2004h> "]
[73.612954, "o", "  const outputDir = '/home/user/project/scraped_data';\r\n\u001b[?2004l\r"]
[73.612989, "o", "\u001b[?2004h> "]
[73.613163, "o", "  const outputFile = path.join(outputDir, 'hn_titles.txt');\r\n\u001b[?2004l\r"]
[73.613204, "o", "\u001b[?2004h> "]
[73.613233, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[73.613264, "o", "> "]
[73.613496, "o", "  const formattedTitles = titles.map((title, index) => `${index + 1}. ${title}`).join('\\n');\r\n\u001b[?2004l\r"]
[73.613527, "o", "\u001b[?2004h> "]
[73.613666, "o", "  fs.writeFileSync(outputFile, formattedTitles);\r\n\u001b[?2004l\r"]
[73.613703, "o", "\u001b[?2004h> "]
[73.613735, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[73.613765, "o", "> "]
[73.613886, "o", "  console.log('Scraping completed successfully!');\r\n\u001b[?2004l\r"]
[73.613918, "o", "\u001b[?2004h> "]
[73.614063, "o", "  console.log(`Extracted ${titles.length} titles`);\r\n\u001b[?2004l\r"]
[73.614095, "o", "\u001b[?2004h> "]
[73.614121, "o", "})();\r\n\u001b[?2004l\r"]
[73.614162, "o", "\u001b[?2004h> "]
[73.614191, "o", "EOF\r\n\u001b[?2004l\r"]
