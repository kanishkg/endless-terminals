[55.960991, "i", "cat > scraper.js << 'EOF'\nconst puppeteer = require('puppeteer');\nconst fs = require('fs');\nconst path = require('path');\n\n(async () => {\n  const browser = await puppeteer.launch({\n    headless: 'new',\n    args: ['--no-sandbox', '--disable-setuid-sandbox']\n  });\n  \n  const page = await browser.newPage();\n  await page.goto('https://news.ycombinator.com', { waitUntil: 'networkidle2' });\n  \n  // Extract the top 5 story titles\n  const titles = await page.evaluate(() => {\n    const titleElements = document.querySelectorAll('.titleline > a');\n    const topTitles = [];\n    \n    for (let i = 0; i < 5 && i < titleElements.length; i++) {\n      topTitles.push(titleElements[i].textContent);\n    }\n    \n    return topTitles;\n  });\n  \n  await browser.close();\n  \n  // Format and save titles\n  const formattedTitles = titles.map((title, index) => `${index + 1}. ${title}`).join('\\n');\n  const outputPath = path.join(__dirname, 'scraped_data', 'hn_titles.txt');\n  fs.writeFileSync(outputPath, formattedTitles, 'utf8');\n  \n  console"]
[55.961119, "i", ".log('Scraping completed successfully!');\n  console.log('Titles saved to:', outputPath);\n})();\nEOF\n"]
