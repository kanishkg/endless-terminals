[75.629315, "o", "\u001b[?2004h> "]
[75.62937, "o", "    headless: 'new',\r\n\u001b[?2004l\r"]
[75.629411, "o", "\u001b[?2004h> "]
[75.629581, "o", "    args: ['--no-sandbox', '--disable-setuid-sandbox']\r\n\u001b[?2004l\r"]
[75.629623, "o", "\u001b[?2004h>   });\r\n\u001b[?2004l\r"]
[75.629653, "o", "\u001b[?2004h>   \r\n"]
[75.629691, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[75.6298, "o", "  const page = await browser.newPage();\r\n\u001b[?2004l\r"]
[75.62983, "o", "\u001b[?2004h> "]
[75.630061, "o", "  await page.goto('https://news.ycombinator.com', { waitUntil: 'networkidle2' });\r\n\u001b[?2004l\r"]
[75.630094, "o", "\u001b[?2004h>   \r\n"]
[75.630122, "o", "\u001b[?2004l\r\u001b[?2004h"]
[75.630155, "o", "> "]
[75.630229, "o", "  // Extract the top 5 story titles\r\n\u001b[?2004l\r"]
[75.63026, "o", "\u001b[?2004h> "]
[75.630385, "o", "  const titles = await page.evaluate(() => {\r\n\u001b[?2004l\r"]
[75.630415, "o", "\u001b[?2004h> "]
[75.630662, "o", "    const titleElements = document.querySelectorAll('.titleline > a');\r\n\u001b[?2004l\r"]
[75.630695, "o", "\u001b[?2004h"]
[75.630728, "o", "> "]
[75.630799, "o", "    const results = [];\r\n\u001b[?2004l\r"]
[75.630833, "o", "\u001b[?2004h"]
[75.630866, "o", "> "]
[75.631087, "o", "    for (let i = 0; i < 5 && i < titleElements.length; i++) {\r\n"]
[75.631115, "o", "\u001b[?2004l\r\u001b[?2004h"]
[75.631149, "o", "> "]
[75.631308, "o", "      results.push(titleElements[i].innerText);\r\n"]
[75.63134, "o", "\u001b[?2004l\r\u001b[?2004h"]
[75.631373, "o", "> "]
[75.631405, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[75.631436, "o", "> "]
[75.631521, "o", "    return results;\r\n\u001b[?2004l\r"]
[75.631557, "o", "\u001b[?2004h> "]
[75.631588, "o", "  });\r\n\u001b[?2004l\r"]
[75.63162, "o", "\u001b[?2004h"]
[75.631652, "o", ">   \r\n\u001b[?2004l\r"]
[75.631684, "o", "\u001b[?2004h> "]
[75.63179, "o", "  await browser.close();\r\n\u001b[?2004l\r"]
[75.631824, "o", "\u001b[?2004h> "]
[75.631856, "o", "  \r\n\u001b[?2004l\r"]
[75.631885, "o", "\u001b[?2004h> "]
[75.63201, "o", "  // Format and save the titles\r\n\u001b[?2004l\r"]
[75.632042, "o", "\u001b[?2004h"]
[75.632075, "o", "> "]
