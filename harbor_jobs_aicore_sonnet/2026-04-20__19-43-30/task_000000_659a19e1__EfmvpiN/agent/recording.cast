[11.40497, "i", "mkdir -p /home/user/scripts /home/user/logs\n"]
[11.405147, "o", "mkdir -p /home/user/scripts /home/user/logs\r\n\u001b[?2004l\r"]
[11.409159, "o", "\u001b[?2004h"]
[11.409247, "o", "root@07b31b730cfc:/home/user# "]
[11.509164, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Get timestamp in required format\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Get disk usage percentage for root filesystem\n# Using df with -h flag and parsing the output\nUSAGE_PERCENT=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')\n\n# Filesystem mount point\nFILESYSTEM=\"/\"\n\n# Determine status based on usage percentage\nif [ \"$USAGE_PERCENT\" -ge 80 ]; then\n    STATUS=\"WARNING\"\nelse\n    STATUS=\"OK\"\nfi\n\n# Write to log file in the specified format\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE_PERCENT}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
[11.509368, "o", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\r\n"]
