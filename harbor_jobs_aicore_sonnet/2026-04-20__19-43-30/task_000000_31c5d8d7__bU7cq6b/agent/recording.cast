[22.158966, "i", "python3 << 'EOF'\nimport csv\nimport json\n\nwith open('filtered_incidents.csv', 'r') as csvfile:\n    reader = csv.DictReader(csvfile)\n    incidents = [row for row in reader]\n\nwith open('priority_incidents.json', 'w') as jsonfile:\n    json.dump(incidents, jsonfile, indent=2)\n\nprint(f\"Converted {len(incidents)} incidents to JSON\")\nEOF\n"]
