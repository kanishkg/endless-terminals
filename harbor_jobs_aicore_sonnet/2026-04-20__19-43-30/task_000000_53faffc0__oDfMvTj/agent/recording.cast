[27.146518, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear output file\n> \"$OUTPUT_FILE\"\n\n# Function to process endpoint\nprocess_endpoint() {\n    local endpoint=$1\n    local url=\"http://localhost:8765${endpoint}\"\n    \n    # Make request and capture response and status code\n    response=$(curl -s -w \"\\n%{http_code}\" \"$url\")\n    \n    # Extract status code (last line) and body (everything else)\n    status_code=$(echo \"$response\" | tail -n 1)\n    body=$(echo \"$response\" | sed '$d')\n    \n    echo \"ENDPOINT: ${endpoint}\" >> \"$OUTPUT_FILE\"\n    \n    if [ \"$status_code\" -eq 200 ]; then\n        echo \"STATUS: SUCCESS\" >> \"$OUTPUT_FILE\"\n        # Count items in JSON array\n        count=$(echo \"$body\" | grep -o '{' | wc -l)\n        echo \"COUNT: ${count}\" >> \"$OUTPUT_FILE\"\n    else\n        echo \"STATUS: ERROR\" >> \"$OUTPUT_FILE\"\n        echo \"ERROR_CODE: ${status_code}\" >> \"$OUTPUT_FILE\"\n    fi\n    \n    echo \"\" >> \"$OUTPUT_FILE\"\n}\n\n# Process all endpoints\nproc"]
[27.146645, "i", "ess_endpoint \"/api/users\"\nprocess_endpoint \"/api/products\"\nprocess_endpoint \"/api/orders\"\n\nEOF\n"]
