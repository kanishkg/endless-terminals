[8.62459, "o", "[\r\n  {\"buildId\": \"AND001\", \"appName\": \"MobileApp\", \"buildDuration\": 334, \"result\": \"SUCCESS\", \"branch\": \"main\", \"date\": \"2024-01-15\"},\r\n  {\"buildId\": \"AND002\", \"appName\": \"MobileApp\", \"buildDuration\": 412, \"result\": \"FAILED\", \"branch\": \"feature/login\", \"date\": \"2024-01-15\"},\r\n  {\"buildId\": \"AND003\", \"appName\": \"Analytics\", \"buildDuration\": 287, \"result\": \"SUCCESS\", \"branch\": \"main\", \"date\": \"2024-01-15\"},\r\n  {\"buildId\": \"AND004\", \"appName\": \"ChatModule\", \"buildDuration\": 378, \"result\": \"FAILED\", \"branch\": \"develop\", \"date\": \"2024-01-15\"},\r\n  {\"buildId\": \"AND005\", \"appName\": \"PaymentSDK\", \"buildDuration\": 445, \"result\": \"FAILED\", \"branch\": \"feature/checkout\", \"date\": \"2024-01-15\"}\r\n]\r\n"]
