[50.776738, "i", "python3 << 'EOF'\nimport json\n\n# Verify the JSON report\nwith open('failed_builds_report.json', 'r') as f:\n    data = json.load(f)\n    print(f\"Total records: {len(data)}\")\n    print(\"\\nRecords sorted by app_name, then build_id:\")\n    for record in data:\n        print(f\"  {record['app_name']:15} | {record['build_id']:10} | {record['platform']:7} | {record['duration_minutes']:6.2f} min | {record['branch']}\")\n    \n    # Verify sorting\n    is_sorted = all(data[i]['app_name'] < data[i+1]['app_name'] or \n                    (data[i]['app_name'] == data[i+1]['app_name'] and data[i]['build_id'] <= data[i+1]['build_id'])\n                    for i in range(len(data)-1))\n    print(f\"\\nSorting correct: {is_sorted}\")\n    \n    # Verify all required fields\n    required_fields = {'platform', 'build_id', 'app_name', 'duration_minutes', 'branch'}\n    all_have_fields = all(set(record.keys()) == required_fields for record in data)\n    print(f\"All records have correct fields: {all_have_fields}\")\n\nprint(\"\\n=== Verifying summary file"]
[50.776867, "i", " ===\\n\")\nwith open('failure_summary.txt', 'r') as f:\n    content = f.read()\n    print(content)\n    lines = content.strip().split('\\n')\n    print(f\"Number of lines: {len(lines)}\")\nEOF\n"]
