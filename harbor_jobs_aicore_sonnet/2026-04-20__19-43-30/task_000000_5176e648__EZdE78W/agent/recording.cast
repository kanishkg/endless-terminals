[50.781296, "o", "\u001b[?2004h> "]
[50.781364, "o", "    content = f.read()\r\n\u001b[?2004l\r"]
[50.781396, "o", "\u001b[?2004h> "]
[50.781451, "o", "    print(content)\r\n\u001b[?2004l\r"]
[50.781482, "o", "\u001b[?2004h> "]
