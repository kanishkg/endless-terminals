[50.779569, "o", "                    (data[i]['app_name'] == data[i+1]['app_name'] and data[i]['build_id'] <= data[i+1]['build_id'])\r\n\u001b[?2004l\r"]
[50.779613, "o", "\u001b[?2004h"]
[50.779644, "o", "> "]
[50.779809, "o", "                    for i in range(len(data)-1))\r\n\u001b[?2004l\r"]
[50.779847, "o", "\u001b[?2004h"]
[50.779881, "o", "> "]
[50.779987, "o", "    print(f\"\\nSorting correct: {is_sorted}\")\r\n\u001b[?2004l\r"]
[50.780019, "o", "\u001b[?2004h> "]
[50.780047, "o", "    \r\n\u001b[?2004l\r"]
[50.780081, "o", "\u001b[?2004h> "]
[50.780158, "o", "    # Verify all required fields\r\n\u001b[?2004l\r"]
[50.780192, "o", "\u001b[?2004h> "]
[50.780431, "o", "    required_fields = {'platform', 'build_id', 'app_name', 'duration_minutes', 'branch'}\r\n\u001b[?2004l\r"]
[50.780465, "o", "\u001b[?2004h> "]
[50.78071, "o", "    all_have_fields = all(set(record.keys()) == required_fields for record in data)\r\n\u001b[?2004l\r"]
[50.780747, "o", "\u001b[?2004h> "]
[50.78093, "o", "    print(f\"All records have correct fields: {all_have_fields}\")\r\n\u001b[?2004l\r"]
[50.780964, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.780996, "o", "\u001b[?2004h> "]
[50.781113, "o", "print(\"\\n=== Verifying summary file ===\\n\")\r\n\u001b[?2004l\r"]
[50.781141, "o", "\u001b[?2004h> "]
