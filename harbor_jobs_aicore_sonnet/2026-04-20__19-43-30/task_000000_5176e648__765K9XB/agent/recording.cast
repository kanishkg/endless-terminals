[23.057667, "i", "python3 << 'EOF'\nimport json\nimport csv\n\n# Read and process iOS builds\nios_failed = []\nwith open('ios_builds.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    for row in reader:\n        if row['status'] == 'FAILED':\n            ios_failed.append({\n                'platform': 'ios',\n                'build_id': row['build_id'],\n                'app_name': row['app_name'],\n                'duration_minutes': round(int(row['build_time_seconds']) / 60, 2),\n                'branch': row['branch']\n            })\n\n# Read and process Android builds\nandroid_failed = []\nwith open('android_builds.json', 'r') as f:\n    android_data = json.load(f)\n    for build in android_data:\n        if build['result'] == 'FAILED':\n            android_failed.append({\n                'platform': 'android',\n                'build_id': build['buildId'],\n                'app_name': build['appName'],\n                'duration_minutes': round(build['buildDuration'] / 60, 2),\n                'branch': build['branch']\n            })\n\n# Combine"]
[23.057796, "i", " and sort\nall_failed = ios_failed + android_failed\nall_failed.sort(key=lambda x: (x['app_name'], x['build_id']))\n\n# Write unified JSON report\nwith open('failed_builds_report.json', 'w') as f:\n    json.dump(all_failed, f, indent=2)\n\n# Write summary file\ntotal = len(all_failed)\nios_count = len(ios_failed)\nandroid_count = len(android_failed)\n\nwith open('failure_summary.txt', 'w') as f:\n    f.write(f'Total failed builds: {total}\\n')\n    f.write(f'iOS failures: {ios_count}\\n')\n    f.write(f'Android failures: {android_count}\\n')\n\nprint(f'Processing complete!')\nprint(f'Total failed builds: {total}')\nprint(f'iOS failures: {ios_count}')\nprint(f'Android failures: {android_count}')\nEOF\n"]
