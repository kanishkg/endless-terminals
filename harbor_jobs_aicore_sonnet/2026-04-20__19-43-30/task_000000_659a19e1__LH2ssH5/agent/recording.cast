[10.578351, "o", "mkdir -p /home/user/scripts /home/user/logs\r\n\u001b[?2004l\r"]
[10.581424, "o", "\u001b[?2004hroot@4183b38c3f79:/home/user# "]
[10.676358, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Get disk usage percentage for root filesystem\nUSAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')\n\n# Get current timestamp\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Filesystem mount point\nFILESYSTEM=\"/\"\n\n# Determine status based on usage threshold\nif [ \"$USAGE\" -ge 80 ]; then\n    STATUS=\"WARNING\"\nelse\n    STATUS=\"OK\"\nfi\n\n# Write to log file\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
