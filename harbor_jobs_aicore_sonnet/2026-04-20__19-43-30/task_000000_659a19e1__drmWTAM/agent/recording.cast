[10.521326, "o", "mkdir -p /home/user/scripts /home/user/logs\r\n\u001b[?2004l\r"]
[10.525152, "o", "\u001b[?2004hroot@e527bea0a5ca:/home/user# "]
[10.615835, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Get disk usage for root filesystem\nUSAGE_PERCENT=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')\n\n# Get current timestamp\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Determine status based on usage\nif [ \"$USAGE_PERCENT\" -ge 80 ]; then\n    STATUS=\"WARNING\"\nelse\n    STATUS=\"OK\"\nfi\n\n# Write to log file\necho \"${TIMESTAMP}|/|${USAGE_PERCENT}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
[10.616026, "o", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\r\n\u001b[?2004l\r"]
