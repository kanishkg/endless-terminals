[9.463326, "o", "mkdir -p /home/user/scripts /home/user/logs\r\n\u001b[?2004l\r"]
[9.467348, "o", "\u001b[?2004h"]
[9.467424, "o", "root@3a5886bd2a42:/home/user# "]
[9.560349, "i", "cat > /home/user/scripts/disk_monitor.sh << 'EOF'\n#!/bin/bash\n\n# Get current timestamp\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\n\n# Get disk usage for root filesystem\nFILESYSTEM=\"/\"\nUSAGE_PERCENT=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')\n\n# Determine status based on usage\nif [ \"$USAGE_PERCENT\" -lt 80 ]; then\n    STATUS=\"OK\"\nelse\n    STATUS=\"WARNING\"\nfi\n\n# Write to log file\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE_PERCENT}|${STATUS}\" > /home/user/logs/disk_status.log\nEOF\n"]
