[15.528887, "o", "#!/bin/bash\r\n\r\n# Get disk usage percentage for root filesystem\r\nUSAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')\r\n\r\n# Get current timestamp\r\nTIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\r\n\r\n# Filesystem mount point\r\nFILESYSTEM=\"/\"\r\n\r\n# Determine status based on usage threshold\r\nif [ \"$USAGE\" -ge 80 ]; then\r\n    STATUS=\"WARNING\"\r\nelse\r\n    STATUS=\"OK\"\r\nfi\r\n\r\n# Write to log file in the specified format\r\necho \"${TIMESTAMP}|${FILESYSTEM}|${USAGE}|${STATUS}\" > /home/user/logs/disk_status.log\r\n"]
