[?2004hroot@f25561f4557d:/home/user# clear
[?2004l[H[J[?2004hroot@f25561f4557d:/home/user# mkdir -p /home/user/scripts /home/user/logs
[?2004l[?2004hroot@f25561f4557d:/home/user# cat > /home/user/scripts/disk_monitor.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Get disk usage for root filesystem
[?2004l[?2004h> USAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
[?2004l[?2004h> 
[?2004l[?2004h> # Get current timestamp
[?2004l[?2004h> TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
[?2004l[?2004h> 
[?2004l[?2004h> # Set filesystem
[?2004l[?2004h> FILESYSTEM="/"
[?2004l[?2004h> 
[?2004l[?2004h> # Determine status based on usage threshold
[?2004l[?2004h> if [ "$USAGE" -ge 80 ]; then
[?2004l[?2004h>     STATUS="WARNING"
[?2004l[?2004h> else
[?2004l[?2004h>     STATUS="OK"
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Write to log file
[?2004l[?2004h> echo "${TIMESTAMP}|${FILESYSTEM}|${USAGE}|${STATUS}" > /home/user/logs/disk_status.log
[?2004l[?2004h> EOF
[?2004l[?2004hroot@f25561f4557d:/home/user# chmod +x /home/user/scripts/disk_monitor.sh
