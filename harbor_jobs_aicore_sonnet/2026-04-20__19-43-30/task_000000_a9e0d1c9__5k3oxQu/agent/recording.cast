[59.151115, "i", "cat > scraper.js << 'EOF'\nconst puppeteer = require('puppeteer');\nconst fs = require('fs');\nconst path = require('path');\n\n(async () => {\n  const browser = await puppeteer.launch({\n    headless: 'new',\n    args: ['--no-sandbox', '--disable-setuid-sandbox']\n  });\n  \n  const page = await browser.newPage();\n  await page.goto('https://news.ycombinator.com', { waitUntil: 'networkidle2' });\n  \n  // Extract the top 5 story titles\n  const titles = await page.evaluate(() => {\n    const titleElements = document.querySelectorAll('.titleline > a');\n    const topTitles = [];\n    for (let i = 0; i < 5 && i < titleElements.length; i++) {\n      topTitles.push(titleElements[i].innerText);\n    }\n    return topTitles;\n  });\n  \n  await browser.close();\n  \n  // Format and save titles\n  const outputDir = '/home/user/project/scraped_data';\n  const titlesFile = path.join(outputDir, 'hn_titles.txt');\n  const logFile = path.join(outputDir, 'scrape_log.txt');\n  \n  // Create numbered titles\n  const numberedTitles = titles.map((title, in"]
[59.151233, "i", "dex) => `${index + 1}. ${title}`).join('\\n');\n  fs.writeFileSync(titlesFile, numberedTitles);\n  \n  // Create log file\n  const logContent = `STATUS: SUCCESS\\nITEMS_SCRAPED: 5\\nSOURCE: https://news.ycombinator.com`;\n  fs.writeFileSync(logFile, logContent);\n  \n  console.log('Scraping completed successfully!');\n  console.log(`Titles saved to: ${titlesFile}`);\n  console.log(`Log saved to: ${logFile}`);\n})();\nEOF\n"]
