[28.370244, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear the output file\n> \"$OUTPUT_FILE\"\n\n# Function to process endpoint\nprocess_endpoint() {\n    local endpoint=$1\n    local temp_response=$(mktemp)\n    local temp_headers=$(mktemp)\n    \n    # Make request and capture response and status code\n    http_code=$(curl -s -w \"%{http_code}\" -o \"$temp_response\" \"http://localhost:8765${endpoint}\")\n    \n    echo \"ENDPOINT: ${endpoint}\" >> \"$OUTPUT_FILE\"\n    \n    if [ \"$http_code\" -eq 200 ]; then\n        echo \"STATUS: SUCCESS\" >> \"$OUTPUT_FILE\"\n        # Count items in JSON array\n        count=$(grep -o '{' \"$temp_response\" | wc -l)\n        echo \"COUNT: ${count}\" >> \"$OUTPUT_FILE\"\n    else\n        echo \"STATUS: ERROR\" >> \"$OUTPUT_FILE\"\n        echo \"ERROR_CODE: ${http_code}\" >> \"$OUTPUT_FILE\"\n    fi\n    \n    # Clean up temp files\n    rm -f \"$temp_response\" \"$temp_headers\"\n}\n\n# Process each endpoint\nprocess_endpoint \"/api/users\"\necho \"\" >> \"$OUTPUT_FILE\"\n"]
[28.370298, "i", "\nprocess_endpoint \"/api/products\"\necho \"\" >> \"$OUTPUT_FILE\"\n\nprocess_endpoint \"/api/orders\"\n\nEOF\n"]
