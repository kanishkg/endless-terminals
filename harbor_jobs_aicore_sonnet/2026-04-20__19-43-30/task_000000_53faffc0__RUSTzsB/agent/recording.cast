[21.220777, "i", "cat > /home/user/data_pipeline.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT_FILE=\"/home/user/pipeline_results.log\"\n\n# Clear the output file\n> \"$OUTPUT_FILE\"\n\n# Function to process endpoint\nprocess_endpoint() {\n    local endpoint=$1\n    local url=\"http://localhost:8765${endpoint}\"\n    \n    # Make the request and capture response and status code\n    response=$(curl -s -w \"\\n%{http_code}\" \"$url\")\n    \n    # Extract status code (last line)\n    status_code=$(echo \"$response\" | tail -n 1)\n    \n    # Extract body (all but last line)\n    body=$(echo \"$response\" | sed '$d')\n    \n    # Write endpoint\n    echo \"ENDPOINT: ${endpoint}\" >> \"$OUTPUT_FILE\"\n    \n    # Check if successful (2xx status code)\n    if [ \"$status_code\" -ge 200 ] && [ \"$status_code\" -lt 300 ]; then\n        echo \"STATUS: SUCCESS\" >> \"$OUTPUT_FILE\"\n        # Count items in JSON array\n        count=$(echo \"$body\" | python3 -c \"import sys, json; data = json.load(sys.stdin); print(len(data))\")\n        echo \"COUNT: ${count}\" >> \"$OUTPUT_FILE\"\n    else\n   "]
[21.220917, "i", "     echo \"STATUS: ERROR\" >> \"$OUTPUT_FILE\"\n        echo \"ERROR_CODE: ${status_code}\" >> \"$OUTPUT_FILE\"\n    fi\n    \n    # Add blank line separator\n    echo \"\" >> \"$OUTPUT_FILE\"\n}\n\n# Process all three endpoints\nprocess_endpoint \"/api/users\"\nprocess_endpoint \"/api/products\"\nprocess_endpoint \"/api/orders\"\n\nEOF\n"]
