[14.823256, "i", "python3 -c '\nimport json\nimport csv\n\nwith open(\"/home/user/data/users.json\", \"r\") as f:\n    users = json.load(f)\n\nwith open(\"/home/user/output/users.csv\", \"w\", newline=\"\") as f:\n    writer = csv.DictWriter(f, fieldnames=[\"id\", \"name\", \"email\", \"signup_date\"], quoting=csv.QUOTE_MINIMAL)\n    writer.writeheader()\n    writer.writerows(users)\n'\n"]
