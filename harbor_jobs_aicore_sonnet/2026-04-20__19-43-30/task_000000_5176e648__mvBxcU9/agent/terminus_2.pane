[?2004hroot@a99592dc3465:/home/user/pipelines# cat > process_builds.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Extract failed iOS builds and convert to JSON format
[?2004l[?2004h> echo '[' > /tmp/ios_failed.json
[?2004l[?2004h> awk -F',' 'NR>1 && $4=="FAILED" {
[?2004l[?2004h>   duration = sprintf("%.2f", $3/60)
[?2004l[?2004h>   printf "{\"platform\":\"ios\",\"build_id\":\"%s\",\"app_name\":\"%s\",\"duration_minutes\":%s,\"branch\":\"%s\"},\n", $1, $2, duration, $5
[?2004l[?2004h> }' ios_builds.csv >> /tmp/ios_failed.json
[?2004l[?2004h> 
[?2004l[?2004h> # Extract failed Android builds and convert to JSON format
[?2004l[?2004h> jq -r '.[] | select(.result=="FAILED") | 
[?2004l[?2004h>   {platform:"android", build_id:.buildId, app_name:.appName, duration_minutes:((.buildDuration/60*100|round)/100), branch:.branch}' \
[?2004l[?2004h>   android_builds.json > /tmp/android_failed.json
[?2004l[?2004h> 
[?2004l[?2004h> # Combine and format
[?2004l[?2004h> cat /tmp/ios_failed.json | sed '$ s/,$//' > /tmp/combined_temp.json
[?2004l[?2004h> echo ']' >> /tmp/combined_temp.json
[?2004l[?2004h> jq -s 'add' /tmp/combined_temp.json /tmp/android_failed.json | \
[?2004l[?2004h>   jq 'sort_by(.app_name, .build_id)' > failed_builds_report.json
[?2004l[?2004h> 
[?2004l[?2004h> # Count failures
[?2004l[?2004h> IOS_COUNT=$(awk -F',' 'NR>1 && $4=="FAILED"' ios_builds.csv | wc -l)
[?2004l[?2004h> ANDROID_COUNT=$(jq '[.[] | select(.result=="FAILED")] | length' android_builds.json)
[?2004l[?2004h> TOTAL=$((IOS_COUNT + ANDROID_COUNT))
[?2004l[?2004h> 
[?2004l[?2004h> # Create summary
[?2004l[?2004h> cat > failure_summary.txt << SUMMARY
[?2004l[?2004h> Total failed builds: $TOTAL
[?2004l[?2004h> iOS failures: $IOS_COUNT
[?2004l[?2004h> Android failures: $ANDROID_COUNT
[?2004l[?2004h> SUMMARY
[?2004l[?2004h> 
[?2004l[?2004h> EOF
