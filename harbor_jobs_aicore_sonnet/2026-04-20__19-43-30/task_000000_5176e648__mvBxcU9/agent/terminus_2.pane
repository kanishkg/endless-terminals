[?2004l[?2004h> import csv
[?2004l[?2004h> 
[?2004l[?2004h> # Read and process iOS builds
[?2004l[?2004h> ios_failed = []
[?2004l[?2004h> with open('ios_builds.csv', 'r') as f:
[?2004l[?2004h>     reader = csv.DictReader(f)
[?2004l[?2004h>     for row in reader:
[?2004l[?2004h>         if row['status'] == 'FAILED':
[?2004l[?2004h>             ios_failed.append({
[?2004l[?2004h>                 'platform': 'ios',
[?2004l[?2004h>                 'build_id': row['build_id'],
[?2004l[?2004h>                 'app_name': row['app_name'],
[?2004l[?2004h>                 'duration_minutes': round(float(row['build_time_seconds']) / 60, 2),
[?2004l[?2004h>                 'branch': row['branch']
[?2004l[?2004h>             })
[?2004l[?2004h> 
[?2004l[?2004h> # Read and process Android builds
[?2004l[?2004h> android_failed = []
[?2004l[?2004h> with open('android_builds.json', 'r') as f:
[?2004l[?2004h>     android_builds = json.load(f)
[?2004l[?2004h>     for build in android_builds:
[?2004l[?2004h>         if build['result'] == 'FAILED':
[?2004l[?2004h>             android_failed.append({
[?2004l[?2004h>                 'platform': 'android',
[?2004l[?2004h>                 'build_id': build['buildId'],
[?2004l[?2004h>                 'app_name': build['appName'],
[?2004l[?2004h>                 'duration_minutes': round(float(build['buildDuration']) / 60, 2),
[?2004l[?2004h>                 'branch': build['branch']
[?2004l[?2004h>             })
[?2004l[?2004h> 
[?2004l[?2004h> # Combine and sort
[?2004l[?2004h> all_failed = ios_failed + android_failed
[?2004l[?2004h> all_failed.sort(key=lambda x: (x['app_name'], x['build_id']))
[?2004l[?2004h> 
[?2004l[?2004h> # Write JSON report
[?2004l[?2004h> with open('failed_builds_report.json', 'w') as f:
[?2004l[?2004h>     json.dump(all_failed, f, indent=2)
[?2004l[?2004h> 
[?2004l[?2004h> # Create summary
[?2004l[?2004h> total_failed = len(all_failed)
[?2004l[?2004h> ios_count = len(ios_failed)
[?2004l[?2004h> android_count = len(android_failed)
[?2004l[?2004h> 
[?2004l[?2004h> with open('failure_summary.txt', 'w') as f:
[?2004l[?2004h>     f.write(f'Total failed builds: {total_failed}\n')
[?2004l[?2004h>     f.write(f'iOS failures: {ios_count}\n')
[?2004l[?2004h>     f.write(f'Android failures: {android_count}\n')
[?2004l[?2004h> 
